<%- include('../partials/header') %>

<div style="padding:40px;max-width:1000px;margin:0 auto">
  <!-- Header -->
  <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:28px;flex-wrap:wrap;gap:12px">
    <div>
      <a href="/pedidos" style="font-size:11px;color:var(--gray);text-decoration:none;letter-spacing:2px;display:flex;align-items:center;gap:6px;margin-bottom:8px" onmouseover="this.style.color='var(--pink)'" onmouseout="this.style.color='var(--gray)'">
        <i class="bi bi-arrow-left"></i> MIS PEDIDOS
      </a>
      <h2 style="font-family:'Bebas Neue',sans-serif;font-size:clamp(28px,5vw,42px);letter-spacing:4px;line-height:1;color:var(--white)">
        PEDIDO <span style="color:var(--pink)">#<%= String(pedido.id).padStart(5,'0') %></span>
      </h2>
      <div style="font-size:12px;color:var(--gray);margin-top:4px;letter-spacing:1px">
        <%= new Date(pedido.creado_en).toLocaleDateString('es-CO', {weekday:'long',year:'numeric',month:'long',day:'numeric'}) %>
      </div>
    </div>
    <%
      var stMap = {pendiente:'#ffc800',confirmado:'#00c8ff',en_transito:'#60a5fa',entregado:'#00ff64',cancelado:'#ff6060'};
      var stColor = stMap[pedido.estado] || 'var(--gray)';
    %>
    <div style="text-align:right;display:flex;flex-direction:column;gap:8px;align-items:flex-end">
      <div style="font-family:'Bebas Neue',sans-serif;font-size:11px;padding:6px 18px;border:2px solid <%= stColor %>;color:<%= stColor %>;letter-spacing:2px;display:inline-block"><%= (pedido.estado||'').toUpperCase().replace('_',' ') %></div>
      <% if (pedido.numero_tracking) { %>
      <div style="font-size:11px;color:var(--pink);letter-spacing:1px"><i class="bi bi-box-seam me-1"></i>Tracking: <%= pedido.numero_tracking %></div>
      <% } %>
      <!-- Botón de recibo -->
      <button onclick="verRecibo()" style="background:rgba(233,30,140,.1);border:1px solid rgba(233,30,140,.4);color:var(--pink);padding:7px 16px;cursor:pointer;font-family:'Bebas Neue',sans-serif;font-size:12px;letter-spacing:2px;display:flex;align-items:center;gap:7px;transition:all .2s" onmouseover="this.style.background='rgba(233,30,140,.22)'" onmouseout="this.style.background='rgba(233,30,140,.1)'">
        <i class="bi bi-receipt"></i>VER RECIBO
      </button>
    </div>
  </div>

  <!-- MODAL RECIBO -->
  <div id="recibo-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:3000;overflow-y:auto;padding:40px 16px">
    <div id="recibo-contenido" style="max-width:520px;margin:0 auto;background:white;color:#111;padding:40px;font-family:'Arial',sans-serif;position:relative">
      <button onclick="cerrarRecibo()" style="position:absolute;top:12px;right:12px;background:none;border:none;font-size:22px;cursor:pointer;color:#999">✕</button>
      <!-- Encabezado del recibo -->
      <div style="text-align:center;border-bottom:2px solid #111;padding-bottom:20px;margin-bottom:20px">
        <div style="font-family:'Arial Black',sans-serif;font-size:28px;letter-spacing:6px;color:#e91e8c">MANTIZ</div>
        <div style="font-size:11px;letter-spacing:2px;color:#666;margin-top:4px">COMPROBANTE DE COMPRA</div>
      </div>
      <!-- Datos del pedido -->
      <div style="display:flex;justify-content:space-between;margin-bottom:6px">
        <span style="font-size:12px;color:#666">Pedido</span>
        <strong style="font-size:12px">#<%= String(pedido.id).padStart(5,'0') %></strong>
      </div>
      <div style="display:flex;justify-content:space-between;margin-bottom:6px">
        <span style="font-size:12px;color:#666">Fecha</span>
        <strong style="font-size:12px"><%= new Date(pedido.creado_en).toLocaleDateString('es-CO') %></strong>
      </div>
      <% if (pedido.numero_tracking) { %>
      <div style="display:flex;justify-content:space-between;margin-bottom:6px">
        <span style="font-size:12px;color:#666">Tracking</span>
        <strong style="font-size:12px"><%= pedido.numero_tracking %></strong>
      </div>
      <% } %>
      <div style="display:flex;justify-content:space-between;margin-bottom:6px">
        <span style="font-size:12px;color:#666">Estado</span>
        <strong style="font-size:12px;color:#e91e8c"><%= (pedido.estado||'').toUpperCase().replace('_',' ') %></strong>
      </div>
      <div style="display:flex;justify-content:space-between;margin-bottom:20px">
        <span style="font-size:12px;color:#666">Método de pago</span>
        <strong style="font-size:12px">
          <%= pedido.metodo_pago && pedido.metodo_pago !== 'transferencia' ? pedido.metodo_pago : (pedido.metodo_pago||'—') %>
        </strong>
      </div>
      <!-- Productos -->
      <div style="border-top:1px solid #ddd;padding-top:16px;margin-bottom:16px">
        <div style="font-size:11px;letter-spacing:2px;color:#666;margin-bottom:12px">PRODUCTOS</div>
        <% if (items && items.length > 0) { items.forEach(function(item) { %>
        <div style="display:flex;justify-content:space-between;margin-bottom:8px;font-size:13px">
          <span><%= item.titulo %><% if(item.talla){ %> <span style="color:#999;font-size:11px">(<%= item.talla %>)</span><% } %> × <%= item.cantidad %></span>
          <strong><%= sitio.simbolo_moneda||'COP' %> <%= (parseFloat(item.precio)*item.cantidad).toLocaleString('es-CO') %></strong>
        </div>
        <% }) } %>
      </div>
      <!-- Totales -->
      <div style="border-top:2px solid #111;padding-top:14px">
        <div style="display:flex;justify-content:space-between;margin-bottom:6px;font-size:13px">
          <span style="color:#666">Subtotal</span>
          <span><%= sitio.simbolo_moneda||'COP' %> <%= parseFloat(pedido.subtotal||0).toLocaleString('es-CO') %></span>
        </div>
        <div style="display:flex;justify-content:space-between;margin-bottom:12px;font-size:13px">
          <span style="color:#666">Envío</span>
          <span><%= parseFloat(pedido.costo_envio||0)===0 ? 'GRATIS' : (sitio.simbolo_moneda||'COP')+' '+parseFloat(pedido.costo_envio||0).toLocaleString('es-CO') %></span>
        </div>
        <div style="display:flex;justify-content:space-between;font-size:16px;font-weight:bold">
          <span>TOTAL</span>
          <span style="color:#e91e8c"><%= sitio.simbolo_moneda||'COP' %> <%= parseFloat(pedido.total||0).toLocaleString('es-CO') %></span>
        </div>
      </div>
      <!-- Footer -->
      <div style="text-align:center;margin-top:28px;padding-top:16px;border-top:1px solid #ddd;font-size:10px;color:#aaa;letter-spacing:1px">
        Gracias por tu compra — <%= sitio.nombre_tienda||'MANTIZ' %> · <%= new Date().getFullYear() %>
      </div>
    </div>
    <!-- Botones de acción FUERA del área de impresión -->
    <div style="max-width:520px;margin:16px auto 0;display:flex;gap:12px">
      <button onclick="window.print()" style="flex:1;background:var(--pink);border:none;color:white;padding:13px;font-family:'Bebas Neue',sans-serif;font-size:14px;letter-spacing:3px;cursor:pointer"><i class="bi bi-printer me-2"></i>IMPRIMIR / GUARDAR PDF</button>
      <button onclick="cerrarRecibo()" style="background:transparent;border:1px solid rgba(255,255,255,.3);color:white;padding:13px 20px;cursor:pointer;font-size:14px">✕</button>
    </div>
  </div>

  <script>
  function verRecibo(){ document.getElementById('recibo-modal').style.display='block'; document.body.style.overflow='hidden'; }
  function cerrarRecibo(){ document.getElementById('recibo-modal').style.display='none'; document.body.style.overflow=''; }
  document.addEventListener('keydown',function(e){ if(e.key==='Escape')cerrarRecibo(); });
  // Al imprimir: solo muestra #recibo-contenido
  window.addEventListener('beforeprint',function(){ document.body.classList.add('printing-recibo'); });
  window.addEventListener('afterprint',function(){ document.body.classList.remove('printing-recibo'); });
  </script>
  <style>
  @media print{
    body > *:not(#recibo-modal) { display:none!important; }
    #recibo-modal { position:static!important; background:white!important; padding:0!important; }
    #recibo-modal > div:last-child { display:none!important; }
    #recibo-contenido { box-shadow:none!important; }
    button[onclick="cerrarRecibo()"] { display:none!important; }
  }
  </style>

  <div style="display:grid;grid-template-columns:1fr 340px;gap:24px" class="pedido-det-grid">
    <!-- LEFT -->
    <div style="display:flex;flex-direction:column;gap:20px">

      <!-- Items -->
      <div style="background:var(--card);border:1px solid var(--border);padding:24px;position:relative">
        <div style="position:absolute;inset:0;border:1px solid var(--faint-2);filter:url(#gb);pointer-events:none"></div>
        <div style="font-family:'Bebas Neue',sans-serif;font-size:14px;letter-spacing:3px;color:var(--pink);margin-bottom:16px">PRODUCTOS</div>
        <div style="display:flex;flex-direction:column;gap:14px">
          <% if (items && items.length > 0) { %>
            <% items.forEach(function(item) { %>
            <div style="display:flex;align-items:center;gap:14px;padding-bottom:14px;border-bottom:1px solid var(--faint-1)">
              <img src="/uploads/products/<%= item.imagen_principal %>" width="72" height="72"
                   style="object-fit:cover;border:2px solid var(--border);flex-shrink:0"
                   onerror="this.src='https://via.placeholder.com/72x72/111/888?text=P'">
              <div style="flex:1;min-width:0">
                <a href="/productos/<%= item.producto_id %>" style="font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:2px;color:var(--white);text-decoration:none;display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" onmouseover="this.style.color='var(--pink)'" onmouseout="this.style.color='var(--white)'"><%= item.titulo %></a>
                <div style="font-size:12px;color:var(--gray);margin-top:3px;letter-spacing:0.5px">
                  <% if (item.talla) { %><span style="border:1px solid var(--border);padding:1px 8px;margin-right:8px">T: <%= item.talla %></span><% } %>
                  <span>Qty: <%= item.cantidad %></span>
                </div>
              </div>
              <div style="text-align:right;flex-shrink:0">
                <div style="font-family:'Bebas Neue',sans-serif;font-size:16px;color:var(--pink)">$<%= parseFloat(item.precio_unitario||0).toLocaleString('es-CO') %></div>
                <div style="font-size:11px;color:var(--gray)">c/u</div>
              </div>
            </div>
            <% }) %>
          <% } else { %>
          <div style="color:var(--gray);text-align:center;padding:20px">Sin detalles de productos</div>
          <% } %>
        </div>
      </div>

      <!-- Tracking timeline -->
      <div style="background:var(--card);border:1px solid var(--border);padding:24px;position:relative">
        <div style="position:absolute;inset:0;border:1px solid var(--faint-2);filter:url(#gb);pointer-events:none"></div>
        <div style="font-family:'Bebas Neue',sans-serif;font-size:14px;letter-spacing:3px;color:var(--pink);margin-bottom:20px">SEGUIMIENTO</div>
        <%
          var estadosOrden = ['pendiente','confirmado','en_transito','entregado'];
          var idxActual = estadosOrden.indexOf(pedido.estado);
        %>
        <div style="display:flex;flex-direction:column;gap:0">
          <% estadosOrden.forEach(function(est, i) {
            var done = i <= idxActual;
            var active = i === idxActual;
            var labels = {pendiente:'Pedido recibido',confirmado:'Confirmado',en_transito:'En camino',entregado:'Entregado'};
            var icons = {pendiente:'bi-cart-check',confirmado:'bi-check-circle',en_transito:'bi-truck',entregado:'bi-house-check'};
          %>
          <div style="display:flex;gap:16px;align-items:flex-start;padding-bottom:<%= i<estadosOrden.length-1?'20px':'0' %>">
            <div style="display:flex;flex-direction:column;align-items:center;flex-shrink:0">
              <div style="width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;border:2px solid <%= done?stColor:'var(--faint-2)' %>;background:<%= active?stColor+'20':'transparent' %>;color:<%= done?stColor:'var(--faint-3)' %>;transition:all 0.3s">
                <i class="bi <%= icons[est] %>"></i>
              </div>
              <% if (i < estadosOrden.length-1) { %>
              <div style="width:2px;flex:1;background:<%= done&&i<idxActual?stColor:'var(--faint-1)' %>;min-height:20px;margin-top:4px"></div>
              <% } %>
            </div>
            <div style="padding-top:6px;flex:1">
              <div style="font-family:'Bebas Neue',sans-serif;font-size:14px;letter-spacing:2px;color:<%= done?'var(--white)':'var(--muted)' %>"><%= labels[est] %></div>
              <% if (seguimiento) { var track = seguimiento.find(function(s){ return s.estado===est; }); if(track){ %>
              <div style="font-size:11px;color:var(--gray);margin-top:2px"><%= new Date(track.fecha).toLocaleDateString('es-CO') %></div>
              <% if(track.comentario){ %><div style="font-size:11px;color:var(--pink);margin-top:2px"><%= track.comentario %></div><% } %>
              <% }} %>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- RIGHT -->
    <div style="display:flex;flex-direction:column;gap:16px">
      <!-- Summary -->
      <div style="background:var(--card);border:1px solid var(--border);padding:20px;position:relative">
        <div style="position:absolute;inset:0;border:1px solid var(--faint-2);filter:url(#gb);pointer-events:none"></div>
        <div style="font-family:'Bebas Neue',sans-serif;font-size:13px;letter-spacing:3px;color:var(--pink);margin-bottom:14px">RESUMEN</div>
        <div style="display:flex;flex-direction:column;gap:8px">
          <div style="display:flex;justify-content:space-between;font-size:13px;color:var(--gray)">
            <span>Subtotal</span>
            <span>$<%= parseFloat(pedido.subtotal||pedido.total||0).toLocaleString('es-CO') %></span>
          </div>
          <div style="display:flex;justify-content:space-between;font-size:13px;color:var(--gray)">
            <span>Envío</span>
            <span>$<%= parseFloat(pedido.envio||8.99).toLocaleString('es-CO') %></span>
          </div>
          <div style="display:flex;justify-content:space-between;font-family:'Bebas Neue',sans-serif;font-size:20px;color:var(--pink);border-top:1px solid var(--border);padding-top:10px;margin-top:4px">
            <span>TOTAL</span>
            <span>$<%= parseFloat(pedido.total||0).toLocaleString('es-CO') %></span>
          </div>
          <div style="font-size:11px;letter-spacing:1px;padding:6px 10px;border:1px solid var(--faint-2);text-align:center;margin-top:4px">
            <span style="color:var(--gray)">Pago: </span>
            <span style="color:<%= pedido.estado_pago==='pagado'?'#00ff64':'#ffc800' %>"><%= (pedido.metodo_pago||'—').toUpperCase() %></span>
          </div>
        </div>
      </div>

      <!-- Shipping address -->
      <% if (pedido.direccion_texto || pedido.ciudad) { %>
      <div style="background:var(--card);border:1px solid var(--border);padding:20px;position:relative">
        <div style="position:absolute;inset:0;border:1px solid var(--faint-2);filter:url(#gb);pointer-events:none"></div>
        <div style="font-family:'Bebas Neue',sans-serif;font-size:13px;letter-spacing:3px;color:var(--pink);margin-bottom:10px">ENTREGA</div>
        <div style="font-size:12px;color:var(--text);line-height:1.7">
          <% if (pedido.nombre_destinatario) { %><strong><%= pedido.nombre_destinatario %></strong><br><% } %>
          <%= pedido.direccion_texto || '' %><br>
          <%= pedido.ciudad || '' %><% if(pedido.departamento){ %>, <%= pedido.departamento %><% } %>
        </div>
      </div>
      <% } %>

      <!-- Actions -->
      <div style="display:flex;flex-direction:column;gap:8px">
        <a href="/productos" class="btn-grunge" style="display:flex;align-items:center;justify-content:center;gap:8px;text-decoration:none;text-align:center">
          <i class="bi bi-bag"></i> SEGUIR COMPRANDO
        </a>
        <% if (pedido.estado === 'pendiente') { %>
        <form action="/pedidos/<%= pedido.id %>/cancelar" method="POST" onsubmit="return confirm('Cancelar este pedido?')">
          <button type="submit" style="width:100%;background:none;border:1px solid #ff6060;color:#ff6060;padding:10px;font-family:'Bebas Neue',sans-serif;font-size:13px;letter-spacing:2px;cursor:pointer;transition:all 0.2s" onmouseover="this.style.background='rgba(255,96,96,0.1)'" onmouseout="this.style.background='none'">
            CANCELAR PEDIDO
          </button>
        </form>
        <% } %>
      </div>
    </div>
  </div>
</div>

<style>
@media(max-width:768px){ .pedido-det-grid{grid-template-columns:1fr!important} div[style*="padding:40px"]{padding:20px!important} }
</style>
<%- include('../partials/footer') %>
