<%- include('../partials/header') %>

<style>
  .y2k-wrap {
    min-height: calc(100vh - 64px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    position: relative;
    overflow: hidden;
    background: #0a000f;
  }

  .y2k-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 70% 70% at 80% 20%, rgba(157,0,255,0.28) 0%, transparent 60%),
      radial-gradient(ellipse 60% 60% at 15% 80%, rgba(0,245,255,0.18) 0%, transparent 55%),
      radial-gradient(ellipse 90% 90% at 50% 50%, rgba(233,30,140,0.08) 0%, transparent 70%);
    animation: bgPulse 9s ease-in-out infinite alternate;
    pointer-events: none;
  }
  @keyframes bgPulse {
    0%   { filter: hue-rotate(0deg) brightness(1); }
    100% { filter: hue-rotate(-18deg) brightness(1.1); }
  }

  .y2k-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(0,245,255,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,245,255,0.05) 1px, transparent 1px);
    background-size: 48px 48px;
    animation: gridMove 22s linear infinite;
    pointer-events: none;
  }
  @keyframes gridMove {
    from { background-position: 0 0; }
    to   { background-position: -48px 48px; }
  }

  .y2k-scanlines {
    position: absolute; inset: 0;
    background: repeating-linear-gradient(
      0deg, transparent, transparent 3px,
      rgba(0,0,0,0.14) 3px, rgba(0,0,0,0.14) 4px
    );
    pointer-events: none;
    animation: scanMove 7s linear infinite;
  }
  @keyframes scanMove {
    from { background-position: 0 0; }
    to   { background-position: 0 80px; }
  }

  .y2k-canvas {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    pointer-events: none;
  }

  .y2k-card {
    width: 100%; max-width: 480px;
    position: relative; z-index: 10;
  }

  .y2k-card-inner {
    background: rgba(10,0,20,0.75);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    padding: 40px;
    position: relative;
    border: 1.5px solid rgba(233,30,140,0.5);
    clip-path: polygon(0 0, calc(100% - 18px) 0, 100% 18px, 100% 100%, 18px 100%, 0 calc(100% - 18px));
    animation: cardIn 0.6s cubic-bezier(0.22,1,0.36,1) both;
  }
  @keyframes cardIn {
    from { opacity: 0; transform: translateY(24px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .y2k-topbar {
    position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, #00f5ff, #9d00ff, var(--pink), #00f5ff);
    background-size: 300% 100%;
    animation: barSlide 3.5s linear infinite;
  }
  @keyframes barSlide {
    from { background-position: 0% 0%; }
    to   { background-position: 300% 0%; }
  }

  .y2k-card-inner::before,
  .y2k-card-inner::after {
    content: ''; position: absolute;
    width: 24px; height: 24px; border-style: solid;
    animation: cornerPulse 2.8s ease-in-out infinite alternate;
  }
  .y2k-card-inner::before { top: 8px; left: 8px; border-width: 2px 0 0 2px; border-color: #00f5ff; }
  .y2k-card-inner::after  { bottom: 8px; right: 8px; border-width: 0 2px 2px 0; border-color: #00f5ff; }
  @keyframes cornerPulse {
    from { border-color: #00f5ff; opacity: 0.5; }
    to   { border-color: var(--pink); opacity: 1; }
  }

  .mantiz-input:-webkit-autofill,
  .mantiz-input:-webkit-autofill:hover,
  .mantiz-input:-webkit-autofill:focus {
    -webkit-box-shadow: 0 0 0 1000px #0a000f inset !important;
    -webkit-text-fill-color: #fff !important;
    caret-color: #fff;
    transition: background-color 9999s ease-in-out 0s;
  }

  .y2k-logo-glitch { animation: logoGlitch 5s steps(1) infinite; }
  @keyframes logoGlitch {
    0%,93%,100% { clip-path: none; text-shadow: 0 0 20px rgba(233,30,140,0.4); }
    94% { clip-path: polygon(0 20%,100% 20%,100% 40%,0 40%); text-shadow: -3px 0 #00f5ff, 3px 0 var(--pink); }
    95% { clip-path: polygon(0 60%,100% 60%,100% 80%,0 80%); text-shadow: 3px 0 #9d00ff; }
    96% { clip-path: none; text-shadow: 0 0 20px rgba(233,30,140,0.4); }
  }

  .y2k-steps {
    display: flex; align-items: center; justify-content: center;
    gap: 0; margin-bottom: 28px;
  }
  .y2k-step { display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .y2k-step-dot {
    width: 30px; height: 30px; border-radius: 50%;
    border: 2px solid rgba(157,0,255,0.4);
    background: rgba(0,0,0,0.5);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Bebas Neue', sans-serif; font-size: 15px;
    color: rgba(255,255,255,0.35);
    transition: all 0.35s;
  }
  .y2k-step.active .y2k-step-dot {
    border-color: var(--pink); background: rgba(233,30,140,0.15);
    color: var(--pink); box-shadow: 0 0 12px rgba(233,30,140,0.5);
  }
  .y2k-step.done .y2k-step-dot {
    border-color: #00f5ff; background: rgba(0,245,255,0.1); color: #00f5ff;
  }
  .y2k-step-label {
    font-family: 'Bebas Neue', sans-serif; font-size: 11px;
    letter-spacing: 2px; color: rgba(255,255,255,0.28);
    transition: color 0.35s;
  }
  .y2k-step.active .y2k-step-label { color: var(--pink); }
  .y2k-step.done  .y2k-step-label  { color: #00f5ff; }
  .y2k-step-line {
    flex: 1; height: 1px; background: rgba(157,0,255,0.25);
    margin: 0 8px 18px; transition: background 0.4s;
    min-width: 40px;
  }
  .y2k-step-line.done { background: #00f5ff; box-shadow: 0 0 6px rgba(0,245,255,0.4); }

  .y2k-section { display: none; animation: secIn 0.35s cubic-bezier(0.22,1,0.36,1) both; }
  .y2k-section.active { display: block; }
  @keyframes secIn {
    from { opacity: 0; transform: translateX(16px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .reg-btn-row { display: flex; gap: 12px; margin-top: 4px; }

  .reg-btn-back {
    padding: 0 18px;
    background: transparent;
    border: 2px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.45);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 16px; letter-spacing: 3px; cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
    clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100% - 8px));
  }
  .reg-btn-back:hover { border-color: var(--pink); color: var(--pink); }

  .pw-strength-bar {
    height: 3px; background: rgba(255,255,255,0.08);
    margin-top: 8px; overflow: hidden;
  }
  .pw-strength-fill {
    height: 100%; width: 0%;
    background: var(--pink);
    transition: width 0.4s, background 0.4s;
    box-shadow: 0 0 8px currentColor;
  }
  .pw-strength-label {
    font-family: 'Bebas Neue', sans-serif; font-size: 11px;
    letter-spacing: 3px; color: rgba(255,255,255,0.25);
    margin-top: 4px; transition: color 0.4s;
  }
  .pw-match-label {
    font-family: 'Bebas Neue', sans-serif; font-size: 11px;
    letter-spacing: 3px; margin-top: 6px; transition: color 0.3s;
  }
</style>

<div class="y2k-wrap">
  <div class="y2k-bg"></div>
  <div class="y2k-grid"></div>
  <div class="y2k-scanlines"></div>
  <canvas class="y2k-canvas" id="y2kCanvas"></canvas>

  <div class="y2k-card">
    <div class="y2k-card-inner">
      <div class="y2k-topbar"></div>
      <div style="position:absolute;inset:0;border:3px solid rgba(255,255,255,0.5);filter:url(#gb);pointer-events:none;z-index:10"></div>

      <div style="text-align:center;margin-bottom:28px">
        <a href="/" class="y2k-logo-glitch" style="font-family:'Permanent Marker',cursive;font-size:36px;color:var(--pink);text-decoration:none;display:block;text-shadow:0 0 20px rgba(233,30,140,0.4)">
          <%= sitio.nombre_tienda || 'MANTIZ' %>
        </a>
        <div style="font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:5px;color:#f0f0f0;margin-top:8px">CREAR CUENTA</div>
        <div style="width:60px;height:2px;background:var(--pink);margin:12px auto 0;filter:url(#gb)"></div>
      </div>

      <div class="y2k-steps">
        <div class="y2k-step active" id="si1">
          <div class="y2k-step-dot">1</div>
          <div class="y2k-step-label">IDENTIDAD</div>
        </div>
        <div class="y2k-step-line" id="sl1"></div>
        <div class="y2k-step" id="si2">
          <div class="y2k-step-dot">2</div>
          <div class="y2k-step-label">ACCESO</div>
        </div>
      </div>

      <form action="/auth/registro" method="POST" id="regForm" novalidate>

        <div class="y2k-section active" id="sec1">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px">
            <div>
              <label class="mantiz-label">Usuario</label>
              <input type="text" name="username" id="f-user" class="mantiz-input" placeholder="mi_usuario" autocomplete="username">
            </div>
            <div>
              <label class="mantiz-label">Nombre visible</label>
              <input type="text" name="nombre_visible" id="f-nombre" class="mantiz-input" placeholder="Mi Nombre">
            </div>
          </div>
          <div style="margin-bottom:24px">
            <label class="mantiz-label">Email</label>
            <input type="email" name="email" id="f-email" class="mantiz-input" placeholder="correo@ejemplo.com" autocomplete="email">
          </div>
          <button type="button" class="btn-grunge-fill" style="width:100%" onclick="goStep2()">SIGUIENTE &#8594;</button>
        </div>

        <div class="y2k-section" id="sec2">
          <div style="margin-bottom:16px">
            <label class="mantiz-label">Contrasena</label>
            <input type="password" name="password" id="f-pw" class="mantiz-input" placeholder="........" minlength="6" autocomplete="new-password" oninput="checkStrength(this.value)">
            <div class="pw-strength-bar"><div class="pw-strength-fill" id="pwBar"></div></div>
            <div class="pw-strength-label" id="pwLabel">SEGURIDAD</div>
          </div>
          <div style="margin-bottom:24px">
            <label class="mantiz-label">Confirmar</label>
            <input type="password" name="confirm_password" id="f-pw2" class="mantiz-input" placeholder="........" autocomplete="new-password" oninput="checkMatch()">
            <div class="pw-match-label" id="matchLabel"></div>
          </div>
          <div class="reg-btn-row">
            <button type="button" class="reg-btn-back" onclick="goStep1()">&#8592; VOLVER</button>
            <button type="submit" class="btn-grunge-fill" style="flex:1">REGISTRARSE &#8594;</button>
          </div>
        </div>

      </form>

      <div style="text-align:center;margin-top:24px;font-size:13px;color:#999;letter-spacing:1px">
        Ya tienes cuenta?
        <a href="/auth/login" style="color:var(--pink);text-decoration:none;font-weight:700">INGRESAR</a>
      </div>
    </div>
  </div>
</div>

<script>
function goStep2() {
  const user   = document.getElementById('f-user');
  const nombre = document.getElementById('f-nombre');
  const email  = document.getElementById('f-email');
  if (!user.value.trim() || user.value.trim().length < 3) { shake(user); return; }
  if (!nombre.value.trim())                                { shake(nombre); return; }
  if (!email.value.trim() || !email.value.includes('@'))   { shake(email); return; }
  document.getElementById('sec1').classList.remove('active');
  document.getElementById('sec2').classList.add('active');
  document.getElementById('si1').classList.replace('active','done');
  document.getElementById('si2').classList.add('active');
  document.getElementById('sl1').classList.add('done');
}

function goStep1() {
  document.getElementById('sec2').classList.remove('active');
  document.getElementById('sec1').classList.add('active');
  document.getElementById('si1').classList.remove('done');
  document.getElementById('si1').classList.add('active');
  document.getElementById('si2').classList.remove('active');
  document.getElementById('sl1').classList.remove('done');
}

function shake(el) {
  el.style.borderColor = 'var(--pink)';
  el.animate([{transform:'translateX(-4px)'},{transform:'translateX(4px)'},{transform:'translateX(-3px)'},{transform:'translateX(3px)'},{transform:'translateX(0)'}],{duration:280});
  setTimeout(() => el.style.borderColor = '', 700);
}

function checkStrength(pw) {
  const bar = document.getElementById('pwBar');
  const lbl = document.getElementById('pwLabel');
  let s = 0;
  if (pw.length >= 6)          s++;
  if (pw.length >= 10)         s++;
  if (/[A-Z]/.test(pw))        s++;
  if (/[0-9]/.test(pw))        s++;
  if (/[^A-Za-z0-9]/.test(pw)) s++;
  const lvl = [
    {pct:'12%', color:'#ff2d9b', txt:'MUY DEBIL'},
    {pct:'32%', color:'#ff6b35', txt:'DEBIL'},
    {pct:'56%', color:'#ffe600', txt:'REGULAR'},
    {pct:'78%', color:'#00f5ff', txt:'BUENA'},
    {pct:'100%',color:'#39ff14', txt:'EXCELENTE'},
  ][Math.min(s,4)];
  bar.style.width      = lvl.pct;
  bar.style.background = lvl.color;
  lbl.style.color      = lvl.color;
  lbl.textContent      = lvl.txt;
}

function checkMatch() {
  const pw   = document.getElementById('f-pw').value;
  const conf = document.getElementById('f-pw2').value;
  const lbl  = document.getElementById('matchLabel');
  if (!conf) { lbl.textContent = ''; return; }
  if (pw === conf) { lbl.textContent = '✓ COINCIDEN'; lbl.style.color = '#00f5ff'; }
  else             { lbl.textContent = '✗ NO COINCIDEN'; lbl.style.color = '#ff2d9b'; }
}

(function() {
  const canvas = document.getElementById('y2kCanvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let W, H, particles = [];
  function resize() { W = canvas.width = canvas.offsetWidth; H = canvas.height = canvas.offsetHeight; }
  resize();
  window.addEventListener('resize', resize);
  const colors = ['#ff2d9b','#00f5ff','#9d00ff','#ffe600'];
  const shapes = ['circle','square','diamond'];
  function spawn() {
    return { x:Math.random()*W, y:H+10, r:Math.random()*3+1,
      vx:(Math.random()-0.5)*0.6, vy:-(Math.random()*1.2+0.4),
      alpha:0, fadeIn:Math.random()*0.012+0.005,
      color:colors[Math.floor(Math.random()*colors.length)],
      shape:shapes[Math.floor(Math.random()*shapes.length)],
      rot:0, rotV:(Math.random()-0.5)*0.04,
      life:0, maxLife:Math.random()*200+120 };
  }
  for (let i=0;i<50;i++) { const p=spawn(); p.y=Math.random()*H; p.life=Math.random()*p.maxLife; p.alpha=Math.random()*0.6; particles.push(p); }
  function draw(p) {
    ctx.save(); ctx.globalAlpha=Math.min(p.alpha,0.7); ctx.fillStyle=p.color;
    ctx.shadowBlur=8; ctx.shadowColor=p.color; ctx.translate(p.x,p.y); ctx.rotate(p.rot);
    const r=p.r;
    if (p.shape==='circle')      { ctx.beginPath(); ctx.arc(0,0,r,0,Math.PI*2); ctx.fill(); }
    else if (p.shape==='square') { ctx.fillRect(-r,-r,r*2,r*2); }
    else { ctx.beginPath(); ctx.moveTo(0,-r*1.5); ctx.lineTo(r*1.2,0); ctx.lineTo(0,r*1.5); ctx.lineTo(-r*1.2,0); ctx.closePath(); ctx.fill(); }
    ctx.restore();
  }
  function tick() {
    ctx.clearRect(0,0,W,H);
    particles.forEach((p,i) => {
      p.life++;
      if (p.life < p.maxLife*0.2)      p.alpha = Math.min(p.alpha+p.fadeIn,0.7);
      else if (p.life > p.maxLife*0.7) p.alpha = Math.max(p.alpha-p.fadeIn,0);
      p.x+=p.vx; p.y+=p.vy; p.rot+=p.rotV;
      draw(p);
      if (p.life>=p.maxLife) particles[i]=spawn();
    });
    requestAnimationFrame(tick);
  }
  tick();
})();
</script>

<%- include('../partials/footer') %>
