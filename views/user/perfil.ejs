<script>
// ── TAB SWITCHING ────────────────────────────────────────
var ALL_PANELS = ['info','favoritos','tableros','pedidos_tab','configuracion','avatar','seguridad','conexiones','logros','amigos'];

function showTab(t) {
  ALL_PANELS.forEach(function(k) {
    var p = document.getElementById('panel-' + k);
    if (p) p.style.display = (k === t) ? 'block' : 'none';
    var b = document.getElementById('tab-' + k);
    if (b) b.classList.toggle('ptab-active', k === t);
  });
  try { history.replaceState(null,'',location.pathname+'#'+t); } catch(e){}
}

window.addEventListener('load', function() {
  var h = location.hash.replace('#','');
  showTab(ALL_PANELS.indexOf(h) > -1 ? h : 'info');
  // Attach tablero button events via data attributes (avoids inline onclick quote issues)
  document.querySelectorAll('.tb-btn-ver').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      abrirTablero(this.dataset.tbId, this.dataset.tbNombre);
    });
  });
  document.querySelectorAll('.tb-btn-edit').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      editarTablero(this.dataset.tbId, this.dataset.tbNombre, this.dataset.tbPriv, this.dataset.tbColor);
    });
  });
  document.querySelectorAll('.tb-btn-del').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      eliminarTablero(this.dataset.tbId, this);
    });
  });
  updateFondoPreview();
});

// ── FAVORITOS ────────────────────────────────────────────
async function quitarFav(id, btn) {
  var card = btn.closest('.product-card');
  try {
    var r = await fetch('/perfil/favorito/quitar/'+id, {method:'POST',headers:{'Content-Type':'application/json'}});
    var d = await r.json();
    if (d.success && card) { card.style.transition='all 0.4s'; card.style.opacity='0'; setTimeout(function(){card.remove();},400); }
  } catch(e) {}
}

    var d = await r.json();
    if (d.success && card) { card.style.transition='all 0.4s'; card.style.opacity='0'; setTimeout(function(){card.remove();},400); }
  } catch(e) {}
}

// ── MENÚ 3 PUNTOS TABLERO ─────────────────────────────────
function toggleTbMenu(id, e) {
  e.stopPropagation();
  var menu = document.getElementById('tb-menu-' + id);
  if (!menu) return;
  var visible = menu.style.display === 'block';
  // cerrar todos
  document.querySelectorAll('[id^="tb-menu-"]').forEach(function(m){ m.style.display='none'; });
  if (!visible) menu.style.display = 'block';
}
document.addEventListener('click', function() {
  document.querySelectorAll('[id^="tb-menu-"]').forEach(function(m){ m.style.display='none'; });
});
// Click en portada del tablero también abre pines
document.querySelectorAll('.tb-cover[data-tb-id]').forEach(function(el) {
  el.addEventListener('click', function() {
    var id = this.getAttribute('data-tb-id');
    var nombre = this.getAttribute('data-tb-nombre');
    if(typeof verPinesTablero === 'function') verPinesTablero(id, nombre);
  });
});

// ── CONEXIONES DE PERFIL ──────────────────────────────────
const PLAT_CFG = {
  playstation:{icon:'bi-controller',color:'#003791',label:'PlayStation',base:'https://www.playstation.com/en-us/profiles/'},
  xbox:       {icon:'bi-xbox',      color:'#107c10',label:'Xbox',       base:'https://www.xbox.com/en-US/play/user/'},
  steam:      {icon:'bi-steam',     color:'#1b2838',label:'Steam',      base:'https://steamcommunity.com/id/'},
  github:     {icon:'bi-github',    color:'#24292f',label:'GitHub',     base:'https://github.com/'},
  tiktok:     {icon:'bi-tiktok',    color:'#010101',label:'TikTok',     base:'https://www.tiktok.com/@'},
  spotify:    {icon:'bi-spotify',   color:'#1db954',label:'Spotify',    base:'https://open.spotify.com/user/'},
  twitch:     {icon:'bi-twitch',    color:'#9146ff',label:'Twitch',     base:'https://www.twitch.tv/'},
  discord:    {icon:'bi-discord',   color:'#5865f2',label:'Discord',    base:null}
};

async function cargarConexionesPerfil() {
  var lista = document.getElementById('conexiones-lista');
  if (!lista) return;
  try {
    var r = await fetch('/gamificacion/conexiones');
    var d = await r.json();
    if (!d.conexiones || !d.conexiones.length) {
      lista.innerHTML = '<div style="color:var(--muted);font-size:13px;letter-spacing:1px">Sin conexiones aún. Agrega una abajo.</div>';
      return;
    }
    lista.innerHTML = d.conexiones.map(function(c) {
      var cfg = PLAT_CFG[c.plataforma] || {icon:'bi-link',color:'#888',label:c.plataforma,base:null};
      return '<div style="display:flex;align-items:center;gap:12px;padding:12px 16px;background:rgba(255,255,255,0.04);border:1px solid var(--border)">'
        + '<i class="' + cfg.icon + '" style="font-size:20px;color:' + cfg.color + ';width:24px;text-align:center"></i>'
        + '<div style="flex:1"><div style="font-size:10px;color:var(--muted);letter-spacing:2px">' + cfg.label.toUpperCase() + '</div>'
        + '<div style="font-size:13px;font-weight:700">@' + c.username + '</div></div>'
        + '<span style="font-size:10px;color:' + (c.publico?'#00c853':'#ff6060') + ';letter-spacing:1px">' + (c.publico?'PÚBLICO':'PRIVADO') + '</span>'
        + '<button onclick="eliminarConexion(\'' + c.plataforma + '\')" title="Eliminar"'
        + ' style="background:none;border:none;color:var(--muted);cursor:pointer;font-size:18px;padding:0 4px;line-height:1;transition:color 0.2s"'
        + ' onmouseover="this.style.color=\'#ff6060\'" onmouseout="this.style.color=\'var(--muted)\'">×</button>'
        + '</div>';
    }).join('');
  } catch(e) { lista.innerHTML = '<div style="color:#ff6060;font-size:12px">Error al cargar conexiones</div>'; }
}

async function guardarConexion() {
  var plataforma = document.getElementById('con-plataforma').value;
  var username = document.getElementById('con-username').value.trim();
  if (!username) { showToast('INGRESA UN USERNAME'); return; }
  try {
    var r = await fetch('/gamificacion/conexiones', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ plataforma, username, publico: document.getElementById('con-publico').checked ? 1 : 0 })
    });
    var d = await r.json();
    if (d.success) {
      showToast('¡CONEXIÓN GUARDADA!');
      document.getElementById('con-username').value = '';
      cargarConexionesPerfil();
    } else { showToast('ERROR: ' + (d.error || 'Desconocido')); }
  } catch(e) { showToast('ERROR DE RED'); }
}

async function eliminarConexion(plataforma) {
  if (!confirm('¿Eliminar esta conexión?')) return;
  await fetch('/gamificacion/conexiones/' + plataforma, {method:'DELETE'});
  showToast('CONEXIÓN ELIMINADA');
  cargarConexionesPerfil();
}

// ── LOGROS Y TIEMPO EN WEB ────────────────────────────────
async function cargarLogrosPerfil() {
  var grid = document.getElementById('logros-grid');
  var tiempoEl = document.getElementById('tiempo-display');
  if (!grid) return;
  try {
    var [rLogros, rTiempo] = await Promise.all([
      fetch('/gamificacion/logros'),
      fetch('/gamificacion/tiempo')
    ]);
    var dL = await rLogros.json();
    var dT = await rTiempo.json();

    if (tiempoEl) tiempoEl.innerHTML = '<i class="bi bi-clock me-1"></i>' + (dT.formato || '0h 0m') + ' en MANTIZ';

    if (!dL.logros || !dL.logros.length) {
      grid.innerHTML = '<div style="color:var(--muted);font-size:13px">Sin logros registrados</div>';
      return;
    }
    grid.innerHTML = dL.logros.map(function(l) {
      var desbloqueado = !!l.desbloqueado;
      var pct = l.umbral > 0 ? Math.min(100, Math.round(((l.progreso||0)/l.umbral)*100)) : 0;
      return '<div style="padding:16px;background:rgba(255,255,255,0.03);border:1px solid '
        + (desbloqueado ? 'rgba(255,215,0,0.3)' : 'var(--border)') + ';opacity:' + (desbloqueado?'1':'0.55') + '">'
        + '<div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">'
        + '<span style="font-size:24px">' + (l.icono||'🏆') + '</span>'
        + '<div><div style="font-family:\'Bebas Neue\',sans-serif;font-size:14px;letter-spacing:2px;color:' + (desbloqueado?'#ffd700':'var(--white)') + '">' + l.nombre + '</div>'
        + '<div style="font-size:11px;color:var(--muted)">' + (l.descripcion||'') + '</div></div>'
        + (desbloqueado ? '<i class="bi bi-check-circle-fill ms-auto" style="color:#ffd700;font-size:16px"></i>' : '')
        + '</div>'
        + '<div style="height:3px;background:rgba(255,255,255,0.08);border-radius:2px;overflow:hidden">'
        + '<div style="height:100%;width:' + pct + '%;background:' + (desbloqueado?'#ffd700':'var(--pink)') + ';transition:width 1s ease"></div>'
        + '</div>'
        + '<div style="font-size:10px;color:var(--muted);margin-top:4px;text-align:right">' + (l.progreso||0) + ' / ' + l.umbral + '</div>'
        + '</div>';
    }).join('');
  } catch(e) { grid.innerHTML = '<div style="color:#ff6060;font-size:12px">Error al cargar logros</div>'; }
}

// ── AMIGOS ────────────────────────────────────────────────
async function cargarAmigos() {
  var grid = document.getElementById('amigos-grid');
  var pendSect = document.getElementById('pendientes-section');
  var pendLista = document.getElementById('pendientes-lista');
  try {
    var [rAmigos, rPend] = await Promise.all([
      fetch('/amigos/lista'),
      fetch('/amigos/pendientes')
    ]);
    var dA = await rAmigos.json();
    var dP = await rPend.json();

    // Solicitudes pendientes
    if (dP.pendientes && dP.pendientes.length > 0) {
      pendSect.style.display = 'block';
      pendLista.innerHTML = dP.pendientes.map(function(p) {
        var av = p.foto_perfil_tipo==='upload' ? '/uploads/profiles/'+p.foto_perfil : '/img/defaults/avatars/'+(p.foto_perfil_preset||'avatar1.png');
        return '<div style="display:flex;align-items:center;gap:12px;padding:12px 16px;background:rgba(255,255,255,0.04);border:1px solid rgba(233,30,140,0.2)">'
          + '<img src="' + av + '" width="40" height="40" style="border-radius:50%;object-fit:cover;border:2px solid var(--pink)" onerror="this.src=\'/img/defaults/avatars/avatar1.png\'">'
          + '<div style="flex:1"><div style="font-weight:700;font-size:13px">' + p.nombre_visible + '</div>'
          + '<div style="font-size:11px;color:var(--muted)">@' + p.username + '</div></div>'
          + '<button onclick="responderSolicitud(' + p.id + ',\'aceptar\',this.closest(\'div[style]\'))" class="btn-grunge" style="padding:6px 14px;font-size:11px;margin-right:6px">✓ ACEPTAR</button>'
          + '<button onclick="responderSolicitud(' + p.id + ',\'rechazar\',this.closest(\'div[style]\'))" style="background:none;border:1px solid var(--border);color:var(--muted);padding:6px 14px;font-family:\'Bebas Neue\',sans-serif;font-size:11px;letter-spacing:1px;cursor:pointer">✕</button>'
          + '</div>';
      }).join('');
    } else {
      pendSect.style.display = 'none';
    }

    // Lista de amigos
    if (!dA.amigos || !dA.amigos.length) {
      grid.innerHTML = '<div style="color:var(--muted);font-size:13px;grid-column:1/-1">Aún no tienes amigos. Busca usuarios y envía solicitudes.</div>';
      return;
    }
    grid.innerHTML = dA.amigos.map(function(a) {
      var av = a.foto_perfil_tipo==='upload' ? '/uploads/profiles/'+a.foto_perfil : '/img/defaults/avatars/'+(a.foto_perfil_preset||'avatar1.png');
      return '<a href="/u/' + a.username + '" style="text-decoration:none;color:var(--white);display:block;padding:16px;background:rgba(255,255,255,0.03);border:1px solid var(--border);text-align:center;transition:all 0.3s" onmouseover="this.style.borderColor=\'var(--pink)\'" onmouseout="this.style.borderColor=\'var(--border)\'">'
        + '<img src="' + av + '" width="56" height="56" style="border-radius:50%;object-fit:cover;border:3px solid var(--border);margin-bottom:8px" onerror="this.src=\'/img/defaults/avatars/avatar1.png\'">'
        + '<div style="font-family:\'Bebas Neue\',sans-serif;font-size:13px;letter-spacing:1px">' + a.nombre_visible + '</div>'
        + '<div style="font-size:11px;color:var(--muted)">@' + a.username + '</div>'
        + '</a>';
    }).join('');
  } catch(e) { grid.innerHTML = '<div style="color:#ff6060;font-size:12px">Error al cargar amigos</div>'; }
}

async function responderSolicitud(uid, accion, card) {
  try {
    var r = await fetch('/amigos/responder/' + uid, {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ accion })
    });
    var d = await r.json();
    if (d.success) {
      if (card) { card.style.opacity='0'; setTimeout(function(){ card.remove(); },300); }
      showToast(accion === 'aceptar' ? '¡AHORA SON AMIGOS!' : 'SOLICITUD RECHAZADA');
      if (accion === 'aceptar') setTimeout(cargarAmigos, 400);
    }
  } catch(e) { showToast('ERROR'); }
}

// ── TABLEROS ─────────────────────────────────────────────
function abrirCrearTablero() {
  document.getElementById('mt-titulo').textContent = 'NUEVO TABLERO';
  document.getElementById('mt-nombre').value = '';
  document.getElementById('mt-privacidad').value = 'privado';
  document.getElementById('mt-color').value = '#e91e8c';
  document.getElementById('mt-edit-id').value = '';
  var m = document.getElementById('modal-tablero');
  m.style.opacity = '1'; m.style.pointerEvents = 'all';
}

function editarTablero(id, nombre, privacidad, color) {
  document.getElementById('mt-titulo').textContent = 'EDITAR TABLERO';
  document.getElementById('mt-nombre').value = nombre || '';
  document.getElementById('mt-privacidad').value = privacidad || 'privado';
  document.getElementById('mt-color').value = color || '#e91e8c';
  document.getElementById('mt-edit-id').value = id;
  var m = document.getElementById('modal-tablero');
  m.style.opacity = '1'; m.style.pointerEvents = 'all';
}

function cerrarModalTablero() {
  var m = document.getElementById('modal-tablero');
  m.style.opacity = '0'; m.style.pointerEvents = 'none';
}
document.getElementById('modal-tablero').addEventListener('click', function(e) {
  if (e.target === this) cerrarModalTablero();
});

async function guardarTablero() {
  var nombre = document.getElementById('mt-nombre').value.trim();
  var editId = document.getElementById('mt-edit-id').value;
  if (!nombre) { document.getElementById('mt-nombre').style.outline='1px solid var(--pink)'; return; }
  try {
    var r = await fetch(editId ? '/tableros/'+editId : '/tableros', {
      method: editId ? 'PUT' : 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({
        nombre: nombre,
        privacidad: document.getElementById('mt-privacidad').value,
        color_portada: document.getElementById('mt-color').value
      })
    });
    var d = await r.json();
    if (d.success) { cerrarModalTablero(); location.reload(); }
  } catch(e) { showToast('Error al guardar tablero'); }
}

async function eliminarTablero(id, btn) {
  if (!confirm('Eliminar este tablero y todos sus pines?')) return;
  try {
    await fetch('/tableros/'+id, {method:'DELETE'});
    var card = document.querySelector('.tablero-card[data-id="'+id+'"]') || btn.closest('.tablero-card');
    if (card) { card.style.opacity='0'; card.style.transition='all 0.3s'; setTimeout(function(){card.remove();},300); }
  } catch(e) {}
}

async function abrirTablero(id, nombre) {
  document.getElementById('vista-tableros').style.display = 'none';
  document.getElementById('vista-pines').style.display = 'block';
  document.getElementById('pines-titulo').textContent = nombre;
  document.getElementById('pines-count').textContent = '';
  document.getElementById('pines-grid').innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:40px;color:var(--gray)"><div style="font-family:Bebas Neue,sans-serif;font-size:16px;letter-spacing:3px">CARGANDO...</div></div>';
  document.getElementById('pines-empty').style.display = 'none';
  try {
    var r = await fetch('/tableros/'+id+'/pines');
    var d = await r.json();
    var pines = d.pines || [];
    document.getElementById('pines-count').textContent = pines.length + ' pines';
    if (pines.length === 0) {
      document.getElementById('pines-grid').innerHTML = '';
      document.getElementById('pines-empty').style.display = 'block';
      return;
    }
    document.getElementById('pines-grid').innerHTML = pines.map(function(p) {
      var img = p.imagen_url || (p.imagen_principal ? '/uploads/products/'+p.imagen_principal : 'https://via.placeholder.com/400x400/111/888?text=PIN');
      var titulo = p.titulo || p.prod_titulo || 'Sin titulo';
      var precio = p.precio_descuento || p.precio;
      return '<div style="background:rgba(255,255,255,0.03);border:1px solid var(--border);overflow:hidden">'
        + (p.producto_id ? '<a href="/productos/'+p.producto_id+'" style="display:block;text-decoration:none">' : '<div>')
        + '<div style="aspect-ratio:1;overflow:hidden;background:#111"><img src="'+img+'" style="width:100%;height:100%;object-fit:cover" onerror="this.src=\'https://via.placeholder.com/400x400/111/888?text=PIN\'"></div>'
        + (p.producto_id ? '</a>' : '</div>')
        + '<div style="padding:10px 12px"><div style="font-size:12px;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#f0f0f0">'+titulo+'</div>'
        + (precio ? '<div style="font-family:Bebas Neue,sans-serif;font-size:14px;color:var(--pink);margin-top:2px">$'+parseFloat(precio).toLocaleString('es-CO')+'</div>' : '')
        + '<button data-tb="'+id+'" data-pin="'+p.id+'" class="pin-del-btn" style="width:100%;margin-top:8px;background:none;border:1px solid rgba(255,60,60,0.3);color:rgba(255,100,100,0.7);padding:5px;font-family:Bebas Neue,sans-serif;font-size:10px;letter-spacing:1.5px;cursor:pointer">QUITAR PIN</button>'
        + '</div></div>';
    }).join('');
    document.querySelectorAll('.pin-del-btn').forEach(function(btn) {
      btn.addEventListener('click', function() { eliminarPin(this.dataset.tb, this.dataset.pin, this); });
    });
  } catch(e) {
    document.getElementById('pines-grid').innerHTML = '<div style="grid-column:1/-1;color:var(--gray);text-align:center;padding:40px">Error al cargar pines</div>';
  }
}

function volverTableros() {
  document.getElementById('vista-pines').style.display = 'none';
  document.getElementById('vista-tableros').style.display = 'block';
}

async function eliminarPin(tableroId, pinId, btn) {
  if (!confirm('Quitar este pin?')) return;
  try {
    await fetch('/tableros/'+tableroId+'/pines/'+pinId, {method:'DELETE'});
    var card = btn.closest('div[style*="background:rgba"]');
    if (card) { card.style.opacity='0'; card.style.transition='all 0.3s'; setTimeout(function(){card.remove();},300); }
  } catch(e) {}
}

// ── CONFIGURACION ─────────────────────────────────────────
function updateFondoPreview() {
  var tipo = document.getElementById('cfg-fondo-tipo');
  var col  = document.getElementById('cfg-fondo-color');
  var blur = document.getElementById('cfg-blur');
  var prev = document.getElementById('fondo-preview');
  if (!prev || !tipo || !col) return;
  prev.style.background = tipo.value==='gradiente'
    ? 'linear-gradient(135deg,'+col.value+',#1a0a16)'
    : col.value;
  prev.style.filter = blur && blur.value > 0 ? 'blur('+blur.value+'px)' : 'none';
}

async function guardarConfig() {
  var data = {
    color_primario: document.getElementById('cfg-color').value,
    tema:           document.getElementById('cfg-tema').value,
    pais:           document.getElementById('cfg-pais').value,
    idioma:         document.getElementById('cfg-idioma').value,
    metodo_pago_pref: document.getElementById('cfg-pago').value,
    fondo_tipo:  document.getElementById('cfg-fondo-tipo').value,
    fondo_valor: document.getElementById('cfg-fondo-color').value,
    fondo_blur:  parseInt(document.getElementById('cfg-blur').value) || 0
  };
  try {
    var r = await fetch('/perfil/config', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)});
    var d = await r.json();
    if (d.success) showToast('CONFIGURACION GUARDADA');
  } catch(e) { showToast('Error al guardar'); }
}

// ── WIDGETS ───────────────────────────────────────────────
async function buscarWidget() {
  var q = document.getElementById('wg-query').value.trim();
  var tipo = document.getElementById('wg-tipo').value;
  if (!q) return;
  document.getElementById('wg-results').innerHTML = '<div style="color:var(--gray);font-size:13px">Buscando...</div>';
  try {
    var r = await fetch('/perfil/config/widgets/buscar',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({query:q,tipo:tipo})});
    var d = await r.json();
    if (d.results && d.results.length > 0) {
      document.getElementById('wg-results').innerHTML = d.results.map(function(item) {
        var enc = encodeURIComponent(JSON.stringify(item));
        return '<div onclick="agregarWidget(\''+enc+'\',\''+tipo+'\')" style="background:rgba(255,255,255,0.04);border:1px solid var(--border);padding:10px 14px;display:flex;align-items:center;gap:10px;cursor:pointer;max-width:220px">'
          + (item.imagen_url ? '<img src="'+item.imagen_url+'" width="36" height="36" style="object-fit:cover;border-radius:4px" onerror="this.style.display=\'none\'">' : '')
          + '<div><div style="font-size:13px;font-weight:600">'+item.titulo+'</div><div style="font-size:11px;color:var(--gray)">'+item.subtitulo+'</div></div></div>';
      }).join('');
    } else {
      document.getElementById('wg-results').innerHTML = '<div style="color:var(--gray);font-size:13px">Sin resultados</div>';
    }
  } catch(e) {
    document.getElementById('wg-results').innerHTML = '<div style="color:#ff6060;font-size:13px">Error</div>';
  }
}

async function agregarWidget(itemEnc, tipo) {
  var item = JSON.parse(decodeURIComponent(itemEnc));
  var el = document.getElementById('widgets-list');
  if (el && el.querySelectorAll('div[style]').length >= 3) { showToast('Maximo 3 widgets'); return; }
  try {
    var r = await fetch('/perfil/config/widgets',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({tipo:tipo,titulo:item.titulo,subtitulo:item.subtitulo||'',imagen_url:item.imagen_url||''})});
    var d = await r.json();
    if (d.success) { showToast('WIDGET AGREGADO'); location.reload(); }
  } catch(e) {}
}

async function eliminarWidget(id, btn) {
  try {
    await fetch('/perfil/config/widgets/'+id,{method:'DELETE'});
    var card = btn.closest('div[style]'); if (card) card.remove();
  } catch(e) {}
}
</script>

