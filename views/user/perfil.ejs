<%- include('../partials/header') %>
<%
// Pre-calculate ALL conditional values BEFORE HTML to avoid single-quote issues
var bannerSrc = (usuario.banner_tipo==='upload' && usuario.banner)
  ? '/uploads/banners/'+usuario.banner
  : '/img/defaults/banners/'+(usuario.banner_preset||'banner1.jpg');
var avatarSrc = (usuario.foto_perfil_tipo==='upload' && usuario.foto_perfil)
  ? '/uploads/profiles/'+usuario.foto_perfil
  : '/img/defaults/avatars/'+(usuario.foto_perfil_preset||'avatar1.png');
var cfgColor  = (perfilConfig && perfilConfig.color_primario) ? perfilConfig.color_primario : '#e91e8c';
var cfgTema   = (perfilConfig && perfilConfig.tema) ? perfilConfig.tema : 'oscuro';
var cfgPais   = (perfilConfig && perfilConfig.pais) ? perfilConfig.pais : 'Colombia';
var cfgIdioma = (perfilConfig && perfilConfig.idioma) ? perfilConfig.idioma : 'es';
var cfgPago   = (perfilConfig && perfilConfig.metodo_pago_pref) ? perfilConfig.metodo_pago_pref : 'tarjeta';
var cfgFondoTipo  = (perfilConfig && perfilConfig.fondo_tipo) ? perfilConfig.fondo_tipo : 'color';
var cfgFondoColor = (perfilConfig && perfilConfig.fondo_valor) ? perfilConfig.fondo_valor : '#0a0a0a';
var cfgBlur   = (perfilConfig && perfilConfig.fondo_blur) ? perfilConfig.fondo_blur : 0;
var avsList   = ['avatar1.png','avatar2.png','avatar3.png','avatar4.png','avatar5.png','avatar6.png'];
var bansList  = ['banner1.jpg','banner2.jpg','banner3.jpg','banner4.jpg','banner5.jpg','banner6.jpg'];
%>

<div style="max-width:1100px;margin:0 auto;padding-bottom:80px">

  <!-- BANNER -->
  <div style="position:relative;height:240px;overflow:hidden;background:#111">
    <img src="<%= bannerSrc %>" style="width:100%;height:100%;object-fit:cover;opacity:0.7" onerror="this.style.display='none'">
    <div style="position:absolute;inset:0;background:linear-gradient(to bottom,transparent 30%,rgba(10,10,10,0.8))"></div>
    <button onclick="showTab('avatar')" style="position:absolute;top:16px;right:16px;background:rgba(0,0,0,0.6);border:1px solid rgba(255,255,255,0.3);color:white;padding:7px 16px;font-family:'Bebas Neue',sans-serif;font-size:12px;letter-spacing:2px;cursor:pointer;backdrop-filter:blur(6px)">
      CAMBIAR BANNER
    </button>
  </div>

  <!-- AVATAR -->
  <div style="display:flex;align-items:flex-end;gap:24px;padding:0 40px;margin-top:-56px;position:relative;z-index:10;flex-wrap:wrap">
    <div style="position:relative;flex-shrink:0">
      <img src="<%= avatarSrc %>" width="112" height="112"
           style="border-radius:50%;object-fit:cover;border:4px solid var(--black);box-shadow:0 0 0 3px var(--pink),0 4px 24px rgba(233,30,140,0.4)"
           onerror="this.src='/img/defaults/avatars/avatar1.png'">
      <button onclick="showTab('avatar')" style="position:absolute;bottom:4px;right:4px;width:28px;height:28px;background:var(--pink);border-radius:50%;border:2px solid var(--black);cursor:pointer;display:flex;align-items:center;justify-content:center">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="white"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
      </button>
    </div>
    <div style="flex:1;min-width:200px;padding-bottom:8px">
      <div style="font-family:'Permanent Marker',cursive;font-size:28px;color:var(--pink)"><%= usuario.nombre_visible %></div>
      <div style="font-size:13px;color:var(--gray);letter-spacing:1.5px;margin-top:2px">@<%= usuario.username %></div>
      <% if (usuario.bio) { %><div style="font-size:13px;color:rgba(240,240,240,0.7);margin-top:6px;max-width:400px"><%= usuario.bio %></div><% } %>
    </div>
    <div style="display:flex;gap:8px;padding-bottom:12px;flex-wrap:wrap">
      <div style="text-align:center;padding:8px 16px;border:1px solid var(--border);min-width:70px">
        <div style="font-family:'Bebas Neue',sans-serif;font-size:22px;color:var(--pink)"><%= favoritos ? favoritos.length : 0 %></div>
        <div style="font-size:10px;color:var(--gray);letter-spacing:1.5px">FAVORITOS</div>
      </div>
      <div style="text-align:center;padding:8px 16px;border:1px solid var(--border);min-width:70px">
        <div style="font-family:'Bebas Neue',sans-serif;font-size:22px;color:var(--pink)"><%= tableros ? tableros.length : 0 %></div>
        <div style="font-size:10px;color:var(--gray);letter-spacing:1.5px">TABLEROS</div>
      </div>
      <div style="text-align:center;padding:8px 16px;border:1px solid var(--border);min-width:70px">
        <div style="font-family:'Bebas Neue',sans-serif;font-size:22px;color:var(--pink)"><%= pedidos ? pedidos.length : 0 %></div>
        <div style="font-size:10px;color:var(--gray);letter-spacing:1.5px">PEDIDOS</div>
      </div>
    </div>
  </div>

  <!-- TABS -->
  <div style="display:flex;border-bottom:1px solid var(--border);margin:24px 0 0;padding:0 40px;overflow-x:auto">
    <button onclick="showTab('info')"          id="tab-info"          class="ptab">PERFIL</button>
    <button onclick="showTab('favoritos')"     id="tab-favoritos"     class="ptab">FAVORITOS</button>
    <button onclick="showTab('tableros')"      id="tab-tableros"      class="ptab">MIS PINES</button>
    <button onclick="showTab('pedidos_tab')"   id="tab-pedidos_tab"   class="ptab">PEDIDOS</button>
    <button onclick="showTab('configuracion')" id="tab-configuracion" class="ptab">CONFIG</button>
    <button onclick="showTab('avatar')"        id="tab-avatar"        class="ptab">APARIENCIA</button>
    <button onclick="showTab('seguridad')"     id="tab-seguridad"     class="ptab">SEGURIDAD</button>
    <button onclick="showTab('conexiones');cargarConexionesPerfil()"  id="tab-conexiones"  class="ptab">CONEXIONES</button>
    <button onclick="showTab('logros');cargarLogrosPerfil()"          id="tab-logros"      class="ptab">🏆 LOGROS</button>
    <button onclick="showTab('amigos');cargarAmigos()"                id="tab-amigos"      class="ptab">AMIGOS</button>
  </div>

  <!-- PANEL: INFO -->
  <div id="panel-info" style="display:none;padding:32px 40px">
    <div style="background:rgba(255,255,255,0.03);border:1px solid var(--border);padding:28px;position:relative;max-width:600px">
      <div style="position:absolute;inset:0;border:2px solid rgba(255,255,255,0.15);filter:url(#gb);pointer-events:none"></div>
      <form action="/perfil/actualizar" method="POST">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px">
          <div><label class="mantiz-label">Nombre visible</label><input type="text" name="nombre_visible" class="mantiz-input" value="<%= usuario.nombre_visible %>" required></div>
          <div><label class="mantiz-label">Telefono</label><input type="text" name="telefono" class="mantiz-input" value="<%= usuario.telefono||'' %>"></div>
        </div>
        <div style="margin-bottom:20px"><label class="mantiz-label">Bio</label><textarea name="bio" class="mantiz-input" rows="3" placeholder="Cuentanos sobre ti..."><%= usuario.bio||'' %></textarea></div>
        <button type="submit" class="btn-grunge-fill">GUARDAR</button>
      </form>

      <div style="margin-top:28px;border-top:1px solid var(--border);padding-top:20px">
        <div style="font-family:'Bebas Neue',sans-serif;font-size:14px;letter-spacing:3px;color:var(--pink);margin-bottom:14px">DIRECCIONES</div>
        <% if (direcciones && direcciones.length > 0) { %>
          <% direcciones.forEach(function(d) { %>
          <%
            var dirBorder = d.predeterminada ? '#e91e8c' : 'rgba(255,255,255,0.1)';
          %>
          <div style="border:1px solid <%= dirBorder %>;padding:12px 16px;margin-bottom:8px;display:flex;justify-content:space-between;align-items:center">
            <div>
              <div style="font-size:13px;font-weight:600"><%= d.alias %>
                <% if (d.predeterminada) { %><span style="background:var(--pink);color:white;font-size:9px;padding:1px 7px;margin-left:8px;font-family:'Bebas Neue',sans-serif;letter-spacing:1px">DEFAULT</span><% } %>
              </div>
              <div style="font-size:11px;color:var(--gray);margin-top:2px"><%= d.direccion %>, <%= d.ciudad %></div>
            </div>
            <form action="/perfil/direccion/eliminar/<%= d.id %>" method="POST">
              <button type="submit" style="background:none;border:none;color:rgba(255,255,255,0.3);cursor:pointer;font-size:16px" onmouseover="this.style.color='#ff4444'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">&#x2715;</button>
            </form>
          </div>
          <% }) %>
        <% } %>
        <form action="/perfil/direcciones" method="POST" style="margin-top:12px">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px">
            <div><label class="mantiz-label">Alias</label><input type="text" name="alias" class="mantiz-input" placeholder="Casa, Trabajo..."></div>
            <div><label class="mantiz-label">Destinatario</label><input type="text" name="nombre_destinatario" class="mantiz-input" required></div>
            <div><label class="mantiz-label">Ciudad</label><input type="text" name="ciudad" class="mantiz-input" required></div>
            <div><label class="mantiz-label">Departamento</label><input type="text" name="departamento" class="mantiz-input" required></div>
            <div style="grid-column:1/-1"><label class="mantiz-label">Direccion</label><input type="text" name="direccion" class="mantiz-input" required></div>
          </div>
          <button type="submit" class="btn-grunge" style="font-size:12px;padding:8px 20px">+ AGREGAR</button>
        </form>
      </div>
    </div>
  </div>

  <!-- PANEL: FAVORITOS -->
  <div id="panel-favoritos" style="display:none;padding:32px 40px">
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px" class="fav-grid">
      <% if (favoritos && favoritos.length > 0) { %>
        <% favoritos.forEach(function(p) { %>
        <div class="product-card" onclick="window.location='/productos/<%= p.id %>'">
          <div class="pc-label"><span class="pc-label-text"><%= p.titulo.substring(0,16) %></span></div>
          <div class="pc-img-wrap"><div class="pc-img-clip">
            <img class="pc-img" src="/uploads/products/<%= p.imagen_principal %>" alt="<%= p.titulo %>" onerror="this.src='https://via.placeholder.com/400x533/111/888?text=MANTIZ'">
          </div>
            <button class="pc-add-btn" onclick="event.stopPropagation();quitarFav(<%= p.id %>,this)" style="background:#ff4444">&#9825;</button>
          </div>
          <div class="pc-info"><span class="pc-name"><%= p.titulo.substring(0,18) %></span><span class="pc-price">$<%= parseFloat(p.precio_descuento||p.precio).toLocaleString('es-CO') %></span></div>
        </div>
        <% }) %>
      <% } else { %>
      <div style="grid-column:1/-1;text-align:center;padding:80px;color:var(--gray)">
        <div style="font-size:48px;margin-bottom:16px;opacity:0.3">&#9825;</div>
        <div style="font-family:'Bebas Neue',sans-serif;font-size:24px;letter-spacing:4px">SIN FAVORITOS</div>
        <a href="/productos" class="btn-grunge" style="display:inline-flex;margin-top:20px">EXPLORAR</a>
      </div>
      <% } %>
    </div>
  </div>

  <!-- PANEL: TABLEROS -->
  <div id="panel-tableros" style="display:none;padding:32px 40px">
    <div id="vista-tableros">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;flex-wrap:wrap;gap:12px">
        <div style="font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:3px">MIS TABLEROS</div>
        <button onclick="abrirCrearTablero()" class="btn-grunge" style="font-size:12px;padding:8px 20px">+ NUEVO TABLERO</button>
      </div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px" class="tb-grid">
        <% if (tableros && tableros.length > 0) { %>
          <% tableros.forEach(function(t) { %>
          <%
            var tbColor = t.color_portada || '#e91e8c';
            var tbNombre = t.nombre;
          %>
          <div class="tablero-card" style="background:rgba(255,255,255,0.03);border:1px solid var(--border);overflow:hidden;transition:all 0.3s;position:relative"
               onmouseover="this.querySelector('.tb-cover').style.opacity='0.9'" onmouseout="this.querySelector('.tb-cover').style.opacity='0.75'">
            <div class="tb-cover" style="height:90px;background:<%= tbColor %>;opacity:0.75;cursor:pointer;transition:opacity 0.2s"
                 data-tb-id="<%= t.id %>" data-tb-nombre="<%= t.nombre %>"></div>
            <div style="padding:12px 14px 10px;display:flex;justify-content:space-between;align-items:flex-start">
              <div style="cursor:pointer" data-tb-id="<%= t.id %>" data-tb-nombre="<%= t.nombre %>">
                <div style="font-family:'Bebas Neue',sans-serif;font-size:15px;letter-spacing:2px;color:var(--white)"><%= tbNombre %></div>
                <div style="font-size:11px;color:var(--gray);margin-top:2px"><%= t.total_pines||0 %> pines &bull; <span style="color:<%= t.privacidad==='publico'?'#00c853':'var(--muted)' %>"><%= t.privacidad %></span></div>
              </div>
              <!-- MENÚ 3 PUNTOS -->
              <div style="position:relative">
                <button class="tb-menu-btn" data-id="<%= t.id %>"
                        style="background:none;border:none;color:var(--gray);cursor:pointer;padding:4px 8px;font-size:18px;line-height:1;transition:color 0.2s"
                        onmouseover="this.style.color='var(--pink)'" onmouseout="this.style.color='var(--gray)'"
                        onclick="toggleTbMenu(<%= t.id %>,event)">⋮</button>
                <div id="tb-menu-<%= t.id %>" style="display:none;position:absolute;right:0;top:28px;background:rgba(17,17,17,0.98);border:1px solid var(--border);min-width:140px;z-index:100">
                  <button data-tb-id="<%= t.id %>" data-tb-nombre="<%= t.nombre %>" class="tb-btn-ver"
                          style="display:block;width:100%;background:none;border:none;border-bottom:1px solid rgba(255,255,255,0.05);color:var(--white);padding:10px 16px;font-family:'Bebas Neue',sans-serif;font-size:11px;letter-spacing:2px;cursor:pointer;text-align:left"
                          onmouseover="this.style.color='var(--pink)'" onmouseout="this.style.color='var(--white)'">
                    <i class="bi bi-eye me-2"></i>VER PINES
                  </button>
                  <button data-tb-id="<%= t.id %>" data-tb-nombre="<%= t.nombre %>" data-tb-priv="<%= t.privacidad %>" data-tb-color="<%= tbColor %>" class="tb-btn-edit"
                          style="display:block;width:100%;background:none;border:none;border-bottom:1px solid rgba(255,255,255,0.05);color:var(--white);padding:10px 16px;font-family:'Bebas Neue',sans-serif;font-size:11px;letter-spacing:2px;cursor:pointer;text-align:left"
                          onmouseover="this.style.color='var(--pink)'" onmouseout="this.style.color='var(--white)'">
                    <i class="bi bi-pencil me-2"></i>EDITAR
                  </button>
                  <button data-tb-id="<%= t.id %>" class="tb-btn-del"
                          style="display:block;width:100%;background:none;border:none;color:rgba(255,100,100,0.7);padding:10px 16px;font-family:'Bebas Neue',sans-serif;font-size:11px;letter-spacing:2px;cursor:pointer;text-align:left"
                          onmouseover="this.style.color='#ff6060'" onmouseout="this.style.color='rgba(255,100,100,0.7)'">
                    <i class="bi bi-trash me-2"></i>ELIMINAR
                  </button>
                </div>
              </div>
            </div>
          </div>
          <% }) %>
        <% } else { %>
        <div style="grid-column:1/-1;text-align:center;padding:60px;color:var(--gray)">
          <div style="font-size:48px;margin-bottom:16px;opacity:0.3">&#128204;</div>
          <div style="font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:4px">SIN TABLEROS</div>
          <p style="margin-top:8px">Guarda productos con el boton GUARDAR</p>
        </div>
        <% } %>
      </div>
    </div>

    <div id="vista-pines" style="display:none">
      <div style="display:flex;align-items:center;gap:16px;margin-bottom:24px">
        <button onclick="volverTableros()" style="background:none;border:1px solid var(--border);color:var(--gray);padding:8px 16px;font-family:'Bebas Neue',sans-serif;font-size:12px;letter-spacing:2px;cursor:pointer">&#8592; VOLVER</button>
        <div id="pines-titulo" style="font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:3px;color:var(--white)"></div>
        <div id="pines-count" style="font-size:12px;color:var(--gray)"></div>
      </div>
      <div id="pines-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:18px" class="pines-pg"></div>
      <div id="pines-empty" style="display:none;text-align:center;padding:60px;color:var(--gray)">
        <div style="font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:3px">TABLERO VACIO</div>
      </div>
    </div>
  </div>

  <!-- PANEL: PEDIDOS -->
  <div id="panel-pedidos_tab" style="display:none;padding:32px 40px">
    <% if (pedidos && pedidos.length > 0) { %>
      <% pedidos.forEach(function(p) { %>
      <%
        var stMap = {pendiente:'#ffc800',confirmado:'#00c8ff',en_transito:'#60a5fa',entregado:'#00ff64',cancelado:'#ff6060'};
        var stColor = stMap[p.estado] || '#888888';
      %>
      <div style="background:rgba(255,255,255,0.03);border:1px solid var(--border);padding:20px;margin-bottom:12px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px">
        <div>
          <div style="font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:2px">PEDIDO #<%= String(p.id).padStart(5,'0') %></div>
          <div style="font-size:11px;color:var(--gray);margin-top:2px"><%= new Date(p.creado_en).toLocaleDateString('es-CO') %></div>
        </div>
        <div style="display:flex;align-items:center;gap:16px">
          <div style="font-family:'Bebas Neue',sans-serif;font-size:11px;padding:4px 12px;border:1px solid <%= stColor %>;color:<%= stColor %>"><%= (p.estado||'').toUpperCase() %></div>
          <div style="font-family:'Bebas Neue',sans-serif;font-size:18px;color:var(--pink)">$<%= parseFloat(p.total).toLocaleString('es-CO') %></div>
          <a href="/pedidos/<%= p.id %>" style="padding:6px 16px;border:1px solid var(--pink);color:var(--pink);text-decoration:none;font-family:'Bebas Neue',sans-serif;font-size:12px;letter-spacing:1px">VER</a>
        </div>
      </div>
      <% }) %>
    <% } else { %>
    <div style="text-align:center;padding:80px;color:var(--gray)">
      <div style="font-family:'Bebas Neue',sans-serif;font-size:24px;letter-spacing:4px">SIN PEDIDOS</div>
      <a href="/productos" class="btn-grunge" style="display:inline-flex;margin-top:20px">EXPLORAR</a>
    </div>
    <% } %>
  </div>

  <!-- PANEL: CONFIGURACION -->
  <div id="panel-configuracion" style="display:none;padding:32px 40px">
    <div style="max-width:700px;display:grid;grid-template-columns:1fr 1fr;gap:20px" class="cfg-grid">
      <div style="background:rgba(255,255,255,0.03);border:1px solid var(--border);padding:24px;position:relative">
        <div style="position:absolute;inset:0;border:2px solid rgba(255,255,255,0.1);filter:url(#gb);pointer-events:none"></div>
        <div style="font-family:'Bebas Neue',sans-serif;font-size:14px;letter-spacing:3px;color:var(--pink);margin-bottom:16px">PREFERENCIAS</div>
        <div style="display:flex;flex-direction:column;gap:14px">
          <div><label class="mantiz-label">Color de acento</label>
            <input type="color" id="cfg-color" value="<%= cfgColor %>" style="width:100%;height:40px;background:transparent;border:1px solid var(--border);padding:3px;cursor:pointer"></div>
          <div><label class="mantiz-label">Tema</label>
            <select id="cfg-tema" style="width:100%;background:rgba(255,255,255,0.04);border:1px solid var(--border);color:var(--white);padding:10px 12px;font-family:'Rajdhani',sans-serif;font-size:14px;outline:none">
              <option value="oscuro" <%= cfgTema==='oscuro'?'selected':'' %>>Oscuro</option>
              <option value="claro" <%= cfgTema==='claro'?'selected':'' %>>Claro</option>
            </select></div>
          <div><label class="mantiz-label">Pais</label>
            <select id="cfg-pais" style="width:100%;background:rgba(255,255,255,0.04);border:1px solid var(--border);color:var(--white);padding:10px 12px;font-family:'Rajdhani',sans-serif;font-size:14px;outline:none">
              <% ['Colombia','Mexico','Argentina','Chile','Peru','Venezuela','Ecuador','USA'].forEach(function(pais){ %>
              <option value="<%= pais %>" <%= cfgPais===pais?'selected':'' %>><%= pais %></option>
              <% }) %>
            </select></div>
          <div><label class="mantiz-label">Idioma</label>
            <select id="cfg-idioma" style="width:100%;background:rgba(255,255,255,0.04);border:1px solid var(--border);color:var(--white);padding:10px 12px;font-family:'Rajdhani',sans-serif;font-size:14px;outline:none">
              <option value="es" <%= cfgIdioma==='es'?'selected':'' %>>Espanol</option>
              <option value="en" <%= cfgIdioma==='en'?'selected':'' %>>English</option>
            </select></div>
          <div><label class="mantiz-label">Metodo de pago preferido</label>
            <select id="cfg-pago" style="width:100%;background:rgba(255,255,255,0.04);border:1px solid var(--border);color:var(--white);padding:10px 12px;font-family:'Rajdhani',sans-serif;font-size:14px;outline:none">
              <% ['tarjeta','nequi','daviplata','transferencia','contraentrega'].forEach(function(mp){ %>
              <option value="<%= mp %>" <%= cfgPago===mp?'selected':'' %>><%= mp.charAt(0).toUpperCase()+mp.slice(1) %></option>
              <% }) %>
            </select></div>
          <button onclick="guardarConfig()" class="btn-grunge-fill" style="margin-top:4px">GUARDAR</button>
          <div style="border-top:1px solid var(--border);padding-top:14px">
