     MODAL: VER 3D
══════════════════════════════════════════════════════════════════ -->
<% if (typeof modelo3d !== 'undefined' && modelo3d) { %>
<style>
#modal3d{position:fixed;inset:0;z-index:3000;background:rgba(5,5,5,.96);display:none;flex-direction:column;align-items:center;justify-content:center;padding:16px}
#modal3d.open{display:flex}
.m3d-wrap{width:min(90vw,700px);aspect-ratio:1/1;position:relative;background:#080808;border-radius:10px;overflow:hidden;border:1px solid rgba(0,200,255,.2);box-shadow:0 0 60px rgba(0,200,255,.08)}
.m3d-wrap canvas{width:100%!important;height:100%!important;display:block}
.m3d-loading{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;color:#00c8ff;font-family:'Bebas Neue',sans-serif;letter-spacing:2px;font-size:.8rem;z-index:4}
