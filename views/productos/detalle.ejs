.m3d-btn{padding:8px 18px;border:1px solid rgba(0,200,255,.3);background:rgba(0,200,255,.06);color:#00c8ff;font-family:'Bebas Neue',sans-serif;font-size:.65rem;letter-spacing:2px;cursor:pointer;border-radius:6px;transition:all .18s;display:flex;align-items:center;gap:5px}
.m3d-btn:hover,.m3d-btn.active{background:rgba(0,200,255,.18);border-color:#00c8ff}
.m3d-title{font-family:'Bebas Neue',sans-serif;font-size:.78rem;letter-spacing:2px;color:rgba(0,200,255,.7);margin-bottom:12px}
.m3d-hint{font-size:.6rem;color:rgba(255,255,255,.3);margin-top:8px;letter-spacing:.5px}
</style>
<div id="modal3d">
  <button class="m3d-close" onclick="cerrar3D()" title="Cerrar (Esc)"><i class="bi bi-x-lg"></i></button>
  <div class="m3d-title"><%= producto.titulo.toUpperCase() %> — MODELO 3D</div>
  <div class="m3d-wrap">
    <div class="m3d-loading" id="m3dLoading">
      <i class="bi bi-box-seam" style="font-size:28px;animation:m3dPulse 1.2s ease infinite alternate"></i>
      CARGANDO MODELO...
    </div>
    <canvas id="m3dCanvas"></canvas>
  </div>
  <div class="m3d-ctrl">
    <button class="m3d-btn active" onclick="m3dView('front',this)"><i class="bi bi-square"></i> FRONTAL</button>
    <button class="m3d-btn" onclick="m3dView('side',this)"><i class="bi bi-square-half"></i> LATERAL</button>
    <button class="m3d-btn" onclick="m3dView('back',this)"><i class="bi bi-square"></i> TRASERA</button>
    <button class="m3d-btn" onclick="m3dSpin(this)" id="m3dSpinBtn"><i class="bi bi-arrow-repeat"></i> AUTO-ROTAR</button>
    <button class="m3d-btn" onclick="m3dZoom(0.8)"><i class="bi bi-zoom-in"></i> +</button>
    <button class="m3d-btn" onclick="m3dZoom(1.25)"><i class="bi bi-zoom-out"></i> −</button>
  </div>
  <div class="m3d-hint">Arrastra para rotar · Scroll para zoom</div>
</div>
<style>@keyframes m3dPulse{from{opacity:.3}to{opacity:1}}</style>
<script>
var m3dViewer=null, m3dSpinning=false;
var MODELO3D_URL='/models/<%= modelo3d.archivo %>';
var MODELO3D_ESCALA=<%= modelo3d.escala || 1 %>;
var MODELO3D_POSY=<%= modelo3d.pos_y || 0 %>;

var m3dLibsReady=false;
function loadM3dLibs(cb){
  if(m3dLibsReady){cb();return;}
  var loads=0, need=3;
  function done(){if(++loads===need){m3dLibsReady=true;cb();}}
  if(typeof THREE!=='undefined'){need--;} else {
    var s=document.createElement('script');s.src='https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';s.onload=done;document.head.appendChild(s);
  }
  var s2=document.createElement('script');s2.src='https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/GLTFLoader.js';s2.onload=done;document.head.appendChild(s2);
  var s3=document.createElement('script');s3.src='https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js';s3.onload=done;document.head.appendChild(s3);
  if(typeof THREE!=='undefined')done();
}

function abrirViewer3D(){
  document.getElementById('modal3d').classList.add('open');
  document.body.style.overflow='hidden';
  document.getElementById('m3dLoading').style.display='flex';
  loadM3dLibs(function(){
    var canvas=document.getElementById('m3dCanvas');
    if(m3dViewer)m3dViewer.dispose();
    m3dViewer=buildM3dViewer(canvas,MODELO3D_ESCALA,MODELO3D_POSY);
    m3dViewer.load(MODELO3D_URL,function(){
      document.getElementById('m3dLoading').style.display='none';
    });
  });
}
function cerrar3D(){
  document.getElementById('modal3d').classList.remove('open');
  document.body.style.overflow='';
  if(m3dViewer){m3dViewer.dispose();m3dViewer=null;}
  m3dSpinning=false;
  document.getElementById('m3dSpinBtn').classList.remove('active');
}
function m3dView(view,btn){
  if(!m3dViewer)return;
  document.querySelectorAll('.m3d-ctrl .m3d-btn:not(#m3dSpinBtn)').forEach(function(b){b.classList.remove('active');});
  if(btn)btn.classList.add('active');
  m3dViewer.setView(view);
}
function m3dSpin(btn){m3dSpinning=m3dViewer?m3dViewer.toggleSpin():false;btn.classList.toggle('active',m3dSpinning);}
function m3dZoom(f){if(m3dViewer)m3dViewer.zoom(f);}

function buildM3dViewer(canvas,escala,posY){
  var scene=new THREE.Scene();scene.background=new THREE.Color(0x080808);
  var w=canvas.clientWidth||500,h=canvas.clientHeight||500;
  var camera=new THREE.PerspectiveCamera(45,w/h,0.01,1000);
  var renderer=new THREE.WebGLRenderer({canvas:canvas,antialias:true});
  renderer.setSize(w,h,false);renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));
  renderer.outputEncoding=THREE.sRGBEncoding;renderer.toneMapping=THREE.ACESFilmicToneMapping;renderer.toneMappingExposure=1.1;
  scene.add(new THREE.AmbientLight(0xffffff,0.7));
  var dir=new THREE.DirectionalLight(0xffffff,1.1);dir.position.set(4,7,4);scene.add(dir);
  var blue=new THREE.PointLight(0x00c8ff,0.7,12);blue.position.set(-3,2,3);scene.add(blue);
  var fill=new THREE.DirectionalLight(0xffffff,0.3);fill.position.set(-4,-2,-4);scene.add(fill);
  var controls=new THREE.OrbitControls(camera,canvas);
  controls.enableDamping=true;controls.dampingFactor=0.08;controls.enablePan=false;controls.minDistance=0.2;controls.maxDistance=40;
  var group=new THREE.Group();scene.add(group);
  var model=null,baseDist=3,spinning=false,disposed=false,rafId=null;
  function frameModel(){
    if(!model)return;
    var box=new THREE.Box3().setFromObject(model);
    var center=box.getCenter(new THREE.Vector3());
    var size=box.getSize(new THREE.Vector3());
    var maxD=Math.max(size.x,size.y,size.z)||1;
    model.position.sub(center);
    baseDist=maxD*2.1;
    camera.position.set(0,maxD*0.15,baseDist);
    camera.lookAt(0,0,0);controls.target.set(0,0,0);controls.update();
  }
  function animate(){
    if(disposed)return;
    rafId=requestAnimationFrame(animate);
    if(spinning)group.rotation.y+=0.006;
    controls.update();
    renderer.render(scene,camera);
  }
  animate();
  var obs=('ResizeObserver' in window)?new ResizeObserver(function(){
    var w2=canvas.clientWidth,h2=canvas.clientHeight;if(!w2||!h2)return;
    camera.aspect=w2/h2;camera.updateProjectionMatrix();renderer.setSize(w2,h2,false);
  }):null;
  if(obs)obs.observe(canvas);
  return{
    load:function(url,onDone){
      var loader=new THREE.GLTFLoader();
      loader.load(url,function(gltf){
        if(disposed)return;
        model=gltf.scene;
        model.scale.setScalar(escala||1);
        group.add(model);
        model.position.y+=(posY||0);
        frameModel();
        if(onDone)onDone();
      });
    },
    setView:function(view){
      if(!model)return;
      var d=baseDist;
      var p={front:[0,.15*d,d],side:[d,.15*d,0],back:[0,.15*d,-d],'three-quarter':[d*.7,d*.4,d*.7]}[view]||[0,.15*d,d];
      camera.position.set(p[0],p[1],p[2]);camera.lookAt(0,0,0);controls.target.set(0,0,0);controls.update();
    },
    zoom:function(f){camera.position.multiplyScalar(f);controls.update();},
    toggleSpin:function(){spinning=!spinning;return spinning;},
    dispose:function(){
      disposed=true;if(rafId)cancelAnimationFrame(rafId);if(obs)obs.disconnect();controls.dispose();
      scene.traverse(function(o){if(o.geometry)o.geometry.dispose();if(o.material){var ms=Array.isArray(o.material)?o.material:[o.material];ms.forEach(function(m){for(var k in m){if(m[k]&&m[k].isTexture)m[k].dispose();}m.dispose&&m.dispose();});}});
      renderer.dispose();
    }
  };
}
document.addEventListener('keydown',function(e){if(e.key==='Escape')cerrar3D();});
</script>
<% } %>

<!-- ══════════════════════════════════════════════════════════════════
     MODAL: PROBAR (Virtual Try-On con cámara)
══════════════════════════════════════════════════════════════════ -->
<style>
#modalTryOn{position:fixed;inset:0;z-index:3000;background:rgba(5,5,5,.97);display:none;flex-direction:column;align-items:center;justify-content:center;padding:16px}
#modalTryOn.open{display:flex}
.to-stage{position:relative;width:min(90vw,540px);aspect-ratio:3/4;background:#000;border-radius:10px;overflow:hidden;border:1px solid rgba(233,30,140,.25);box-shadow:0 0 60px rgba(233,30,140,.08);cursor:move;user-select:none}
#toVideo{width:100%;height:100%;object-fit:cover;display:block;transform:scaleX(-1)}/* espejo natural */
#toOverlay{position:absolute;top:10%;left:15%;width:70%;cursor:move;user-select:none;touch-action:none;filter:drop-shadow(0 4px 16px rgba(0,0,0,.7));opacity:.88;transition:opacity .18s}
#toOverlay:hover{opacity:1}
.to-close{position:absolute;top:16px;right:20px;background:rgba(233,30,140,.1);border:1px solid rgba(233,30,140,.3);color:var(--cp);width:36px;height:36px;border-radius:8px;cursor:pointer;font-size:18px;display:flex;align-items:center;justify-content:center;z-index:5}
.to-close:hover{background:rgba(255,60,60,.15);border-color:#ff4444;color:#ff4444}
.to-ctrl{display:flex;gap:8px;margin-top:14px;flex-wrap:wrap;justify-content:center}
.to-btn{padding:9px 18px;border:1px solid rgba(233,30,140,.35);background:rgba(233,30,140,.07);color:var(--cp);font-family:'Bebas Neue',sans-serif;font-size:.68rem;letter-spacing:2px;cursor:pointer;border-radius:6px;transition:all .18s;display:flex;align-items:center;gap:6px}
.to-btn:hover{background:rgba(233,30,140,.2)}
.to-btn.primary{background:var(--cp);color:white;border-color:var(--cp)}
.to-btn.primary:hover{background:#d01478}
.to-hint{font-size:.6rem;color:rgba(255,255,255,.35);margin-top:8px;text-align:center;letter-spacing:.5px;max-width:420px}
.to-no-cam{display:none;flex-direction:column;align-items:center;justify-content:center;gap:12px;color:var(--muted);text-align:center;padding:40px;position:absolute;inset:0;background:#070707}
.to-no-cam i{font-size:2rem;color:rgba(233,30,140,.3)}
#toCaptureResult{display:none;max-width:min(90vw,540px);border-radius:10px;border:1px solid rgba(233,30,140,.3);margin-top:12px}
</style>

<div id="modalTryOn">
  <button class="to-close" onclick="cerrarTryOn()" title="Cerrar (Esc)"><i class="bi bi-x-lg"></i></button>
  <div style="font-family:'Bebas Neue',sans-serif;font-size:.78rem;letter-spacing:2px;color:rgba(233,30,140,.7);margin-bottom:12px">
    PROBADOR VIRTUAL — <%= producto.titulo.toUpperCase() %>
  </div>
  <div class="to-stage" id="toStage">
    <video id="toVideo" autoplay playsinline muted></video>
    <img id="toOverlay"
         src="<%= producto.imagen_principal ? '/uploads/products/'+producto.imagen_principal : '' %>"
         alt="<%= producto.titulo %>"
         onerror="this.style.display='none'">
    <div class="to-no-cam" id="toNoCam">
      <i class="bi bi-camera-video-off"></i>
      <div style="font-family:'Bebas Neue',sans-serif;font-size:.8rem;letter-spacing:2px">SIN ACCESO A CÁMARA</div>
      <div style="font-size:.72rem;max-width:260px;line-height:1.5">
        Para usar el probador virtual necesitas permitir el acceso a tu cámara en el navegador.
      </div>
    </div>
  </div>
  <!-- Foto capturada (aparece debajo tras capturar) -->
  <img id="toCaptureResult" alt="Captura probador">
  <div class="to-ctrl">
    <button class="to-btn" onclick="toScale(1.1)"><i class="bi bi-zoom-in"></i> AMPLIAR</button>
    <button class="to-btn" onclick="toScale(0.9)"><i class="bi bi-zoom-out"></i> REDUCIR</button>
    <button class="to-btn" onclick="toResetPos()"><i class="bi bi-arrow-counterclockwise"></i> RESET</button>
    <button class="to-btn primary" onclick="toCapturar()"><i class="bi bi-camera-fill"></i> CAPTURAR FOTO</button>
  </div>
  <div class="to-hint">
    Arrastra la prenda sobre tu cuerpo · Usa Ampliar/Reducir para ajustar el tamaño · Haz clic en Capturar para guardar la foto
  </div>
</div>

<script>
// ── TRY-ON: cámara + overlay arrastrable ───────────────────────────────────
var toStream=null, toOvEl=null, toDragging=false, toStartX=0, toStartY=0, toOvX=0, toOvY=0, toOvW=70;

function abrirTryOn(){
  document.getElementById('modalTryOn').classList.add('open');
  document.body.style.overflow='hidden';
  toOvEl=document.getElementById('toOverlay');
  document.getElementById('toCaptureResult').style.display='none';
  initTryOnCamera();
  setupDrag();
}
function cerrarTryOn(){
  document.getElementById('modalTryOn').classList.remove('open');
  document.body.style.overflow='';
  if(toStream){toStream.getTracks().forEach(function(t){t.stop();});toStream=null;}
}

function initTryOnCamera(){
  var video=document.getElementById('toVideo');
  var noCam=document.getElementById('toNoCam');
  if(!navigator.mediaDevices||!navigator.mediaDevices.getUserMedia){
    noCam.style.display='flex'; return;
  }
  navigator.mediaDevices.getUserMedia({video:{facingMode:'user',width:{ideal:720},height:{ideal:960}},audio:false})
    .then(function(stream){
      toStream=stream;
      video.srcObject=stream;
      noCam.style.display='none';
    })
    .catch(function(){noCam.style.display='flex';});
}

function setupDrag(){
  var el=document.getElementById('toOverlay');
  var stage=document.getElementById('toStage');

  // Reset posición y tamaño
  el.style.left='15%'; el.style.top='10%'; el.style.width='70%'; toOvW=70;

  // Mouse
  el.addEventListener('mousedown',function(e){
    toDragging=true;
    toStartX=e.clientX; toStartY=e.clientY;
    toOvX=parseFloat(el.style.left)||0;
    toOvY=parseFloat(el.style.top)||0;
    e.preventDefault();
  });
  document.addEventListener('mousemove',function(e){
    if(!toDragging)return;
    var stageW=stage.offsetWidth,stageH=stage.offsetHeight;
    var dx=(e.clientX-toStartX)/stageW*100;
    var dy=(e.clientY-toStartY)/stageH*100;
    el.style.left=Math.min(80,Math.max(-10,toOvX+dx))+'%';
    el.style.top=Math.min(80,Math.max(-10,toOvY+dy))+'%';
  });
  document.addEventListener('mouseup',function(){toDragging=false;});

  // Touch
  el.addEventListener('touchstart',function(e){
    if(e.touches.length===1){
      toDragging=true;
      toStartX=e.touches[0].clientX; toStartY=e.touches[0].clientY;
      toOvX=parseFloat(el.style.left)||0;
      toOvY=parseFloat(el.style.top)||0;
    }
    e.preventDefault();
  },{passive:false});
  document.addEventListener('touchmove',function(e){
    if(!toDragging||e.touches.length!==1)return;
    var stageW=stage.offsetWidth,stageH=stage.offsetHeight;
    var dx=(e.touches[0].clientX-toStartX)/stageW*100;
    var dy=(e.touches[0].clientY-toStartY)/stageH*100;
    el.style.left=Math.min(80,Math.max(-10,toOvX+dx))+'%';
    el.style.top=Math.min(80,Math.max(-10,toOvY+dy))+'%';
  },{passive:true});
  document.addEventListener('touchend',function(){toDragging=false;});
}

function toScale(factor){
  toOvW=Math.min(130,Math.max(20,toOvW*factor));
  document.getElementById('toOverlay').style.width=toOvW+'%';
}
function toResetPos(){
  var el=document.getElementById('toOverlay');
  el.style.left='15%'; el.style.top='10%'; el.style.width='70%'; toOvW=70;
}

function toCapturar(){
  var video=document.getElementById('toVideo');
  var stage=document.getElementById('toStage');
  var ovEl=document.getElementById('toOverlay');
  var sw=stage.offsetWidth, sh=stage.offsetHeight;
  var canvas=document.createElement('canvas');
  canvas.width=sw*2; canvas.height=sh*2; // double resolution
  var ctx=canvas.getContext('2d');
  ctx.save();
  ctx.translate(canvas.width,0);
  ctx.scale(-1,1); // espejo para coincidir con el video
  ctx.drawImage(video,0,0,canvas.width,canvas.height);
  ctx.restore();
  // Dibujar overlay
  var ovRect=ovEl.getBoundingClientRect();
  var stRect=stage.getBoundingClientRect();
  var ox=(ovRect.left-stRect.left)*2, oy=(ovRect.top-stRect.top)*2;
  var ow=ovRect.width*2, oh=ovRect.height*2;
  var img=new Image();
  img.crossOrigin='anonymous';
  img.onload=function(){
    ctx.drawImage(img,ox,oy,ow,oh);
    var dataUrl=canvas.toDataURL('image/jpeg',.9);
    var resultEl=document.getElementById('toCaptureResult');
    resultEl.src=dataUrl;
    resultEl.style.display='block';
    // Descargar automáticamente
    var a=document.createElement('a');
    a.href=dataUrl;
    a.download='mantiz-tryon-<%= producto.id %>.jpg';
    a.click();
  };
  img.onerror=function(){
    // Si la imagen no carga por CORS, mostrar solo el video
    var dataUrl=canvas.toDataURL('image/jpeg',.9);
    var resultEl=document.getElementById('toCaptureResult');
    resultEl.src=dataUrl; resultEl.style.display='block';
  };
  img.src=ovEl.src;
}

document.addEventListener('keydown',function(e){if(e.key==='Escape'){cerrar3D();cerrarTryOn();}});
</script>

