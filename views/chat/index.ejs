<%- include('../partials/header') %>

<style>
.chat-wrap { display:flex; flex-direction:column; height:calc(100vh - 64px); max-width:720px; margin:0 auto; padding:0 16px; }
.chat-header { display:flex; align-items:center; gap:12px; padding:16px 0; border-bottom:1px solid var(--border); flex-shrink:0; }
.chat-av { width:42px; height:42px; border-radius:50%; background:var(--pink); display:flex; align-items:center; justify-content:center; font-size:18px; flex-shrink:0; filter:url(#gb); }
.chat-header-name { font-family:'Bebas Neue',sans-serif; font-size:1.1rem; letter-spacing:2px; color:var(--white); }
.chat-header-status { font-size:11px; color:#00c853; letter-spacing:1px; }
.chat-msgs { flex:1; overflow-y:auto; padding:16px 0; display:flex; flex-direction:column; gap:8px; }
.msg-row { display:flex; align-items:flex-end; gap:8px; }
.msg-row.mine { flex-direction:row-reverse; }
.msg-av { width:28px; height:28px; border-radius:50%; background:var(--dark3); display:flex; align-items:center; justify-content:center; font-size:12px; flex-shrink:0; object-fit:cover; }
.msg-bubble { max-width:75%; padding:10px 14px; border-radius:18px; word-break:break-word; }
.msg-bubble.theirs { background:var(--card-bg); border:1px solid var(--faint-1); border-bottom-left-radius:4px; }
.msg-bubble.mine { background:var(--pink); color:white; border-bottom-right-radius:4px; }
.msg-text { font-size:14px; line-height:1.5; }
.msg-meta { display:flex; align-items:center; gap:4px; margin-top:4px; justify-content:flex-end; }
.msg-time { font-size:10px; opacity:.7; }
.msg-status.leido { color:#7fffd4; }
.msg-img { max-width:100%; border-radius:10px; cursor:pointer; }
.chat-input-wrap { border-top:1px solid var(--border); padding:12px 0; flex-shrink:0; display:flex; flex-direction:column; gap:8px; }
.chat-input-row { display:flex; align-items:flex-end; gap:10px; position:relative; }
.chat-input { flex:1; background:var(--card-bg); border:2px solid var(--faint-2); color:var(--white); padding:10px 14px; border-radius:22px; font-family:'Rajdhani',sans-serif; font-size:14px; outline:none; resize:none; max-height:120px; min-height:42px; line-height:1.5; }
.chat-input:focus { border-color:var(--pink); }
.chat-send-btn { width:42px; height:42px; border-radius:50%; background:var(--pink); border:2px solid white; color:white; cursor:pointer; display:flex; align-items:center; justify-content:center; flex-shrink:0; filter:url(#gb); }
.chat-action-btn { background:none; border:1px solid var(--faint-2); color:var(--gray); padding:6px 10px; border-radius:16px; font-size:14px; cursor:pointer; display:flex; align-items:center; }
.chat-empty { display:flex; flex-direction:column; align-items:center; justify-content:center; flex:1; color:var(--gray); text-align:center; gap:12px; }
.emoji-picker { display:none; position:absolute; bottom:100%; left:0; background:var(--dark3); border:1px solid var(--border); border-radius:12px; padding:10px; width:260px; z-index:100; }
.emoji-picker.open { display:flex; flex-wrap:wrap; gap:4px; }
.emoji-btn { font-size:20px; cursor:pointer; padding:4px; border-radius:6px; }
.emoji-btn:hover { background:var(--faint-1); }
.file-preview { display:none; align-items:center; gap:8px; padding:8px 12px; background:var(--card-bg); border:1px solid var(--faint-1); border-radius:8px; }
.file-preview.visible { display:flex; }
</style>

<div class="chat-wrap">
  <div class="chat-header">
    <div class="chat-av"><i class="bi bi-headset"></i></div>
    <div style="flex:1">
      <div class="chat-header-name">SOPORTE MANTIZ</div>
      <div class="chat-header-status">● En línea</div>
    </div>
    <% if (conv) { %>
    <div style="font-size:11px;color:var(--gray);font-family:'Bebas Neue',sans-serif;letter-spacing:1px">
      <%= (conv.estado||'pendiente').toUpperCase() %>
    </div>
    <% } %>
  </div>

  <div class="chat-msgs" id="chatMsgs">
    <% if (!conv) { %>
    <div class="chat-empty">
      <i class="bi bi-chat-heart" style="font-size:3rem;color:rgba(233,30,140,.2)"></i>
      <div style="font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:2px">EMPIEZA UNA CONVERSACIÓN</div>
      <div style="font-size:13px">Escríbenos y te responderemos pronto</div>
    </div>
    <% } else if (mensajes.length === 0) { %>
    <div class="chat-empty">
      <i class="bi bi-chat-dots" style="font-size:2.4rem;color:rgba(233,30,140,.2)"></i>
      <div style="font-size:13px">Aún no hay mensajes. ¡Escribe el primero!</div>
    </div>
    <% } %>
    <% mensajes.forEach(function(m) {
      var esMio = m.remitente_id == userId;
      var hora = new Date(m.creado_en).toLocaleTimeString('es-CO', {hour:'2-digit', minute:'2-digit'});
    %>
    <div class="msg-row <%= esMio ? 'mine' : '' %>" data-msg-id="<%= m.id %>">
      <% if (!esMio) { %><div class="msg-av"><i class="bi bi-headset"></i></div><% } %>
      <div class="msg-bubble <%= esMio ? 'mine' : 'theirs' %>">
        <% if (m.tipo === 'imagen') { %><img src="<%= m.archivo_url %>" class="msg-img" onclick="window.open(this.src)"><% } %>
        <% if (m.tipo === 'archivo') { %>
        <div style="display:flex;align-items:center;gap:8px;padding:4px 0">
          <i class="bi bi-file-earmark"></i>
          <a href="<%= m.archivo_url %>" target="_blank" style="color:inherit"><%= m.archivo_nombre || 'Archivo' %></a>
        </div>
        <% } %>
        <% if (m.contenido) { %><div class="msg-text"><%- m.contenido.replace(/\n/g,'<br>') %></div><% } %>
        <div class="msg-meta">
          <span class="msg-time"><%= hora %></span>
          <% if (esMio) { %><span class="msg-status <%= m.estado==='leido'?'leido':'' %>"><%= m.estado==='leido' ? '✓✓' : '✓' %></span><% } %>
        </div>
      </div>
    </div>
    <% }) %>
  </div>

  <% if (conv) { %>
  <div class="chat-input-wrap">
    <div class="file-preview" id="filePreview">
      <i class="bi bi-paperclip"></i>
      <span id="filePreviewName" style="font-size:12px;color:var(--white)"></span>
      <button onclick="clearFile()" style="background:none;border:none;color:var(--gray);cursor:pointer;font-size:14px">✕</button>
    </div>
    <div class="chat-input-row">
      <div id="emojiPicker" class="emoji-picker"></div>
      <button class="chat-action-btn" onclick="toggleEmoji()">😊</button>
      <label class="chat-action-btn" style="cursor:pointer">
        <i class="bi bi-paperclip"></i>
        <input type="file" id="chatFile" accept="image/*,.pdf,.doc,.docx,.txt" style="display:none" onchange="onFileChange(this)">
      </label>
      <textarea class="chat-input" id="chatInput" placeholder="Escribe un mensaje..." rows="1"
        onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();enviarMensaje()}"
        oninput="autoResize(this)"></textarea>
      <button class="chat-send-btn" onclick="enviarMensaje()"><i class="bi bi-send-fill" style="font-size:13px"></i></button>
    </div>
  </div>
  <% } %>
</div>

<script>
var CONV_ID = '<%= conv ? conv.id : "" %>';
var USER_ID = '<%= userId %>';
var lastMsg  = '<%= mensajes.length ? new Date(mensajes[mensajes.length-1].creado_en).toISOString() : new Date().toISOString() %>';
var chatMsgs = document.getElementById('chatMsgs');
function scrollBottom(){ chatMsgs.scrollTop = chatMsgs.scrollHeight; }
scrollBottom();
function autoResize(el){ el.style.height='auto'; el.style.height=Math.min(el.scrollHeight,120)+'px'; }

var EMOJIS = ['😊','❤️','😂','😍','🔥','👏','✅','😎','🙌','💯','🥳','😅','💪','🤔','😢','🙏','✨','🎉','💬','👍'];
var emojiOpen = false;
function toggleEmoji(){
  var p=document.getElementById('emojiPicker');
  if(!emojiOpen){ p.innerHTML=EMOJIS.map(function(e){return '<button class="emoji-btn" onclick="insertEmoji(\''+e+'\')" type="button">'+e+'</button>';}).join(''); }
  p.classList.toggle('open',!emojiOpen); emojiOpen=!emojiOpen;
}
function insertEmoji(e){ var i=document.getElementById('chatInput'); i.value+=e; i.focus(); }
document.addEventListener('click',function(e){ if(emojiOpen&&!e.target.closest('#emojiPicker')&&!e.target.closest('.chat-action-btn')){ document.getElementById('emojiPicker').classList.remove('open'); emojiOpen=false; } });

var selectedFile=null;
function onFileChange(input){ selectedFile=input.files[0]; if(selectedFile){ document.getElementById('filePreviewName').textContent=selectedFile.name; document.getElementById('filePreview').classList.add('visible'); } }
function clearFile(){ selectedFile=null; document.getElementById('chatFile').value=''; document.getElementById('filePreview').classList.remove('visible'); }

async function enviarMensaje(){
  var texto=document.getElementById('chatInput').value.trim();
  if(!texto&&!selectedFile) return;
  var fd=new FormData();
  fd.append('conversacion_id', CONV_ID);
  if(texto) fd.append('contenido', texto);
  if(selectedFile) fd.append('archivo', selectedFile);
  document.getElementById('chatInput').value=''; autoResize(document.getElementById('chatInput')); clearFile();
  try{
    var r=await fetch('/chat/enviar',{method:'POST',body:fd});
    var d=await r.json();
    if(d.success){ appendMsg(d.msg); scrollBottom(); lastMsg=d.msg.creado_en; }
  }catch(e){ console.error(e); }
}

function appendMsg(m){
  var esMio = m.remitente_id == USER_ID;
  var hora = new Date(m.creado_en).toLocaleTimeString('es-CO',{hour:'2-digit',minute:'2-digit'});
  var bubble='';
  if(m.tipo==='imagen') bubble+='<img src="'+m.archivo_url+'" class="msg-img" onclick="window.open(this.src)">';
  else if(m.tipo==='archivo') bubble+='<div style="display:flex;align-items:center;gap:8px"><i class="bi bi-file-earmark"></i><a href="'+m.archivo_url+'" target="_blank" style="color:inherit">'+(m.archivo_nombre||'Archivo')+'</a></div>';
  if(m.contenido) bubble+='<div class="msg-text">'+m.contenido.replace(/</g,'&lt;').replace(/\n/g,'<br>')+'</div>';
  bubble+='<div class="msg-meta"><span class="msg-time">'+hora+'</span>'+(esMio?'<span class="msg-status">✓</span>':'')+'</div>';
  var row=document.createElement('div');
  row.className='msg-row'+(esMio?' mine':'');
  row.innerHTML=(esMio?'':'<div class="msg-av"><i class="bi bi-headset"></i></div>')+'<div class="msg-bubble '+(esMio?'mine':'theirs')+'">'+bubble+'</div>';
  chatMsgs.appendChild(row);
}

if (CONV_ID) {
  setInterval(async function(){
    try{
      var r=await fetch('/chat/mensajes/'+CONV_ID+'?desde='+encodeURIComponent(lastMsg));
      var d=await r.json();
      if(d.success&&d.mensajes.length){
        var wasBottom = chatMsgs.scrollHeight-chatMsgs.clientHeight-chatMsgs.scrollTop<50;
        d.mensajes.forEach(function(m){ appendMsg(m); lastMsg=m.creado_en; });
        if(wasBottom) scrollBottom();
      }
    }catch(e){}
  }, 3000);
}
</script>

<%- include('../partials/footer') %>
