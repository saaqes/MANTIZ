<%- include('../partials/header') %>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<div style="padding:40px;max-width:1300px;margin:0 auto">
  <h2 class="section-title">NUESTRAS TIENDAS</h2>
  <div style="text-align:center;margin:10px 0 32px;opacity:0.7">
    <svg width="200" height="20" viewBox="0 0 200 20" fill="none">
      <line x1="0" y1="10" x2="80" y2="10" stroke="rgba(233,30,140,0.4)" stroke-width="1"/>
      <circle cx="100" cy="10" r="5" fill="var(--pink)"/>
      <line x1="120" y1="10" x2="200" y2="10" stroke="rgba(233,30,140,0.4)" stroke-width="1"/>
    </svg>
  </div>

  <% if (!tiendas || tiendas.length === 0) { %>
  <div style="text-align:center;padding:80px;color:var(--gray)">
    <div style="font-size:48px;margin-bottom:16px">🏪</div>
    <div style="font-family:'Bebas Neue',sans-serif;font-size:28px;letter-spacing:4px">SIN TIENDAS REGISTRADAS</div>
    <p style="margin-top:8px;letter-spacing:1px">Pronto abriremos locales cerca de ti</p>
  </div>
  <% } else { %>

  <div style="display:grid;grid-template-columns:320px 1fr;gap:24px" class="map-layout">
    <!-- Lista -->
    <div style="display:flex;flex-direction:column;gap:10px;max-height:580px;overflow-y:auto;padding-right:4px">
      <% tiendas.forEach(function(t, idx) { %>
      <div class="tienda-card" data-id="<%= idx %>" onclick="flyTo(<%= t.lat || 4.71 %>,<%= t.lng || -74.07 %>,<%= idx %>)"
           style="background:rgba(255,255,255,0.03);border:1px solid var(--border);padding:18px;cursor:pointer;transition:all 0.2s;position:relative">
        <div style="position:absolute;inset:0;border:1px solid rgba(255,255,255,0.1);filter:url(#gb);pointer-events:none"></div>
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px">
          <div style="font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:2px;color:var(--white)"><%= t.nombre %></div>
          <span style="font-size:9px;padding:2px 8px;border-radius:4px;font-family:'Bebas Neue',sans-serif;letter-spacing:1px;background:<%= t.activa?'rgba(0,255,100,.1)':'rgba(255,96,96,.1)' %>;color:<%= t.activa?'#00ff64':'#ff6060' %>"><%= t.activa?'ABIERTA':'CERRADA' %></span>
        </div>
        <div style="font-size:12px;color:var(--gray);letter-spacing:0.5px;margin-bottom:6px">
          <i class="bi bi-geo-alt me-1" style="color:var(--pink)"></i><%= t.direccion %><% if(t.ciudad){ %>, <%= t.ciudad %><% } %>
        </div>
        <% if (t.telefono) { %>
        <div style="font-size:11px;color:var(--pink);letter-spacing:1px"><i class="bi bi-telephone me-1"></i><%= t.telefono %></div>
        <% } %>
        <% if (t.horario) { %>
        <div style="font-size:11px;color:var(--gray);margin-top:4px;letter-spacing:0.5px"><i class="bi bi-clock me-1"></i><%= t.horario %></div>
        <% } %>
      </div>
      <% }) %>
    </div>

    <!-- Mapa -->
    <div style="position:relative;border:2px solid var(--border);filter:url(#gb);overflow:hidden">
      <div id="map" style="height:580px;width:100%;background:#0a0a0a"></div>
      <div id="map-info" style="position:absolute;bottom:0;left:0;right:0;background:rgba(10,10,10,0.92);backdrop-filter:blur(8px);padding:16px 20px;transform:translateY(100%);transition:transform 0.3s;border-top:1px solid var(--border)">
        <div id="map-info-nombre" style="font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:3px;color:var(--pink)"></div>
        <div id="map-info-dir" style="font-size:13px;color:var(--gray);margin-top:4px"></div>
        <div id="map-info-tel" style="font-size:12px;color:var(--pink);margin-top:3px"></div>
      </div>
    </div>
  </div>
  <% } %>
</div>

<style>
.tienda-card.active { border-color: var(--pink) !important; background: rgba(233,30,140,0.08) !important; }
.leaflet-container { background: #0a0a0a !important; }
.leaflet-tile { filter: brightness(0.65) saturate(0.5) hue-rotate(200deg); }
.leaflet-control-attribution { display: none; }
.leaflet-popup-content-wrapper { background: rgba(15,10,15,0.95); border: 1px solid rgba(233,30,140,0.3); border-radius: 0; box-shadow: 0 8px 32px rgba(0,0,0,0.6); }
.leaflet-popup-content { color: #f0f0f0; font-family: 'Rajdhani', sans-serif; font-size: 13px; margin: 12px 16px; }
.leaflet-popup-tip { background: rgba(15,10,15,0.95); }
.leaflet-popup-close-button { color: rgba(233,30,140,0.8) !important; }
@media(max-width:768px) { .map-layout { grid-template-columns: 1fr !important; } #map { height: 320px !important; } div[style*="padding:40px"] { padding: 20px !important; } }
</style>

<script>
// Data from server
var tiendasData = <%- JSON.stringify(tiendas || []) %>;
var activeIdx = -1;

// Init map centered on Colombia
var defaultLat = 4.7110, defaultLng = -74.0721, defaultZoom = 6;

// Try to find center from first store with coords
var firstWithCoords = tiendasData.find(function(t){ return t.lat && t.lng; });
if (firstWithCoords) { defaultLat = firstWithCoords.lat; defaultLng = firstWithCoords.lng; defaultZoom = 13; }

var map = L.map('map', { zoomControl: true, scrollWheelZoom: true }).setView([defaultLat, defaultLng], defaultZoom);
// Fix distortion: invalidate size after render and on window resize
setTimeout(function() { map.invalidateSize(); }, 200);
window.addEventListener('resize', function() { map.invalidateSize(); });

L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
  maxZoom: 19,
  attribution: ''
}).addTo(map);

// Custom pink marker
function makePinkIcon(active) {
  return L.divIcon({
    className: '',
    html: '<div style="width:32px;height:32px;background:'+(active?'white':'var(--pink)')+';border:3px solid '+(active?'var(--pink)':'rgba(255,255,255,0.6)')+';border-radius:50% 50% 50% 0;transform:rotate(-45deg);display:flex;align-items:center;justify-content:center;box-shadow:0 4px 14px rgba(233,30,140,0.7)"><div style="transform:rotate(45deg);color:'+(active?'var(--pink)':'white')+';font-size:14px">◈</div></div>',
    iconSize: [32, 32],
    iconAnchor: [16, 32],
    popupAnchor: [0, -36]
  });
}

var markers = [];
tiendasData.forEach(function(t, idx) {
  if (!t.lat || !t.lng) return;
  var marker = L.marker([t.lat, t.lng], { icon: makePinkIcon(false) }).addTo(map);
  marker.bindPopup(
    '<strong style="color:#e91e8c;font-family:Bebas Neue,sans-serif;letter-spacing:2px;font-size:15px">' + t.nombre + '</strong>' +
    '<br><span style="color:#888">' + (t.direccion||'') + (t.ciudad?', '+t.ciudad:'') + '</span>' +
    (t.telefono ? '<br><span style="color:#e91e8c">&#9742; '+t.telefono+'</span>' : '') +
    (t.horario ? '<br><span style="color:#666;font-size:11px">'+t.horario+'</span>' : '')
  );
  marker.on('click', function() { selectTienda(idx); });
  markers.push({ marker: marker, data: t });
});

function flyTo(lat, lng, idx) {
  map.flyTo([lat, lng], 16, { duration: 1.2 });
  selectTienda(idx);
}

function selectTienda(idx) {
  // Reset all cards and markers
  document.querySelectorAll('.tienda-card').forEach(function(c) { c.classList.remove('active'); });
  markers.forEach(function(m) { m.marker.setIcon(makePinkIcon(false)); });

  var card = document.querySelector('.tienda-card[data-id="'+idx+'"]');
  if (card) { card.classList.add('active'); card.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }
  if (markers[idx]) { markers[idx].marker.setIcon(makePinkIcon(true)); markers[idx].marker.openPopup(); }

  // Show bottom info panel
  var t = tiendasData.find(function(td, i){ return i===idx; });
  if (t) {
    document.getElementById('map-info-nombre').textContent = t.nombre;
    document.getElementById('map-info-dir').textContent = (t.direccion||'') + (t.ciudad?', '+t.ciudad:'');
    document.getElementById('map-info-tel').textContent = t.telefono ? '☎ ' + t.telefono : '';
    document.getElementById('map-info').style.transform = 'translateY(0)';
  }
  activeIdx = idx;
}

// If there's only one store with coords, zoom in
if (markers.length === 1) { map.setView([markers[0].data.lat, markers[0].data.lng], 15); }
</script>

<%- include('../partials/footer') %>
