<%- include('../partials/header') %>

<style>
/* ── Layout principal (igual que admin, pero read-only) ── */
.mapa-wrapper{display:grid;grid-template-columns:340px 1fr;gap:0;height:calc(100vh - 180px);min-height:500px;border:1px solid var(--border);border-radius:14px;overflow:hidden}
.tiendas-panel{background:var(--dark2);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden}
.panel-header{padding:16px;border-bottom:1px solid var(--border);flex-shrink:0}
.panel-header-title{font-family:var(--fd);font-size:.72rem;font-weight:800;letter-spacing:2px;color:var(--cp)}
.tiendas-list{flex:1;overflow-y:auto;padding:8px;scrollbar-width:thin;scrollbar-color:rgba(233,30,140,.3) transparent}
.tiendas-list::-webkit-scrollbar{width:3px}
.tiendas-list::-webkit-scrollbar-thumb{background:rgba(233,30,140,.3);border-radius:2px}

/* ── Tarjeta de tienda (read-only: sin acciones) ── */
.tienda-item{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:12px 14px;cursor:pointer;transition:all .2s;margin-bottom:8px;border-left:3px solid transparent}
.tienda-item:hover{border-color:rgba(233,30,140,.4);background:rgba(233,30,140,.04)}
.tienda-item.activa{border-left-color:var(--cp)}
.tienda-item.inactiva{border-left-color:#5a5a7a;opacity:.65}
.tienda-item.selected{border-color:var(--cp);background:rgba(233,30,140,.08)}
.tienda-name{font-family:var(--fb);font-weight:700;font-size:.9rem;color:var(--text)}
.tienda-meta{font-family:var(--fm);font-size:.63rem;color:var(--muted);margin-top:3px;display:flex;align-items:center;gap:4px}
.tienda-contact{display:flex;gap:8px;margin-top:8px;flex-wrap:wrap}
.contact-chip{display:inline-flex;align-items:center;gap:4px;padding:3px 9px;border-radius:20px;font-family:var(--fm);font-size:.6rem;font-weight:700;text-decoration:none;transition:all .18s}
.chip-tel{background:rgba(233,30,140,.1);color:var(--cp);border:1px solid rgba(233,30,140,.2)}
.chip-tel:hover{background:rgba(233,30,140,.2);color:var(--cp)}
.chip-email{background:rgba(0,200,255,.08);color:#00c8ff;border:1px solid rgba(0,200,255,.15)}
.chip-email:hover{background:rgba(0,200,255,.18);color:#00c8ff}
.status-badge{font-family:var(--fm);font-size:.55rem;padding:2px 7px;border-radius:4px;font-weight:700;letter-spacing:.5px}

/* ── Mapa ── */
#mapaUsuario{height:100%;width:100%}

/* ── Botón "Cerca de mí" ── */
.geo-btn{position:absolute;top:12px;right:12px;z-index:1000;background:rgba(17,17,17,.92);border:1px solid rgba(233,30,140,.35);color:var(--text);padding:8px 14px;border-radius:8px;font-family:var(--fb);font-size:.75rem;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:6px;transition:all .2s;backdrop-filter:blur(8px)}
.geo-btn:hover{border-color:var(--cp);color:var(--cp);background:rgba(233,30,140,.08)}
.geo-btn.locating{animation:pulsegeo .8s infinite alternate}
@keyframes pulsegeo{from{opacity:.6}to{opacity:1}}

/* ── Panel de info en el fondo del mapa ── */
#map-detail{position:absolute;bottom:0;left:0;right:0;background:rgba(10,10,10,.93);backdrop-filter:blur(12px);padding:14px 18px;transform:translateY(100%);transition:transform .3s cubic-bezier(.4,0,.2,1);border-top:2px solid rgba(233,30,140,.3);z-index:900}
#map-detail.open{transform:translateY(0)}
#map-detail-nombre{font-family:var(--fd);font-size:1rem;letter-spacing:2px;color:var(--cp)}
#map-detail-dir{font-family:var(--fb);font-size:.78rem;color:var(--muted);margin-top:4px}
#map-detail-extras{display:flex;gap:8px;margin-top:6px;flex-wrap:wrap}
.detail-close{position:absolute;top:10px;right:14px;background:none;border:none;color:var(--muted);font-size:16px;cursor:pointer;line-height:1;padding:2px}

/* ── Empty state ── */
.empty-map{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;color:var(--muted);gap:12px;padding:40px}
.empty-map i{font-size:2.5rem;color:rgba(233,30,140,.3)}

/* ── Responsive ── */
@media(max-width:900px){.mapa-wrapper{grid-template-columns:1fr;grid-template-rows:auto 350px;height:auto}}
@media(max-width:767px){
  .mapa-wrapper{grid-template-rows:auto 300px;border-radius:10px}
  .tiendas-list{max-height:220px}
  .panel-header-title{font-size:.65rem}
}

/* Estilos del mapa (mismos que admin) */
.leaflet-container{background:#0a0a0a !important}
.leaflet-popup-content-wrapper{background:rgba(15,10,15,.97);border:1px solid rgba(233,30,140,.3);border-radius:8px !important;box-shadow:0 8px 32px rgba(0,0,0,.7)}
.leaflet-popup-content{color:#f0f0f0;font-family:'Rajdhani',sans-serif;font-size:13px;margin:12px 16px !important}
.leaflet-popup-tip{background:rgba(15,10,15,.97)}
.leaflet-popup-close-button{color:rgba(233,30,140,.8) !important;font-size:16px !important;top:8px !important;right:8px !important}
.leaflet-control-zoom a{background:rgba(17,17,17,.92) !important;color:var(--text) !important;border-color:rgba(255,255,255,.1) !important}
.leaflet-control-zoom a:hover{background:rgba(233,30,140,.15) !important;color:var(--cp) !important}
</style>

<!-- Page header -->
<div style="max-width:1400px;margin:0 auto;padding:0 24px 20px">
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
    <div>
      <div style="font-family:var(--fm);font-size:.58rem;color:var(--muted);letter-spacing:2px;text-transform:uppercase">MANTIZ</div>
      <div style="font-family:var(--fd);font-size:1.4rem;font-weight:800;color:var(--text)">Nuestras Sucursales</div>
    </div>
    <div style="font-family:var(--fm);font-size:.75rem;color:var(--muted)">
      <i class="bi bi-geo-alt-fill me-1" style="color:var(--cp)"></i>
      <%= tiendas.length %> sucursal<%= tiendas.length !== 1 ? 'es' : '' %> en el mapa
    </div>
  </div>

  <% if (!tiendas || tiendas.length === 0) { %>
  <div class="empty-map" style="height:480px;border:1px solid var(--border);border-radius:14px">
    <i class="bi bi-shop"></i>
    <div style="font-family:var(--fd);font-size:1.1rem;letter-spacing:3px;color:var(--text)">Próximamente</div>
    <div style="font-family:var(--fm);font-size:.85rem;color:var(--muted);text-align:center;max-width:300px">
      Estamos expandiéndonos. Pronto encontrarás una sucursal cerca de ti.
    </div>
  </div>
  <% } else { %>

  <!-- Mapa + panel (mismo layout que admin) -->
  <div class="mapa-wrapper">

    <!-- Panel lateral de tiendas -->
    <div class="tiendas-panel">
      <div class="panel-header">
        <div class="panel-header-title mb-2">◈ SUCURSALES (<%= tiendas.length %>)</div>
        <input type="text" id="buscarTienda" class="form-control form-control-sm" placeholder="🔍 Buscar tienda o ciudad...">
      </div>
      <div class="tiendas-list" id="listaTiendas">
        <% tiendas.forEach(t => { %>
        <div class="tienda-item <%= t.activa ? 'activa' : 'inactiva' %>" id="tc-<%= t.id %>"
             onclick="focusTienda(<%= parseFloat(t.latitud)||0 %>, <%= parseFloat(t.longitud)||0 %>, <%= t.id %>)">
          <div class="d-flex justify-content-between align-items-start gap-2">
            <div class="tienda-name"><%= t.nombre %></div>
            <span class="status-badge" style="background:<%= t.activa ? 'rgba(0,255,100,.1)' : 'rgba(90,90,122,.15)' %>;color:<%= t.activa ? '#00ff64' : 'var(--muted)' %>;white-space:nowrap">
              <%= t.activa ? 'ABIERTA' : 'CERRADA' %>
            </span>
          </div>
          <% if(t.ciudad || t.direccion) { %>
          <div class="tienda-meta">
            <i class="bi bi-geo-alt" style="color:var(--cp)"></i>
            <span><%= [t.direccion, t.ciudad].filter(Boolean).join(', ') %></span>
          </div>
          <% } %>
          <% if(t.horario) { %>
          <div class="tienda-meta"><i class="bi bi-clock" style="color:var(--muted)"></i><span><%= t.horario %></span></div>
          <% } %>
          <div class="tienda-contact">
            <% if(t.telefono) { %><a class="contact-chip chip-tel" href="tel:<%= t.telefono %>" onclick="event.stopPropagation()"><i class="bi bi-telephone"></i><%= t.telefono %></a><% } %>
            <% if(t.email) { %><a class="contact-chip chip-email" href="mailto:<%= t.email %>" onclick="event.stopPropagation()"><i class="bi bi-envelope"></i><%= t.email %></a><% } %>
          </div>
        </div>
        <% }) %>
      </div>
    </div>

    <!-- Mapa -->
    <div style="position:relative">
      <div id="mapaUsuario"></div>

      <!-- Botón geolocalización -->
      <button class="geo-btn" id="geoBtn" onclick="locateMe()" title="Ver sucursales cerca de ti">
        <i class="bi bi-crosshair" id="geoIco"></i> Cerca de mí
      </button>

      <!-- Panel de detalle al seleccionar -->
      <div id="map-detail">
        <button class="detail-close" onclick="closeDetail()"><i class="bi bi-x-lg"></i></button>
        <div id="map-detail-nombre"></div>
        <div id="map-detail-dir"></div>
        <div id="map-detail-extras"></div>
      </div>
    </div>

  </div>
  <% } %>
</div>

<script>
// ══════════════════════════════════════════════════════════════════════════
// MAPA USUARIO — Sistema idéntico al admin, modo solo lectura
// ══════════════════════════════════════════════════════════════════════════
const tiendasData = <%- JSON.stringify(tiendas || []) %>;
let mapaMain = null, markers = {}, userCircle = null;

// ── Mismo pin SVG que el admin ──────────────────────────────────────────
function makePinIcon(color){
  return L.divIcon({
    html: `<svg width="28" height="36" viewBox="0 0 32 40"><path d="M16 0C7.163 0 0 7.163 0 16c0 10 16 24 16 24S32 26 32 16C32 7.163 24.837 0 16 0z" fill="${color}"/><circle cx="16" cy="16" r="7" fill="white"/><circle cx="16" cy="16" r="4" fill="${color}"/></svg>`,
    iconSize:[28,36], iconAnchor:[14,36], className:''
  });
}

// ── Inicialización del mapa ─────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  const first = tiendasData.find(t => t.latitud && t.longitud);
  const center = first ? [parseFloat(first.latitud), parseFloat(first.longitud)] : [4.6, -74.0];
  const zoom   = first ? 13 : 6;

  mapaMain = L.map('mapaUsuario', { zoomControl: true }).setView(center, zoom);

  // ── Mismos tiles oscuros que el admin ──
  L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
    attribution: '©OpenStreetMap ©Carto', maxZoom: 19
  }).addTo(mapaMain);

  // ── Invalidar tamaño al redimensionar (fix distorsión) ──
  setTimeout(() => mapaMain.invalidateSize(), 200);
  window.addEventListener('resize', () => mapaMain.invalidateSize());

  renderMarkers();

  // ── Búsqueda en la lista lateral ──
  document.getElementById('buscarTienda').addEventListener('input', function(){
    const q = this.value.toLowerCase();
    document.querySelectorAll('.tienda-item').forEach(el => {
      el.style.display = el.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
  });

  // Zoom a la vista de todas si hay más de una tienda
  if (tiendasData.filter(t => t.latitud && t.longitud).length > 1) {
    try {
      const bounds = Object.values(markers).map(m => m.getLatLng());
      if (bounds.length > 1) mapaMain.fitBounds(L.latLngBounds(bounds), { padding: [40, 40] });
    } catch(e) {}
  }
});

// ── Renderizar marcadores ───────────────────────────────────────────────
function renderMarkers(){
  Object.values(markers).forEach(m => mapaMain.removeLayer(m));
  markers = {};
  tiendasData.forEach(t => {
    const lat = parseFloat(t.latitud), lng = parseFloat(t.longitud);
    if (!lat || !lng) return;
    const color = t.activa ? '#e91e8c' : '#5a5a7a';
    const m = L.marker([lat, lng], { icon: makePinIcon(color) }).addTo(mapaMain);
    m.bindPopup(buildPopup(t));
    m.on('click', () => {
      selectCard(t.id);
      showDetail(t);
    });
    markers[t.id] = m;
  });
}

// ── Popup idéntico al admin ─────────────────────────────────────────────
function buildPopup(t){
  return `<div style="font-family:'Rajdhani',sans-serif;min-width:160px">
    <div style="font-weight:700;color:#e91e8c;font-size:.9rem;margin-bottom:4px">${t.nombre}</div>
    ${t.direccion ? `<div style="font-size:.78rem;color:#ccc">${t.direccion}${t.ciudad?', '+t.ciudad:''}</div>` : ''}
    ${t.telefono  ? `<div style="font-size:.78rem;color:#e91e8c;margin-top:3px">📞 ${t.telefono}</div>` : ''}
    ${t.horario   ? `<div style="font-size:.73rem;color:#888;margin-top:2px">🕐 ${t.horario}</div>` : ''}
    <div style="margin-top:6px;font-size:.7rem;font-weight:700;color:${t.activa?'#00ff64':'#5a5a7a'}">${t.activa?'✓ ABIERTA':'✗ CERRADA'}</div>
  </div>`;
}

// ── Focus al hacer clic en una tarjeta de la lista ─────────────────────
function focusTienda(lat, lng, id){
  if (!lat || !lng) return;
  mapaMain.setView([lat, lng], 16, { animate: true });
  if (markers[id]) markers[id].openPopup();
  selectCard(id);
  const t = tiendasData.find(x => x.id === id);
  if (t) showDetail(t);
}

// ── Resaltar tarjeta activa ─────────────────────────────────────────────
function selectCard(id){
  document.querySelectorAll('.tienda-item').forEach(el => el.classList.remove('selected'));
  const card = document.getElementById('tc-' + id);
  if (card) { card.classList.add('selected'); card.scrollIntoView({ behavior:'smooth', block:'nearest' }); }
}

// ── Panel de detalle inferior ───────────────────────────────────────────
function showDetail(t){
  document.getElementById('map-detail-nombre').textContent = t.nombre;
  document.getElementById('map-detail-dir').textContent = [t.direccion, t.ciudad, t.pais].filter(Boolean).join(' · ');
  let extras = '';
  if(t.telefono) extras += `<a class="contact-chip chip-tel" href="tel:${t.telefono}"><i class="bi bi-telephone"></i>${t.telefono}</a>`;
  if(t.email)    extras += `<a class="contact-chip chip-email" href="mailto:${t.email}"><i class="bi bi-envelope"></i>${t.email}</a>`;
  if(t.horario)  extras += `<span style="font-family:var(--fm);font-size:.65rem;color:var(--muted);display:flex;align-items:center;gap:4px"><i class="bi bi-clock"></i>${t.horario}</span>`;
  document.getElementById('map-detail-extras').innerHTML = extras;
  document.getElementById('map-detail').classList.add('open');
}
function closeDetail(){ document.getElementById('map-detail').classList.remove('open'); }

// ── Geolocalización "Cerca de mí" ───────────────────────────────────────
function locateMe(){
  if (!navigator.geolocation) { alert('Tu navegador no soporta geolocalización.'); return; }
  const btn = document.getElementById('geoBtn');
  const ico = document.getElementById('geoIco');
  btn.classList.add('locating');
  ico.className = 'bi bi-hourglass-split';
  navigator.geolocation.getCurrentPosition(pos => {
    const lat = pos.coords.latitude, lng = pos.coords.longitude;
    btn.classList.remove('locating');
    ico.className = 'bi bi-crosshair';
    mapaMain.setView([lat, lng], 13, { animate: true });
    if (userCircle) mapaMain.removeLayer(userCircle);
    userCircle = L.circle([lat, lng], {
      radius: 3000, color: '#e91e8c', fillColor: '#e91e8c',
      fillOpacity: 0.06, weight: 1.5, dashArray: '4'
    }).addTo(mapaMain);
    // Mostrar distancias y ordenar la lista por cercanía
    sortByDistance(lat, lng);
  }, () => {
    btn.classList.remove('locating');
    ico.className = 'bi bi-crosshair';
    alert('No se pudo obtener tu ubicación. Verifica los permisos del navegador.');
  });
}

function sortByDistance(myLat, myLng){
  const list = document.getElementById('listaTiendas');
  const items = [...list.querySelectorAll('.tienda-item')];
  items.forEach(el => {
    const id = parseInt(el.id.replace('tc-',''));
    const t  = tiendasData.find(x => x.id === id);
    if (!t || !t.latitud || !t.longitud) { el.dataset.dist = 99999; return; }
    const d = haversine(myLat, myLng, parseFloat(t.latitud), parseFloat(t.longitud));
    el.dataset.dist = d;
    // Mostrar etiqueta de distancia
    let distLabel = el.querySelector('.dist-label');
    if (!distLabel) { distLabel = document.createElement('div'); distLabel.className = 'tienda-meta dist-label'; el.appendChild(distLabel); }
    distLabel.innerHTML = `<i class="bi bi-signpost-split" style="color:var(--cp)"></i><span>${d < 1 ? Math.round(d*1000)+' m' : d.toFixed(1)+' km'} de ti</span>`;
  });
  items.sort((a,b) => parseFloat(a.dataset.dist) - parseFloat(b.dataset.dist));
  items.forEach(el => list.appendChild(el));
}

function haversine(lat1,lng1,lat2,lng2){
  const R=6371, dLat=(lat2-lat1)*Math.PI/180, dLng=(lng2-lng1)*Math.PI/180;
  const a=Math.sin(dLat/2)**2+Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLng/2)**2;
  return R*2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a));
}
</script>

<%- include('../partials/footer') %>
