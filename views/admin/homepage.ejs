<!-- ══════════════════════════════════════════════════════════
     SCRIPTS
     ══════════════════════════════════════════════════════════ -->
<script>
/* ── Helpers de modal ── */
function mcOpen(id)  { document.getElementById(id).classList.add('open'); }
function mcClose(id) { document.getElementById(id).classList.remove('open'); }

// Cerrar al hacer click en el fondo
document.querySelectorAll('.mc-backdrop').forEach(function(bd) {
  bd.addEventListener('click', function(e) {
    if (e.target === bd) mcClose(bd.id);
  });
});

// Cerrar con Escape
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    document.querySelectorAll('.mc-backdrop.open').forEach(function(bd) {
      mcClose(bd.id);
    });
  }
});

/* ── Toggle visibilidad de sección ── */
function toggleSec(btn, key) {
  var isOn = btn.classList.contains('on');
  btn.classList.toggle('on', !isOn);
  btn.classList.toggle('off',  isOn);
  document.getElementById('hid-' + key).value = isOn ? '0' : '1';
}

/* ── Drag-and-drop para reordenar secciones (solo desde el grip) ── */
(function() {
  var list     = document.getElementById('secciones-list');
  var dragging = null;

  list.querySelectorAll('.sec-card').forEach(function(card) {
    var handle = card.querySelector('.sec-drag-handle');
    if (!handle) return;

    handle.setAttribute('draggable', 'true');

    handle.addEventListener('dragstart', function(e) {
      dragging = card;
      card.classList.add('dragging');
      e.dataTransfer.effectAllowed = 'move';
    });

    card.addEventListener('dragend', function() {
      card.classList.remove('dragging');
      list.querySelectorAll('.sec-card').forEach(function(c) { c.classList.remove('drag-over'); });
      updateSecOrder();
    });

    card.addEventListener('dragover', function(e) {
      e.preventDefault();
      if (!dragging) return;
      e.dataTransfer.dropEffect = 'move';
      var after = getDragAfter(list, e.clientY);
      if (after == null) list.appendChild(dragging);
      else list.insertBefore(dragging, after);
    });
  });

  function getDragAfter(container, y) {
    var els = Array.from(container.querySelectorAll('.sec-card:not(.dragging)'));
    return els.reduce(function(closest, child) {
      var box    = child.getBoundingClientRect();
      var offset = y - box.top - box.height / 2;
      if (offset < 0 && offset > closest.offset)
        return { offset: offset, element: child };
      return closest;
    }, { offset: Number.NEGATIVE_INFINITY }).element;
  }

  function updateSecOrder() {
    var order = Array.from(list.querySelectorAll('.sec-card'))
                     .map(function(c) { return c.dataset.sec; });
    document.getElementById('seccion_orden_input').value = order.join(',');
  }
})();

function decodeDataAttr(val) {
  try { return decodeURIComponent(val || ''); } catch(e) { return val || ''; }
}

/* ── Abrir modal editar slide ── */
function abrirEditSlide(btn) {
  document.getElementById('formEditSlide').action =
    '/admin/homepage/carrusel/' + btn.dataset.id + '/editar';
  document.getElementById('es-titulo').value    = decodeDataAttr(btn.dataset.titulo);
  document.getElementById('es-subtitulo').value = decodeDataAttr(btn.dataset.subtitulo);
  document.getElementById('es-activo').checked  = btn.dataset.activo === '1';
  mcOpen('mcEditSlide');
}

function abrirEditMarca(btn) {
  document.getElementById('formEditMarca').action =
    '/admin/homepage/carrusel-marca/' + btn.dataset.id + '/editar';
  document.getElementById('em-titulo').value    = decodeDataAttr(btn.dataset.titulo);
  document.getElementById('em-subtitulo').value = decodeDataAttr(btn.dataset.subtitulo);
  document.getElementById('em-activo').checked  = btn.dataset.activo === '1';
  mcOpen('mcEditMarca');
}

document.querySelectorAll('.btn-edit-slide').forEach(function(btn) {
  btn.addEventListener('click', function() { abrirEditSlide(btn); });
});
document.querySelectorAll('.btn-edit-marca').forEach(function(btn) {
  btn.addEventListener('click', function() { abrirEditMarca(btn); });
});
</script>

