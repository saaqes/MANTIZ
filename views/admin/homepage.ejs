<%- include('../partials/header', {isAdmin: true}) %>

<style>
/* Sección cards drag & drop */
.sec-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 16px 18px;
  margin-bottom: 10px;
  transition: all .2s;
  user-select: none;
}
.sec-drag-handle { cursor: grab; }
.sec-drag-handle:active { cursor: grabbing; }
.sec-card:hover { border-color: var(--cp); }
.sec-card.dragging { opacity: .4; border-color: var(--cp); box-shadow: 0 0 0 2px rgba(233,30,140,.3); }

/* Toggle switch */
.sec-toggle {
  width: 44px; height: 24px; border-radius: 12px;
  border: none; cursor: pointer;
  transition: background .25s; position: relative; flex-shrink: 0;
}
.sec-toggle.on  { background: var(--cp); }
.sec-toggle.off { background: var(--faint-2); }
.sec-toggle::after {
  content: ''; position: absolute;
  width: 18px; height: 18px; border-radius: 50%;
  background: white; top: 3px; transition: left .25s;
}
.sec-toggle.on::after  { left: 22px; }
.sec-toggle.off::after { left: 3px; }

/* Miniatura slides */
.slide-thumb {
  width: 110px; height: 62px; object-fit: cover;
  border-radius: 6px; border: 1px solid var(--border); flex-shrink: 0;
  background: #111;
}

/* Miniatura slides */
.slide-thumb {
  width: 110px; height: 62px; object-fit: cover;
  border-radius: 6px; border: 1px solid var(--border); flex-shrink: 0;
  background: #111;
}

/* ── MODALES CUSTOM: eliminados (la gestión de banners ahora vive en /admin/carrusel) ── */

/* Drag-over indicator */
.drag-over { border-top: 2px solid var(--cp); }
</style>

<!-- ── PAGE HEADER ── -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 style="font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:3px;color:var(--cp)">ESTRUCTURA DEL INICIO</h4>
    <p class="small text-muted mb-0">Configura qué secciones se muestran, su orden y contenido</p>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════════
     FILA PRINCIPAL: izquierda (config) | derecha (slides hero)
     ══════════════════════════════════════════════════════════ -->
<div class="row g-4">

  <!-- ── COLUMNA IZQUIERDA ── -->
  <div class="col-12 col-lg-6">

    <!-- Card: Orden & toggles -->
    <div class="card mb-4">
      <div class="card-body">
        <h6 style="font-family:'Bebas Neue',sans-serif;font-size:.7rem;letter-spacing:2px;color:var(--cp);margin-bottom:14px">
          ORDEN DE SECCIONES
        </h6>
        <p class="small text-muted mb-3">Arrastra para reordenar. Activa/desactiva con el toggle.</p>

        <form action="/admin/homepage/guardar" method="POST" id="formLayout">
          <input type="hidden" name="seccion_orden" id="seccion_orden_input"
                 value="<%= cfg.seccion_orden || 'hero,productos,bestsellers,carrusel_marca' %>">

          <div id="secciones-list">
            <%
              var secOrden = (cfg.seccion_orden || 'hero,productos,bestsellers,carrusel_marca').split(',');
              var secInfo = {
                hero:           { label: 'Hero / Carrusel principal',  icon: 'bi-images',     key: 'mostrar_hero' },
                productos:      { label: 'Grid de Productos',           icon: 'bi-grid-3x3',   key: 'mostrar_productos' },
                bestsellers:    { label: 'Lo Más Vendido + Viewer 3D', icon: 'bi-box-seam',   key: 'mostrar_bestsellers' },
                carrusel_marca: { label: 'Carrusel de Marca',           icon: 'bi-film',       key: 'mostrar_carrusel_marca' }
              };
            %>
            <% secOrden.forEach(function(sec) {
                 var info = secInfo[sec];
                 if (!info) return;
                 var isOn = cfg[info.key] !== '0';
            %>
            <div class="sec-card d-flex align-items-center gap-3" data-sec="<%= sec %>">
              <i class="bi bi-grip-vertical text-muted sec-drag-handle" title="Arrastrar para reordenar"></i>
              <i class="bi <%= info.icon %>" style="color:var(--cp);font-size:1.1rem;width:22px"></i>
              <div class="flex-grow-1">
                <div style="font-weight:600;font-size:.85rem"><%= info.label %></div>
                <div class="small text-muted">clave: <code><%= sec %></code></div>
              </div>
              <button type="button"
                      class="sec-toggle <%= isOn ? 'on' : 'off' %>"
                      onclick="toggleSec(this,'<%= info.key %>')"
                      title="<%= isOn ? 'Ocultar sección' : 'Mostrar sección' %>">
              </button>
              <input type="hidden" name="<%= info.key %>" id="hid-<%= info.key %>" value="<%= isOn ? '1' : '0' %>">
            </div>
            <% }) %>
          </div><!-- /#secciones-list -->

          <!-- Cantidades y título -->
          <div class="row g-3 mt-3">
            <div class="col-6">
              <label class="form-label">Productos en inicio</label>
              <input type="number" name="productos_cantidad" class="form-control"
                     value="<%= cfg.productos_cantidad || 8 %>" min="2" max="12">
            </div>
            <div class="col-6">
              <label class="form-label">Bestsellers / Recomendados</label>
              <input type="number" name="bestsellers_cantidad" class="form-control"
                     value="<%= cfg.bestsellers_cantidad || 4 %>" min="2" max="8">
            </div>
            <div class="col-12">
              <label class="form-label">Título del carrusel de marca</label>
              <input type="text" name="carrusel_marca_titulo" class="form-control"
                     value="<%= cfg.carrusel_marca_titulo || 'NUEVA COLECCION' %>">
            </div>
          </div>

          <button type="submit" class="btn btn-pm w-100 mt-3">
            <i class="bi bi-floppy me-2"></i>Guardar Configuración
          </button>
        </form>
      </div>
    </div><!-- /card orden -->

    <!-- Card: Modelo 3D activo -->
    <div class="card">
      <div class="card-body">
        <h6 style="font-family:'Bebas Neue',sans-serif;font-size:.7rem;letter-spacing:2px;color:var(--cp);margin-bottom:14px">
          MODELO 3D ACTIVO EN INICIO
        </h6>
        <% if (modelos && modelos.length > 0) { %>
        <div class="d-flex flex-column gap-2">
          <% modelos.forEach(function(m) { %>
          <div class="d-flex align-items-center gap-3 p-2 rounded"
               style="border:1px solid <%= m.es_principal ? 'var(--cp)' : 'var(--border)' %>;background:<%= m.es_principal ? 'rgba(233,30,140,.07)' : 'transparent' %>">
            <div class="d-flex align-items-center justify-content-center rounded"
                 style="width:40px;height:40px;background:#0e0e0e;flex-shrink:0">
              <i class="bi bi-box" style="color:var(--cp)"></i>
            </div>
            <div class="flex-grow-1">
              <div style="font-weight:600;font-size:.85rem"><%= m.nombre %></div>
              <div class="small text-muted"><%= m.archivo %></div>
            </div>
            <% if (m.es_principal) { %>
            <span style="background:var(--cp);color:white;font-size:.6rem;padding:2px 8px;border-radius:4px;letter-spacing:1px">ACTIVO</span>
            <% } else { %>
            <form action="/admin/modelos/<%= m.id %>/principal" method="POST" style="margin:0">
              <input type="hidden" name="returnTo" value="/admin/homepage">
              <button type="submit" class="btn btn-om btn-sm">Activar</button>
            </form>
            <% } %>
          </div>
          <% }) %>
        </div>
        <% } else { %>
        <div class="text-center py-3 text-muted small">
          Sin modelos 3D. <a href="/admin/modelos" style="color:var(--cp)">Ir a Modelos 3D →</a>
        </div>
        <% } %>
        <a href="/admin/modelos" class="btn btn-om btn-sm w-100 mt-3">
          <i class="bi bi-box-seam me-1"></i>Gestionar todos los modelos
        </a>
      </div>
    </div><!-- /card modelos 3D -->

  </div><!-- /col izquierda -->

  <!-- ── COLUMNA DERECHA: redirección al editor unificado ── -->
  <div class="col-12 col-lg-6">
    <div class="card h-100">
      <div class="card-body d-flex flex-column align-items-center justify-content-center text-center" style="min-height:280px">
        <i class="bi bi-images" style="font-size:2.2rem;color:var(--cp);margin-bottom:14px"></i>
        <h6 style="font-family:'Bebas Neue',sans-serif;font-size:.85rem;letter-spacing:2px;color:var(--text);margin-bottom:8px">
          BANNER PRINCIPAL Y CARRUSEL SECUNDARIO
        </h6>
        <p class="small text-muted mb-3" style="max-width:320px">
          La gestión de imágenes, textos, botones y vista previa en tiempo real de ambos carruseles
          vive en el editor dedicado — con guardado independiente para cada uno.
        </p>
        <a href="/admin/carrusel" class="btn btn-pm btn-sm">
          <i class="bi bi-pencil-square me-1"></i>Abrir editor de banners
        </a>
      </div>
    </div>
  </div><!-- /col derecha -->

</div><!-- /row principal -->





<!-- ══════════════════════════════════════════════════════════
     MODALES CUSTOM
     ══════════════════════════════════════════════════════════ -->


<!-- ══════════════════════════════════════════════════════════
     SCRIPTS
     ══════════════════════════════════════════════════════════ -->
<script>
/* ── Toggle visibilidad de sección ── */
function toggleSec(btn, key) {
  var isOn = btn.classList.contains('on');
  btn.classList.toggle('on', !isOn);
  btn.classList.toggle('off',  isOn);
  document.getElementById('hid-' + key).value = isOn ? '0' : '1';
}

/* ── Drag-and-drop para reordenar secciones (solo desde el grip) ── */
(function() {
  var list     = document.getElementById('secciones-list');
  var dragging = null;

  list.querySelectorAll('.sec-card').forEach(function(card) {
    var handle = card.querySelector('.sec-drag-handle');
    if (!handle) return;

    handle.setAttribute('draggable', 'true');

    handle.addEventListener('dragstart', function(e) {
      dragging = card;
      card.classList.add('dragging');
      e.dataTransfer.effectAllowed = 'move';
    });

    card.addEventListener('dragend', function() {
      card.classList.remove('dragging');
      list.querySelectorAll('.sec-card').forEach(function(c) { c.classList.remove('drag-over'); });
      updateSecOrder();
    });

    card.addEventListener('dragover', function(e) {
      e.preventDefault();
      if (!dragging) return;
      e.dataTransfer.dropEffect = 'move';
      var after = getDragAfter(list, e.clientY);
      if (after == null) list.appendChild(dragging);
      else list.insertBefore(dragging, after);
    });
  });

  function getDragAfter(container, y) {
    var els = Array.from(container.querySelectorAll('.sec-card:not(.dragging)'));
    return els.reduce(function(closest, child) {
      var box    = child.getBoundingClientRect();
      var offset = y - box.top - box.height / 2;
      if (offset < 0 && offset > closest.offset)
        return { offset: offset, element: child };
      return closest;
    }, { offset: Number.NEGATIVE_INFINITY }).element;
  }

  function updateSecOrder() {
    var order = Array.from(list.querySelectorAll('.sec-card'))
                     .map(function(c) { return c.dataset.sec; });
    document.getElementById('seccion_orden_input').value = order.join(',');
  }
})();

</script>

<%- include('../partials/footer') %>
