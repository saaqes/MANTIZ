<%- include('../../partials/header', {isAdmin: true}) %>
<div class="container-fluid py-4 px-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">Gestión de Pedidos</h3>
    <div class="d-flex gap-2">
      <% const estadosFilter = ['','pendiente','confirmado','empaquetando','en_transito','en_aduana','con_conductor','entregado','cancelado']; %>
      <select class="form-select form-select-sm rounded-3" onchange="window.location='/admin/pedidos?estado='+this.value">
        <option value="">Todos los estados</option>
        <% estadosFilter.forEach(e => { %><option value="<%= e %>" <%= estado===e?'selected':'' %>><%= e||'Todos' %></option><% }) %>
      </select>
    </div>
  </div>
  <div class="card border-0 rounded-4 shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light"><tr><th>#</th><th>Cliente</th><th>Total</th><th>Método pago</th><th>Estado</th><th>Tracking</th><th>Fecha</th><th></th></tr></thead>
        <tbody>
          <% pedidos.forEach(p => { %>
          <tr>
            <td class="fw-semibold">#<%= p.id %></td>
            <td><div class="fw-semibold small"><%= p.nombre_visible %></div><div class="text-muted" style="font-size:0.75rem"><%= p.email %></div></td>
            <td class="fw-bold" style="color:var(--color-primary)">$<%= parseFloat(p.total).toFixed(2) %></td>
            <td class="small"><%= p.metodo_pago||'tarjeta' %></td>
            <td>
              <select class="form-select form-select-sm rounded-3" style="min-width:130px" onchange="cambiarEstado(<%= p.id %>, this.value)">
                <% ['pendiente','confirmado','empaquetando','en_transito','en_aduana','con_conductor','entregado','cancelado'].forEach(e => { %>
                <option value="<%= e %>" <%= p.estado===e?'selected':'' %>><%= e.replace('_',' ') %></option>
                <% }) %>
              </select>
            </td>
            <td><span class="small text-muted"><%= p.numero_tracking||'—' %></span></td>
            <td class="small text-muted"><%= new Date(p.creado_en).toLocaleDateString('es-CO') %></td>
            <td><a href="/admin/pedidos/<%= p.id %>" class="btn btn-sm btn-outline-mantiz rounded-3">Gestionar</a></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<script>
async function cambiarEstado(id, estado) {
  const r = await fetch(`/admin/pedidos/${id}/estado`, {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({estado})});
  const d = await r.json();
  if (!d.success) alert('Error al actualizar');
}
</script>
<%- include('../../partials/footer', {isAdmin: true}) %>
