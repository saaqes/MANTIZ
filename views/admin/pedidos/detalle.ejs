<%- include('../../partials/header', {isAdmin: true}) %>
<div class="container-fluid py-4 px-4">
  <div class="d-flex align-items-center gap-3 mb-4">
    <a href="/admin/pedidos" class="btn btn-outline-secondary btn-sm rounded-3"><i class="bi bi-arrow-left"></i></a>
    <div>
      <h3 class="fw-bold mb-0">Pedido #<%= pedido.id %></h3>
      <div class="text-muted small">Tracking: <strong><%= pedido.numero_tracking %></strong> | Cliente: <%= pedido.nombre_visible %> (<%= pedido.email %>)</div>
    </div>
  </div>

  <div class="row g-4">
    <!-- MAPA + SEGUIMIENTO -->
    <div class="col-lg-7">
      <div class="card border-0 rounded-4 shadow-sm p-4 mb-4">
        <h5 class="fw-bold mb-3">Mapa de seguimiento</h5>
        <div id="mapaAdmin" style="height:320px;border-radius:12px;overflow:hidden"></div>
      </div>

      <!-- AGREGAR ACTUALIZACIÓN -->
      <div class="card border-0 rounded-4 shadow-sm p-4 mb-4">
        <h5 class="fw-bold mb-3"><i class="bi bi-plus-circle me-2" style="color:var(--color-primary)"></i>Agregar actualización de seguimiento</h5>
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label small fw-semibold">Estado/Descripción corta *</label>
            <input type="text" id="segEstado" class="form-control rounded-3" placeholder="Ej: Paquete en aduana Bogotá">
          </div>
          <div class="col-md-6">
            <label class="form-label small fw-semibold">Proveedor</label>
            <select id="segProveedor" class="form-select rounded-3">
              <option value="">Sin proveedor asignado</option>
              <% proveedores.forEach(p => { %><option value="<%= p.id %>" data-tipo="<%= p.tipo %>"><%= p.nombre %> (<%= p.tipo %>)</option><% }) %>
            </select>
          </div>
          <div class="col-12">
            <label class="form-label small fw-semibold">Descripción detallada</label>
            <textarea id="segDesc" class="form-control rounded-3" rows="2" placeholder="Detalles adicionales..."></textarea>
          </div>
          <div class="col-md-6">
            <label class="form-label small fw-semibold">Ubicación (texto)</label>
            <input type="text" id="segUbicacion" class="form-control rounded-3" placeholder="Ej: Aduana Bogotá, Colombia">
          </div>
          <div class="col-md-3">
            <label class="form-label small fw-semibold">Latitud</label>
            <input type="number" step="0.0001" id="segLat" class="form-control rounded-3" placeholder="4.6097">
          </div>
          <div class="col-md-3">
            <label class="form-label small fw-semibold">Longitud</label>
            <input type="number" step="0.0001" id="segLng" class="form-control rounded-3" placeholder="-74.0817">
          </div>
          <div class="col-md-6">
            <label class="form-label small fw-semibold">Tipo de punto</label>
            <select id="segTipo" class="form-select rounded-3">
              <option value="almacen">🏢 Almacén</option>
              <option value="empaquetador">📦 Empaquetador</option>
              <option value="transporte">🚚 Transporte</option>
              <option value="aduana">🛂 Aduana</option>
              <option value="entrega">🏠 Entrega final</option>
            </select>
          </div>
          <div class="col-md-6 d-flex align-items-end">
            <div class="form-check">
              <input type="checkbox" id="segActualizar" class="form-check-input" checked>
              <label class="form-check-label small">Actualizar estado del pedido automáticamente</label>
            </div>
          </div>
        </div>
        <button class="btn btn-primary-mantiz mt-3 rounded-3" onclick="agregarSeguimiento()">
          <i class="bi bi-plus me-2"></i>Publicar actualización
        </button>
      </div>

      <!-- HISTORIAL SEGUIMIENTO -->
      <div class="card border-0 rounded-4 shadow-sm p-4">
        <h5 class="fw-bold mb-4">Historial de seguimiento</h5>
        <div id="seguimientoLista">
        <% seguimiento.slice().reverse().forEach((s,i) => { %>
        <div class="d-flex gap-3 mb-4">
          <div class="d-flex flex-column align-items-center">
            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:34px;height:34px;background:<%= i===0?'var(--color-primary)':'#f0f0f0' %>;color:<%= i===0?'white':'#666' %>">
              <i class="bi bi-<% const ic={almacen:'building',empaquetador:'box',transporte:'truck',aduana:'shield',entrega:'house'}; %><%= ic[s.tipo_proveedor]||'circle' %> small"></i>
            </div>
          </div>
          <div>
            <div class="fw-semibold"><%= s.estado %></div>
            <% if (s.descripcion) { %><div class="text-muted small"><%= s.descripcion %></div><% } %>
            <% if (s.ubicacion) { %><div class="small"><i class="bi bi-geo-alt me-1" style="color:var(--color-primary)"></i><%= s.ubicacion %></div><% } %>
            <% if (s.proveedor_nombre) { %><div class="small text-muted">👷 <%= s.proveedor_nombre %> <% if (s.prov_tel) { %>| 📞 <%= s.prov_tel %><% } %></div><% } %>
            <div class="text-muted" style="font-size:0.72rem"><%= new Date(s.fecha_hora).toLocaleString('es-CO') %></div>
          </div>
        </div>
        <% }) %>
        </div>
      </div>
    </div>

    <!-- INFO SIDEBAR -->
    <div class="col-lg-5">
      <!-- Estado actual + cambiar -->
      <div class="card border-0 rounded-4 shadow-sm p-4 mb-4">
        <h5 class="fw-bold mb-3">Estado del pedido</h5>
        <div class="mb-3">
          <span class="badge rounded-pill px-3 py-2 fs-6" style="background:<% const c={pendiente:'#ffc107',confirmado:'#17a2b8',empaquetando:'#6f42c1',en_transito:'#fd7e14',en_aduana:'#dc3545',con_conductor:'#20c997',entregado:'#28a745',cancelado:'#6c757d'}; %><%= c[pedido.estado]||'#999' %>">
            <%= pedido.estado.replace('_',' ').toUpperCase() %>
          </span>
        </div>
        <div class="d-flex gap-2">
          <select id="estadoSelect" class="form-select rounded-3">
            <% estados.forEach(e => { %><option value="<%= e %>" <%= pedido.estado===e?'selected':'' %>><%= e.replace('_',' ') %></option><% }) %>
          </select>
          <button class="btn btn-primary-mantiz rounded-3 px-3" onclick="cambiarEstado()">Cambiar</button>
        </div>
      </div>

      <!-- Items -->
      <div class="card border-0 rounded-4 shadow-sm p-4 mb-4">
        <h5 class="fw-bold mb-3">Productos</h5>
        <% items.forEach(item => { %>
        <div class="d-flex gap-3 mb-3">
          <img src="/uploads/products/<%= item.imagen_principal %>" style="width:55px;height:55px;border-radius:8px;object-fit:cover" onerror="this.src='https://via.placeholder.com/55x55/f0f0f0/999?text=IMG'">
          <div>
            <div class="small fw-semibold"><%= item.titulo %></div>
            <div class="text-muted small">Talla: <%= item.talla %> × <%= item.cantidad %></div>
            <div style="color:var(--color-primary);font-size:0.85rem;font-weight:700">$<%= parseFloat(item.subtotal).toFixed(2) %></div>
          </div>
        </div>
        <% }) %>
        <div class="border-top pt-2 mt-1 d-flex justify-content-between fw-bold">
          <span>Total</span><span style="color:var(--color-primary)">$<%= parseFloat(pedido.total).toFixed(2) %></span>
        </div>
      </div>

      <!-- Dirección -->
      <% if (pedido.direccion) { %>
      <div class="card border-0 rounded-4 shadow-sm p-4">
        <h5 class="fw-bold mb-3"><i class="bi bi-geo-alt me-2" style="color:var(--color-primary)"></i>Dirección de entrega</h5>
        <div class="small">
          <div class="fw-semibold"><%= pedido.nombre_destinatario %></div>
          <div class="text-muted"><%= pedido.tel_envio %></div>
          <div><%= pedido.direccion %></div>
          <div><%= pedido.ciudad %><% if (pedido.departamento) { %>, <%= pedido.departamento %><% } %></div>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>

<script>
const pedidoId = <%= pedido.id %>;
const puntosIniciales = <%- JSON.stringify(seguimiento.filter(s => s.latitud && s.longitud)) %>;
let mapa;

document.addEventListener('DOMContentLoaded', () => {
  mapa = L.map('mapaAdmin').setView([4.6097, -74.0817], 6);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(mapa);
  renderMapa(puntosIniciales);
});

function renderMapa(puntos) {
  const colors = {almacen:'#17a2b8',empaquetador:'#6f42c1',transporte:'#fd7e14',aduana:'#dc3545',entrega:'#28a745'};
  const latlngs = [];
  puntos.forEach((p,i) => {
    const lat=parseFloat(p.latitud), lng=parseFloat(p.longitud);
    latlngs.push([lat,lng]);
    const color = colors[p.tipo_proveedor]||'#e91e8c';
    L.marker([lat,lng], {icon:L.divIcon({html:`<div style="background:${color};width:28px;height:28px;border-radius:50%;border:3px solid white;box-shadow:0 2px 8px rgba(0,0,0,.3);display:flex;align-items:center;justify-content:center;color:white;font-size:11px;font-weight:bold">${i+1}</div>`,iconSize:[28,28],iconAnchor:[14,14],className:''})}).addTo(mapa)
      .bindPopup(`<strong>${p.estado}</strong><br>${p.ubicacion||''}`);
  });
  if (latlngs.length>1) L.polyline(latlngs,{color:'#e91e8c',weight:3,dashArray:'8,5'}).addTo(mapa);
  if (latlngs.length>0) mapa.fitBounds(L.latLngBounds(latlngs),{padding:[30,30]});
}

async function cambiarEstado() {
  const estado = document.getElementById('estadoSelect').value;
  const r = await fetch(`/admin/pedidos/${pedidoId}/estado`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({estado})});
  const d = await r.json();
  if (d.success) {
    alert('Estado actualizado correctamente');
    location.reload();
  }
}

async function agregarSeguimiento() {
  const provSel = document.getElementById('segProveedor');
  const data = {
    estado: document.getElementById('segEstado').value,
    descripcion: document.getElementById('segDesc').value,
    ubicacion: document.getElementById('segUbicacion').value,
    latitud: document.getElementById('segLat').value,
    longitud: document.getElementById('segLng').value,
    proveedor_id: provSel.value || null,
    tipo_proveedor: document.getElementById('segTipo').value,
    actualizar_estado_pedido: document.getElementById('segActualizar').checked
  };
  
  if (!data.estado) { alert('Por favor ingresa el estado'); return; }
  
  const r = await fetch(`/admin/pedidos/${pedidoId}/seguimiento`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)});
  const d = await r.json();
  if (d.success) {
    alert('Actualización publicada. El cliente la verá en tiempo real.');
    location.reload();
  } else {
    alert('Error: ' + d.error);
  }
}
</script>
<%- include('../../partials/footer', {isAdmin: true}) %>
