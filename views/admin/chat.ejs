<%- include('../partials/header', {isAdmin: true}) %>

<style>
.ac-wrap { display:flex; height:calc(100vh - 64px); overflow:hidden; }
.ac-sidebar { width:320px; flex-shrink:0; border-right:1px solid var(--border); display:flex; flex-direction:column; overflow:hidden; }
.ac-sidebar-head { padding:14px 16px; border-bottom:1px solid var(--border); flex-shrink:0; }
.ac-sidebar-title { font-family:'Bebas Neue',sans-serif; font-size:.9rem; letter-spacing:2px; color:var(--pink); }
.ac-filtros { display:flex; gap:4px; margin-top:8px; flex-wrap:wrap; }
.ac-filtro { padding:3px 10px; border:1px solid var(--faint-2); border-radius:12px; font-size:11px; color:var(--gray); text-decoration:none; }
.ac-filtro.active { border-color:var(--pink); color:var(--pink); background:rgba(233,30,140,.07); }
.ac-stats { display:flex; gap:10px; margin-top:8px; }
.ac-stat { font-size:10px; color:var(--gray); }
.ac-convlist { flex:1; overflow-y:auto; }
.ac-conv-item { display:flex; gap:10px; padding:12px 14px; border-bottom:1px solid var(--faint-1); cursor:pointer; text-decoration:none; align-items:flex-start; }
.ac-conv-item:hover { background:rgba(233,30,140,.05); }
.ac-conv-item.active { background:rgba(233,30,140,.1); border-left:3px solid var(--pink); }
.ac-conv-av { width:38px; height:38px; border-radius:50%; background:var(--dark3); display:flex; align-items:center; justify-content:center; font-size:14px; flex-shrink:0; object-fit:cover; }
.ac-conv-name { font-size:13px; font-weight:600; color:var(--white); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.ac-conv-last { font-size:11px; color:var(--gray); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; margin-top:2px; max-width:170px; }
.ac-badge { background:var(--pink); color:white; border-radius:50%; width:18px; height:18px; font-size:10px; display:flex; align-items:center; justify-content:center; font-weight:700; }
.ac-estado-badge { font-size:9px; padding:1px 6px; border-radius:8px; }
.estado-pendiente { background:rgba(255,165,0,.15); color:#ffa500; border:1px solid rgba(255,165,0,.3); }
.estado-resuelta  { background:rgba(0,200,83,.12); color:#00c853; border:1px solid rgba(0,200,83,.25); }
.estado-activa    { background:rgba(0,150,255,.12); color:#0096ff; border:1px solid rgba(0,150,255,.25); }
.ac-main { flex:1; display:flex; flex-direction:column; overflow:hidden; }
.ac-main-head { padding:12px 18px; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:12px; flex-shrink:0; }
.ac-main-av { width:38px; height:38px; border-radius:50%; background:var(--dark3); display:flex; align-items:center; justify-content:center; object-fit:cover; }
.ac-main-name { font-family:'Bebas Neue',sans-serif; font-size:.95rem; letter-spacing:1px; color:var(--white); }
.ac-main-sub { font-size:11px; color:var(--gray); }
.ac-estado-btn { padding:5px 10px; border:1px solid var(--border); background:none; color:var(--gray); font-size:10px; cursor:pointer; border-radius:6px; font-family:'Bebas Neue',sans-serif; letter-spacing:1px; }
.ac-estado-btn:hover { border-color:var(--pink); color:var(--pink); }
.ac-msgs { flex:1; overflow-y:auto; padding:16px 18px; display:flex; flex-direction:column; gap:8px; }
.msg-row { display:flex; align-items:flex-end; gap:8px; }
.msg-row.mine { flex-direction:row-reverse; }
.msg-av { width:26px; height:26px; border-radius:50%; background:var(--dark3); display:flex; align-items:center; justify-content:center; font-size:11px; flex-shrink:0; object-fit:cover; }
.msg-bubble { max-width:72%; padding:9px 13px; border-radius:18px; }
.msg-bubble.theirs { background:var(--card-bg); border:1px solid var(--faint-1); border-bottom-left-radius:4px; }
.msg-bubble.mine { background:var(--pink); color:white; border-bottom-right-radius:4px; }
.msg-text { font-size:13.5px; line-height:1.5; }
.msg-meta { display:flex; gap:4px; margin-top:3px; justify-content:flex-end; }
.msg-time { font-size:10px; opacity:.65; }
.msg-status.leido { color:#7fffd4; }
.msg-img { max-width:100%; border-radius:8px; cursor:pointer; max-height:220px; }
.ac-input-wrap { border-top:1px solid var(--border); padding:10px 18px; flex-shrink:0; display:flex; flex-direction:column; gap:8px; }
.ac-rapidos { display:flex; gap:6px; overflow-x:auto; padding-bottom:4px; }
.ac-rapido-chip { flex-shrink:0; padding:5px 12px; border:1px solid var(--faint-2); border-radius:14px; font-size:11px; color:var(--gray); cursor:pointer; white-space:nowrap; background:var(--card-bg); }
.ac-rapido-chip:hover { border-color:var(--pink); color:var(--pink); }
.ac-input-row { display:flex; align-items:flex-end; gap:10px; position:relative; }
.ac-input { flex:1; background:var(--card-bg); border:2px solid var(--faint-2); color:var(--white); padding:10px 14px; border-radius:22px; font-family:'Rajdhani',sans-serif; font-size:13.5px; outline:none; resize:none; max-height:120px; min-height:40px; }
.ac-input:focus { border-color:var(--pink); }
.ac-send-btn { width:40px; height:40px; border-radius:50%; background:var(--pink); border:2px solid white; color:white; cursor:pointer; display:flex; align-items:center; justify-content:center; flex-shrink:0; filter:url(#gb); }
.ac-action-btn { background:none; border:1px solid var(--faint-2); color:var(--gray); padding:5px 10px; border-radius:14px; font-size:11px; cursor:pointer; }
.ac-empty { flex:1; display:flex; align-items:center; justify-content:center; flex-direction:column; gap:12px; color:var(--gray); }
</style>

<div class="ac-wrap">
  <div class="ac-sidebar">
    <div class="ac-sidebar-head">
      <div class="ac-sidebar-title">CONVERSACIONES</div>
      <div class="ac-filtros">
        <a href="/admin/chat?filtro=todas" class="ac-filtro <%= filtro==='todas'?'active':'' %>">Todas</a>
        <a href="/admin/chat?filtro=no_leidas" class="ac-filtro <%= filtro==='no_leidas'?'active':'' %>">No leídas<% if(stats.no_leidas>0){%> (<%= stats.no_leidas %>)<%}%></a>
        <a href="/admin/chat?filtro=pendiente" class="ac-filtro <%= filtro==='pendiente'?'active':'' %>">Pendientes</a>
        <a href="/admin/chat?filtro=resuelta" class="ac-filtro <%= filtro==='resuelta'?'active':'' %>">Resueltas</a>
      </div>
      <div class="ac-stats">
        <span class="ac-stat"><i class="bi bi-chat"></i> <%= stats.total||0 %> totales</span>
        <span class="ac-stat" style="color:#ffa500"><i class="bi bi-clock"></i> <%= stats.pendientes||0 %> pendientes</span>
      </div>
    </div>
    <div class="ac-convlist">
      <% if (!convs || convs.length===0) { %><div style="padding:30px;text-align:center;color:var(--gray);font-size:12px">Sin conversaciones</div><% } %>
      <% (convs||[]).forEach(function(c) { %>
      <a href="/admin/chat/<%= c.id %>?filtro=<%= filtro %>" class="ac-conv-item <%= convActiva && convActiva.id===c.id ? 'active':'' %>">
        <div class="ac-conv-av">
          <% if(c.foto_perfil_tipo==='upload'&&c.foto_perfil){%><img src="/uploads/profiles/<%= c.foto_perfil %>" style="width:100%;height:100%;border-radius:50%;object-fit:cover">
          <%}else{%><img src="/img/defaults/avatars/<%= c.foto_perfil_preset||'avatar1.png' %>" style="width:100%;height:100%;border-radius:50%;object-fit:cover"><%}%>
        </div>
        <div style="flex:1;min-width:0">
          <div class="ac-conv-name"><%= c.nombre_visible %></div>
          <div class="ac-conv-last"><%= c.ultimo_msg || 'Sin mensajes' %></div>
        </div>
        <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0">
          <span style="font-size:10px;color:var(--gray)"><%= c.ultimo_msg_en ? new Date(c.ultimo_msg_en).toLocaleTimeString('es-CO',{hour:'2-digit',minute:'2-digit'}) : '' %></span>
          <% if (c.no_leidos_adm>0) { %><span class="ac-badge"><%= c.no_leidos_adm %></span><% } %>
          <span class="ac-estado-badge estado-<%= c.estado %>"><%= (c.estado||'pendiente').toUpperCase() %></span>
        </div>
      </a>
      <% }) %>
    </div>
  </div>

  <div class="ac-main">
    <% if (!convActiva) { %>
    <div class="ac-empty"><i class="bi bi-chat-dots" style="font-size:3rem;color:rgba(233,30,140,.2)"></i><div style="font-family:'Bebas Neue',sans-serif;letter-spacing:2px">SELECCIONA UNA CONVERSACIÓN</div></div>
    <% } else { %>
    <div class="ac-main-head">
      <div class="ac-main-av">
        <% if(convActiva.foto_perfil_tipo==='upload'&&convActiva.foto_perfil){%><img src="/uploads/profiles/<%= convActiva.foto_perfil %>" style="width:100%;height:100%;border-radius:50%;object-fit:cover">
        <%}else{%><img src="/img/defaults/avatars/<%= convActiva.foto_perfil_preset||'avatar1.png' %>" style="width:100%;height:100%;border-radius:50%;object-fit:cover"><%}%>
      </div>
      <div style="flex:1">
        <div class="ac-main-name"><%= convActiva.nombre_visible %></div>
        <div class="ac-main-sub">@<%= convActiva.username %> · <%= convActiva.email %></div>
      </div>
      <div style="display:flex;gap:6px">
        <button class="ac-estado-btn" onclick="setEstado('pendiente')">⏳ PEND</button>
        <button class="ac-estado-btn" onclick="setEstado('resuelta')">✅ RES</button>
      </div>
    </div>

    <div class="ac-msgs" id="acMsgs">
      <% (mensajes||[]).forEach(function(m) {
        var esMio = m.rol === 'admin';
        var hora = new Date(m.creado_en).toLocaleTimeString('es-CO',{hour:'2-digit',minute:'2-digit'});
      %>
      <div class="msg-row <%= esMio?'mine':'' %>" data-msg-id="<%= m.id %>">
        <% if (!esMio) { %><div class="msg-av"><i class="bi bi-person-fill"></i></div><% } %>
        <div class="msg-bubble <%= esMio?'mine':'theirs' %>">
          <% if(m.tipo==='imagen'){%><img src="<%= m.archivo_url %>" class="msg-img" onclick="window.open(this.src)"><%}%>
          <% if(m.tipo==='archivo'){%><div style="display:flex;gap:8px;align-items:center"><i class="bi bi-file-earmark"></i><a href="<%= m.archivo_url %>" target="_blank" style="color:inherit;font-size:12px"><%= m.archivo_nombre||'Archivo' %></a></div><%}%>
          <% if(m.contenido){%><div class="msg-text"><%- m.contenido.replace(/\n/g,'<br>') %></div><%}%>
          <div class="msg-meta"><span class="msg-time"><%= hora %></span><% if(esMio){%><span class="msg-status <%= m.estado==='leido'?'leido':'' %>"><%= m.estado==='leido'?'✓✓':'✓' %></span><%}%></div>
        </div>
      </div>
      <% }) %>
    </div>

    <div class="ac-input-wrap">
      <!-- Mensajes rápidos predefinidos -->
      <div class="ac-rapidos">
        <% (mensajesRapidos||[]).forEach(function(mr) { %>
        <div class="ac-rapido-chip" onclick="usarRapido('<%= mr.replace(/'/g,String.fromCharCode(39)) %>')"><%= mr.substring(0,32) %><%= mr.length>32?'…':'' %></div>
        <% }) %>
      </div>
      <div class="ac-input-row">
        <label class="ac-action-btn" style="cursor:pointer">
          <i class="bi bi-paperclip"></i>
          <input type="file" id="acFile" accept="image/*,.pdf,.doc,.docx,.txt" style="display:none" onchange="onAcFile(this)">
        </label>
        <textarea class="ac-input" id="acInput" placeholder="Escribe un mensaje..." rows="1"
          onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();acEnviar()}"
          oninput="acResize(this)"></textarea>
        <button class="ac-send-btn" onclick="acEnviar()"><i class="bi bi-send-fill"></i></button>
      </div>
    </div>
    <% } %>
  </div>
</div>

<% if (convActiva) { %>
<script>
var CONV_ID = '<%= convActiva.id %>';
var acMsgs = document.getElementById('acMsgs');
var lastMsg = '<%= mensajes&&mensajes.length ? new Date(mensajes[mensajes.length-1].creado_en).toISOString() : new Date().toISOString() %>';
acMsgs.scrollTop = acMsgs.scrollHeight;
function acResize(el){ el.style.height='auto'; el.style.height=Math.min(el.scrollHeight,120)+'px'; }
function usarRapido(texto){ document.getElementById('acInput').value = texto; document.getElementById('acInput').focus(); }

var acFile=null;
function onAcFile(input){ acFile=input.files[0]; if(acFile) acEnviarConArchivo(); }
async function acEnviarConArchivo(){
  if(!acFile) return;
  var fd=new FormData(); fd.append('archivo',acFile);
  var r=await fetch('/admin/chat/'+CONV_ID+'/enviar',{method:'POST',body:fd});
  var d=await r.json();
  if(d.success){ appendAcMsg(d.msg); acMsgs.scrollTop=acMsgs.scrollHeight; lastMsg=d.msg.creado_en; }
  acFile=null; document.getElementById('acFile').value='';
}

function appendAcMsg(m){
  var esMio=m.rol==='admin';
  var hora=new Date(m.creado_en).toLocaleTimeString('es-CO',{hour:'2-digit',minute:'2-digit'});
  var bubble='';
  if(m.tipo==='imagen') bubble+='<img src="'+m.archivo_url+'" class="msg-img" onclick="window.open(this.src)">';
  else if(m.tipo==='archivo') bubble+='<div style="display:flex;gap:8px;align-items:center"><i class="bi bi-file-earmark"></i><a href="'+m.archivo_url+'" target="_blank" style="color:inherit;font-size:12px">'+(m.archivo_nombre||'Archivo')+'</a></div>';
  if(m.contenido) bubble+='<div class="msg-text">'+m.contenido.replace(/</g,'&lt;').replace(/\n/g,'<br>')+'</div>';
  bubble+='<div class="msg-meta"><span class="msg-time">'+hora+'</span>'+(esMio?'<span class="msg-status">✓</span>':'')+'</div>';
  var row=document.createElement('div');
  row.className='msg-row'+(esMio?' mine':'');
  row.innerHTML=(esMio?'':'<div class="msg-av"><i class="bi bi-person-fill"></i></div>')+'<div class="msg-bubble '+(esMio?'mine':'theirs')+'">'+bubble+'</div>';
  acMsgs.appendChild(row);
}

async function acEnviar(){
  var texto=document.getElementById('acInput').value.trim();
  if(!texto) return;
  var fd=new FormData(); fd.append('contenido',texto);
  document.getElementById('acInput').value=''; acResize(document.getElementById('acInput'));
  var r=await fetch('/admin/chat/'+CONV_ID+'/enviar',{method:'POST',body:fd});
  var d=await r.json();
  if(d.success){ appendAcMsg(d.msg); acMsgs.scrollTop=acMsgs.scrollHeight; lastMsg=d.msg.creado_en; }
}

async function setEstado(e){
  await fetch('/admin/chat/'+CONV_ID+'/estado',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({estado:e})});
  location.reload();
}

setInterval(async function(){
  var r=await fetch('/admin/chat/'+CONV_ID+'/mensajes?desde='+encodeURIComponent(lastMsg));
  var d=await r.json();
  if(d.success&&d.mensajes.length){
    var wasB=acMsgs.scrollHeight-acMsgs.clientHeight-acMsgs.scrollTop<50;
    d.mensajes.forEach(function(m){ appendAcMsg(m); lastMsg=m.creado_en; });
    if(wasB) acMsgs.scrollTop=acMsgs.scrollHeight;
  }
}, 3000);
</script>
<% } %>

<%- include('../partials/footer', {isAdmin: true}) %>
