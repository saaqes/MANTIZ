<%- include('../partials/header', {isAdmin: true}) %>

<style>
.notif-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:16px;transition:all .2s}
.notif-card:hover{border-color:rgba(233,30,140,.3)}
.section-title{font-family:var(--fm);font-size:.58rem;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:10px}
.sticker-thumb{width:48px;height:48px;border-radius:8px;object-fit:cover;background:var(--dark2)}
.poll-bar-bg{background:var(--dark2);border-radius:6px;height:8px;overflow:hidden;flex:1}
.poll-bar-fill{background:var(--cp);height:100%;border-radius:6px}
.empty-state{text-align:center;padding:40px 20px;color:var(--muted)}
.empty-state i{font-size:1.8rem;display:block;margin-bottom:8px}
</style>

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
  <div>
    <div style="font-family:var(--fm);font-size:.58rem;color:var(--muted);letter-spacing:2px;text-transform:uppercase">GESTIÓN</div>
    <div style="font-family:var(--fd);font-size:1.1rem;font-weight:800;color:var(--text)">Notificaciones y Comunidad</div>
  </div>
</div>

<!-- Stats rápidas -->
<div class="row g-3 mb-4">
  <% const stats = [
       {bg:'rgba(233,30,140,.1)',color:'var(--cp)',val:pendStickers.length,label:'Stickers pendientes'},
       {bg:'rgba(0,255,100,.1)',color:'#00ff64',val:encuestas.filter(e=>e.activa).length,label:'Encuestas activas'},
       {bg:'rgba(255,200,0,.1)',color:'#ffc800',val:encuestas.reduce((s,e)=>s+Number(e.total_votos||0),0),label:'Votos totales'}
     ]; %>
  <% stats.forEach(s=>{ %>
  <div class="col-6 col-md-4">
    <div style="background:var(--card);border:1px solid var(--border);border-radius:10px;padding:16px;text-align:center">
      <div style="font-family:var(--fd);font-size:1.3rem;font-weight:800;color:<%= s.color %>"><%= s.val %></div>
      <div style="font-family:var(--fm);font-size:.58rem;color:var(--muted);letter-spacing:1px;text-transform:uppercase;margin-top:4px"><%= s.label %></div>
    </div>
  </div>
  <% }) %>
</div>

<!-- Notificación masiva -->
<div class="notif-card mb-4">
  <div class="section-title">◈ Enviar notificación a todos los usuarios</div>
  <form id="broadcastForm" class="row g-2">
    <div class="col-12 col-md-5">
      <input type="text" class="form-control form-control-sm" name="titulo" placeholder="Título" required>
    </div>
    <div class="col-12 col-md-7">
      <input type="text" class="form-control form-control-sm" name="mensaje" placeholder="Mensaje" required>
    </div>
    <div class="col-6 col-md-3">
      <select class="form-select form-select-sm" name="tipo">
        <option value="noticia">Noticia</option>
        <option value="descuento">Descuento</option>
        <option value="mantenimiento">Mantenimiento</option>
      </select>
    </div>
    <div class="col-6 col-md-3">
      <input type="text" class="form-control form-control-sm" name="icono" placeholder="bi-megaphone" value="bi-megaphone">
    </div>
    <div class="col-6 col-md-3">
      <input type="color" class="form-control form-control-sm" name="color" value="#e91e8c" style="height:31px">
    </div>
    <div class="col-6 col-md-3">
      <input type="text" class="form-control form-control-sm" name="enlace" placeholder="/productos (opcional)">
    </div>
    <div class="col-12">
      <button type="submit" class="btn btn-pm btn-sm"><i class="bi bi-send me-1"></i>Enviar a todos</button>
      <span id="broadcastMsg" style="font-family:var(--fm);font-size:.7rem;color:var(--muted);margin-left:10px"></span>
    </div>
  </form>
</div>

<!-- Stickers pendientes -->
<div class="notif-card mb-4">
  <div class="section-title">◈ Stickers pendientes de moderación</div>
  <% if (pendStickers.length === 0) { %>
    <div class="empty-state"><i class="bi bi-emoji-smile"></i>No hay stickers pendientes</div>
  <% } else { %>
  <div class="d-flex flex-wrap gap-3" id="stickersList">
    <% pendStickers.forEach(s => { %>
    <div class="d-flex align-items-center gap-2 p-2" style="background:var(--dark2);border-radius:8px" id="sticker-<%= s.id %>">
      <img class="sticker-thumb" src="/uploads/stickers/<%= s.archivo %>" alt="<%= s.nombre %>" onerror="this.src='/img/defaults/sticker-placeholder.png'">
      <div>
        <div style="font-family:var(--fb);font-weight:700;font-size:.8rem;color:var(--text)"><%= s.nombre %></div>
        <div style="font-family:var(--fm);font-size:.6rem;color:var(--muted)">por <%= s.nombre_visible || 'desconocido' %></div>
      </div>
      <button class="btn btn-sm" style="background:rgba(0,255,100,.1);color:#00ff64;border:1px solid rgba(0,255,100,.2)" onclick="moderarSticker(<%= s.id %>,'aprobar',this)"><i class="bi bi-check-lg"></i></button>
      <button class="btn btn-sm" style="background:rgba(255,60,60,.1);color:#ff6060;border:1px solid rgba(255,60,60,.2)" onclick="moderarSticker(<%= s.id %>,'rechazar',this)"><i class="bi bi-x-lg"></i></button>
    </div>
    <% }) %>
  </div>
  <% } %>
</div>

<!-- Encuestas de la comunidad -->
<div class="notif-card">
  <div class="section-title">◈ Encuestas de la comunidad</div>
  <% if (encuestas.length === 0) { %>
    <div class="empty-state"><i class="bi bi-bar-chart"></i>No hay encuestas creadas todavía</div>
  <% } else { %>
  <% encuestas.forEach(e => { %>
  <div class="mb-3 pb-3" style="border-bottom:1px solid var(--border)">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-1">
      <div style="font-family:var(--fb);font-weight:700;color:var(--text)"><%= e.titulo %></div>
      <span style="font-family:var(--fm);font-size:.6rem;color:var(--muted)">
        <%= e.activa ? '🟢 Activa' : '⚪ Cerrada' %> · <%= e.total_votos %> voto<%= e.total_votos==1?'':'s' %> · por <%= e.creador %>
      </span>
    </div>
    <% if (e.descripcion) { %><div style="font-family:var(--fb);font-size:.8rem;color:var(--muted);margin-bottom:6px"><%= e.descripcion %></div><% } %>
  </div>
  <% }) %>
  <% } %>
</div>

<script>
document.getElementById('broadcastForm').addEventListener('submit', async function(ev){
  ev.preventDefault();
  const msg = document.getElementById('broadcastMsg');
  const data = Object.fromEntries(new FormData(this).entries());
  msg.textContent = 'Enviando...';
  try {
    const r = await fetch('/admin/notificaciones/broadcast', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify(data)
    });
    const j = await r.json();
    if (j.success) { msg.textContent = `✓ Enviada a ${j.enviadas} usuario(s)`; this.reset(); }
    else { msg.textContent = '✗ ' + (j.error || 'Error'); }
  } catch(e) { msg.textContent = '✗ Error de red'; }
});

async function moderarSticker(id, accion, btn){
  btn.closest('div[id^="sticker-"]').style.opacity='.4';
  try {
    const r = await fetch(`/admin/notificaciones/stickers/${id}/${accion}`, {method:'POST'});
    const j = await r.json();
    if (j.success) document.getElementById('sticker-'+id).remove();
    else { alert(j.error||'Error'); btn.closest('div[id^="sticker-"]').style.opacity='1'; }
  } catch(e) { alert('Error de red'); btn.closest('div[id^="sticker-"]').style.opacity='1'; }
}
</script>

<%- include('../partials/footer') %>
