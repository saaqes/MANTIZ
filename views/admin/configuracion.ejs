<%- include('../partials/header', {isAdmin: true}) %>

<style>
.config-section{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:24px;margin-bottom:24px}
.config-section-title{font-family:var(--fd);font-size:.72rem;font-weight:700;letter-spacing:3px;color:var(--cp);text-transform:uppercase;margin-bottom:18px;display:flex;align-items:center;gap:8px}
.config-section-title i{font-size:1rem}
.color-preview{width:42px;height:42px;border-radius:8px;border:2px solid var(--border);cursor:pointer;transition:transform .2s;flex-shrink:0}
.color-preview:hover{transform:scale(1.08)}
.color-picker-wrap{display:flex;align-items:center;gap:10px}
.color-hex{background:var(--dark2);border:1px solid var(--border);color:var(--text);border-radius:6px;padding:6px 12px;font-family:var(--fm);font-size:.75rem;width:110px}
.palette-swatches{display:flex;flex-wrap:wrap;gap:8px;margin-top:10px}
.swatch{width:30px;height:30px;border-radius:6px;cursor:pointer;border:2px solid transparent;transition:all .2s}
.swatch:hover,.swatch.selected{transform:scale(1.15);border-color:var(--text)}
.preview-card{background:var(--dark2);border:1px solid var(--border);border-radius:12px;padding:16px;text-align:center}
.logo-current{max-height:60px;max-width:200px;object-fit:contain;border:1px solid var(--border);border-radius:8px;padding:8px;background:var(--dark3)}
.theme-option{background:var(--dark2);border:2px solid var(--border);border-radius:10px;padding:14px;cursor:pointer;transition:all .2s;text-align:center}
.theme-option:hover{border-color:rgba(233,30,140,.4)}
.theme-option.selected{border-color:var(--cp);background:rgba(233,30,140,.07)}
.theme-preview{width:100%;height:50px;border-radius:6px;margin-bottom:8px}
.live-preview{background:#050510;border:1px solid rgba(233,30,140,.2);border-radius:10px;padding:16px;position:relative;overflow:hidden}
.lp-nav{height:40px;border-radius:6px;background:rgba(7,7,16,.97);border:1px solid rgba(255,255,255,.1);display:flex;align-items:center;padding:0 12px;gap:8px;margin-bottom:10px}
.lp-brand{font-family:'Orbitron',monospace;font-size:.7rem;font-weight:900}
.lp-card{background:#0f0f1e;border-radius:8px;padding:10px;flex:1;min-height:60px}
.lp-btn{border:none;border-radius:4px;color:white;padding:4px 10px;font-size:.7rem;font-family:'Rajdhani',sans-serif;font-weight:700;cursor:default}
.save-bar{position:fixed;bottom:0;left:var(--sw);right:0;background:var(--dark2);border-top:1px solid var(--border);padding:14px 28px;display:flex;justify-content:space-between;align-items:center;z-index:100;backdrop-filter:blur(10px)}
</style>

<div style="padding-bottom:80px">

<!-- Live Preview -->
<div class="config-section mb-4">
  <div class="config-section-title"><i class="bi bi-eye"></i>Vista Previa en Tiempo Real</div>
  <div class="live-preview" id="livePreview">
    <div class="lp-nav">
      <div class="lp-brand" id="lp-brand" style="color:var(--cp)">◈ <%= config.nombre_tienda||'MANTIZ' %></div>
      <div style="flex:1"></div>
      <div style="display:flex;gap:6px">
        <div style="width:50px;height:18px;border-radius:3px;background:rgba(255,255,255,.1)"></div>
        <div style="width:50px;height:18px;border-radius:3px;background:rgba(255,255,255,.1)"></div>
        <div style="width:50px;height:18px;border-radius:3px;background:rgba(255,255,255,.1)"></div>
      </div>
    </div>
    <div style="display:flex;gap:8px">
      <div class="lp-card">
        <div style="width:60%;height:8px;border-radius:4px;margin-bottom:6px" id="lp-bar1" style="background:var(--cp)"></div>
        <div style="width:40%;height:6px;border-radius:4px;background:rgba(255,255,255,.1)"></div>
        <div style="margin-top:8px;display:flex;gap:6px">
          <div class="lp-btn" id="lp-btn1">COMPRAR</div>
          <div class="lp-btn" id="lp-btn2" style="background:transparent;color:white;border:1px solid">VER MÁS</div>
        </div>
      </div>
      <div class="lp-card">
        <div style="width:80%;height:8px;border-radius:4px;margin-bottom:6px" id="lp-bar2"></div>
        <div style="width:55%;height:6px;border-radius:4px;background:rgba(255,255,255,.1)"></div>
      </div>
      <div class="lp-card">
        <div style="width:70%;height:8px;border-radius:4px;margin-bottom:6px" id="lp-bar3"></div>
        <div style="width:45%;height:6px;border-radius:4px;background:rgba(255,255,255,.1)"></div>
      </div>
    </div>
  </div>
</div>

<form action="/admin/configuracion" method="POST" enctype="multipart/form-data" id="configForm">

  <!-- Identidad -->
  <div class="config-section">
    <div class="config-section-title"><i class="bi bi-shop"></i>Identidad de la Tienda</div>
    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label">Nombre de la tienda</label>
        <input type="text" name="nombre_tienda" class="form-control" 
               value="<%= config.nombre_tienda||'MANTIZ' %>"
               oninput="document.getElementById('lp-brand').textContent='◈ '+this.value"
               placeholder="Ej: MANTIZ">
      </div>
      <div class="col-md-6">
        <label class="form-label">Logo actual</label>
        <div class="d-flex align-items-center gap-3">
          <% if (config.logo) { %>
            <img src="/uploads/logos/<%= config.logo %>" class="logo-current" onerror="this.style.display='none'" alt="Logo">
          <% } else { %>
            <div style="width:80px;height:60px;background:var(--dark3);border:1px dashed var(--border);border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--muted);font-size:.7rem">Sin logo</div>
          <% } %>
          <div class="flex-1">
            <input type="file" name="logo" class="form-control form-control-sm" accept="image/*">
            <div style="font-family:var(--fm);font-size:.6rem;color:var(--muted);margin-top:4px">PNG, SVG, JPG – Recomendado 200x60px</div>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <label class="form-label">Tagline / Eslogan</label>
        <input type="text" name="tagline" class="form-control" value="<%= config.tagline||'' %>" placeholder="Ej: Moda que te define">
      </div>
      <div class="col-md-6">
        <label class="form-label">Email de contacto</label>
        <input type="email" name="email_contacto" class="form-control" value="<%= config.email_contacto||'' %>" placeholder="contacto@tienda.com">
      </div>
    </div>
  </div>

  <!-- Colores -->
  <div class="config-section">
    <div class="config-section-title"><i class="bi bi-palette"></i>Paleta de Colores</div>
    
    <div class="row g-4">
      <!-- Color primario -->
      <div class="col-md-6">
        <label class="form-label">Color Primario <span style="color:var(--muted);font-weight:400">(botones, acentos, links)</span></label>
        <div class="color-picker-wrap">
          <div class="color-preview" id="prev_cp" style="background:<%= config.color_primario||'#e91e8c' %>" onclick="document.getElementById('cp_input').click()"></div>
          <input type="color" id="cp_input" name="color_primario" value="<%= config.color_primario||'#e91e8c' %>" 
                 style="display:none" oninput="updateColor('cp', this.value)">
          <input type="text" class="color-hex" id="cp_hex" value="<%= config.color_primario||'#e91e8c' %>" 
                 oninput="if(this.value.match(/^#[0-9a-fA-F]{6}$/)){updateColor('cp',this.value)}">
          <span style="font-family:var(--fm);font-size:.62rem;color:var(--muted)">Color primario</span>
        </div>
        <div class="palette-swatches" id="swatches_cp">
          <% ['#e91e8c','#ff0066','#e040fb','#7c4dff','#2196f3','#00bcd4','#00e676','#ff6d00','#ff1744','#ffea00'].forEach(c=>{ %>
            <div class="swatch <%= (config.color_primario||'#e91e8c')===c?'selected':'' %>" 
                 style="background:<%= c %>" 
                 onclick="updateColor('cp','<%= c %>')" title="<%= c %>"></div>
          <% }) %>
        </div>
      </div>

      <!-- Color acento -->
      <div class="col-md-6">
        <label class="form-label">Color Acento <span style="color:var(--muted);font-weight:400">(degradados, hover)</span></label>
        <div class="color-picker-wrap">
          <div class="color-preview" id="prev_ca" style="background:<%= config.color_acento||'#ff5cb8' %>" onclick="document.getElementById('ca_input').click()"></div>
          <input type="color" id="ca_input" name="color_acento" value="<%= config.color_acento||'#ff5cb8' %>" 
                 style="display:none" oninput="updateColor('ca', this.value)">
          <input type="text" class="color-hex" id="ca_hex" value="<%= config.color_acento||'#ff5cb8' %>"
                 oninput="if(this.value.match(/^#[0-9a-fA-F]{6}$/)){updateColor('ca',this.value)}">
          <span style="font-family:var(--fm);font-size:.62rem;color:var(--muted)">Color acento</span>
        </div>
        <div class="palette-swatches" id="swatches_ca">
          <% ['#ff5cb8','#ff80ab','#ea80fc','#b388ff','#82b1ff','#80d8ff','#ccff90','#ffd180','#ff6e40','#ffff8d'].forEach(c=>{ %>
            <div class="swatch <%= (config.color_acento||'#ff5cb8')===c?'selected':'' %>" 
                 style="background:<%= c %>" 
                 onclick="updateColor('ca','<%= c %>')" title="<%= c %>"></div>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- Temas predefinidos -->
    <div class="mt-4">
      <label class="form-label">Temas predefinidos</label>
      <div class="row g-3">
        <% const themes = [
          {name:'Pink Neon',cp:'#e91e8c',ca:'#ff5cb8',grad:'linear-gradient(135deg,#e91e8c,#ff5cb8)'},
          {name:'Cyber Purple',cp:'#7c4dff',ca:'#e040fb',grad:'linear-gradient(135deg,#7c4dff,#e040fb)'},
          {name:'Ocean Blue',cp:'#0088ff',ca:'#00c8ff',grad:'linear-gradient(135deg,#0088ff,#00c8ff)'},
          {name:'Neon Green',cp:'#00e676',ca:'#69ff47',grad:'linear-gradient(135deg,#00e676,#69ff47)'},
          {name:'Fire Red',cp:'#ff1744',ca:'#ff6d00',grad:'linear-gradient(135deg,#ff1744,#ff6d00)'},
          {name:'Gold',cp:'#ffc400',ca:'#ffea00',grad:'linear-gradient(135deg,#ffc400,#ffea00)'},
        ]; %>
        <% themes.forEach(t=>{ %>
        <div class="col-6 col-md-2">
          <div class="theme-option" onclick="applyTheme('<%= t.cp %>','<%= t.ca %>')">
            <div class="theme-preview" style="background:<%= t.grad %>"></div>
            <div style="font-family:var(--fb);font-size:.78rem;font-weight:600;color:var(--text)"><%= t.name %></div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </div>

  <!-- Configuración tienda -->
  <div class="config-section">
    <div class="config-section-title"><i class="bi bi-toggles"></i>Opciones de la Tienda</div>
    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label">Moneda</label>
        <select name="moneda" class="form-select">
          <% ['MXN','USD','EUR','COP','ARS','PEN','CLP'].forEach(m=>{ %>
            <option value="<%= m %>" <%= (config.moneda||'MXN')===m?'selected':'' %>><%= m %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-6">
        <label class="form-label">Símbolo moneda</label>
        <input type="text" name="simbolo_moneda" class="form-control" value="<%= config.simbolo_moneda||'$' %>" placeholder="$">
      </div>
      <div class="col-md-6">
        <label class="form-label">Mínimo de compra</label>
        <input type="number" name="minimo_compra" class="form-control" value="<%= config.minimo_compra||0 %>" min="0" step="0.01">
      </div>
      <div class="col-md-6">
        <label class="form-label">Envío gratis desde</label>
        <input type="number" name="envio_gratis_desde" class="form-control" value="<%= config.envio_gratis_desde||'' %>" min="0" step="0.01" placeholder="0 = siempre gratis">
      </div>
      <div class="col-12">
        <label class="form-label">Aviso / Banner de alerta <span style="color:var(--muted);font-weight:400">(se muestra en el navbar)</span></label>
        <input type="text" name="banner_aviso" class="form-control" value="<%= config.banner_aviso||'' %>" placeholder="Ej: 🚚 Envío gratis en compras mayores a $599">
      </div>
      <div class="col-12">
        <div class="d-flex gap-4 flex-wrap">
          <label class="d-flex align-items-center gap-2" style="cursor:pointer">
            <input type="checkbox" name="tienda_activa" value="1" <%= (config.tienda_activa==='1'||!config.tienda_activa)?'checked':'' %>
                   style="width:18px;height:18px;accent-color:var(--cp)">
            <span style="font-family:var(--fb);font-weight:600">Tienda activa</span>
          </label>
          <label class="d-flex align-items-center gap-2" style="cursor:pointer">
            <input type="checkbox" name="registro_activo" value="1" <%= config.registro_activo==='0'?'':'checked' %>
                   style="width:18px;height:18px;accent-color:var(--cp)">
            <span style="font-family:var(--fb);font-weight:600">Permitir nuevos registros</span>
          </label>
          <label class="d-flex align-items-center gap-2" style="cursor:pointer">
            <input type="checkbox" name="chat_ia_activo" value="1" <%= (config.chat_ia_activo!=='0')?'checked':'' %>
                   style="width:18px;height:18px;accent-color:var(--cp)">
            <span style="font-family:var(--fb);font-weight:600">Chat IA activo</span>
          </label>
        </div>
      </div>
    </div>
  </div>

  <!-- Redes sociales -->
  <div class="config-section">
    <div class="config-section-title"><i class="bi bi-share"></i>Redes Sociales</div>
    <div class="row g-3">
      <% [
        {name:'instagram',icon:'instagram',placeholder:'@tutienda'},
        {name:'facebook',icon:'facebook',placeholder:'facebook.com/tutienda'},
        {name:'tiktok',icon:'tiktok',placeholder:'@tutienda'},
        {name:'whatsapp',icon:'whatsapp',placeholder:'5212345678901'},
      ].forEach(s=>{ %>
      <div class="col-md-6">
        <label class="form-label"><i class="bi bi-<%= s.icon %> me-1" style="color:var(--cp)"></i><%= s.name.charAt(0).toUpperCase()+s.name.slice(1) %></label>
        <input type="text" name="<%= s.name %>" class="form-control" value="<%= config[s.name]||'' %>" placeholder="<%= s.placeholder %>">
      </div>
      <% }) %>
    </div>
  </div>

  <!-- SEO -->
  <div class="config-section">
    <div class="config-section-title"><i class="bi bi-search"></i>SEO & Metadatos</div>
    <div class="row g-3">
      <div class="col-12">
        <label class="form-label">Meta descripción</label>
        <textarea name="meta_descripcion" class="form-control" rows="2" placeholder="Descripción breve de tu tienda para buscadores..."><%= config.meta_descripcion||'' %></textarea>
      </div>
      <div class="col-md-6">
        <label class="form-label">Meta keywords</label>
        <input type="text" name="meta_keywords" class="form-control" value="<%= config.meta_keywords||'' %>" placeholder="ropa, moda, tienda online">
      </div>
      <div class="col-md-6">
        <label class="form-label">Google Analytics ID</label>
        <input type="text" name="google_analytics" class="form-control" value="<%= config.google_analytics||'' %>" placeholder="G-XXXXXXXXXX">
      </div>
    </div>
  </div>

</form>
</div>

<!-- Save bar -->
<div class="save-bar">
  <div style="font-family:var(--fm);font-size:.65rem;color:var(--muted)">
    <i class="bi bi-info-circle me-1"></i>Los cambios se aplican de inmediato en toda la tienda
  </div>
  <div class="d-flex gap-2">
    <a href="/admin" class="btn btn-om btn-sm">Cancelar</a>
    <button type="submit" form="configForm" class="btn btn-pm btn-sm px-4">
      <i class="bi bi-check2-circle me-1"></i>Guardar Configuración
    </button>
  </div>
</div>

<script>
function updateColor(key, val) {
  // Update input
  if (key === 'cp') {
    document.getElementById('cp_input').value = val;
    document.getElementById('cp_hex').value = val;
    document.getElementById('prev_cp').style.background = val;
    // Update swatches
    document.querySelectorAll('#swatches_cp .swatch').forEach(s => {
      s.classList.toggle('selected', s.title === val);
    });
    // Live preview
    document.getElementById('lp-brand').style.color = val;
    document.getElementById('lp-bar1').style.background = val;
    document.getElementById('lp-bar2').style.background = val;
    document.getElementById('lp-bar3').style.background = val;
    document.getElementById('lp-btn1').style.background = `linear-gradient(135deg,${val},${document.getElementById('ca_input').value})`;
    document.getElementById('lp-btn2').style.borderColor = val;
    document.getElementById('lp-btn2').style.color = val;
  } else {
    document.getElementById('ca_input').value = val;
    document.getElementById('ca_hex').value = val;
    document.getElementById('prev_ca').style.background = val;
    document.querySelectorAll('#swatches_ca .swatch').forEach(s => {
      s.classList.toggle('selected', s.title === val);
    });
    const cp = document.getElementById('cp_input').value;
    document.getElementById('lp-btn1').style.background = `linear-gradient(135deg,${cp},${val})`;
  }
}

function applyTheme(cp, ca) {
  updateColor('cp', cp);
  updateColor('ca', ca);
  document.querySelectorAll('.theme-option').forEach(t => t.classList.remove('selected'));
  event.currentTarget.classList.add('selected');
}

// Init preview
window.addEventListener('DOMContentLoaded', () => {
  const cp = document.getElementById('cp_input').value;
  const ca = document.getElementById('ca_input').value;
  document.getElementById('lp-bar1').style.background = cp;
  document.getElementById('lp-bar2').style.background = cp;
  document.getElementById('lp-bar3').style.background = cp;
  document.getElementById('lp-btn1').style.background = `linear-gradient(135deg,${cp},${ca})`;
  document.getElementById('lp-btn2').style.borderColor = cp;
  document.getElementById('lp-btn2').style.color = cp;
});
</script>

<%- include('../partials/footer') %>
