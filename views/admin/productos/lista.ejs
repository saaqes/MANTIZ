<%- include('../../partials/header', {isAdmin: true}) %>
<div class="container-fluid py-4 px-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">Productos</h3>
    <a href="/admin/productos/nuevo" class="btn btn-primary-mantiz rounded-3"><i class="bi bi-plus me-2"></i>Nuevo producto</a>
  </div>
  <div class="card border-0 rounded-4 shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light"><tr><th>Imagen</th><th>Producto</th><th>Categoría</th><th>Precio</th><th>Stock</th><th>Estado</th><th>Acciones</th></tr></thead>
        <tbody>
          <% productos.forEach(p => { %>
          <tr>
            <td><img src="/uploads/products/<%= p.imagen_principal %>" width="50" height="50" class="rounded-2" style="object-fit:cover" onerror="this.src='https://via.placeholder.com/50x50/f0f0f0/999?text=IMG'"></td>
            <td><div class="fw-semibold"><%= p.titulo %></div><div class="text-muted small">ID: #<%= p.id %></div></td>
            <td><span class="badge rounded-pill" style="background:var(--color-primary)"><%= p.categoria %></span></td>
            <td>
              <span class="fw-bold" style="color:var(--color-primary)">$<%= parseFloat(p.precio_descuento||p.precio).toFixed(2) %></span>
              <% if (p.precio_descuento) { %><span class="text-muted text-decoration-line-through small ms-1">$<%= parseFloat(p.precio).toFixed(2) %></span><% } %>
            </td>
            <td><%= p.total_visitas || 0 %> visitas</td>
            <td><span class="badge rounded-pill" style="background:<%= p.activo?'#28a745':'#6c757d' %>"><%= p.activo?'Activo':'Inactivo' %></span></td>
            <td class="d-flex gap-2">
              <a href="/admin/productos/<%= p.id %>/editar" class="btn btn-sm btn-outline-secondary rounded-3"><i class="bi bi-pencil"></i></a>
              <form action="/admin/productos/<%= p.id %>/eliminar" method="POST" onsubmit="return confirm('¿Eliminar este producto?')">
                <button type="submit" class="btn btn-sm btn-outline-danger rounded-3"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include('../../partials/footer', {isAdmin: true}) %>
