<%- include('../partials/header', {isAdmin: true}) %>

<style>
/* ── Sistema de animaciones (mismo set que el hero público, para que el
   preview del editor reproduzca exactamente lo que verá el usuario) ── */
@keyframes hanim-fade-in{from{opacity:0}to{opacity:1}}
@keyframes hanim-fade-up{from{opacity:0;transform:translateY(40px)}to{opacity:1;transform:translateY(0)}}
@keyframes hanim-fade-left{from{opacity:0;transform:translateX(50px)}to{opacity:1;transform:translateX(0)}}
@keyframes hanim-fade-right{from{opacity:0;transform:translateX(-50px)}to{opacity:1;transform:translateX(0)}}
@keyframes hanim-zoom-in{from{opacity:0;transform:scale(0.82)}to{opacity:1;transform:scale(1)}}
@keyframes hanim-zoom-out{from{opacity:0;transform:scale(1.18)}to{opacity:1;transform:scale(1)}}
@keyframes hanim-scale{from{opacity:0;transform:scale(0.5)}to{opacity:1;transform:scale(1)}}
@keyframes hanim-slide{from{opacity:0;transform:translateX(-70px)}to{opacity:1;transform:translateX(0)}}
.hanim-fade-in{animation:hanim-fade-in .8s ease forwards}
.hanim-fade-up{animation:hanim-fade-up .8s cubic-bezier(.22,1,.36,1) forwards}
.hanim-fade-left{animation:hanim-fade-left .8s cubic-bezier(.22,1,.36,1) forwards}
.hanim-fade-right{animation:hanim-fade-right .8s cubic-bezier(.22,1,.36,1) forwards}
.hanim-zoom-in{animation:hanim-zoom-in .8s cubic-bezier(.22,1,.36,1) forwards}
.hanim-zoom-out{animation:hanim-zoom-out .8s cubic-bezier(.22,1,.36,1) forwards}
.hanim-scale{animation:hanim-scale .6s cubic-bezier(.34,1.56,.64,1) forwards}
.hanim-slide{animation:hanim-slide .7s cubic-bezier(.22,1,.36,1) forwards}
.hanim-ninguna{opacity:1;animation:none}

/* ── Grid de slides existentes (vista de gestión, sin cambios de fondo) ── */
.slide-card { background:var(--card); border:1px solid var(--border); border-radius:12px; overflow:hidden; transition:all .3s; }
.slide-card:hover { border-color:var(--cp); box-shadow:0 8px 24px rgba(233,30,140,.15); }
.slide-thumb { height:140px; overflow:hidden; position:relative; background:var(--dark2); cursor:pointer; }
.slide-thumb img { width:100%;height:100%;object-fit:cover;transition:transform .4s; }
.slide-card:hover .slide-thumb img { transform:scale(1.04); }

/* ══════════════════════════════════════════════════════════════════════
   EDITOR PROFESIONAL FULLSCREEN
   ══════════════════════════════════════════════════════════════════════ */
#proEditor{
  position:fixed!important;inset:0!important;width:100vw!important;height:100vh!important;z-index:99999!important;background:#050505;
  display:none;flex-direction:column;
  margin:0!important;padding:0!important;top:0!important;left:0!important;right:0!important;bottom:0!important;
}
#proEditor.open{display:flex!important}
.pe-topbar{
  height:56px;flex-shrink:0;display:flex;align-items:center;justify-content:space-between;
  padding:0 20px;background:#0a0a0a;border-bottom:1px solid var(--border);z-index:5;
}
.pe-topbar-title{font-family:var(--fd);font-size:.78rem;letter-spacing:2px;color:var(--cp);display:flex;align-items:center;gap:10px}
.pe-topbar-actions{display:flex;gap:8px;align-items:center}
.pe-close-btn{background:none;border:1px solid var(--border);color:var(--muted);width:34px;height:34px;border-radius:8px;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;transition:all .2s}
.pe-close-btn:hover{border-color:#ff4444;color:#ff4444}

.pe-body{flex:1;display:flex;overflow:hidden;min-height:0}

/* ── Canvas central (ocupa la mayor parte de la pantalla) ──
   FIX: overflow:auto + falta de min-width:0 hacía que este contenedor flex
   no pudiera reducirse por debajo del ancho intrínseco del canvas, causando
   que el viewer se desbordara/quedara mal posicionado (visualmente "oculto"
   en relación al sidebar admin en pantallas no muy anchas). */
.pe-canvas-wrap{flex:1;min-width:0!important;display:flex;align-items:center;justify-content:center;padding:24px;overflow:hidden!important;max-width:100%;background:repeating-conic-gradient(#0d0d0d 0% 25%, #0a0a0a 0% 50%) 50%/24px 24px}
.pe-canvas{
  position:relative;width:100%;max-width:min(1280px,100%);aspect-ratio:1920/600;
  background:#0a0a0a;overflow:hidden;border-radius:6px;
  box-shadow:0 20px 60px rgba(0,0,0,.6),0 0 0 1px rgba(233,30,140,.15);
  flex-shrink:0;
}
.pe-canvas-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:brightness(0.45)}
.pe-canvas-noimg{position:absolute;inset:0;background:linear-gradient(135deg,#0a0a0a,#1a0816,#0a0a0a);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.15);font-family:var(--fd);font-size:1.2rem;letter-spacing:4px}
.pe-canvas-overlay{position:absolute;inset:0;background:linear-gradient(to bottom,rgba(0,0,0,0.1),rgba(0,0,0,0.5))}
.pe-canvas-content{
  position:absolute;inset:0;display:flex;flex-direction:column;justify-content:center;gap:clamp(6px,1.4vw,16px);
  z-index:5;padding:0 clamp(20px,5vw,60px);
}
.pe-c-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(20px,5.2vw,56px);letter-spacing:6px;line-height:1.05;color:white;text-shadow:0 2px 30px rgba(0,0,0,0.7);margin:0;max-width:75%}
.pe-c-subtitle{font-family:'Rajdhani',sans-serif;font-size:clamp(9px,1.3vw,15px);letter-spacing:2px;color:rgba(255,255,255,0.85);margin:0;max-width:60%;text-shadow:0 1px 10px rgba(0,0,0,0.8)}
.pe-c-countdown{font-family:'Bebas Neue',sans-serif;font-size:clamp(14px,2.6vw,30px);letter-spacing:5px;color:white;text-shadow:0 2px 14px rgba(233,30,140,0.6)}
.pe-c-btn{background:transparent;border:2px solid var(--cp);color:var(--cp);padding:clamp(6px,1vw,12px) clamp(16px,3vw,40px);font-family:'Bebas Neue',sans-serif;font-size:clamp(10px,1.6vw,18px);letter-spacing:4px;display:inline-block;width:fit-content}
.pe-canvas-zoomlabel{position:absolute;bottom:10px;left:14px;font-family:var(--fm);font-size:.6rem;color:rgba(255,255,255,.4);letter-spacing:1px;z-index:6}

/* ── Sidebar de herramientas (alrededor del canvas) ── */
.pe-sidebar{
  width:260px;min-width:240px;max-width:260px;flex-shrink:0;background:var(--dark2);border-left:1px solid var(--border);
  overflow-y:auto;padding:14px;display:flex;flex-direction:column;
}
.pe-sidebar-inner{flex:1}
.pe-sidebar-save{flex-shrink:0;border-top:1px solid var(--border);padding-top:14px;margin-top:12px}
.pe-sidebar::-webkit-scrollbar{width:4px}
.pe-sidebar::-webkit-scrollbar-thumb{background:var(--cp);border-radius:2px}
.pe-sec-title{font-family:var(--fd);font-size:.6rem;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin:14px 0 6px}
.pe-sec-title:first-child{margin-top:0}

@media(max-width:900px){
  .pe-body{flex-direction:column}
  .pe-canvas-wrap{padding:14px}
  .pe-sidebar{width:100%;max-width:100%;min-width:unset;border-left:none;border-top:1px solid var(--border);max-height:45vh}
}

.upload-zone { border:2px dashed var(--border); border-radius:10px; padding:24px; text-align:center; cursor:pointer; transition:all .3s; background:var(--dark3); }
.upload-zone:hover { border-color:var(--cp); background:rgba(233,30,140,.05); }

/* Tabs reutilizables (content type, botón, destino) */
.ct-tab { padding:6px 12px; border:1px solid var(--border); background:none; color:var(--muted); font-family:var(--fd); font-size:.6rem; letter-spacing:1px; cursor:pointer; border-radius:4px; transition:all .2s; }
.ct-tab.active { background:var(--cp); border-color:var(--cp); color:white; }

/* Selector de posición de texto (3 botones visuales) */
.pos-row{display:flex;gap:6px}
.pos-btn{flex:1;height:44px;border:1px solid var(--border);background:var(--dark3);border-radius:6px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .18s;position:relative}
.pos-btn.active{border-color:var(--cp);background:rgba(233,30,140,.1)}
.pos-btn-bar{width:14px;height:3px;background:var(--muted);border-radius:1px}
.pos-btn.active .pos-btn-bar{background:var(--cp)}
.pos-btn[data-pos="izquierda"] .pos-btn-bar{margin-right:auto}
.pos-btn[data-pos="derecha"] .pos-btn-bar{margin-left:auto}
.pos-btn-inner{width:24px;display:flex;flex-direction:column;gap:3px}

/* Selector de animación (grid de 9 opciones con mini-ícono) */
.anim-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px}
.anim-btn{padding:10px 6px;border:1px solid var(--border);background:var(--dark3);border-radius:6px;cursor:pointer;transition:all .18s;text-align:center;font-family:var(--fm);font-size:.55rem;color:var(--muted);letter-spacing:.5px}
.anim-btn:hover{border-color:rgba(233,30,140,.4)}
.anim-btn.active{border-color:var(--cp);background:rgba(233,30,140,.12);color:var(--cp)}
.anim-btn i{display:block;font-size:1.1rem;margin-bottom:4px;color:inherit}

/* Selector de destino */
.dest-row{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px}
</style>

<div class="d-flex align-items-center justify-content-between mb-4">
  <div>
    <div style="font-family:var(--fd);font-size:.7rem;color:var(--muted);letter-spacing:3px;text-transform:uppercase">GESTIÓN</div>
    <div style="font-family:var(--fd);font-size:1.2rem;font-weight:800;color:var(--text)">Carrusel y Banners</div>
  </div>
  <button class="btn btn-pm" onclick="abrirNuevo()">
    <i class="bi bi-plus-lg me-2"></i>NUEVO SLIDE
  </button>
</div>

<!-- Grid de slides existentes -->
<% if (slides && slides.length > 0) { %>
<div class="row g-3 mb-4" id="slidesGrid">
  <% slides.forEach(function(s, i) { %>
  <div class="col-12 col-md-6 col-xl-4" id="slide-<%= s.id %>">
    <div class="slide-card" id="card-<%= s.id %>">
      <div class="slide-thumb" onclick="abrirEditar(<%= s.id %>)">
        <img src="/uploads/banners/<%= s.imagen %>" alt="Slide <%= i+1 %>" onerror="this.parentElement.style.background='var(--dark3)'">
        <div style="position:absolute;top:8px;left:8px;background:rgba(0,0,0,.7);border:1px solid var(--cp);color:var(--cp);font-family:var(--fd);font-size:.6rem;padding:2px 8px;border-radius:4px">
          #<%= s.orden || i+1 %>
        </div>
        <% if (s.activo) { %>
        <div style="position:absolute;top:8px;right:8px;background:rgba(0,255,100,.15);border:1px solid rgba(0,255,100,.3);color:#00ff64;font-family:var(--fd);font-size:.58rem;padding:2px 8px;border-radius:4px">ACTIVO</div>
        <% } else { %>
        <div style="position:absolute;top:8px;right:8px;background:rgba(255,100,100,.1);border:1px solid rgba(255,100,100,.3);color:#ff6060;font-family:var(--fd);font-size:.58rem;padding:2px 8px;border-radius:4px">OCULTO</div>
        <% } %>
        <div style="position:absolute;bottom:8px;left:8px;background:rgba(233,30,140,.85);color:white;font-family:var(--fd);font-size:.55rem;padding:2px 8px;border-radius:4px;letter-spacing:1px">
          <%= (s.content_type||'texto').toUpperCase().replace('_',' ') %>
          <% if (s.mostrar_boton) { %> + BTN<% } %>
        </div>
        <% if (s.animacion && s.animacion !== 'fade-in') { %>
        <div style="position:absolute;bottom:8px;right:8px;background:rgba(0,200,255,.15);border:1px solid rgba(0,200,255,.3);color:#00c8ff;font-family:var(--fd);font-size:.5rem;padding:2px 7px;border-radius:4px">
          <i class="bi bi-magic"></i> <%= s.animacion.toUpperCase() %>
        </div>
        <% } %>
        <div style="position:absolute;inset:0;background:rgba(0,0,0,0);transition:background .2s;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .2s" onmouseover="this.style.opacity='1';this.style.background='rgba(0,0,0,.4)'" onmouseout="this.style.opacity='0'">
          <div style="font-family:var(--fd);font-size:.65rem;letter-spacing:2px;color:white;border:1px solid white;padding:6px 14px">EDITAR EN PANTALLA COMPLETA</div>
        </div>
      </div>
      <div class="p-3">
        <div style="font-weight:700;font-size:.85rem;margin-bottom:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= s.titulo || '(sin título)' %></div>
        <% if (s.subtitulo) { %><div style="font-size:.75rem;color:var(--muted);margin-bottom:8px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= s.subtitulo %></div><% } %>
        <div class="d-flex gap-2">
          <button class="btn btn-sm btn-om" style="flex:1" onclick="abrirEditar(<%= s.id %>)">
            <i class="bi bi-pencil-fill me-1"></i>Editar
          </button>
          <form action="/admin/carrusel/<%= s.id %>/toggle" method="POST" style="flex:0"
                onsubmit="event.preventDefault();toggleSlide(this,<%= s.id %>)">
            <button type="submit" class="btn btn-sm" style="border:1px solid <%= s.activo ? 'rgba(255,100,100,.4)' : 'rgba(0,255,100,.4)' %>;color:<%= s.activo ? '#ff6464' : '#00ff64' %>;background:transparent;font-size:.72rem;padding:5px 10px">
              <i class="bi bi-<%= s.activo ? 'eye-slash' : 'eye' %>-fill"></i>
            </button>
          </form>
          <form action="/admin/carrusel/<%= s.id %>/eliminar" method="POST" style="flex:0"
                onsubmit="return confirm('Eliminar este slide?')">
            <button type="submit" class="btn btn-sm" style="border:1px solid rgba(255,60,60,.3);color:#ff6060;background:transparent;font-size:.72rem;padding:5px 10px">
              <i class="bi bi-trash-fill"></i>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
  <% }) %>
</div>
<% } else { %>
<div class="text-center py-5" style="border:2px dashed var(--border);border-radius:12px">
  <i class="bi bi-images" style="font-size:3rem;color:var(--muted)"></i>
  <div style="font-family:var(--fd);font-size:.75rem;color:var(--muted);letter-spacing:2px;margin-top:12px">SIN SLIDES AÚN</div>
  <button class="btn btn-pm mt-3" onclick="abrirNuevo()"><i class="bi bi-plus-lg me-2"></i>Añadir primero</button>
</div>
<% } %>

<!-- ══════════════════════════════════════════════════════════
     EDITOR PROFESIONAL FULLSCREEN
══════════════════════════════════════════════════════════ -->
<div id="proEditor">
  <!-- Barra superior -->
  <div class="pe-topbar">
    <div class="pe-topbar-title">
      <i class="bi bi-magic"></i>
      <span id="peTitle">NUEVO SLIDE</span>
    </div>
    <div class="pe-topbar-actions">
      <button class="btn btn-pm" style="padding:8px 24px;font-size:.82rem;letter-spacing:2px;min-width:150px" onclick="document.getElementById('slideForm').requestSubmit()">
        <i class="bi bi-floppy-fill me-2"></i><span id="submitBtnText">GUARDAR CAMBIOS</span>
      </button>
      <button class="pe-close-btn" onclick="cerrarEditor()" title="Cerrar (Esc)"><i class="bi bi-x-lg"></i></button>
    </div>
  </div>

  <div class="pe-body">
    <!-- CANVAS: ocupa la mayor parte de la pantalla -->
    <div class="pe-canvas-wrap">
      <div class="pe-canvas" id="peCanvas">
        <img id="peCanvasImg" class="pe-canvas-img" src="" style="display:none">
        <div id="peCanvasNoImg" class="pe-canvas-noimg">SUBE UNA IMAGEN PARA VER LA VISTA PREVIA</div>
        <div class="pe-canvas-overlay"></div>
        <div class="pe-canvas-content" id="peCanvasContent">
          <h1 class="pe-c-title" id="peTitulo" style="display:none"></h1>
          <p class="pe-c-subtitle" id="peSubtitulo" style="display:none"></p>
          <div class="pe-c-countdown" id="peCountdown" style="display:none">00D 00H 00M 00S</div>
          <div id="peBtnWrap" style="display:none">
            <div class="pe-c-btn" id="peBtnText">EXPLORAR</div>
          </div>
        </div>
        <div class="pe-canvas-zoomlabel">VISTA PREVIA · 1920×600 — esto es exactamente lo que verán tus clientes</div>
      </div>
    </div>

    <!-- SIDEBAR: herramientas alrededor del canvas -->
    <div class="pe-sidebar">
      <div class="pe-sidebar-inner">
      <form id="slideForm" method="POST" enctype="multipart/form-data">

        <div class="pe-sec-title">◈ Imagen</div>
        <div class="upload-zone" id="uploadZone" onclick="document.getElementById('slideImgInput').click()">
          <i class="bi bi-cloud-arrow-up" style="font-size:1.6rem;color:var(--cp)"></i>
          <div style="font-family:var(--fd);font-size:.6rem;color:var(--muted);letter-spacing:2px;margin-top:6px">CLIC O ARRASTRA</div>
          <div style="font-size:.6rem;color:var(--muted);margin-top:3px">PNG, JPG, WebP · Máx 5MB · Rec. 1920×600px</div>
          <div id="uploadFileName" style="font-size:.68rem;color:var(--cp);margin-top:6px;display:none"></div>
        </div>
        <input type="file" id="slideImgInput" name="imagen" accept="image/*" style="display:none" onchange="onImageChange(this)">

        <div class="pe-sec-title">◈ Texto</div>
        <div class="mb-2">
          <label class="form-label" style="font-size:.72rem">Título</label>
          <input type="text" name="titulo" id="f-titulo" class="form-control form-control-sm" placeholder="NUEVA COLECCIÓN" oninput="updatePreview()">
        </div>
        <div class="mb-2">
          <label class="form-label" style="font-size:.72rem">Subtítulo</label>
          <input type="text" name="subtitulo" id="f-subtitulo" class="form-control form-control-sm" placeholder="Descubre los últimos lanzamientos" oninput="updatePreview()">
        </div>

        <div class="pe-sec-title">◈ Posición del texto</div>
        <div class="pos-row" id="posRow">
          <button type="button" class="pos-btn" data-pos="izquierda" onclick="setPosicion('izquierda')" title="Izquierda">
            <div class="pos-btn-inner"><span class="pos-btn-bar" style="width:16px"></span><span class="pos-btn-bar" style="width:10px"></span></div>
          </button>
          <button type="button" class="pos-btn active" data-pos="centro" onclick="setPosicion('centro')" title="Centro">
            <div class="pos-btn-inner" style="align-items:center"><span class="pos-btn-bar" style="width:16px"></span><span class="pos-btn-bar" style="width:10px"></span></div>
          </button>
          <button type="button" class="pos-btn" data-pos="derecha" onclick="setPosicion('derecha')" title="Derecha">
            <div class="pos-btn-inner" style="align-items:flex-end"><span class="pos-btn-bar" style="width:16px"></span><span class="pos-btn-bar" style="width:10px"></span></div>
          </button>
        </div>
        <input type="hidden" name="posicion_texto" id="f-posicion" value="centro">

        <div class="pe-sec-title">◈ Animación de entrada</div>
        <div class="anim-grid" id="animGrid">
          <button type="button" class="anim-btn active" data-anim="fade-in" onclick="setAnimacion('fade-in')"><i class="bi bi-square"></i>Fade In</button>
          <button type="button" class="anim-btn" data-anim="fade-up" onclick="setAnimacion('fade-up')"><i class="bi bi-arrow-up-square"></i>Fade Up</button>
          <button type="button" class="anim-btn" data-anim="fade-left" onclick="setAnimacion('fade-left')"><i class="bi bi-arrow-left-square"></i>Fade Left</button>
          <button type="button" class="anim-btn" data-anim="fade-right" onclick="setAnimacion('fade-right')"><i class="bi bi-arrow-right-square"></i>Fade Right</button>
          <button type="button" class="anim-btn" data-anim="zoom-in" onclick="setAnimacion('zoom-in')"><i class="bi bi-zoom-in"></i>Zoom In</button>
          <button type="button" class="anim-btn" data-anim="zoom-out" onclick="setAnimacion('zoom-out')"><i class="bi bi-zoom-out"></i>Zoom Out</button>
          <button type="button" class="anim-btn" data-anim="scale" onclick="setAnimacion('scale')"><i class="bi bi-aspect-ratio"></i>Scale</button>
          <button type="button" class="anim-btn" data-anim="slide" onclick="setAnimacion('slide')"><i class="bi bi-arrow-right"></i>Slide</button>
          <button type="button" class="anim-btn" data-anim="ninguna" onclick="setAnimacion('ninguna')"><i class="bi bi-slash-circle"></i>Ninguna</button>
        </div>
        <input type="hidden" name="animacion" id="f-animacion" value="fade-in">
        <button type="button" class="btn btn-om btn-sm w-100 mt-2" onclick="replayPreviewAnim()" style="font-size:.65rem">
          <i class="bi bi-play-fill me-1"></i>REPRODUCIR ANIMACIÓN
        </button>

        <div class="pe-sec-title">◈ Contenido central del slide</div>
        <div class="d-flex gap-2 flex-wrap mb-2" id="ctTabs">
          <button type="button" class="ct-tab active" data-val="texto" onclick="setContentType('texto')">Solo texto</button>
          <button type="button" class="ct-tab" data-val="cronometro" onclick="setContentType('cronometro')">Solo cronómetro</button>
          <button type="button" class="ct-tab" data-val="texto_cronometro" onclick="setContentType('texto_cronometro')">Texto + cronómetro</button>
          <button type="button" class="ct-tab" data-val="nada" onclick="setContentType('nada')">Sin contenido</button>
        </div>
        <input type="hidden" name="content_type" id="f-content-type" value="texto">

        <div class="mb-2" id="countdownSection" style="display:none">
          <label class="form-label" style="font-size:.72rem">Fecha objetivo del cronómetro</label>
          <input type="datetime-local" name="countdown_fecha" id="f-countdown" class="form-control form-control-sm" oninput="updatePreview()">
        </div>

        <div class="pe-sec-title">◈ Botón de acción</div>
        <div class="d-flex gap-2 mb-2">
          <button type="button" class="ct-tab active" id="btnTabShow" onclick="setBoton(true)">Mostrar botón</button>
          <button type="button" class="ct-tab" id="btnTabHide" onclick="setBoton(false)">Sin botón</button>
        </div>
        <input type="hidden" name="mostrar_boton" id="f-mostrar-boton" value="1">

        <div id="botonTextoSection">
          <div class="mb-2">
            <label class="form-label" style="font-size:.72rem">Texto del botón</label>
            <input type="text" name="boton_texto" id="f-boton-texto" class="form-control form-control-sm" placeholder="EXPLORAR" value="EXPLORAR" oninput="updatePreview()">
          </div>

          <label class="form-label" style="font-size:.72rem">Destino del botón</label>
          <div class="dest-row" id="destTabs">
            <button type="button" class="ct-tab active" data-val="url" onclick="setDestino('url')">URL</button>
            <button type="button" class="ct-tab" data-val="producto" onclick="setDestino('producto')">Producto</button>
            <button type="button" class="ct-tab" data-val="categoria" onclick="setDestino('categoria')">Categoría</button>
            <button type="button" class="ct-tab" data-val="pagina" onclick="setDestino('pagina')">Página</button>
          </div>
          <input type="hidden" name="destino_tipo" id="f-destino-tipo" value="url">
          <input type="hidden" name="destino_valor" id="f-destino-valor" value="">
          <input type="hidden" name="boton_url" id="f-boton-url" value="/productos">

          <!-- Campo dinámico según destino_tipo -->
          <div id="destUrlField" class="mb-3">
            <input type="text" id="f-dest-url-inp" class="form-control form-control-sm" placeholder="/productos o https://..." value="/productos" oninput="onDestUrlChange()">
          </div>
          <div id="destProductoField" class="mb-3" style="display:none">
            <select id="f-dest-producto-inp" class="form-select form-select-sm" onchange="onDestSelectChange()">
              <option value="">Selecciona un producto...</option>
              <% (productosLista||[]).forEach(function(p){ %>
              <option value="<%= p.id %>"><%= p.titulo %></option>
              <% }) %>
            </select>
          </div>
          <div id="destCategoriaField" class="mb-3" style="display:none">
            <select id="f-dest-categoria-inp" class="form-select form-select-sm" onchange="onDestSelectChange()">
              <option value="">Selecciona una categoría...</option>
              <% (categoriasLista||[]).forEach(function(c){ %>
              <option value="<%= c.categoria %>"><%= c.categoria %></option>
              <% }) %>
            </select>
          </div>
          <div id="destPaginaField" class="mb-3" style="display:none">
            <select id="f-dest-pagina-inp" class="form-select form-select-sm" onchange="onDestSelectChange()">
              <option value="/">Inicio</option>
              <option value="/productos">Productos</option>
              <option value="/comunidad">Comunidad</option>
              <option value="/opiniones">Opiniones</option>
              <option value="/usuarios">Directorio de usuarios</option>
              <option value="/tiendas">Sucursales</option>
              <option value="/ayuda">Ayuda</option>
            </select>
          </div>
          <div style="font-size:.62rem;color:var(--muted);margin-top:-6px;margin-bottom:10px" id="destPreviewLabel">→ /productos</div>
        </div>

        <div class="pe-sec-title">◈ Orden y visibilidad</div>
        <div class="row g-2 mb-3">
          <div class="col-6">
            <label class="form-label" style="font-size:.72rem">Orden</label>
            <input type="number" name="orden" id="f-orden" class="form-control form-control-sm" value="<%= (slides ? slides.length : 0) + 1 %>" min="1">
          </div>
          <div class="col-6 d-flex align-items-end">
            <div class="form-check">
              <input type="checkbox" name="activo" id="f-activo" class="form-check-input" value="1" checked>
              <label class="form-check-label" style="font-size:.75rem" for="f-activo">Visible en el sitio</label>
            </div>
          </div>
        </div>
      </form>
      </div><!-- /pe-sidebar-inner -->
      <!-- Botón guardar al pie del sidebar — siempre visible sin scrollear -->
      <div class="pe-sidebar-save">
        <button type="button" onclick="document.getElementById('slideForm').requestSubmit()"
                style="width:100%;background:var(--cp);border:2px solid rgba(255,255,255,.5);color:white;padding:13px;font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:4px;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:10px;transition:opacity .2s"
                onmouseover="this.style.opacity='.85'" onmouseout="this.style.opacity='1'">
          <i class="bi bi-floppy-fill" style="font-size:1.1rem"></i> GUARDAR CAMBIOS
        </button>
      </div>
    </div>
  </div>
</div>

<script>
var editorOpen = false;
var cdInterval = null;
var currentSlides = <%- JSON.stringify(slides || []) %>;
var HANIM_CLASSES = ['hanim-fade-in','hanim-fade-up','hanim-fade-left','hanim-fade-right','hanim-zoom-in','hanim-zoom-out','hanim-scale','hanim-slide','hanim-ninguna'];

// ── ABRIR / CERRAR EDITOR ──────────────────────────────
function abrirNuevo() {
  document.getElementById('peTitle').textContent = 'NUEVO SLIDE';
  document.getElementById('submitBtnText').textContent = 'SUBIR SLIDE';
  document.getElementById('slideForm').action = '/admin/carrusel/nuevo';
  document.getElementById('slideForm').reset();
  document.getElementById('slideImgInput').required = true;
  document.getElementById('f-titulo').value = '';
  document.getElementById('f-subtitulo').value = '';
  document.getElementById('f-orden').value = (currentSlides.length || 0) + 1;
  document.getElementById('f-activo').checked = true;
  document.getElementById('peCanvasImg').style.display = 'none';
  document.getElementById('peCanvasNoImg').style.display = 'flex';
  setContentType('texto');
  setBoton(true);
  setPosicion('centro');
  setAnimacion('fade-in');
  setDestino('url');
  document.getElementById('f-dest-url-inp').value = '/productos';
  onDestUrlChange();
  document.getElementById('f-boton-texto').value = 'EXPLORAR';
  updatePreview();
  abrirEditorPanel();
}

function abrirEditar(id) {
  var s = currentSlides.find(function(sl){ return sl.id == id; });
  if (!s) return;
  document.getElementById('peTitle').textContent = 'EDITANDO: ' + (s.titulo || 'SLIDE #' + id);
  document.getElementById('submitBtnText').textContent = 'GUARDAR CAMBIOS';
  document.getElementById('slideForm').action = '/admin/carrusel/' + id + '/editar';
  document.getElementById('slideForm').reset();
  document.getElementById('f-titulo').value = s.titulo || '';
  document.getElementById('f-subtitulo').value = s.subtitulo || '';
  document.getElementById('f-orden').value = s.orden || 1;
  document.getElementById('f-activo').checked = !!s.activo;
  document.getElementById('f-boton-texto').value = s.boton_texto || 'EXPLORAR';
  if (s.countdown_fecha) document.getElementById('f-countdown').value = String(s.countdown_fecha).substring(0,16);

  var img = document.getElementById('peCanvasImg');
  img.src = '/uploads/banners/' + s.imagen;
  img.style.display = 'block';
  document.getElementById('peCanvasNoImg').style.display = 'none';

  setContentType(s.content_type || 'texto');
  setBoton(s.mostrar_boton !== 0 && s.mostrar_boton !== '0');
  setPosicion(s.posicion_texto || 'centro');
  setAnimacion(s.animacion || 'fade-in');
  setDestino(s.destino_tipo || 'url');

  // Restaurar el valor del campo de destino según el tipo
  var dt = s.destino_tipo || 'url';
  if (dt === 'producto' && s.destino_valor) document.getElementById('f-dest-producto-inp').value = s.destino_valor;
  else if (dt === 'categoria' && s.destino_valor) document.getElementById('f-dest-categoria-inp').value = s.destino_valor;
  else if (dt === 'pagina' && s.destino_valor) document.getElementById('f-dest-pagina-inp').value = s.destino_valor;
  else document.getElementById('f-dest-url-inp').value = s.boton_url || '/productos';
  recalcDestino();

  document.getElementById('slideImgInput').required = false;
  updatePreview();
  abrirEditorPanel();
}

function abrirEditorPanel() {
  document.getElementById('proEditor').classList.add('open');
  document.body.style.overflow = 'hidden';
  editorOpen = true;
}
function cerrarEditor() {
  document.getElementById('proEditor').classList.remove('open');
  document.body.style.overflow = '';
  editorOpen = false;
  if (cdInterval) { clearInterval(cdInterval); cdInterval = null; }
}
document.addEventListener('keydown', function(e){ if (e.key === 'Escape' && editorOpen) cerrarEditor(); });

// ── CONTENT TYPE ──────────────────────────────────────
function setContentType(val) {
  document.getElementById('f-content-type').value = val;
  document.querySelectorAll('#ctTabs .ct-tab').forEach(function(btn) {
    btn.classList.toggle('active', btn.dataset.val === val);
  });
  document.getElementById('countdownSection').style.display = (val === 'cronometro' || val === 'texto_cronometro') ? 'block' : 'none';
  updatePreview();
}

function setBoton(show) {
  document.getElementById('f-mostrar-boton').value = show ? '1' : '0';
  document.getElementById('btnTabShow').classList.toggle('active', show);
  document.getElementById('btnTabHide').classList.toggle('active', !show);
  document.getElementById('botonTextoSection').style.display = show ? 'block' : 'none';
  updatePreview();
}

// ── POSICIÓN DEL TEXTO ─────────────────────────────────
function setPosicion(pos) {
  document.getElementById('f-posicion').value = pos;
  document.querySelectorAll('.pos-btn').forEach(function(b){ b.classList.toggle('active', b.dataset.pos === pos); });
  var content = document.getElementById('peCanvasContent');
  var map = { izquierda:'flex-start', centro:'center', derecha:'flex-end' };
  content.style.alignItems = map[pos] || 'center';
  content.style.textAlign = pos === 'izquierda' ? 'left' : (pos === 'derecha' ? 'right' : 'center');
}

// ── ANIMACIÓN ───────────────────────────────────────────
function setAnimacion(anim) {
  document.getElementById('f-animacion').value = anim;
  document.querySelectorAll('.anim-btn').forEach(function(b){ b.classList.toggle('active', b.dataset.anim === anim); });
  replayPreviewAnim();
}
function replayPreviewAnim() {
  var anim = document.getElementById('f-animacion').value || 'fade-in';
  var titleEl = document.getElementById('peTitulo');
  HANIM_CLASSES.forEach(function(c){ titleEl.classList.remove(c); });
  titleEl.style.opacity = '0';
  void titleEl.offsetWidth; // forzar reflow para reiniciar la animación
  titleEl.classList.add('hanim-' + anim);
}

// ── DESTINO DEL BOTÓN ──────────────────────────────────
function setDestino(tipo) {
  document.getElementById('f-destino-tipo').value = tipo;
  document.querySelectorAll('#destTabs .ct-tab').forEach(function(b){ b.classList.toggle('active', b.dataset.val === tipo); });
  document.getElementById('destUrlField').style.display = tipo === 'url' ? 'block' : 'none';
  document.getElementById('destProductoField').style.display = tipo === 'producto' ? 'block' : 'none';
  document.getElementById('destCategoriaField').style.display = tipo === 'categoria' ? 'block' : 'none';
  document.getElementById('destPaginaField').style.display = tipo === 'pagina' ? 'block' : 'none';
  recalcDestino();
}
function onDestUrlChange() { recalcDestino(); }
function onDestSelectChange() { recalcDestino(); }
function recalcDestino() {
  var tipo = document.getElementById('f-destino-tipo').value;
  var valor = '', url = '/productos';
  if (tipo === 'url') {
    url = document.getElementById('f-dest-url-inp').value || '/productos';
    valor = '';
  } else if (tipo === 'producto') {
    var sel = document.getElementById('f-dest-producto-inp');
    valor = sel.value;
    url = valor ? '/productos/' + valor : '/productos';
  } else if (tipo === 'categoria') {
    var sel2 = document.getElementById('f-dest-categoria-inp');
    valor = sel2.value;
    url = valor ? '/productos?categoria=' + encodeURIComponent(valor) : '/productos';
  } else if (tipo === 'pagina') {
    var sel3 = document.getElementById('f-dest-pagina-inp');
    valor = sel3.value;
    url = valor || '/';
  }
  document.getElementById('f-destino-valor').value = valor;
  document.getElementById('f-boton-url').value = url;
  document.getElementById('destPreviewLabel').textContent = '→ ' + url;
}

// ── LIVE PREVIEW (sincronizado 1:1 con el render público) ─
function updatePreview() {
  var ct = document.getElementById('f-content-type').value;
  var titulo = document.getElementById('f-titulo').value;
  var subtitulo = document.getElementById('f-subtitulo').value;
  var btnTexto = document.getElementById('f-boton-texto').value || 'EXPLORAR';
  var mostrarBtn = document.getElementById('f-mostrar-boton').value === '1';
  var cdFecha = document.getElementById('f-countdown').value;

  var showText = ct === 'texto' || ct === 'texto_cronometro';
  var showCd = ct === 'cronometro' || ct === 'texto_cronometro';

  var prevTitulo = document.getElementById('peTitulo');
  prevTitulo.textContent = titulo || 'TÍTULO DEL SLIDE';
  prevTitulo.style.display = showText && titulo ? 'block' : 'none';

  var prevSub = document.getElementById('peSubtitulo');
  prevSub.textContent = subtitulo;
  prevSub.style.display = showText && subtitulo ? 'block' : 'none';

  var prevCd = document.getElementById('peCountdown');
  if (showCd) {
    prevCd.style.display = 'block';
    if (cdInterval) clearInterval(cdInterval);
    if (cdFecha) {
      function tick() {
        var diff = Math.max(0, new Date(cdFecha).getTime() - Date.now());
        var d = Math.floor(diff/86400000), h = Math.floor((diff%86400000)/3600000);
        var m = Math.floor((diff%3600000)/60000), s = Math.floor((diff%60000)/1000);
        var p = function(n){ return String(n).padStart(2,'0'); };
        prevCd.textContent = p(d)+'D '+p(h)+'H '+p(m)+'M '+p(s)+'S';
      }
      tick(); cdInterval = setInterval(tick, 1000);
    } else { prevCd.textContent = '00D 00H 00M 00S'; }
  } else {
    prevCd.style.display = 'none';
    if (cdInterval) { clearInterval(cdInterval); cdInterval = null; }
  }

  var prevBtnWrap = document.getElementById('peBtnWrap');
  document.getElementById('peBtnText').textContent = btnTexto;
  prevBtnWrap.style.display = mostrarBtn ? 'block' : 'none';
}

// ── IMAGEN ──────────────────────────────────────────────
function onImageChange(input) {
  if (input.files && input.files[0]) {
    var reader = new FileReader();
    reader.onload = function(e) {
      var img = document.getElementById('peCanvasImg');
      img.src = e.target.result;
      img.style.display = 'block';
      document.getElementById('peCanvasNoImg').style.display = 'none';
    };
    reader.readAsDataURL(input.files[0]);
    document.getElementById('uploadFileName').textContent = input.files[0].name;
    document.getElementById('uploadFileName').style.display = 'block';
  }
}
var uz = document.getElementById('uploadZone');
if (uz) {
  uz.addEventListener('dragover', function(e) { e.preventDefault(); uz.style.borderColor = 'var(--cp)'; });
  uz.addEventListener('dragleave', function() { uz.style.borderColor = 'var(--border)'; });
  uz.addEventListener('drop', function(e) {
    e.preventDefault(); uz.style.borderColor = 'var(--border)';
    if (e.dataTransfer.files[0]) {
      document.getElementById('slideImgInput').files = e.dataTransfer.files;
      onImageChange(document.getElementById('slideImgInput'));
    }
  });
}

// ── TOGGLE SLIDE ─────────────────────────────────────
function toggleSlide(form, id) {
  fetch(form.action, { method: 'POST' })
    .then(function() { location.reload(); })
    .catch(function() { location.reload(); });
}
</script>

<!-- ══════════════════════════════════════════════════════════
     CARRUSEL INFERIOR / DE MARCA (banner secundario, antes del footer)
     Editor con paridad completa al editor principal: vista previa en
     tiempo real, botón+destino, color de acento, edición de imagen.
══════════════════════════════════════════════════════════ -->
<style>
.em-canvas-wrap{flex:1;min-width:0!important;display:flex;align-items:center;justify-content:center;padding:20px;overflow:hidden!important;max-width:100%;background:repeating-conic-gradient(#0d0d0d 0% 25%, #0a0a0a 0% 50%) 50%/20px 20px}
.em-canvas{position:relative;width:100%;max-width:min(1280px,100%);aspect-ratio:1920/600;background:#0a0a0a;overflow:hidden;border-radius:6px;box-shadow:0 16px 40px rgba(0,0,0,.6),0 0 0 1px rgba(0,200,255,.12)}
.em-canvas img.em-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:brightness(.45)}
.em-canvas-noimg{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.12);font-family:var(--fd);font-size:.9rem;letter-spacing:4px}
.em-canvas-content{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:5;padding:0 40px;text-align:center;gap:clamp(6px,1.2vw,14px)}
.em-c-titulo{font-family:'Bebas Neue',sans-serif;font-size:clamp(18px,4.8vw,50px);letter-spacing:6px;color:white;text-shadow:0 2px 20px rgba(0,0,0,.7);margin:0;max-width:80%}
.em-c-subtitulo{font-family:'Rajdhani',sans-serif;font-size:clamp(9px,1.2vw,14px);letter-spacing:2px;color:rgba(255,255,255,.85);margin:0;max-width:65%;text-shadow:0 1px 10px rgba(0,0,0,.8)}
.em-c-btn{display:inline-block;padding:8px 26px;border:2px solid var(--em-color,#e91e8c);color:var(--em-color,#e91e8c);font-family:'Bebas Neue',sans-serif;font-size:clamp(11px,1.6vw,16px);letter-spacing:3px;background:transparent;margin-top:4px}
#editorMarca{position:fixed!important;inset:0!important;width:100vw!important;height:100vh!important;z-index:99999!important;background:#050505;display:none;flex-direction:column}
#editorMarca.open{display:flex!important}
.em-topbar{height:56px;flex-shrink:0;display:flex;align-items:center;justify-content:space-between;padding:0 20px;background:#0a0a0a;border-bottom:1px solid var(--border)}
.em-body{flex:1;display:flex;overflow:hidden;min-height:0}
.em-sidebar{width:360px;flex-shrink:0;background:var(--dark2);border-left:1px solid var(--border);overflow-y:auto;padding:20px}
.em-sec{font-family:var(--fd);font-size:.6rem;color:var(--muted);letter-spacing:2px;margin:16px 0 8px}
.em-sec:first-child{margin-top:0}
.em-upload{border:2px dashed var(--border);border-radius:10px;padding:20px;text-align:center;cursor:pointer;transition:all .3s;background:var(--dark3)}
.em-upload:hover{border-color:#00c8ff;background:rgba(0,200,255,.04)}
@media(max-width:900px){#editorMarca .em-body{flex-direction:column}.em-sidebar{width:100%;border-left:none;border-top:1px solid var(--border);max-height:50vh}}
</style>

<div style="margin-top:48px;border-top:1px solid var(--border);padding-top:32px">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <div style="font-family:var(--fd);font-size:.7rem;color:var(--muted);letter-spacing:3px;text-transform:uppercase">SECUNDARIO</div>
      <div style="font-family:var(--fd);font-size:1rem;font-weight:700;color:var(--text)">Banner Secundario (antes del footer)</div>
      <div style="font-size:.72rem;color:var(--muted);margin-top:3px">Editor con la misma vista previa en tiempo real que el banner principal</div>
    </div>
    <button class="btn btn-om btn-sm" onclick="abrirEditorMarca()">
      <i class="bi bi-plus-lg me-1"></i>Agregar Imagen
    </button>
  </div>

  <% if (typeof carruselMarca !== 'undefined' && carruselMarca && carruselMarca.length > 0) { %>
  <div class="row g-3">
    <% carruselMarca.forEach(function(m, i) { %>
    <div class="col-12 col-md-6 col-xl-4">
      <div class="slide-card">
        <div class="slide-thumb" onclick='abrirEditorMarca(<%- JSON.stringify(m) %>)'>
          <img src="/uploads/banners/<%= m.imagen %>" alt="Marca <%= i+1 %>" onerror="this.parentElement.style.background='var(--dark3)'">
          <span class="slide-order-badge">ORDEN <%= m.orden || i+1 %></span>
          <% if (m.activo) { %><span class="slide-active-badge"><i class="bi bi-circle-fill me-1" style="font-size:.5rem"></i>ACTIVO</span><% } %>
        </div>
        <div class="p-3">
          <% if (m.titulo) { %><div style="font-family:var(--fd);font-size:.78rem;font-weight:700;margin-bottom:4px"><%= m.titulo %></div><% } %>
          <% if (m.subtitulo) { %><div style="font-size:.75rem;color:var(--muted);margin-bottom:8px"><%= m.subtitulo %></div><% } %>
          <div class="d-flex gap-2">
            <button class="btn btn-sm btn-om" style="font-size:.72rem;padding:5px 10px" onclick='abrirEditorMarca(<%- JSON.stringify(m) %>)'>
              <i class="bi bi-pencil-fill"></i> Editar
            </button>
            <form action="/admin/homepage/carrusel-marca/<%= m.id %>/toggle" method="POST" class="d-inline"
                  onsubmit="event.preventDefault();fetch(this.action,{method:'POST'}).then(function(){location.reload()})">
              <button type="submit" class="btn btn-sm" style="border:1px solid <%= m.activo ? 'rgba(255,100,100,.4)' : 'rgba(0,255,100,.4)' %>;color:<%= m.activo ? '#ff6464' : '#00ff64' %>;background:transparent;font-size:.72rem;padding:5px 10px">
                <i class="bi bi-<%= m.activo ? 'eye-slash' : 'eye' %>-fill"></i>
              </button>
            </form>
            <form action="/admin/homepage/carrusel-marca/<%= m.id %>/eliminar" method="POST" class="d-inline"
                  onsubmit="return confirm('Eliminar esta imagen?')">
              <button type="submit" class="btn btn-sm" style="border:1px solid rgba(255,60,60,.3);color:#ff6060;background:transparent;font-size:.72rem;padding:5px 10px">
                <i class="bi bi-trash-fill"></i>
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } else { %>
  <div class="text-center py-4" style="border:1px dashed var(--border);border-radius:8px">
    <i class="bi bi-images" style="color:var(--muted);font-size:2rem"></i>
    <div style="font-family:var(--fd);font-size:.65rem;color:var(--muted);letter-spacing:2px;margin-top:8px">SIN IMÁGENES DE MARCA AÚN</div>
    <button class="btn btn-om btn-sm mt-3" onclick="abrirEditorMarca()">
      <i class="bi bi-plus me-1"></i>Agregar primera imagen
    </button>
  </div>
  <% } %>
</div>

<!-- EDITOR FULLSCREEN DE BANNER SECUNDARIO -->
<div id="editorMarca">
  <div class="em-topbar">
    <div style="font-family:var(--fd);font-size:.75rem;letter-spacing:2px;color:#00c8ff;display:flex;align-items:center;gap:8px">
      <i class="bi bi-images"></i><span id="emTitle">NUEVA IMAGEN DE MARCA</span>
    </div>
    <div style="display:flex;gap:8px">
      <button class="btn btn-pm" style="padding:8px 20px;font-size:.82rem;letter-spacing:2px;min-width:140px" onclick="document.getElementById('emForm').requestSubmit()">
        <i class="bi bi-floppy-fill me-2"></i>GUARDAR CAMBIOS
      </button>
      <button onclick="cerrarEditorMarca()" style="background:rgba(0,200,255,.08);border:1px solid rgba(0,200,255,.25);color:#00c8ff;width:34px;height:34px;border-radius:8px;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center">
        <i class="bi bi-x-lg"></i>
      </button>
    </div>
  </div>
  <div class="em-body">
    <div class="em-canvas-wrap">
      <div class="em-canvas" id="emCanvas">
        <img id="emBgImg" class="em-bg" src="" style="display:none">
        <div id="emNoImg" class="em-canvas-noimg">SUBE UNA IMAGEN DE FONDO</div>
        <div style="position:absolute;inset:0;background:linear-gradient(to bottom,rgba(0,0,0,.1),rgba(0,0,0,.5))"></div>
        <div class="em-canvas-content">
          <h1 class="em-c-titulo" id="emPrevTitulo" style="display:none"></h1>
          <p class="em-c-subtitulo" id="emPrevSub" style="display:none"></p>
          <span class="em-c-btn" id="emPrevBtn" style="display:none"></span>
        </div>
      </div>
    </div>
    <div class="em-sidebar">
      <form id="emForm" method="POST" enctype="multipart/form-data">
        <div class="em-sec">◈ Imagen de fondo</div>
        <div class="em-upload" onclick="document.getElementById('emImgInput').click()">
          <i class="bi bi-cloud-arrow-up" style="font-size:1.6rem;color:#00c8ff"></i>
          <div style="font-family:var(--fd);font-size:.6rem;color:var(--muted);letter-spacing:2px;margin-top:6px">CLIC O ARRASTRA</div>
          <div style="font-size:.6rem;color:var(--muted);margin-top:3px">PNG, JPG, WebP · Rec. 1920×600px</div>
        </div>
        <input type="file" id="emImgInput" name="imagen" accept="image/*" style="display:none" onchange="onEmImagen(this)">

        <div class="em-sec">◈ Texto del banner (opcional)</div>
        <div class="mb-2">
          <label class="form-label" style="font-size:.72rem">Título</label>
          <input type="text" name="titulo" id="emTitulo" class="form-control form-control-sm" placeholder="OFERTA ESPECIAL" oninput="emUpdatePreview()">
        </div>
        <div class="mb-3">
          <label class="form-label" style="font-size:.72rem">Subtítulo</label>
          <input type="text" name="subtitulo" id="emSub" class="form-control form-control-sm" placeholder="Hasta 50% de descuento" oninput="emUpdatePreview()">
        </div>

        <div class="em-sec">◈ Botón (opcional)</div>
        <div class="mb-2">
          <label class="form-label" style="font-size:.72rem">Texto del botón</label>
          <input type="text" name="boton_texto" id="emBotonTexto" class="form-control form-control-sm" placeholder="VER OFERTAS" oninput="emUpdatePreview()">
        </div>
        <div class="mb-2">
          <label class="form-label" style="font-size:.72rem">Enlace del botón</label>
          <input type="text" name="boton_url" id="emBotonUrl" class="form-control form-control-sm" placeholder="/productos" value="/productos">
        </div>
        <div class="mb-3">
          <label class="form-label" style="font-size:.72rem">Color de acento</label>
          <input type="color" name="color_acento" id="emColor" class="form-control form-control-sm" value="#e91e8c" style="height:36px;padding:3px" oninput="emUpdatePreview()">
        </div>

        <div class="em-sec">◈ Visibilidad</div>
        <div class="form-check">
          <input type="checkbox" name="activo" id="emActivo" class="form-check-input" value="1" checked>
          <label class="form-check-label" style="font-size:.75rem" for="emActivo">Visible en el sitio</label>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
var emCurrentId = null;

function abrirEditorMarca(data) {
  emCurrentId = data ? data.id : null;
  document.getElementById('emTitle').textContent = data ? 'EDITANDO BANNER SECUNDARIO' : 'NUEVA IMAGEN DE MARCA';
  var form = document.getElementById('emForm');
  form.reset();
  document.getElementById('emBgImg').style.display = 'none';
  document.getElementById('emNoImg').style.display = 'flex';

  if (data) {
    form.action = '/admin/homepage/carrusel-marca/' + data.id + '/editar';
    document.getElementById('emImgInput').required = false;
    if (data.imagen) {
      var bg = document.getElementById('emBgImg');
      bg.src = '/uploads/banners/' + data.imagen;
      bg.style.display = 'block';
      document.getElementById('emNoImg').style.display = 'none';
    }
    document.getElementById('emTitulo').value = data.titulo || '';
    document.getElementById('emSub').value = data.subtitulo || '';
    document.getElementById('emBotonTexto').value = data.boton_texto || '';
    document.getElementById('emBotonUrl').value = data.boton_url || '/productos';
    document.getElementById('emColor').value = data.color_acento || '#e91e8c';
    document.getElementById('emActivo').checked = !!data.activo;
  } else {
    form.action = '/admin/homepage/carrusel-marca/nuevo';
    document.getElementById('emImgInput').required = true;
    document.getElementById('emBotonUrl').value = '/productos';
    document.getElementById('emColor').value = '#e91e8c';
  }

  emUpdatePreview();
  document.getElementById('editorMarca').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function cerrarEditorMarca() {
  document.getElementById('editorMarca').classList.remove('open');
  document.body.style.overflow = '';
  emCurrentId = null;
}

function onEmImagen(input) {
  if (!input.files || !input.files[0]) return;
  var reader = new FileReader();
  reader.onload = function(e) {
    var bg = document.getElementById('emBgImg');
    bg.src = e.target.result;
    bg.style.display = 'block';
    document.getElementById('emNoImg').style.display = 'none';
  };
  reader.readAsDataURL(input.files[0]);
}

function emUpdatePreview() {
  var titulo = document.getElementById('emTitulo').value;
  var sub = document.getElementById('emSub').value;
  var botonTexto = document.getElementById('emBotonTexto').value;
  var color = document.getElementById('emColor').value;

  var tEl = document.getElementById('emPrevTitulo');
  var sEl = document.getElementById('emPrevSub');
  var bEl = document.getElementById('emPrevBtn');

  tEl.textContent = titulo || ''; tEl.style.display = titulo ? 'block' : 'none';
  sEl.textContent = sub || ''; sEl.style.display = sub ? 'block' : 'none';
  bEl.textContent = botonTexto || ''; bEl.style.display = botonTexto ? 'inline-block' : 'none';
  document.getElementById('emCanvas').style.setProperty('--em-color', color);
}

var emUpload = document.querySelector('#editorMarca .em-upload');
if (emUpload) {
  emUpload.addEventListener('dragover', function(e) { e.preventDefault(); emUpload.style.borderColor = '#00c8ff'; });
  emUpload.addEventListener('dragleave', function() { emUpload.style.borderColor = 'var(--border)'; });
  emUpload.addEventListener('drop', function(e) {
    e.preventDefault(); emUpload.style.borderColor = 'var(--border)';
    if (e.dataTransfer.files[0]) {
      document.getElementById('emImgInput').files = e.dataTransfer.files;
      onEmImagen(document.getElementById('emImgInput'));
    }
  });
}

document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape' && document.getElementById('editorMarca').classList.contains('open')) {
    cerrarEditorMarca();
  }
});
</script>

