<%- include('../partials/header', {isAdmin: true}) %>

<style>
.slide-card { background:var(--card); border:1px solid var(--border); border-radius:12px; overflow:hidden; transition:all .3s; }
.slide-card:hover { border-color:var(--cp); box-shadow:0 8px 24px rgba(233,30,140,.15); }
.slide-card.editing { border-color:var(--cp); box-shadow:0 0 0 2px var(--cp); }
.slide-thumb { height:140px; overflow:hidden; position:relative; background:var(--dark2); cursor:pointer; }
.slide-thumb img { width:100%;height:100%;object-fit:cover;transition:transform .4s; }
.slide-card:hover .slide-thumb img { transform:scale(1.04); }
.upload-zone { border:2px dashed var(--border); border-radius:10px; padding:32px; text-align:center; cursor:pointer; transition:all .3s; background:var(--dark2); }
.upload-zone:hover { border-color:var(--cp); background:rgba(233,30,140,.05); }
.live-preview { position:relative; background:#0a0a0a; height:220px; overflow:hidden; border-radius:8px; border:1px solid var(--border); display:flex; align-items:center; justify-content:center; }
.live-preview-img { position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.55; }
.live-preview-overlay { position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;text-align:center;gap:8px;padding:16px; }
.countdown-display { font-family:'Bebas Neue',sans-serif; font-size:22px; letter-spacing:6px; color:white; }
.ct-tab { padding:6px 14px; border:1px solid var(--border); background:none; color:var(--muted); font-family:var(--fd); font-size:.65rem; letter-spacing:1px; cursor:pointer; border-radius:4px; transition:all .2s; }
.ct-tab.active { background:var(--cp); border-color:var(--cp); color:white; }
</style>

<div class="d-flex align-items-center justify-content-between mb-4">
  <div>
    <div style="font-family:var(--fd);font-size:.7rem;color:var(--muted);letter-spacing:3px;text-transform:uppercase">GESTIÓN</div>
    <div style="font-family:var(--fd);font-size:1.2rem;font-weight:800;color:var(--text)">Carrusel y Banners</div>
  </div>
  <button class="btn btn-pm" onclick="abrirNuevo()">
    <i class="bi bi-plus-lg me-2"></i>NUEVO SLIDE
  </button>
</div>

<!-- Grid de slides existentes -->
<% if (slides && slides.length > 0) { %>
<div class="row g-3 mb-4" id="slidesGrid">
  <% slides.forEach(function(s, i) { %>
  <div class="col-12 col-md-6 col-xl-4" id="slide-<%= s.id %>">
    <div class="slide-card" id="card-<%= s.id %>">
      <div class="slide-thumb" onclick="abrirEditar(<%= s.id %>)">
        <img src="/uploads/banners/<%= s.imagen %>" alt="Slide <%= i+1 %>" onerror="this.parentElement.style.background='var(--dark3)'">
        <div style="position:absolute;top:8px;left:8px;background:rgba(0,0,0,.7);border:1px solid var(--cp);color:var(--cp);font-family:var(--fd);font-size:.6rem;padding:2px 8px;border-radius:4px">
          #<%= s.orden || i+1 %>
        </div>
        <% if (s.activo) { %>
        <div style="position:absolute;top:8px;right:8px;background:rgba(0,255,100,.15);border:1px solid rgba(0,255,100,.3);color:#00ff64;font-family:var(--fd);font-size:.58rem;padding:2px 8px;border-radius:4px">ACTIVO</div>
        <% } else { %>
        <div style="position:absolute;top:8px;right:8px;background:rgba(255,100,100,.1);border:1px solid rgba(255,100,100,.3);color:#ff6060;font-family:var(--fd);font-size:.58rem;padding:2px 8px;border-radius:4px">OCULTO</div>
        <% } %>
        <!-- Content type badge -->
        <div style="position:absolute;bottom:8px;left:8px;background:rgba(233,30,140,.85);color:white;font-family:var(--fd);font-size:.55rem;padding:2px 8px;border-radius:4px;letter-spacing:1px">
          <%= (s.content_type||'texto').toUpperCase().replace('_',' ') %>
          <% if (s.mostrar_boton) { %> + BTN<% } %>
        </div>
        <div style="position:absolute;inset:0;background:rgba(0,0,0,0);transition:background .2s;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .2s" onmouseover="this.style.opacity='1';this.style.background='rgba(0,0,0,.4)'" onmouseout="this.style.opacity='0'">
          <div style="font-family:var(--fd);font-size:.65rem;letter-spacing:2px;color:white;border:1px solid white;padding:6px 14px">EDITAR</div>
        </div>
      </div>
      <div class="p-3">
        <div style="font-weight:700;font-size:.85rem;margin-bottom:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= s.titulo || '(sin título)' %></div>
        <% if (s.subtitulo) { %><div style="font-size:.75rem;color:var(--muted);margin-bottom:8px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= s.subtitulo %></div><% } %>
        <div class="d-flex gap-2">
          <button class="btn btn-sm btn-om" style="flex:1" onclick="abrirEditar(<%= s.id %>)">
            <i class="bi bi-pencil-fill me-1"></i>Editar
          </button>
          <form action="/admin/carrusel/<%= s.id %>/toggle" method="POST" style="flex:0"
                onsubmit="event.preventDefault();toggleSlide(this,<%= s.id %>)">
            <button type="submit" class="btn btn-sm" style="border:1px solid <%= s.activo ? 'rgba(255,100,100,.4)' : 'rgba(0,255,100,.4)' %>;color:<%= s.activo ? '#ff6464' : '#00ff64' %>;background:transparent;font-size:.72rem;padding:5px 10px">
              <i class="bi bi-<%= s.activo ? 'eye-slash' : 'eye' %>-fill"></i>
            </button>
          </form>
          <form action="/admin/carrusel/<%= s.id %>/eliminar" method="POST" style="flex:0"
                onsubmit="return confirm('Eliminar este slide?')">
            <button type="submit" class="btn btn-sm" style="border:1px solid rgba(255,60,60,.3);color:#ff6060;background:transparent;font-size:.72rem;padding:5px 10px">
              <i class="bi bi-trash-fill"></i>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
  <% }) %>
</div>
<% } else { %>
<div class="text-center py-5" style="border:2px dashed var(--border);border-radius:12px">
  <i class="bi bi-images" style="font-size:3rem;color:var(--muted)"></i>
  <div style="font-family:var(--fd);font-size:.75rem;color:var(--muted);letter-spacing:2px;margin-top:12px">SIN SLIDES AÚN</div>
  <button class="btn btn-pm mt-3" onclick="abrirNuevo()"><i class="bi bi-plus-lg me-2"></i>Añadir primero</button>
</div>
<% } %>

<!-- PANEL LATERAL DE EDICION -->
<div id="editorPanel" style="position:fixed;top:0;right:0;bottom:0;width:500px;background:var(--dark2);border-left:1px solid var(--border);z-index:1050;transform:translateX(100%);transition:transform .35s cubic-bezier(.4,0,.2,1);overflow-y:auto;box-shadow:-8px 0 40px rgba(0,0,0,.5)">
  <div style="padding:20px 24px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;background:var(--dark2);z-index:10">
    <div id="panelTitle" style="font-family:var(--fd);font-size:.8rem;letter-spacing:2px;color:var(--cp)">NUEVO SLIDE</div>
    <button onclick="cerrarPanel()" style="background:none;border:none;color:var(--muted);font-size:20px;cursor:pointer;line-height:1" onmouseover="this.style.color='var(--cp)'" onmouseout="this.style.color='var(--muted)'">&#x2715;</button>
  </div>

  <div style="padding:24px">
    <!-- LIVE PREVIEW -->
    <div style="margin-bottom:20px">
      <div style="font-family:var(--fd);font-size:.6rem;color:var(--muted);letter-spacing:2px;margin-bottom:8px">VISTA PREVIA EN TIEMPO REAL</div>
      <div class="live-preview" id="livePreview">
        <img id="previewBg" class="live-preview-img" src="" style="display:none">
        <div id="previewNoBg" style="position:absolute;inset:0;background:linear-gradient(135deg,#0a0a0a,#1a0816);opacity:0.8"></div>
        <div class="live-preview-overlay" id="previewContent">
          <div id="prev-titulo" style="font-family:'Permanent Marker',cursive;font-size:22px;letter-spacing:4px;color:white;display:none"></div>
          <div id="prev-subtitulo" style="font-family:'Rajdhani',sans-serif;font-size:12px;color:rgba(255,255,255,0.7);letter-spacing:1px;display:none"></div>
          <div id="prev-countdown" style="display:none;font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:5px;color:white">00D 00H 00M 00S</div>
          <div id="prev-btn" style="display:none;margin-top:4px">
            <div id="prev-btn-text" style="background:transparent;border:2px solid var(--cp);color:var(--cp);padding:6px 18px;font-family:'Bebas Neue',sans-serif;font-size:12px;letter-spacing:3px;display:inline-block">EXPLORAR</div>
          </div>
        </div>
      </div>
    </div>

    <form id="slideForm" method="POST" enctype="multipart/form-data">
      <!-- IMAGEN -->
      <div class="mb-3">
        <label class="form-label">Imagen del slide <span id="img-required-mark">*</span></label>
        <div class="upload-zone" id="uploadZone" onclick="document.getElementById('slideImgInput').click()">
          <i class="bi bi-cloud-arrow-up" style="font-size:1.8rem;color:var(--cp)"></i>
          <div style="font-family:var(--fd);font-size:.65rem;color:var(--muted);letter-spacing:2px;margin-top:6px">CLIC O ARRASTRA</div>
          <div style="font-size:.62rem;color:var(--muted);margin-top:3px">PNG, JPG, WebP · Máx 5MB · Rec. 1920×600px</div>
          <div id="uploadFileName" style="font-size:.7rem;color:var(--cp);margin-top:6px;display:none"></div>
        </div>
        <input type="file" id="slideImgInput" name="imagen" accept="image/*" style="display:none" onchange="onImageChange(this)">
      </div>

      <!-- TITULO + SUBTITULO -->
      <div class="mb-3">
        <label class="form-label">Título</label>
        <input type="text" name="titulo" id="f-titulo" class="form-control" placeholder="NUEVA COLECCIÓN" oninput="updatePreview()">
      </div>
      <div class="mb-3">
        <label class="form-label">Subtítulo</label>
        <input type="text" name="subtitulo" id="f-subtitulo" class="form-control" placeholder="Descubre los últimos lanzamientos" oninput="updatePreview()">
      </div>

      <!-- CONTENT TYPE -->
      <div class="mb-3">
        <label class="form-label">Contenido central del slide</label>
        <div class="d-flex gap-2 flex-wrap mb-2" id="ctTabs">
          <button type="button" class="ct-tab active" data-val="texto" onclick="setContentType('texto')">Solo texto</button>
          <button type="button" class="ct-tab" data-val="cronometro" onclick="setContentType('cronometro')">Solo cronómetro</button>
          <button type="button" class="ct-tab" data-val="texto_cronometro" onclick="setContentType('texto_cronometro')">Texto + cronómetro</button>
          <button type="button" class="ct-tab" data-val="nada" onclick="setContentType('nada')">Sin contenido</button>
        </div>
        <input type="hidden" name="content_type" id="f-content-type" value="texto">
      </div>

      <!-- COUNTDOWN DATE (shown when cronometro) -->
      <div class="mb-3" id="countdownSection" style="display:none">
        <label class="form-label">Fecha objetivo del cronómetro</label>
        <input type="datetime-local" name="countdown_fecha" id="f-countdown" class="form-control" oninput="updatePreview()">
        <div class="form-text">El cronómetro cuenta regresiva hasta esta fecha</div>
      </div>

      <!-- BOTON -->
      <div class="mb-3">
        <label class="form-label">Botón de acción</label>
        <div class="d-flex gap-2 mb-2">
          <button type="button" class="ct-tab active" id="btnTabShow" onclick="setBoton(true)">Mostrar botón</button>
          <button type="button" class="ct-tab" id="btnTabHide" onclick="setBoton(false)">Sin botón</button>
        </div>
        <input type="hidden" name="mostrar_boton" id="f-mostrar-boton" value="1">
      </div>
      <div class="mb-3" id="botonTextoSection">
        <label class="form-label">Texto del botón</label>
        <div class="d-flex gap-2">
          <input type="text" name="boton_texto" id="f-boton-texto" class="form-control" placeholder="EXPLORAR" value="EXPLORAR" oninput="updatePreview()">
          <input type="text" name="boton_url" id="f-boton-url" class="form-control" placeholder="/productos" style="max-width:140px">
        </div>
      </div>

      <!-- ORDEN + ACTIVO -->
      <div class="row g-3 mb-4">
        <div class="col-6">
          <label class="form-label">Orden</label>
          <input type="number" name="orden" id="f-orden" class="form-control" value="<%= (slides ? slides.length : 0) + 1 %>" min="1">
        </div>
        <div class="col-6 d-flex align-items-end">
          <div class="form-check">
            <input type="checkbox" name="activo" id="f-activo" class="form-check-input" value="1" checked>
            <label class="form-check-label" for="f-activo">Visible en el sitio</label>
          </div>
        </div>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-pm" style="flex:1">
          <i class="bi bi-check-lg me-2"></i><span id="submitBtnText">SUBIR SLIDE</span>
        </button>
        <button type="button" class="btn btn-om" onclick="cerrarPanel()">CANCELAR</button>
      </div>
    </form>
  </div>
</div>
<div id="panelOverlay" style="position:fixed;inset:0;background:rgba(0,0,0,0);pointer-events:none;z-index:1040;transition:background .35s" onclick="cerrarPanel()"></div>

<script>
var panelOpen = false;
var cdInterval = null;
var currentSlides = <%- JSON.stringify(slides || []) %>;

// ── PANEL OPEN/CLOSE ──────────────────────────────────
function abrirNuevo() {
  document.getElementById('panelTitle').textContent = 'NUEVO SLIDE';
  document.getElementById('submitBtnText').textContent = 'SUBIR SLIDE';
  document.getElementById('slideForm').action = '/admin/carrusel/nuevo';
  document.getElementById('slideForm').reset();
  document.getElementById('slideImgInput').required = true;
  var mark = document.getElementById('img-required-mark'); if(mark) mark.style.display='inline';
  document.getElementById('f-titulo').value = '';
  document.getElementById('f-subtitulo').value = '';
  document.getElementById('f-orden').value = (currentSlides.length || 0) + 1;
  document.getElementById('f-activo').checked = true;
  document.getElementById('previewBg').style.display = 'none';
  document.getElementById('previewNoBg').style.display = 'block';
  setContentType('texto');
  setBoton(true);
  document.getElementById('f-boton-texto').value = 'EXPLORAR';
  updatePreview();
  abrirPanel();
}

function abrirEditar(id) {
  var s = currentSlides.find(function(sl){ return sl.id == id; });
  if (!s) return;
  document.getElementById('panelTitle').textContent = 'EDITAR SLIDE';
  document.getElementById('submitBtnText').textContent = 'GUARDAR CAMBIOS';
  document.getElementById('slideForm').action = '/admin/carrusel/' + id + '/editar';
  document.getElementById('slideForm').reset();
  document.getElementById('f-titulo').value = s.titulo || '';
  document.getElementById('f-subtitulo').value = s.subtitulo || '';
  document.getElementById('f-orden').value = s.orden || 1;
  document.getElementById('f-activo').checked = !!s.activo;
  document.getElementById('f-boton-texto').value = s.boton_texto || 'EXPLORAR';
  if (s.countdown_fecha) document.getElementById('f-countdown').value = s.countdown_fecha.substring(0,16);
  // Set preview bg
  var bg = document.getElementById('previewBg');
  bg.src = '/uploads/banners/' + s.imagen;
  bg.style.display = 'block';
  document.getElementById('previewNoBg').style.display = 'none';
  setContentType(s.content_type || 'texto');
  setBoton(s.mostrar_boton !== 0 && s.mostrar_boton !== '0');
  document.getElementById('slideImgInput').required = false;
  var mark = document.getElementById('img-required-mark'); if(mark) mark.style.display='none';
  updatePreview();
  abrirPanel();
}

function abrirPanel() {
  document.getElementById('editorPanel').style.transform = 'translateX(0)';
  document.getElementById('panelOverlay').style.background = 'rgba(0,0,0,0.5)';
  document.getElementById('panelOverlay').style.pointerEvents = 'all';
  panelOpen = true;
}

function cerrarPanel() {
  document.getElementById('editorPanel').style.transform = 'translateX(100%)';
  document.getElementById('panelOverlay').style.background = 'rgba(0,0,0,0)';
  document.getElementById('panelOverlay').style.pointerEvents = 'none';
  panelOpen = false;
}

// ── CONTENT TYPE ──────────────────────────────────────
function setContentType(val) {
  document.getElementById('f-content-type').value = val;
  document.querySelectorAll('#ctTabs .ct-tab').forEach(function(btn) {
    btn.classList.toggle('active', btn.dataset.val === val);
  });
  document.getElementById('countdownSection').style.display = (val === 'cronometro' || val === 'texto_cronometro') ? 'block' : 'none';
  updatePreview();
}

function setBoton(show) {
  document.getElementById('f-mostrar-boton').value = show ? '1' : '0';
  document.getElementById('btnTabShow').classList.toggle('active', show);
  document.getElementById('btnTabHide').classList.toggle('active', !show);
  document.getElementById('botonTextoSection').style.display = show ? 'block' : 'none';
  updatePreview();
}

// ── LIVE PREVIEW ──────────────────────────────────────
function updatePreview() {
  var ct = document.getElementById('f-content-type').value;
  var titulo = document.getElementById('f-titulo').value;
  var subtitulo = document.getElementById('f-subtitulo').value;
  var btnTexto = document.getElementById('f-boton-texto').value || 'EXPLORAR';
  var mostrarBtn = document.getElementById('f-mostrar-boton').value === '1';
  var cdFecha = document.getElementById('f-countdown').value;

  // Title
  var prevTitulo = document.getElementById('prev-titulo');
  prevTitulo.textContent = titulo || 'TITULO DEL SLIDE';
  prevTitulo.style.display = (ct === 'texto' || ct === 'texto_cronometro') && titulo ? 'block' : 'none';

  // Subtitle
  var prevSub = document.getElementById('prev-subtitulo');
  prevSub.textContent = subtitulo;
  prevSub.style.display = (ct === 'texto' || ct === 'texto_cronometro') && subtitulo ? 'block' : 'none';

  // Countdown
  var prevCd = document.getElementById('prev-countdown');
  if (ct === 'cronometro' || ct === 'texto_cronometro') {
    prevCd.style.display = 'block';
    if (cdInterval) clearInterval(cdInterval);
    if (cdFecha) {
      function tick() {
        var diff = Math.max(0, new Date(cdFecha).getTime() - Date.now());
        var d = Math.floor(diff/86400000), h = Math.floor((diff%86400000)/3600000);
        var m = Math.floor((diff%3600000)/60000), s = Math.floor((diff%60000)/1000);
        var p = function(n){ return String(n).padStart(2,'0'); };
        prevCd.textContent = p(d)+'D '+p(h)+'H '+p(m)+'M '+p(s)+'S';
      }
      tick(); cdInterval = setInterval(tick, 1000);
    } else { prevCd.textContent = '00D 00H 00M 00S'; }
  } else {
    prevCd.style.display = 'none';
    if (cdInterval) { clearInterval(cdInterval); cdInterval = null; }
  }

  // Button
  var prevBtn = document.getElementById('prev-btn');
  document.getElementById('prev-btn-text').textContent = btnTexto;
  prevBtn.style.display = mostrarBtn ? 'block' : 'none';
}

// ── IMAGE CHANGE ──────────────────────────────────────
function onImageChange(input) {
  if (input.files && input.files[0]) {
    var reader = new FileReader();
    reader.onload = function(e) {
      var bg = document.getElementById('previewBg');
      bg.src = e.target.result;
      bg.style.display = 'block';
      document.getElementById('previewNoBg').style.display = 'none';
    };
    reader.readAsDataURL(input.files[0]);
    document.getElementById('uploadFileName').textContent = input.files[0].name;
    document.getElementById('uploadFileName').style.display = 'block';
  }
}

// Drag & drop
var uz = document.getElementById('uploadZone');
if (uz) {
  uz.addEventListener('dragover', function(e) { e.preventDefault(); uz.style.borderColor = 'var(--cp)'; });
  uz.addEventListener('dragleave', function() { uz.style.borderColor = 'var(--border)'; });
  uz.addEventListener('drop', function(e) {
    e.preventDefault(); uz.style.borderColor = 'var(--border)';
    if (e.dataTransfer.files[0]) {
      document.getElementById('slideImgInput').files = e.dataTransfer.files;
      onImageChange(document.getElementById('slideImgInput'));
    }
  });
}

// ── TOGGLE SLIDE ─────────────────────────────────────
function toggleSlide(form, id) {
  fetch(form.action, { method: 'POST' })
    .then(function() { location.reload(); })
    .catch(function() { location.reload(); });
}
</script>


<!-- ══════════════════════════════════════════════════════════
     CARRUSEL INFERIOR / DE MARCA (imagenes separadas)
══════════════════════════════════════════════════════════ -->
<div style="margin-top:48px;border-top:1px solid var(--border);padding-top:32px">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <div style="font-family:var(--fd);font-size:.7rem;color:var(--muted);letter-spacing:3px;text-transform:uppercase">SECUNDARIO</div>
      <div style="font-family:var(--fd);font-size:1rem;font-weight:700;color:var(--text)">Carrusel Inferior de Marca</div>
      <div style="font-size:.72rem;color:var(--muted);margin-top:3px">Sección al final de la página de inicio · Imágenes independientes del hero</div>
    </div>
    <button class="btn btn-om btn-sm" onclick="document.getElementById('marcaModal').style.display='flex'">
      <i class="bi bi-plus-lg me-1"></i>Agregar Imagen
    </button>
  </div>

  <% if (typeof carruselMarca !== 'undefined' && carruselMarca && carruselMarca.length > 0) { %>
  <div class="row g-3">
    <% carruselMarca.forEach(function(m, i) { %>
    <div class="col-12 col-md-6 col-xl-4">
      <div class="slide-card">
        <div class="slide-thumb">
          <img src="/uploads/banners/<%= m.imagen %>" alt="Marca <%= i+1 %>" onerror="this.parentElement.style.background='var(--dark3)'">
          <span class="slide-order-badge">ORDEN <%= m.orden || i+1 %></span>
          <% if (m.activo) { %><span class="slide-active-badge"><i class="bi bi-circle-fill me-1" style="font-size:.5rem"></i>ACTIVO</span><% } %>
        </div>
        <div class="p-3">
          <% if (m.titulo) { %><div style="font-family:var(--fd);font-size:.78rem;font-weight:700;margin-bottom:4px"><%= m.titulo %></div><% } %>
          <% if (m.subtitulo) { %><div style="font-size:.75rem;color:var(--muted);margin-bottom:8px"><%= m.subtitulo %></div><% } %>
          <div class="d-flex gap-2">
            <form action="/admin/homepage/carrusel-marca/<%= m.id %>/toggle" method="POST" class="d-inline"
                  onsubmit="event.preventDefault();fetch(this.action,{method:'POST'}).then(function(){location.reload()})">
              <button type="submit" class="btn btn-sm" style="border:1px solid <%= m.activo ? 'rgba(255,100,100,.4)' : 'rgba(0,255,100,.4)' %>;color:<%= m.activo ? '#ff6464' : '#00ff64' %>;background:transparent;font-size:.72rem;padding:5px 10px">
                <i class="bi bi-<%= m.activo ? 'eye-slash' : 'eye' %>-fill"></i>
              </button>
            </form>
            <form action="/admin/homepage/carrusel-marca/<%= m.id %>/eliminar" method="POST" class="d-inline"
                  onsubmit="return confirm('Eliminar esta imagen?')">
              <button type="submit" class="btn btn-sm" style="border:1px solid rgba(255,60,60,.3);color:#ff6060;background:transparent;font-size:.72rem;padding:5px 10px">
                <i class="bi bi-trash-fill"></i>
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } else { %>
  <div class="text-center py-4" style="border:1px dashed var(--border);border-radius:8px">
    <i class="bi bi-images" style="color:var(--muted);font-size:2rem"></i>
    <div style="font-family:var(--fd);font-size:.65rem;color:var(--muted);letter-spacing:2px;margin-top:8px">SIN IMÁGENES DE MARCA AÚN</div>
    <button class="btn btn-om btn-sm mt-3" onclick="document.getElementById('marcaModal').style.display='flex'">
      <i class="bi bi-plus me-1"></i>Agregar primera imagen
    </button>
  </div>
  <% } %>
</div>

<!-- MODAL: Nueva imagen de marca -->
<div id="marcaModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:2000;align-items:center;justify-content:center" onclick="if(event.target===this)this.style.display='none'">
  <div style="background:var(--dark2);border:1px solid var(--border);width:90%;max-width:480px;max-height:90vh;overflow-y:auto">
    <div style="padding:16px 20px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center">
      <div style="font-family:var(--fd);font-size:.75rem;letter-spacing:2px;color:var(--cp)">NUEVA IMAGEN DE MARCA</div>
      <button onclick="document.getElementById('marcaModal').style.display='none'" style="background:none;border:none;color:var(--muted);font-size:18px;cursor:pointer">&#x2715;</button>
    </div>
    <form action="/admin/homepage/carrusel-marca/nuevo" method="POST" enctype="multipart/form-data" style="padding:20px">
      <div class="mb-3">
        <label class="form-label">Imagen <span style="color:var(--cp)">*</span></label>
        <input type="file" name="imagen" accept="image/*" class="form-control" required>
        <div class="form-text">1920×600px recomendado. Máx 20MB.</div>
      </div>
      <div class="mb-3">
        <label class="form-label">Título (opcional)</label>
        <input type="text" name="titulo" class="form-control" placeholder="NUEVA COLECCIÓN">
      </div>
      <div class="mb-3">
        <label class="form-label">Subtítulo (opcional)</label>
        <input type="text" name="subtitulo" class="form-control" placeholder="Temporada 2025">
      </div>
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-pm" style="flex:1"><i class="bi bi-cloud-upload me-1"></i>SUBIR</button>
        <button type="button" class="btn btn-om" onclick="document.getElementById('marcaModal').style.display='none'">CANCELAR</button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer', {isAdmin: true}) %>
