<%- include('../partials/header') %>

<div style="padding:40px;max-width:1200px;margin:0 auto">
  <h2 class="section-title">MI CARRITO</h2>
  <div class="tribal-divider"><svg width="200" height="20" viewBox="0 0 200 20" fill="none"><line x1="0" y1="10" x2="80" y2="10" stroke="rgba(233,30,140,0.4)" stroke-width="1"/><circle cx="100" cy="10" r="5" fill="var(--pink)"/><line x1="120" y1="10" x2="200" y2="10" stroke="rgba(233,30,140,0.4)" stroke-width="1"/></svg></div>

  <% if(items&&items.length>0){%>
  <div style="display:grid;grid-template-columns:1fr 360px;gap:32px" class="cart-layout">
    <!-- Items -->
    <div id="cartItems">
      <% items.forEach(item=>{%>
      <div style="display:flex;gap:20px;padding:20px;background:rgba(255,255,255,0.03);border:1px solid var(--border);margin-bottom:12px;position:relative" id="cart-item-<%=item.id%>">
        <div style="position:absolute;inset:0;border:2px solid rgba(255,255,255,0.2);filter:url(#gb);pointer-events:none"></div>
        <img src="<%= item.imagen_principal %>" alt="<%=item.titulo%>" style="width:100px;height:130px;object-fit:cover;flex-shrink:0;filter:url(#gb)" onerror="this.src='https://via.placeholder.com/100x130/111/888?text=?'">
        <div style="flex:1;min-width:0">
          <div style="font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:2px;color:var(--white);margin-bottom:4px"><%=item.titulo%></div>
          <% if(item.talla){%><div style="font-size:12px;color:var(--pink);letter-spacing:2px;margin-bottom:8px">TALLA: <%=item.talla%></div><%}%>
          <div style="font-family:'Bebas Neue',sans-serif;font-size:22px;color:var(--pink);letter-spacing:1px;margin-bottom:12px">$<%=parseFloat(item.precio_final).toLocaleString('es-CO')%></div>
          <div style="display:flex;align-items:center;gap:12px">
            <div style="display:flex;align-items:center;gap:8px">
              <button onclick="cambiarCantidad(<%=item.id%>, -1)"
                style="width:28px;height:28px;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.2);color:var(--white);cursor:pointer;transition:all 0.15s;font-size:16px"
                onmouseover="this.style.background='var(--pink)'" onmouseout="this.style.background='rgba(255,255,255,0.07)'">−</button>
              <span id="qty-<%=item.id%>" style="font-family:'Bebas Neue',sans-serif;font-size:18px;min-width:24px;text-align:center"><%=item.cantidad%></span>
              <button onclick="cambiarCantidad(<%=item.id%>, 1)"
                style="width:28px;height:28px;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.2);color:var(--white);cursor:pointer;transition:all 0.15s;font-size:16px"
                onmouseover="this.style.background='var(--pink)'" onmouseout="this.style.background='rgba(255,255,255,0.07)'">+</button>
            </div>
            <button onclick="eliminarItem(<%=item.id%>)"
              style="background:none;border:none;color:rgba(255,255,255,0.3);font-size:18px;cursor:pointer;transition:color 0.2s"
              onmouseover="this.style.color='#ff4444'" onmouseout="this.style.color='rgba(255,255,255,0.3)'" title="Eliminar">✕</button>
          </div>
        </div>
        <div id="subtotal-<%=item.id%>" style="font-family:'Bebas Neue',sans-serif;font-size:20px;color:var(--white);letter-spacing:1px;flex-shrink:0">
          $<%=parseFloat(item.precio_final*item.cantidad).toLocaleString('es-CO')%>
        </div>
      </div>
      <%})%>
    </div>

    <!-- Summary -->
    <div>
      <div style="background:rgba(255,255,255,0.03);border:1px solid var(--border);padding:28px;position:relative;top:0">
        <div style="position:absolute;inset:0;border:2px solid rgba(255,255,255,0.3);filter:url(#gb);pointer-events:none"></div>
        <div style="font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:4px;color:var(--pink);margin-bottom:20px;border-bottom:1px solid var(--border);padding-bottom:12px">RESUMEN</div>
        <div style="display:flex;justify-content:space-between;margin-bottom:10px;font-size:14px;color:rgba(240,240,240,0.7)">
          <span>SUBTOTAL</span><span id="resumen-subtotal" style="font-family:'Bebas Neue',sans-serif;font-size:16px">$<%=parseFloat(subtotal).toLocaleString('es-CO')%></span>
        </div>
        <div style="display:flex;justify-content:space-between;margin-bottom:16px;font-size:14px;color:rgba(240,240,240,0.7)">
          <span>ENVÍO</span><span id="resumen-envio" style="font-family:'Bebas Neue',sans-serif;font-size:16px">$<%=parseFloat(envio).toLocaleString('es-CO')%></span>
        </div>
        <div style="height:1px;background:var(--border);margin-bottom:16px"></div>
        <div style="display:flex;justify-content:space-between;margin-bottom:24px">
          <span style="font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:2px">TOTAL</span>
          <span id="resumen-total" style="font-family:'Bebas Neue',sans-serif;font-size:24px;color:var(--pink);letter-spacing:1px">$<%=parseFloat(total).toLocaleString('es-CO')%></span>
        </div>
        <a href="/pedidos/checkout" class="btn-grunge-fill" style="width:100%;display:block;text-align:center;text-decoration:none;color:white;margin-bottom:12px">FINALIZAR COMPRA →</a>
        <a href="/productos" class="btn-grunge-w" style="color:white;text-decoration:none">← SEGUIR COMPRANDO</a>
      </div>
    </div>
  </div>
  <%}else{%>
  <div style="text-align:center;padding:80px 20px">
    <div style="font-size:60px;margin-bottom:16px;opacity:0.3">🛒</div>
    <div style="font-family:'Bebas Neue',sans-serif;font-size:28px;letter-spacing:4px;color:var(--gray);margin-bottom:8px">TU CARRITO ESTÁ VACÍO</div>
    <p style="color:var(--gray);margin-bottom:32px;letter-spacing:1px">Descubre nuestra colección</p>
    <a href="/productos" class="btn-grunge">VER PRODUCTOS →</a>
  </div>
  <%}%>
</div>

<style>@media(max-width:768px){.cart-layout{grid-template-columns:1fr!important}div[style*="padding:40px"]{padding:20px!important}}</style>

<script>
// Precios por item para recalcular totales localmente
const precios = {
  <% items.forEach((item, i) => { %>
  <%=item.id%>: <%=parseFloat(item.precio_final)%><% if(i < items.length-1) { %>,<% } %>
  <% }) %>
};
const ENVIO = <%=envio%>;

async function cambiarCantidad(itemId, delta) {
  const qtyEl = document.getElementById(`qty-${itemId}`);
  const actual = parseInt(qtyEl.textContent);
  const nueva = actual + delta;
  if (nueva < 1) return;

  try {
    const res = await fetch('/carrito/actualizar', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ item_id: itemId, cantidad: nueva })
    });
    const data = await res.json();
    if (data.success) {
      qtyEl.textContent = nueva;
      // Actualizar subtotal del item
      const precio = precios[itemId];
      document.getElementById(`subtotal-${itemId}`).textContent =
        '$' + (precio * nueva).toLocaleString('es-CO');
      recalcularResumen();
    } else {
      alert(data.error || 'No se pudo actualizar');
    }
  } catch(e) {
    alert('Error de red al actualizar');
  }
}

async function eliminarItem(itemId) {
  if (!confirm('¿Eliminar este producto del carrito?')) return;
  try {
    const res = await fetch(`/carrito/eliminar/${itemId}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' }
    });
    // La ruta de eliminar redirige, pero como usamos fetch capturamos la respuesta
    if (res.ok) {
      const card = document.getElementById(`cart-item-${itemId}`);
      card.style.transition = 'all 0.3s';
      card.style.opacity = '0';
      card.style.transform = 'translateX(20px)';
      setTimeout(() => {
        delete precios[itemId];
        card.remove();
        recalcularResumen();
        if (Object.keys(precios).length === 0) location.reload();
      }, 300);
    }
  } catch(e) {
    location.reload();
  }
}

function recalcularResumen() {
  let subtotal = 0;
  for (const [id, precio] of Object.entries(precios)) {
    const qty = parseInt(document.getElementById(`qty-${id}`)?.textContent || 0);
    subtotal += precio * qty;
  }
  const envio = subtotal > 0 ? ENVIO : 0;
  const total = subtotal + envio;
  document.getElementById('resumen-subtotal').textContent = '$' + subtotal.toLocaleString('es-CO');
  document.getElementById('resumen-envio').textContent = '$' + envio.toLocaleString('es-CO');
  document.getElementById('resumen-total').textContent = '$' + total.toLocaleString('es-CO');
}
</script>

<%- include('../partials/footer') %>
