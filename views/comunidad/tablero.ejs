<%- include('../partials/header') %>
<%
var bannerSrc = tablero.imagen_portada
  ? '/uploads/tableros/'+tablero.imagen_portada
  : null;
var avatarSrc = tablero.foto_perfil_tipo==='upload' && tablero.foto_perfil
  ? '/uploads/profiles/'+tablero.foto_perfil
  : '/img/defaults/avatars/'+(tablero.foto_perfil_preset||'avatar1.png');
var cleanDesc = (tablero.descripcion||'').replace(/^\[cat:[^\]]+\]\s*/,'');
var catMatch  = (tablero.descripcion||'').match(/^\[cat:([^\]]+)\]/);
var cat       = catMatch ? catMatch[1] : '';
%>
<style>
.tab-wrap{max-width:1200px;margin:0 auto;padding:0 24px 80px}

/* Hero del tablero */
.tab-hero{position:relative;margin:-8px -24px 0;overflow:hidden}
.tab-hero-bg{height:220px;background:<%= tablero.color_portada||'#1a0a1a' %>;position:relative;overflow:hidden}
.tab-hero-bg img{width:100%;height:100%;object-fit:cover;opacity:.45;position:absolute;inset:0}
.tab-hero-overlay{position:absolute;inset:0;background:linear-gradient(to bottom,transparent 30%,rgba(10,10,10,.92))}
.tab-hero-content{position:absolute;bottom:0;left:0;right:0;padding:24px 32px;display:flex;align-items:flex-end;justify-content:space-between;gap:16px;flex-wrap:wrap}
.tab-title{font-family:var(--fd);font-size:clamp(1.4rem,4vw,2.4rem);letter-spacing:5px;color:white;line-height:1}
.tab-meta-row{display:flex;align-items:center;gap:12px;margin-top:8px;flex-wrap:wrap}
.tab-stat{font-family:var(--fm);font-size:.65rem;color:rgba(255,255,255,.6);display:flex;align-items:center;gap:4px;letter-spacing:.5px}

/* Author chip */
.tab-author{display:flex;align-items:center;gap:8px;text-decoration:none}
.tab-author img{border-radius:50%;border:2px solid rgba(233,30,140,.5)}
.tab-author-name{font-family:var(--fm);font-size:.72rem;color:rgba(255,255,255,.7)}

/* Action buttons */
.tab-actions{display:flex;gap:8px;padding-bottom:4px}
.tab-btn{height:38px;padding:0 16px;border-radius:8px;font-family:var(--fm);font-size:.7rem;font-weight:700;letter-spacing:1.5px;cursor:pointer;display:flex;align-items:center;gap:6px;transition:all .2s;border:1px solid;white-space:nowrap}
.tab-btn-save{background:transparent;border-color:rgba(255,255,255,.3);color:rgba(255,255,255,.8)}
.tab-btn-save:hover,.tab-btn-save.saved{background:var(--cp);color:white;border-color:var(--cp)}
.tab-btn-react{background:transparent;border-color:rgba(255,255,255,.3);color:rgba(255,255,255,.8);font-size:16px;letter-spacing:4px;padding:0 12px}
.tab-btn-react:hover{background:rgba(233,30,140,.2);border-color:rgba(233,30,140,.4)}
.tab-btn-back{background:transparent;border-color:rgba(255,255,255,.2);color:rgba(255,255,255,.5);text-decoration:none;display:flex;align-items:center;gap:5px;height:34px;padding:0 12px;border-radius:8px;font-family:var(--fm);font-size:.65rem}
.tab-btn-back:hover{color:white}

/* Cuerpo */
.tab-body{padding:24px 0}

/* Descripción y tags */
.tab-desc-block{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:16px 20px;margin-bottom:24px}

/* Masonry de pines */
.pins-masonry{columns:5 180px;gap:12px}
.pin-card{break-inside:avoid;margin-bottom:12px;border-radius:10px;overflow:hidden;background:var(--card);border:1px solid var(--border);transition:all .2s;cursor:pointer}
.pin-card:hover{border-color:rgba(233,30,140,.35);transform:translateY(-3px);box-shadow:0 8px 28px rgba(233,30,140,.1)}
.pin-card img{width:100%;display:block;transition:transform .3s}
.pin-card:hover img{transform:scale(1.05)}
.pin-card-body{padding:10px 12px}
.pin-card-title{font-family:var(--fb);font-weight:700;font-size:.8rem;color:var(--text);line-height:1.3;margin-bottom:2px}
.pin-card-meta{font-family:var(--fm);font-size:.6rem;color:var(--muted)}
.pin-card-product{display:flex;align-items:center;justify-content:space-between;margin-top:6px}
.pin-price{font-family:var(--fd);font-size:.8rem;color:var(--cp)}

/* Empty pines */
.pines-empty{text-align:center;padding:60px 24px;color:var(--muted)}
.pines-empty i{font-size:2rem;display:block;margin-bottom:12px;color:rgba(233,30,140,.2)}

/* Panel lateral (solo desktop) */
.tab-layout{display:grid;grid-template-columns:1fr 260px;gap:24px;align-items:start}
.tab-sidebar{position:sticky;top:84px}
.sidebar-card{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:16px;margin-bottom:14px}
.sidebar-title{font-family:var(--fm);font-size:.58rem;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:10px}

/* Modal lightbox */
.lightbox{position:fixed;inset:0;background:rgba(0,0,0,.93);z-index:3000;display:none;align-items:center;justify-content:center;padding:16px}
.lightbox.open{display:flex}
.lightbox img{max-width:90vw;max-height:88vh;object-fit:contain;border-radius:6px}
.lightbox-close{position:absolute;top:16px;right:20px;background:none;border:none;color:rgba(255,255,255,.7);font-size:22px;cursor:pointer}
.lightbox-close:hover{color:white}

/* Responsive */
@media(max-width:900px){.tab-layout{grid-template-columns:1fr}.tab-sidebar{position:static}}
@media(max-width:600px){.pins-masonry{columns:2 140px}.tab-hero-content{padding:16px 20px}.tab-wrap{padding:0 12px 100px}}
</style>

<!-- Back -->
<div style="max-width:1200px;margin:8px auto 0;padding:0 24px">
  <a href="/comunidad" class="tab-btn-back"><i class="bi bi-arrow-left"></i>COMUNIDAD</a>
</div>

<!-- HERO TABLERO -->
<div class="tab-wrap">
<div class="tab-hero">
  <div class="tab-hero-bg">
    <% if (bannerSrc) { %><img src="<%= bannerSrc %>" onerror="this.style.display='none'"><% } %>
    <div class="tab-hero-overlay"></div>
  </div>
  <div class="tab-hero-content">
    <div>
      <% if (cat) { %>
      <div style="font-family:var(--fm);font-size:.58rem;letter-spacing:2px;color:rgba(233,30,140,.8);text-transform:uppercase;margin-bottom:6px"><%= cat %></div>
      <% } %>
      <div class="tab-title"><%= tablero.nombre.toUpperCase() %></div>
      <div class="tab-meta-row">
        <a href="/u/<%= tablero.username %>" class="tab-author">
          <img src="<%= avatarSrc %>" width="26" height="26" onerror="this.src='/img/defaults/avatars/avatar1.png'">
          <span class="tab-author-name">@<%= tablero.username %></span>
        </a>
        <span class="tab-stat"><i class="bi bi-pin-fill"></i><%= tablero.total_pines %> pines</span>
        <span class="tab-stat"><i class="bi bi-eye"></i><%= tablero.total_vistas||0 %> vistas</span>
        <span class="tab-stat"><i class="bi bi-heart"></i><%= tablero.total_reacciones||0 %></span>
        <span class="tab-stat"><i class="bi bi-bookmark"></i><%= tablero.total_guardados||0 %></span>
      </div>
    </div>
    <div class="tab-actions">
      <button class="tab-btn tab-btn-react" onclick="panelReaccionar()" title="Reaccionar">🔥 ❤️ 😮</button>
      <% if (user) { %>
      <button class="tab-btn tab-btn-save <%= yaGuardado ? 'saved' : '' %>" id="main-save-btn" onclick="guardarTablero()">
        <i class="bi bi-bookmark<%= yaGuardado ? '-check-fill' : '' %>"></i>
        <%= yaGuardado ? 'GUARDADO' : 'GUARDAR' %>
      </button>
      <% } %>
    </div>
  </div>
</div>

<!-- BODY -->
<div class="tab-body">
  <div class="tab-layout">
    <!-- Pines masonry -->
    <div>
      <% if (cleanDesc) { %>
      <div class="tab-desc-block">
        <div style="font-family:var(--fb);font-size:.88rem;color:var(--text);line-height:1.5"><%= cleanDesc %></div>
      </div>
      <% } %>

      <% if (!pines || pines.length === 0) { %>
      <div class="pines-empty">
        <i class="bi bi-pin"></i>
        <div style="font-family:var(--fd);font-size:1rem;letter-spacing:3px;color:var(--text)">Tablero vacío</div>
        <div style="font-size:.8rem;margin-top:6px">Este tablero aún no tiene pines.</div>
      </div>
      <% } else { %>
      <div class="pins-masonry" id="pins-masonry">
        <% pines.forEach(p => {
          var imgSrc = p.imagen_url || (p.imagen_principal ? '/uploads/products/'+p.imagen_principal : null);
          var href = p.prod_id ? '/productos/'+p.prod_id : (p.url_externa||null);
        %><div class="pin-card" onclick="<%= imgSrc ? 'openLightbox(\''+imgSrc+'\')' : (href ? 'window.open(\''+href+'\',\'_blank\')' : '') %>">
          <% if (imgSrc) { %>
          <img src="<%= imgSrc %>" alt="<%= p.titulo||p.prod_titulo||'' %>" loading="lazy" onerror="this.parentElement.style.display='none'">
          <% } %>
          <% if (p.titulo || p.prod_titulo || p.precio) { %>
          <div class="pin-card-body">
            <% if (p.titulo||p.prod_titulo) { %>
            <div class="pin-card-title"><%= p.titulo || p.prod_titulo %></div>
            <% } %>
            <% if (p.descripcion) { %><div class="pin-card-meta"><%= p.descripcion %></div><% } %>
            <% if (p.precio) { %>
            <div class="pin-card-product">
              <div class="pin-price">$<%= parseFloat(p.precio_descuento||p.precio).toLocaleString('es-CO') %></div>
              <% if (p.prod_id) { %>
              <a href="/productos/<%= p.prod_id %>" onclick="event.stopPropagation()"
                 style="font-family:var(--fm);font-size:.6rem;color:var(--cp);letter-spacing:1px;text-decoration:none">VER</a>
              <% } %>
            </div>
            <% } %>
          </div>
          <% } %>
        </div><% }) %>
      </div>
      <% } %>
    </div>

    <!-- Sidebar -->
    <div class="tab-sidebar">
      <!-- Reacciones rápidas -->
      <div class="sidebar-card">
        <div class="sidebar-title">Reaccionar</div>
        <div style="display:flex;gap:8px;flex-wrap:wrap">
          <% [['fuego','🔥'],['love','❤️'],['wow','😮']].forEach(function(r){ %>
          <button onclick="reaccionar('<%= r[0] %>',this)"
            style="background:var(--dark2);border:1px solid var(--border);border-radius:8px;padding:6px 12px;font-size:18px;cursor:pointer;transition:all .18s"
            onmouseover="this.style.borderColor='rgba(233,30,140,.4)'" onmouseout="this.style.borderColor='var(--border)'">
            <%= r[1] %>
          </button>
          <% }) %>
        </div>
      </div>

      <!-- Autor -->
      <div class="sidebar-card">
        <div class="sidebar-title">Creado por</div>
        <a href="/u/<%= tablero.username %>" style="display:flex;align-items:center;gap:10px;text-decoration:none;color:var(--text)">
          <img src="<%= avatarSrc %>" width="40" height="40"
               style="border-radius:50%;border:2px solid rgba(233,30,140,.3)" onerror="this.src='/img/defaults/avatars/avatar1.png'">
          <div>
            <div style="font-family:var(--fb);font-weight:700;font-size:.88rem"><%= tablero.nombre_visible %></div>
            <div style="font-family:var(--fm);font-size:.65rem;color:var(--muted)">@<%= tablero.username %></div>
          </div>
        </a>
      </div>

      <!-- Info del tablero -->
      <div class="sidebar-card">
        <div class="sidebar-title">Info</div>
        <div style="display:flex;flex-direction:column;gap:6px">
          <div style="display:flex;justify-content:space-between;font-family:var(--fm);font-size:.72rem">
            <span style="color:var(--muted)">Pines</span>
            <span style="color:var(--text);font-weight:700"><%= tablero.total_pines %></span>
          </div>
          <div style="display:flex;justify-content:space-between;font-family:var(--fm);font-size:.72rem">
            <span style="color:var(--muted)">Vistas</span>
            <span style="color:var(--text);font-weight:700"><%= tablero.total_vistas||0 %></span>
          </div>
          <div style="display:flex;justify-content:space-between;font-family:var(--fm);font-size:.72rem">
            <span style="color:var(--muted)">Reacciones</span>
            <span style="color:var(--text);font-weight:700"><%= tablero.total_reacciones||0 %></span>
          </div>
          <div style="display:flex;justify-content:space-between;font-family:var(--fm);font-size:.72rem">
            <span style="color:var(--muted)">Guardados</span>
            <span style="color:var(--text);font-weight:700"><%= tablero.total_guardados||0 %></span>
          </div>
          <div style="display:flex;justify-content:space-between;font-family:var(--fm);font-size:.72rem">
            <span style="color:var(--muted)">Creado</span>
            <span style="color:var(--text)"><%= new Date(tablero.creado_en).toLocaleDateString('es-CO',{day:'2-digit',month:'short',year:'2-digit'}) %></span>
          </div>
        </div>
      </div>

      <!-- Volver -->
      <a href="/comunidad"
         style="display:flex;align-items:center;justify-content:center;gap:6px;padding:10px;border:1px solid var(--border);border-radius:8px;font-family:var(--fm);font-size:.65rem;color:var(--muted);text-decoration:none;transition:all .2s"
         onmouseover="this.style.borderColor='rgba(233,30,140,.3)';this.style.color='var(--cp)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--muted)'">
        <i class="bi bi-arrow-left"></i>VOLVER A COMUNIDAD
      </a>
    </div>
  </div>
</div>
</div>

<!-- Lightbox -->
<div class="lightbox" id="lightbox" onclick="closeLightbox()">
  <button class="lightbox-close" onclick="closeLightbox()"><i class="bi bi-x-lg"></i></button>
  <img id="lightbox-img" src="" alt="">
</div>

<script>
const TABLERO_ID = <%= tablero.id %>;
const IS_LOGGED  = <%= user ? 'true' : 'false' %>;

function openLightbox(src){ document.getElementById('lightbox-img').src=src; document.getElementById('lightbox').classList.add('open'); }
function closeLightbox(){ document.getElementById('lightbox').classList.remove('open'); }
document.addEventListener('keydown',function(e){ if(e.key==='Escape') closeLightbox(); });

async function reaccionar(tipo, btn){
  if(!IS_LOGGED){ window.location='/auth/login'; return; }
  try{
    const r=await fetch('/comunidad/tablero/'+TABLERO_ID+'/reaccion',{
      method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({tipo})});
    const d=await r.json();
    if(btn){ btn.style.transform=d.reaccion?'scale(1.3)':'scale(1)'; setTimeout(function(){ if(btn) btn.style.transform='scale(1)'; },300); }
  }catch(e){}
}

async function guardarTablero(){
  if(!IS_LOGGED){ window.location='/auth/login'; return; }
  const btn=document.getElementById('main-save-btn');
  if(btn) btn.style.opacity='.5';
  try{
    const r=await fetch('/comunidad/tablero/'+TABLERO_ID+'/guardar',{method:'POST'});
    const d=await r.json();
    if(btn){
      btn.style.opacity='1';
      btn.classList.toggle('saved',d.guardado);
      btn.innerHTML=d.guardado
        ?'<i class="bi bi-bookmark-check-fill"></i>GUARDADO'
        :'<i class="bi bi-bookmark"></i>GUARDAR';
    }
  }catch(e){ if(btn) btn.style.opacity='1'; }
}

function panelReaccionar(){
  document.querySelector('.sidebar-card:first-child').scrollIntoView({behavior:'smooth',block:'center'});
}
</script>

<%- include('../partials/footer') %>
