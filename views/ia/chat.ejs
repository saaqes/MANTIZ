<%- include('../partials/header') %>
<div style="padding:40px;max-width:860px;margin:0 auto">
  <h2 class="section-title">ASISTENTE IA</h2>
  <div class="tribal-divider"><svg width="200" height="20" viewBox="0 0 200 20" fill="none"><line x1="0" y1="10" x2="80" y2="10" stroke="rgba(233,30,140,0.4)" stroke-width="1"/><circle cx="100" cy="10" r="5" fill="var(--pink)"/><line x1="120" y1="10" x2="200" y2="10" stroke="rgba(233,30,140,0.4)" stroke-width="1"/></svg></div>
  <div style="background:rgba(255,255,255,0.03);border:1px solid var(--border);display:flex;flex-direction:column;height:580px;position:relative">
    <div style="position:absolute;inset:0;border:2px solid rgba(255,255,255,0.25);filter:url(#gb);pointer-events:none;z-index:10"></div>
    <div style="background:var(--pink);padding:14px 20px;font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:3px;display:flex;align-items:center;gap:10px">
      <i class="bi bi-robot"></i> ASISTENTE MANTIZ
      <span style="font-size:10px;opacity:0.8;font-family:'Rajdhani',sans-serif;letter-spacing:1px;margin-left:auto">IA · EN LÍNEA</span>
    </div>
    <div id="chatMsgs" style="flex:1;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:12px">
      <div style="max-width:80%;padding:12px 16px;background:rgba(255,255,255,0.06);color:var(--white);border-left:2px solid var(--pink);font-size:13px;line-height:1.5">
        👋 ¡Hola! Soy el asistente de <strong>Mantiz</strong>. Puedo ayudarte a encontrar productos, resolver dudas sobre pedidos, tallas y más. ¿En qué te ayudo?
      </div>
    </div>
    <div style="padding:16px;border-top:1px solid rgba(255,255,255,0.08);display:flex;gap:10px">
      <input type="text" id="chatInp" style="flex:1;background:rgba(255,255,255,0.05);border:1px solid var(--border);color:var(--white);padding:10px 16px;font-family:'Rajdhani',sans-serif;font-size:14px;outline:none;transition:border-color 0.2s" placeholder="Escribe tu mensaje..." onkeydown="if(event.key==='Enter')sendMsg()" onfocus="this.style.borderColor='var(--pink)'" onblur="this.style.borderColor='var(--border)'">
      <button onclick="sendMsg()" style="background:var(--pink);border:none;color:white;padding:10px 20px;font-family:'Bebas Neue',sans-serif;font-size:14px;letter-spacing:2px;cursor:pointer;transition:background 0.2s" onmouseover="this.style.background='var(--pink-light)'" onmouseout="this.style.background='var(--pink)'">ENVIAR</button>
    </div>
  </div>
</div>
<style>@media(max-width:768px){div[style*="padding:40px"]{padding:20px!important}}</style>
<script>
let chatH=[];
async function sendMsg(){
  const inp=document.getElementById('chatInp');const msg=inp.value.trim();if(!msg)return;
  appendM(msg,'user');inp.value='';
  const msgs=document.getElementById('chatMsgs');
  const el=document.createElement('div');el.id='cld';el.style.cssText='max-width:80%;padding:12px 16px;background:rgba(255,255,255,0.06);color:var(--gray);border-left:2px solid var(--pink);font-size:13px';el.textContent='...';msgs.appendChild(el);msgs.scrollTop=msgs.scrollHeight;
  try{const r=await fetch('/ia/chat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({mensaje:msg,historial:chatH})});
    const d=await r.json();document.getElementById('cld')?.remove();
    const resp=d.respuesta||'Sin respuesta.';appendM(resp,'bot');chatH.push({rol:'user',contenido:msg},{rol:'assistant',contenido:resp});if(chatH.length>16)chatH=chatH.slice(-16);
  }catch(e){document.getElementById('cld')?.remove();appendM('Error de conexión.','bot');}
}
function appendM(text,role){
  const msgs=document.getElementById('chatMsgs');const d=document.createElement('div');
  d.style.cssText=`max-width:80%;padding:12px 16px;font-size:13px;line-height:1.5;${role==='user'?'background:var(--pink);color:white;align-self:flex-end':'background:rgba(255,255,255,0.06);color:var(--white);border-left:2px solid var(--pink)'}`;
  d.textContent=text;msgs.appendChild(d);msgs.scrollTop=msgs.scrollHeight;
}
</script>
<%- include('../partials/footer') %>
