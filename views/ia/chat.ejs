<%- include('../partials/header') %>

<style>
.ia-wrap{max-width:1160px;margin:0 auto;padding:0 20px 80px}

/* HERO */
.ia-hero{text-align:center;padding:56px 20px 36px;position:relative}
.ia-hero::before{content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);width:700px;height:320px;background:radial-gradient(ellipse,rgba(233,30,140,.13) 0%,transparent 70%);pointer-events:none}
.ia-label{font-family:'Bebas Neue',sans-serif;font-size:10px;letter-spacing:5px;color:var(--pink);margin-bottom:10px}
.ia-divider svg{display:block;margin:12px auto 16px}

/* GRID */
.ia-grid{display:grid;grid-template-columns:260px 1fr;gap:22px}

/* SIDEBAR */
.ia-panel{background:var(--card);border:1px solid var(--faint-1);padding:16px}
.ia-panel-title{font-family:'Bebas Neue',sans-serif;font-size:11px;letter-spacing:3px;color:var(--pink);margin-bottom:12px;display:flex;align-items:center;gap:8px}
.ia-panel-title i{font-size:12px}
.ia-quick{display:block;width:100%;text-align:left;background:var(--card);border:1px solid var(--faint-1);color:var(--muted);padding:9px 13px;font-size:12px;font-family:'Rajdhani',sans-serif;letter-spacing:.5px;cursor:pointer;transition:all .2s;margin-bottom:6px}
.ia-quick:hover{background:rgba(233,30,140,.1);border-color:rgba(233,30,140,.3);color:var(--pink)}
.ia-quick i{margin-right:8px;color:var(--pink);font-size:11px}
.ia-tag{display:inline-block;background:rgba(233,30,140,.08);border:1px solid rgba(233,30,140,.2);color:var(--pink);font-size:10px;font-family:'Bebas Neue',sans-serif;letter-spacing:2px;padding:4px 10px;cursor:pointer;margin:3px;transition:all .2s}
.ia-tag:hover{background:rgba(233,30,140,.22);transform:scale(1.03)}
.status-pulse{width:7px;height:7px;border-radius:50%;background:#00ff64;display:inline-block;animation:sp 2s infinite}
@keyframes sp{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(0,255,100,.4)}50%{opacity:.8;box-shadow:0 0 0 5px rgba(0,255,100,0)}}

/* CHAT */
.ia-chat{background:var(--card);border:1px solid var(--faint-1);display:flex;flex-direction:column;height:660px}
.ia-chat-hdr{background:linear-gradient(90deg,var(--pink),#c2185b);padding:15px 20px;font-family:'Bebas Neue',sans-serif;font-size:14px;letter-spacing:3px;display:flex;align-items:center;gap:12px;flex-shrink:0}
.ia-chat-hdr .ia-actions{margin-left:auto;display:flex;gap:8px}
.ia-act-btn{background:rgba(255,255,255,.15);border:none;color:white;padding:5px 12px;font-family:'Bebas Neue',sans-serif;font-size:10px;letter-spacing:2px;cursor:pointer;transition:all .2s}
.ia-act-btn:hover{background:rgba(255,255,255,.25)}

.ia-msgs{flex:1;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:14px;scroll-behavior:smooth}
.ia-msgs::-webkit-scrollbar{width:3px}
.ia-msgs::-webkit-scrollbar-thumb{background:rgba(233,30,140,.35)}

.im{display:flex;flex-direction:column;gap:4px;max-width:80%}
.im.user{align-self:flex-end;align-items:flex-end}
.im.bot{align-self:flex-start;align-items:flex-start}
.im .ib{padding:12px 16px;font-size:13.5px;line-height:1.6;font-family:'Rajdhani',sans-serif;letter-spacing:.2px}
.im.user .ib{background:var(--pink);color:#fff}
.im.bot .ib{background:var(--card);color:var(--text);border-left:3px solid var(--pink)}
.im .it{font-size:10px;color:var(--muted);font-family:'Rajdhani',sans-serif;letter-spacing:.5px}

/* Typing */
.ia-typing{align-self:flex-start;display:none}
.ia-typing.show{display:flex}
.ia-typing .ib{background:var(--card);border-left:3px solid var(--pink);padding:13px 16px;display:flex;gap:5px;align-items:center}
.iad{width:7px;height:7px;border-radius:50%;background:var(--pink);animation:iadot 1.2s infinite}
.iad:nth-child(2){animation-delay:.2s}.iad:nth-child(3){animation-delay:.4s}
@keyframes iadot{0%,60%,100%{transform:translateY(0);opacity:.35}30%{transform:translateY(-7px);opacity:1}}

/* Sugerencias */
.ia-sugs{display:flex;gap:7px;flex-wrap:wrap;padding:12px 16px;border-top:1px solid var(--faint-1);flex-shrink:0}
.ia-sug{background:rgba(233,30,140,.07);border:1px solid rgba(233,30,140,.2);color:rgba(233,30,140,.9);font-size:10px;font-family:'Bebas Neue',sans-serif;letter-spacing:1.5px;padding:5px 12px;cursor:pointer;transition:all .2s}
.ia-sug:hover{background:rgba(233,30,140,.2)}

/* Input */
.ia-inp-wrap{padding:14px 16px;border-top:1px solid var(--faint-1);display:flex;gap:10px;align-items:center;background:rgba(0,0,0,.35);flex-shrink:0}
.ia-inp{flex:1;background:var(--card);border:1px solid var(--faint-2);color:var(--text);padding:11px 15px;font-family:'Rajdhani',sans-serif;font-size:14px;outline:none;transition:border-color .2s;resize:none;height:46px;overflow:hidden;line-height:1.4}
.ia-inp:focus{border-color:var(--pink)}
.ia-send{background:var(--pink);border:none;color:#fff;width:46px;height:46px;cursor:pointer;font-size:16px;transition:all .2s;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.ia-send:hover{background:#c2185b;transform:scale(1.05)}
.ia-send:disabled{opacity:.45;cursor:not-allowed;transform:none}

/* Info extra */
.ia-info-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-top:20px}
.ia-info-card{background:var(--card);border:1px solid var(--faint-1);padding:18px;text-align:center}
.ia-info-card i{font-size:1.6rem;color:var(--pink);margin-bottom:10px;display:block}
.ia-info-card .iic-title{font-family:'Bebas Neue',sans-serif;font-size:13px;letter-spacing:2px;margin-bottom:6px}
.ia-info-card .iic-desc{font-size:11px;color:var(--muted);font-family:'Rajdhani',sans-serif;line-height:1.5}

@media(max-width:820px){.ia-grid{grid-template-columns:1fr}.ia-chat{height:520px}.ia-info-grid{grid-template-columns:1fr}}
</style>

<div class="ia-wrap">
  <!-- HERO -->
  <div class="ia-hero">
    <div class="ia-label">INTELIGENCIA ARTIFICIAL</div>
    <h1 class="section-title" style="margin-bottom:10px">ASISTENTE MANTIZ</h1>
    <%- include('../partials/tribal-separator') %>
    <p style="color:var(--muted);font-size:13px;letter-spacing:1px;max-width:500px;margin:0 auto">
      Tu asistente personal de moda con IA. Outfits, tallas, pedidos y todo lo que necesites.
    </p>
  </div>

  <!-- MAIN GRID -->
  <div class="ia-grid">

    <!-- SIDEBAR -->
    <div style="display:flex;flex-direction:column;gap:14px">

      <!-- Estado -->
      <div class="ia-panel">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px">
          <span class="status-pulse"></span>
          <span style="font-family:'Rajdhani',sans-serif;font-size:12px;color:var(--muted);letter-spacing:1px">IA EN LÍNEA</span>
        </div>
        <div style="font-size:10px;color:var(--muted);font-family:'Rajdhani',sans-serif;margin-bottom:10px">Powered by Google Gemini · 100% Gratis</div>
        <a href="/ia/chat" style="display:block;text-align:center;background:rgba(233,30,140,.12);border:1px solid rgba(233,30,140,.3);color:var(--pink);font-family:'Bebas Neue',sans-serif;font-size:11px;letter-spacing:2px;padding:8px;text-decoration:none;transition:all .2s" onmouseover="this.style.background='rgba(233,30,140,.22)'" onmouseout="this.style.background='rgba(233,30,140,.12)'">
          VER PÁGINA COMPLETA →
        </a>
      </div>

      <!-- Accesos rápidos -->
      <div class="ia-panel">
        <div class="ia-panel-title"><i class="bi bi-lightning-fill"></i>ACCESOS RÁPIDOS</div>
        <button class="ia-quick" onclick="iaQuick('¿Qué productos tienen disponibles ahora?')"><i class="bi bi-bag"></i>Productos disponibles</button>
        <button class="ia-quick" onclick="iaQuick('¿Cuánto cuesta el envío y cuánto demora?')"><i class="bi bi-truck"></i>Info de envíos</button>
        <button class="ia-quick" onclick="iaQuick('¿Cómo funciona la política de devoluciones?')"><i class="bi bi-arrow-return-left"></i>Devoluciones</button>
        <button class="ia-quick" onclick="iaQuick('¿Qué métodos de pago aceptan?')"><i class="bi bi-credit-card"></i>Métodos de pago</button>
        <button class="ia-quick" onclick="iaQuick('¿Cómo sé cuál es mi talla correcta?')"><i class="bi bi-rulers"></i>Guía de tallas</button>
        <button class="ia-quick" onclick="iaQuick('¿Tienen descuentos o promociones activas?')"><i class="bi bi-tag"></i>Promociones</button>
      </div>

      <!-- Outfits -->
      <div class="ia-panel">
        <div class="ia-panel-title"><i class="bi bi-stars"></i>IDEAS DE OUTFITS</div>
        <span class="ia-tag" onclick="iaQuick('Recomiéndame un outfit casual para el día a día')">CASUAL</span>
        <span class="ia-tag" onclick="iaQuick('Arma un outfit urbano streetwear para salir de noche')">STREETWEAR</span>
        <span class="ia-tag" onclick="iaQuick('Qué outfit elegante tienen disponible?')">ELEGANTE</span>
        <span class="ia-tag" onclick="iaQuick('Necesito un outfit para hacer deporte')">SPORT</span>
        <span class="ia-tag" onclick="iaQuick('Recomiéndame ropa para el verano')">VERANO</span>
        <span class="ia-tag" onclick="iaQuick('Cómo combinar colores oscuros en un outfit?')">DARK MODE</span>
        <span class="ia-tag" onclick="iaQuick('Outfit minimalista para oficina o trabajo')">MINIMAL</span>
        <span class="ia-tag" onclick="iaQuick('Outfit para una cita especial')">CITA</span>
      </div>

      <!-- Puedo ayudarte -->
      <div class="ia-panel">
        <div class="ia-panel-title"><i class="bi bi-info-circle"></i>TE AYUDO CON</div>
        <div style="font-size:11.5px;color:var(--muted);font-family:'Rajdhani',sans-serif;line-height:2.2">
          ✦ Recomendaciones personalizadas<br>
          ✦ Combinación de prendas y colores<br>
          ✦ Estado de pedidos y envíos<br>
          ✦ Guía de tallas y medidas<br>
          ✦ Nuevas colecciones<br>
          ✦ Preguntas sobre la tienda
        </div>
      </div>
    </div>

    <!-- CHAT PRINCIPAL -->
    <div class="ia-chat">
      <div class="ia-chat-hdr">
        <i class="bi bi-robot" style="font-size:18px"></i>
        <div>
          <div>ASISTENTE MANTIZ</div>
          <div style="font-size:10px;font-family:'Rajdhani',sans-serif;letter-spacing:1px;opacity:.8;display:flex;align-items:center;gap:5px">
            <span class="status-pulse"></span>EN LÍNEA · RESPUESTA INMEDIATA
          </div>
        </div>
        <div class="ia-actions">
          <button class="ia-act-btn" onclick="limpiarChat()"><i class="bi bi-trash me-1"></i>LIMPIAR</button>
        </div>
      </div>

      <div class="ia-msgs" id="iaMsgs">
        <div class="im bot">
          <div class="ib">
            👋 ¡Hola! Soy el asistente virtual de <strong>Mantiz</strong>.<br><br>
            Puedo ayudarte con <strong>recomendaciones de outfits</strong>, información sobre productos, tallas, pedidos, envíos y mucho más.<br><br>
            ¿En qué te puedo ayudar hoy?
          </div>
          <div class="it">Ahora</div>
        </div>
      </div>

      <div class="ia-typing" id="iaTyping">
        <div class="ib"><div class="iad"></div><div class="iad"></div><div class="iad"></div></div>
      </div>

      <!-- Sugerencias iniciales -->
      <div class="ia-sugs" id="iaSugs">
        <span class="ia-sug" onclick="iaQuick(this.dataset.msg)" data-msg="¿Qué hay de nuevo en la tienda?">¿QUÉ HAY DE NUEVO?</span>
        <span class="ia-sug" onclick="iaQuick(this.dataset.msg)" data-msg="Recomiéndame un outfit para hoy">OUTFIT PARA HOY</span>
        <span class="ia-sug" onclick="iaQuick(this.dataset.msg)" data-msg="¿Cómo sé cuál es mi talla?">MI TALLA</span>
        <span class="ia-sug" onclick="iaQuick(this.dataset.msg)" data-msg="¿Cuánto demora el envío?">ENVÍOS</span>
        <span class="ia-sug" onclick="iaQuick(this.dataset.msg)" data-msg="¿Cuáles son los productos más populares?">LO MÁS POPULAR</span>
      </div>

      <div class="ia-inp-wrap">
        <textarea class="ia-inp" id="iaInp" placeholder="Escribe tu mensaje aquí..." rows="1"
          onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();iaSend()}"
          oninput="this.style.height='46px';this.style.height=Math.min(this.scrollHeight,120)+'px'"></textarea>
        <button class="ia-send" id="iaSendBtn" onclick="iaSend()"><i class="bi bi-send-fill"></i></button>
      </div>
    </div>
  </div>

  <!-- INFO CARDS -->
  <div class="ia-info-grid">
    <div class="ia-info-card">
      <i class="bi bi-shield-check"></i>
      <div class="iic-title">100% GRATUITO</div>
      <div class="iic-desc">Usa Google Gemini AI sin ningún costo adicional. Sin límites en tus preguntas.</div>
    </div>
    <div class="ia-info-card">
      <i class="bi bi-lightning-charge"></i>
      <div class="iic-title">RESPUESTA INMEDIATA</div>
      <div class="iic-desc">Obtén respuestas en segundos sobre productos, tallas, envíos y más.</div>
    </div>
    <div class="ia-info-card">
      <i class="bi bi-palette"></i>
      <div class="iic-title">EXPERTO EN MODA</div>
      <div class="iic-desc">Combinaciones, outfits y recomendaciones personalizadas para tu estilo.</div>
    </div>
  </div>
</div>

<script>
let iaH = [], iaSending = false;

function iaTime(){ return new Date().toLocaleTimeString('es-CO',{hour:'2-digit',minute:'2-digit'}); }

function iaAppend(text, role) {
  const msgs = document.getElementById('iaMsgs');
  const div = document.createElement('div');
  div.className = 'im ' + role;
  const fmt = text
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.*?)\*/g, '<em>$1</em>')
    .replace(/\n/g, '<br>');
  div.innerHTML = `<div class="ib">${fmt}</div><div class="it">${iaTime()}</div>`;
  // Animación entrada
  div.style.opacity = '0';
  div.style.transform = role === 'user' ? 'translateX(10px)' : 'translateX(-10px)';
  div.style.transition = 'all 0.25s ease';
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
  requestAnimationFrame(() => {
    div.style.opacity = '1';
    div.style.transform = 'translateX(0)';
  });
  document.getElementById('iaSugs').style.display = 'none';
}

function iaSetTyping(s) {
  const t = document.getElementById('iaTyping');
  if(t) t.classList.toggle('show', s);
  document.getElementById('iaMsgs').scrollTop = 99999;
}

async function iaSend() {
  if (iaSending) return;
  const inp = document.getElementById('iaInp');
  const msg = inp.value.trim();
  if (!msg) return;

  iaSending = true;
  const btn = document.getElementById('iaSendBtn');
  if(btn) btn.disabled = true;
  inp.value = '';
  inp.style.height = '46px';

  iaAppend(msg, 'user');
  iaSetTyping(true);

  try {
    const r = await fetch('/ia/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ mensaje: msg, historial: iaH })
    });
    const d = await r.json();
    iaSetTyping(false);
    const resp = d.respuesta || 'No pude procesar tu mensaje. Intenta de nuevo.';
    iaAppend(resp, 'bot');
    iaH.push({ rol: 'user', contenido: msg }, { rol: 'assistant', contenido: resp });
    if (iaH.length > 20) iaH = iaH.slice(-20);
  } catch(e) {
    iaSetTyping(false);
    iaAppend('❌ Error de conexión. Por favor intenta de nuevo en unos segundos.', 'bot');
  }

  iaSending = false;
  if(btn) btn.disabled = false;
  document.getElementById('iaInp').focus();
}

function iaQuick(text) {
  document.getElementById('iaInp').value = text;
  iaSend();
}

function limpiarChat() {
  if (!confirm('¿Limpiar el historial del chat?')) return;
  const msgs = document.getElementById('iaMsgs');
  msgs.innerHTML = `<div class="im bot"><div class="ib">🔄 Chat reiniciado. ¡Hola de nuevo! ¿En qué te puedo ayudar?</div><div class="it">${iaTime()}</div></div>`;
  iaH = [];
  document.getElementById('iaSugs').style.display = 'flex';
}
</script>

<%- include('../partials/footer') %>
