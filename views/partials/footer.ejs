<% const isAdminPage = typeof isAdmin !== 'undefined' && isAdmin; %>

<% if (!isAdminPage) { %>
</main>

<!-- FOOTER -->
<footer style="background:#060606;padding:70px 40px 40px;position:relative;overflow:hidden;margin-top:80px">
  <div style="position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,transparent,var(--pink),var(--pink-light),transparent);filter:url(#gb)"></div>

  <!-- Logo figure (decorative) -->
  <div style="display:flex;justify-content:center;margin-bottom:60px">
    <div style="font-family:'Permanent Marker',cursive;font-size:clamp(48px,8vw,80px);color:var(--pink);letter-spacing:8px;text-shadow:0 0 40px rgba(233,30,140,0.4),0 0 80px rgba(233,30,140,0.15);filter:url(#gb)">
      <%= sitio.nombre_tienda || 'MANTIZ' %>
    </div>
  </div>

  <div style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr auto auto auto;gap:60px;padding-left:0;flex-wrap:wrap">
    <!-- Brand -->
    <div>
      <div style="font-family:'Bebas Neue',sans-serif;font-size:14px;letter-spacing:4px;color:var(--pink);margin-bottom:12px">MANTIZ</div>
      <p style="font-size:13px;color:var(--gray);line-height:1.8;letter-spacing:0.5px;max-width:280px">Tu tienda de moda con estilo urbano. Descubre las últimas tendencias.</p>
      <div style="display:flex;gap:12px;margin-top:20px">
        <a href="#" style="width:36px;height:36px;border:2px solid rgba(255,255,255,0.3);display:flex;align-items:center;justify-content:center;color:var(--white);text-decoration:none;transition:all 0.2s;filter:url(#gb)" onmouseover="this.style.borderColor='var(--pink)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.3)'">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
        <a href="#" style="width:36px;height:36px;border:2px solid rgba(255,255,255,0.3);display:flex;align-items:center;justify-content:center;color:var(--white);text-decoration:none;transition:all 0.2s;filter:url(#gb)" onmouseover="this.style.borderColor='var(--pink)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.3)'">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.17 8.17 0 004.78 1.52V6.73a4.85 4.85 0 01-1.01-.04z"/></svg>
        </a>
        <a href="#" style="width:36px;height:36px;border:2px solid rgba(255,255,255,0.3);display:flex;align-items:center;justify-content:center;color:var(--white);text-decoration:none;transition:all 0.2s;filter:url(#gb)" onmouseover="this.style.borderColor='#25d366';this.style.color='#25d366'" onmouseout="this.style.borderColor='rgba(255,255,255,0.3)';this.style.color='var(--white)'">
          <i class="fab fa-whatsapp" style="font-size:15px"></i>
        </a>
      </div>
      <!-- Newsletter -->
      <div style="display:flex;margin-top:20px;gap:0">
        <input type="email" placeholder="@ejemplo.com" style="flex:1;background:rgba(255,255,255,0.05);border:2px solid rgba(255,255,255,0.2);border-right:none;color:var(--white);padding:8px 14px;font-family:'Rajdhani',sans-serif;font-size:13px;outline:none">
        <button style="background:var(--pink);border:2px solid white;color:white;padding:8px 16px;font-family:'Bebas Neue',sans-serif;font-size:14px;letter-spacing:2px;cursor:pointer;transition:background 0.2s;filter:url(#gb)" onmouseover="this.style.background='var(--pink-light)'" onmouseout="this.style.background='var(--pink)'">SUB</button>
      </div>
    </div>

    <!-- Services -->
    <div>
      <h4 style="font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:3px;color:var(--pink);margin-bottom:16px">TIENDA</h4>
      <a href="/productos" style="display:block;color:rgba(240,240,240,0.6);text-decoration:none;font-size:13px;letter-spacing:1px;margin-bottom:8px;transition:color 0.2s" onmouseover="this.style.color='var(--pink)'" onmouseout="this.style.color='rgba(240,240,240,0.6)'">Todos los Productos</a>
      <% ['Camisetas','Pantalones','Chaquetas','Vestidos','Hoodies'].forEach(c => { %>
      <a href="/productos?categoria=<%= c %>" style="display:block;color:rgba(240,240,240,0.6);text-decoration:none;font-size:13px;letter-spacing:1px;margin-bottom:8px;transition:color 0.2s" onmouseover="this.style.color='var(--pink)'" onmouseout="this.style.color='rgba(240,240,240,0.6)'"><%= c %></a>
      <% }) %>
    </div>

    <!-- Account -->
    <div>
      <h4 style="font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:3px;color:var(--pink);margin-bottom:16px">CUENTA</h4>
      <% if (user) { %>
      <a href="/perfil" style="display:block;color:rgba(240,240,240,0.6);text-decoration:none;font-size:13px;letter-spacing:1px;margin-bottom:8px;transition:color 0.2s" onmouseover="this.style.color='var(--pink)'" onmouseout="this.style.color='rgba(240,240,240,0.6)'">Mi Perfil</a>
      <a href="/pedidos" style="display:block;color:rgba(240,240,240,0.6);text-decoration:none;font-size:13px;letter-spacing:1px;margin-bottom:8px;transition:color 0.2s" onmouseover="this.style.color='var(--pink)'" onmouseout="this.style.color='rgba(240,240,240,0.6)'">Mis Pedidos</a>
      <a href="/carrito" style="display:block;color:rgba(240,240,240,0.6);text-decoration:none;font-size:13px;letter-spacing:1px;margin-bottom:8px;transition:color 0.2s" onmouseover="this.style.color='var(--pink)'" onmouseout="this.style.color='rgba(240,240,240,0.6)'">Mi Carrito</a>
      <% } else { %>
      <a href="/auth/login" style="display:block;color:rgba(240,240,240,0.6);text-decoration:none;font-size:13px;letter-spacing:1px;margin-bottom:8px;transition:color 0.2s" onmouseover="this.style.color='var(--pink)'" onmouseout="this.style.color='rgba(240,240,240,0.6)'">Iniciar Sesión</a>
      <a href="/auth/registro" style="display:block;color:rgba(240,240,240,0.6);text-decoration:none;font-size:13px;letter-spacing:1px;margin-bottom:8px;transition:color 0.2s" onmouseover="this.style.color='var(--pink)'" onmouseout="this.style.color='rgba(240,240,240,0.6)'">Registrarse</a>
      <% } %>
      <a href="/tiendas" style="display:block;color:rgba(240,240,240,0.6);text-decoration:none;font-size:13px;letter-spacing:1px;margin-bottom:8px;transition:color 0.2s" onmouseover="this.style.color='var(--pink)'" onmouseout="this.style.color='rgba(240,240,240,0.6)'">Nuestras Tiendas</a>
      <a href="/ia/chat" style="display:block;color:rgba(240,240,240,0.6);text-decoration:none;font-size:13px;letter-spacing:1px;margin-bottom:8px;transition:color 0.2s" onmouseover="this.style.color='var(--pink)'" onmouseout="this.style.color='rgba(240,240,240,0.6)'">Asistente IA</a>
    </div>

    <!-- Envíos -->
    <div>
      <h4 style="font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:3px;color:var(--pink);margin-bottom:16px">ENVÍOS</h4>
      <div style="font-size:13px;color:rgba(240,240,240,0.6);letter-spacing:0.5px;margin-bottom:10px"><i class="bi bi-truck me-2" style="color:var(--pink)"></i>Envío $8.99</div>
      <div style="font-size:13px;color:rgba(240,240,240,0.6);letter-spacing:0.5px;margin-bottom:10px"><i class="bi bi-clock me-2" style="color:var(--pink)"></i>3-7 días hábiles</div>
      <div style="font-size:13px;color:rgba(240,240,240,0.6);letter-spacing:0.5px;margin-bottom:10px"><i class="bi bi-arrow-counterclockwise me-2" style="color:var(--pink)"></i>7 días devolución</div>
      <div style="display:flex;gap:8px;margin-top:16px;flex-wrap:wrap">
        <i class="fab fa-cc-visa fa-2x" style="color:#1a73e8"></i>
        <i class="fab fa-cc-mastercard fa-2x" style="color:#eb5424"></i>
        <i class="fab fa-cc-paypal fa-2x" style="color:#009cde"></i>
        <i class="fas fa-money-bill-wave fa-2x" style="color:#4caf50"></i>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div style="max-width:1200px;margin:48px auto 0;padding-top:20px;border-top:2px solid rgba(255,255,255,0.07);font-size:11px;color:var(--gray);letter-spacing:1px;text-align:center;position:relative;z-index:1">
    © <%= new Date().getFullYear() %> <%= sitio.nombre_tienda || 'MANTIZ' %> · TODOS LOS DERECHOS RESERVADOS · HECHO CON <i class="bi bi-heart-fill" style="color:var(--pink)"></i> EN COLOMBIA
  </div>
</footer>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<% } else { %>
    </div><!-- end admin content padding -->
  </div><!-- end admin-content -->
</div><!-- end admin-wrapper -->
<% } %>
