<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%
    // ── SEO: valores por página con fallback al default global del sitio ──
    // Cada controlador puede pasar `metaDescription`/`ogImage`/`ogType` como
    // locals para personalizar cómo se ve la página al compartirse (WhatsApp,
    // Twitter, Facebook, etc). Si no los pasa, se usa el default de
    // configuracion_sitio (clave meta_descripcion/og_image).
    var pageTitle = title + ' | ' + (sitio.nombre_tienda || 'MANTIZ');
    var pageDesc = (typeof metaDescription !== 'undefined' && metaDescription)
      ? metaDescription
      : (sitio.meta_descripcion || 'MANTIZ — Moda urbana y streetwear Y2K. Ropa, accesorios y piezas exclusivas con probador virtual y modelos 3D.');
    var pageKeywords = (typeof metaKeywords !== 'undefined' && metaKeywords) ? metaKeywords : (sitio.meta_keywords || 'mantiz, ropa y2k, streetwear, moda urbana');
    var pageOgType = (typeof ogType !== 'undefined' && ogType) ? ogType : 'website';
    var pageOgImageRaw = (typeof ogImage !== 'undefined' && ogImage) ? ogImage : (sitio.og_image || '');
    var pageOgImage = pageOgImageRaw
      ? (pageOgImageRaw.indexOf('http') === 0 ? pageOgImageRaw : (baseUrl + pageOgImageRaw))
      : (baseUrl + '/img/og-default.png'); // fallback estático (ver nota en CAMBIOS_SEO.md)
    var pageCanonical = (typeof canonicalUrlOverride !== 'undefined' && canonicalUrlOverride) ? canonicalUrlOverride : canonicalUrl;
    var pageNoindex = (typeof noindex !== 'undefined' && noindex) ? true : false;
  %>
  <title><%= pageTitle %></title>
  <meta name="description" content="<%= pageDesc %>">
  <meta name="keywords" content="<%= pageKeywords %>">
  <link rel="canonical" href="<%= pageCanonical %>">
  <% if (pageNoindex) { %><meta name="robots" content="noindex, nofollow"><% } else { %><meta name="robots" content="index, follow"><% } %>

  <!-- Favicon: SVG inline con el color de marca actual, sin depender de ningún archivo subido -->
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='<%= encodeURIComponent(sitio.color_primario || '#e91e8c') %>'/><text x='50' y='68' font-family='Arial,sans-serif' font-size='58' font-weight='900' fill='white' text-anchor='middle'>M</text></svg>">

  <!-- PWA: manifest + theme-color (instalación + notificaciones push) -->
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="<%= sitio.color_primario || '#e91e8c' %>">

  <!-- Open Graph -->
  <meta property="og:type" content="<%= pageOgType %>">
  <meta property="og:title" content="<%= pageTitle %>">
  <meta property="og:description" content="<%= pageDesc %>">
  <meta property="og:image" content="<%= pageOgImage %>">
  <meta property="og:url" content="<%= pageCanonical %>">
  <meta property="og:site_name" content="<%= sitio.nombre_tienda || 'MANTIZ' %>">
  <meta property="og:locale" content="es_CO">
  <% if (typeof ogPrice !== 'undefined' && ogPrice) { %>
  <meta property="product:price:amount" content="<%= ogPrice %>">
  <meta property="product:price:currency" content="COP">
  <% } %>

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= pageTitle %>">
  <meta name="twitter:description" content="<%= pageDesc %>">
  <meta name="twitter:image" content="<%= pageOgImage %>">

  <!-- JSON-LD: Organization (siempre presente, ayuda a Google a entender la marca).
       Usa el og_image GLOBAL del sitio (configuracion_sitio), nunca la imagen
       específica de la página actual (ej. la foto de un producto no es el
       logo de la empresa, aunque sí sea el og:image correcto para esa página). -->
  <% var orgLogo = sitio.og_image ? (sitio.og_image.indexOf('http') === 0 ? sitio.og_image : (baseUrl + sitio.og_image)) : undefined; %>
  <script type="application/ld+json"><%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": sitio.nombre_tienda || 'MANTIZ',
    "url": baseUrl,
    "logo": orgLogo
  }) %></script>
  <!-- JSON-LD adicional específico de la página (p.ej. Product, BreadcrumbList) -->
  <% if (typeof jsonLd !== 'undefined' && jsonLd) { %>
  <script type="application/ld+json"><%- JSON.stringify(jsonLd) %></script>
  <% } %>

  <!-- ── Resource hints: reducen latencia de CDN en la primera carga ─────── -->
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="dns-prefetch" href="https://cdn.jsdelivr.net">
  <link rel="dns-prefetch" href="https://unpkg.com">
  <!-- ───────────────────────────────────────────────────────────────────── -->
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Permanent+Marker&family=Bebas+Neue&family=Rajdhani:wght@300;400;500;600;700&display=swap">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
  <!-- Bootstrap only for admin -->
  <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <% } %>
  <style>
    :root {
      --black: #0a0a0a;
      --dark: #111111;
      --dark2: #0d0d0d;
      --dark3: #151515;
      --card-bg: #1a1a1a;
      --card: rgba(255,255,255,0.03);
      --pink: <%= sitio.color_primario || '#e91e8c' %>;
      --pink-light: #ff3da6;
      --white: #f0f0f0;
      --gray: #888;
      --border: rgba(233,30,140,0.2);
      --text: #e8e8f0;
      --muted: #888;
      --sw: 252px;
      --cp: <%= sitio.color_primario || '#e91e8c' %>;
      --ca: <%= sitio.color_acento || '#ff5cb8' %>;
      --color-primary: <%= sitio.color_primario || '#e91e8c' %>;
      --fd: 'Bebas Neue', sans-serif;
      --fb: 'Rajdhani', sans-serif;
      --fm: 'Rajdhani', sans-serif;
      /* Variables "faint" para elementos sutiles sobre fondo que SÍ cambia
         con el tema: bordes hairline, divisores, íconos/estrellas/puntos
         inactivos. Antes estos casos usaban rgba(255,255,255,X) fijo
         directamente, lo que los volvía invisibles en modo claro (texto
         casi-blanco sobre fondo casi-blanco). Usar estas variables en vez
         del rgba fijo hace que el elemento se vea bien en ambos temas. */
      --faint-1: rgba(255,255,255,0.07);  /* divisores/hairlines sutiles */
      --faint-2: rgba(255,255,255,0.15);  /* bordes/íconos inactivos */
      --faint-3: rgba(255,255,255,0.2);   /* estrellas/dots inactivos, algo más visibles */
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { background: var(--black); color: var(--white); font-family: 'Rajdhani', sans-serif; overflow-x: hidden; }
    ::-webkit-scrollbar { width: 4px; height: 4px; }
    ::-webkit-scrollbar-track { background: var(--dark); }
    ::-webkit-scrollbar-thumb { background: var(--pink); }

    /* ── NAVBAR ── */
    #navbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      background: rgba(8,8,12,0.32);
      backdrop-filter: blur(16px) saturate(160%) brightness(0.92);
      -webkit-backdrop-filter: blur(16px) saturate(160%) brightness(0.92);
      border-bottom: 1px solid rgba(233,30,140,0.10);
      height: 64px; transition: transform 0.4s cubic-bezier(0.4,0,0.2,1), background 0.35s ease, backdrop-filter 0.35s ease;
    }
    #navbar:hover {
      background: rgba(10,10,18,0.74);
      backdrop-filter: blur(26px) saturate(200%) brightness(0.86);
      -webkit-backdrop-filter: blur(26px) saturate(200%) brightness(0.86);
    }
    /* navbar border line removed */
    #navbar.hidden { transform: translateY(-100%); }
    #navbar.scrolled { background: rgba(10,10,10,0.92) !important; backdrop-filter: blur(20px) saturate(180%) !important; }
    .nav-inner { display: flex; align-items: center; height: 64px; padding: 0 32px; gap: 16px; }
    .nav-left { display: flex; gap: 28px; flex: 1; }
    .nav-left a {
      color: var(--white); text-decoration: none; font-family: 'Rajdhani', sans-serif;
      font-weight: 600; font-size: 13px; letter-spacing: 2px; text-transform: uppercase;
      transition: color 0.2s; position: relative;
    }
    .nav-left a::after {
      content: ''; position: absolute; bottom: -4px; left: 0;
      width: 0; height: 1px; background: var(--pink); transition: width 0.3s;
    }
    .nav-left a:hover { color: var(--pink); }
    .nav-left a:hover::after { width: 100%; }
    .nav-logo {
      font-family: 'Permanent Marker', cursive; font-size: 32px; color: var(--pink);
      letter-spacing: 1px; text-decoration: none; position: absolute;
      left: 50%; transform: translateX(-50%);
      text-shadow: 0 0 20px rgba(233,30,140,0.5);
    }
    .nav-right { display: flex; align-items: center; gap: 16px; flex: 1; justify-content: flex-end; }
    .nav-btn {
      background: none; border: none; color: var(--white); cursor: pointer;
      font-size: 18px; padding: 6px; transition: color 0.2s, transform 0.2s; position: relative; line-height: 1;
    }
    .nav-btn:hover { color: var(--pink); transform: scale(1.1); }
    .theme-toggle-btn {
      background: none; border: 1px solid var(--border); color: var(--white);
      width: 34px; height: 34px; border-radius: 50%; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      font-size: 15px; transition: all 0.2s; flex-shrink: 0;
    }
    .theme-toggle-btn:hover { border-color: var(--pink); color: var(--pink); background: rgba(233,30,140,0.08); }
    .cart-count {
      position: absolute; top: -4px; right: -4px; background: var(--pink); color: white;
      font-size: 9px; width: 16px; height: 16px; border-radius: 50%;
      display: none; align-items: center; justify-content: center; font-weight: 700;
    }
    .cart-count.show { display: flex; }
    .login-btn {
      background: transparent; border: 2px solid var(--pink); color: var(--pink);
      padding: 6px 18px; font-family: 'Rajdhani', sans-serif; font-weight: 600;
      font-size: 12px; letter-spacing: 2px; text-transform: uppercase; cursor: pointer;
      transition: all 0.2s; text-decoration: none; display: inline-flex; align-items: center;
      filter: url(#gb);
    }
    .login-btn:hover { color: white; background: var(--pink); }
    .user-btn {
      background: none; border: 1px solid var(--border); color: var(--white);
      padding: 4px 12px 4px 6px; font-family: 'Rajdhani', sans-serif; font-weight: 600;
      font-size: 12px; letter-spacing: 1px; cursor: pointer;
      display: flex; align-items: center; gap: 8px; transition: border-color 0.2s; position: relative;
    }
    .user-btn:hover { border-color: var(--pink); }
    .user-btn img { border-radius: 50%; border: 2px solid var(--pink); }
    .user-dropdown {
      position: absolute; top: calc(100% + 8px); right: 0;
      background: rgba(17,17,17,0.98); backdrop-filter: blur(20px);
      border: 1px solid var(--border); min-width: 180px; z-index: 2000; display: none;
    }
    .user-dropdown.open { display: block; }
    .user-dropdown a {
      display: flex; align-items: center; gap: 10px; padding: 12px 16px;
      color: var(--white); text-decoration: none; font-size: 12px;
      letter-spacing: 1px; font-weight: 600; text-transform: uppercase;
      transition: background 0.2s, color 0.2s; border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .user-dropdown a:hover { background: rgba(233,30,140,0.1); color: var(--pink); }

    /* SEARCH */
    #search-bar {
      position: fixed; top: 64px; left: 0; right: 0;
      background: rgba(10,10,10,0.95); backdrop-filter: blur(10px);
      padding: 0 32px; height: 0; overflow: hidden; transition: height 0.3s ease; z-index: 999;
    }
    #search-bar.open { height: 64px; padding: 12px 32px; }
    #search-bar form { position: relative; }
    #search-bar input {
      width: 100%; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.2);
      color: var(--white); padding: 10px 20px; font-family: 'Rajdhani', sans-serif;
      font-size: 15px; letter-spacing: 1px; outline: none;
    }
    #search-bar input::placeholder { color: var(--gray); }
    .search-suggestions {
      position: absolute; top: 100%; left: 0; right: 0;
      background: rgba(17,17,17,0.98); border: 1px solid var(--border);
      z-index: 1000; max-height: 280px; overflow-y: auto; display: none;
    }
    .search-suggestions .item {
      padding: 10px 20px; cursor: pointer; border-bottom: 1px solid rgba(255,255,255,0.05);
      transition: background 0.2s; font-family: 'Rajdhani', sans-serif; font-size: 13px;
    }
    .search-suggestions .item:hover { background: rgba(233,30,140,0.1); color: var(--pink); }

    /* CART PANEL */
    #cart-panel {
      position: fixed; top: 0; right: 0; width: 340px; height: 100vh;
      background: rgba(17,17,17,0.98); backdrop-filter: blur(20px);
      z-index: 1001; transform: translateX(100%);
      transition: transform 0.4s cubic-bezier(0.4,0,0.2,1);
      display: flex; flex-direction: column;
    }
    #cart-panel::before {
      content: ''; position: absolute; inset: 0;
      border-left: 3px solid var(--pink); filter: url(#gb); pointer-events: none; z-index: 10;
    }
    #cart-panel.open { transform: translateX(0); }
    .cart-ph { padding: 20px 24px 12px; border-bottom: 1px solid rgba(255,255,255,0.1); font-family: 'Bebas Neue', sans-serif; font-size: 18px; letter-spacing: 3px; color: var(--pink); display: flex; justify-content: space-between; align-items: center; flex-shrink: 0; }
    .cart-pi { padding: 8px 0; flex: 1; overflow-y: auto; }
    .cart-pf { padding: 20px 24px; border-top: 1px solid rgba(255,255,255,0.1); flex-shrink: 0; }
    .cart-pt { display: flex; justify-content: space-between; margin-bottom: 16px; font-family: 'Bebas Neue', sans-serif; font-size: 20px; letter-spacing: 2px; }
    .cart-pt span:last-child { color: var(--pink); }
    .cart-empty-msg { text-align: center; padding: 40px; color: var(--gray); font-size: 13px; letter-spacing: 1px; }
    .cart-pitem { display: flex; align-items: center; gap: 12px; padding: 12px 24px; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .cart-pitem img { width: 56px; height: 56px; object-fit: cover; border: 1px solid rgba(255,255,255,0.2); flex-shrink: 0; filter: url(#gb); }

    /* GRUNGE BUTTONS */
    .btn-grunge {
      position: relative; background: transparent; border: 2px solid var(--pink);
      color: var(--pink); padding: 12px 40px; font-family: 'Bebas Neue', sans-serif;
      font-size: 15px; letter-spacing: 4px; cursor: pointer; transition: all 0.2s;
      text-transform: uppercase; text-decoration: none; display: inline-flex;
      align-items: center; justify-content: center; isolation: isolate;
    }
    .btn-grunge::after { content: ''; position: absolute; inset: 0; border: 2px solid var(--pink); background: transparent; filter: url(#gb); pointer-events: none; z-index: 2; }
    .btn-grunge:hover { color: white; background: rgba(233,30,140,0.15); }
    .btn-grunge-w {
      position: relative; background: transparent; border: 2px solid var(--text); color: var(--text);
      padding: 14px; font-family: 'Bebas Neue', sans-serif; font-size: 15px; letter-spacing: 4px;
      cursor: pointer; transition: all 0.2s; text-transform: uppercase; width: 100%;
      text-align: center; text-decoration: none; display: block; isolation: isolate;
    }
    .btn-grunge-w::after { content: ''; position: absolute; inset: 0; border: 2px solid var(--text); filter: url(#gb); pointer-events: none; z-index: 2; }
    .btn-grunge-w:hover { color: var(--pink); }
    .btn-grunge-fill {
      position: relative; background: var(--pink); border: 2px solid white; color: white;
      padding: 14px 32px; font-family: 'Bebas Neue', sans-serif; font-size: 16px; letter-spacing: 4px;
      cursor: pointer; transition: all 0.2s; text-transform: uppercase; text-decoration: none;
      display: inline-flex; align-items: center; justify-content: center; isolation: isolate;
    }
    .btn-grunge-fill::after { content: ''; position: absolute; inset: 0; border: 2px solid white; filter: url(#gb); pointer-events: none; z-index: 2; }
    .btn-grunge-fill:hover { background: var(--pink-light); color: white; transform: translateY(-2px); }

    /* PRODUCT CARDS */
    .product-card {
      background: var(--dark); border: none; position: relative; overflow: visible;
      transition: transform 0.3s; cursor: pointer; display: block; text-decoration: none;
    }
    .product-card::before {
      content: ''; position: absolute; inset: -4px; border: 2px solid rgba(255,255,255,0.5);
      z-index: 2; pointer-events: none; filter: url(#gb); transition: border-color 0.3s;
    }
    .product-card:hover::before { border-color: var(--pink); }
    .product-card:hover { transform: translateY(-5px); }
    .pc-label {
      background: var(--pink); padding: 5px 12px;
      display: flex; align-items: center; justify-content: space-between;
      position: relative; z-index: 3; filter: url(#gb);
    }
    .pc-label-text { font-family: 'Bebas Neue', sans-serif; font-size: 14px; letter-spacing: 3px; color: white; }
    .pc-img-wrap { position: relative; overflow: visible; }
    .pc-img-clip { overflow: hidden; position: relative; display: block; }
    .pc-img { width: 100%; aspect-ratio: 3/4; object-fit: cover; display: block; transition: transform 0.5s; position: relative; z-index: 0; }
    .pc-img-hover { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity 0.4s ease; z-index: 2; pointer-events: none; display: block; }
    .product-card:hover .pc-img-hover { opacity: 1; }
    .product-card:hover .pc-img { transform: scale(1.04); }
    .pc-add-btn {
      position: absolute; bottom: -16px; right: 12px;
      width: 32px; height: 32px; background: var(--pink); border: 2px solid white;
      border-radius: 50%; color: white; font-size: 18px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: all 0.2s; z-index: 6; filter: url(#gb); line-height: 1;
    }
    .pc-add-btn:hover { background: white; color: var(--pink); transform: scale(1.15) rotate(90deg); }
    .pc-info { padding: 12px 14px 16px; display: flex; justify-content: space-between; align-items: flex-end; gap: 8px; min-height: 54px; }
    .pc-name { font-family: 'Bebas Neue', sans-serif; font-size: 14px; letter-spacing: 2px; color: var(--white); }
    .pc-price { font-family: 'Bebas Neue', sans-serif; font-size: 16px; color: var(--pink); letter-spacing: 1px; }
    .badge-oferta { font-family: 'Bebas Neue', sans-serif; font-size: 11px; background: var(--pink); color: white; padding: 2px 8px; letter-spacing: 1px; }

    /* SECTION TITLES */
    .section-title {
      font-family: 'Permanent Marker', cursive; font-size: clamp(36px,6vw,52px);
      letter-spacing: 2px; font-weight: lighter; text-align: center; color: var(--pink); margin-bottom: 16px;
    }
    .tribal-divider { text-align: center; margin: 16px 0 40px; opacity: 0.8; }

    /* FORMS */
    .mantiz-input {
      width: 100%; background: rgba(255,255,255,0.04); border: 1px solid var(--border);
      color: var(--white); padding: 12px 16px; font-family: 'Rajdhani', sans-serif;
      font-size: 14px; letter-spacing: 0.5px; outline: none; transition: border-color 0.2s;
    }
    .mantiz-input:focus { border-color: var(--pink); }
    .mantiz-input::placeholder { color: var(--gray); }
    .mantiz-label { display: block; font-size: 11px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--gray); margin-bottom: 6px; }
    .mantiz-select { width: 100%; background: rgba(255,255,255,0.04); border: 1px solid var(--border); color: var(--white); padding: 12px 16px; font-family: 'Rajdhani', sans-serif; font-size: 14px; outline: none; cursor: pointer; }
    .mantiz-select:focus { border-color: var(--pink); }
    .mantiz-select option { background: var(--dark); }
    textarea.mantiz-input { resize: vertical; }

    /* ALERTS */
    .alert-mantiz { padding: 12px 16px; font-family: 'Rajdhani', sans-serif; font-weight: 600; font-size: 13px; letter-spacing: 0.5px; margin-bottom: 16px; }
    .alert-success { background: rgba(0,255,100,0.07); color: #00ff64; border: 1px solid rgba(0,255,100,0.2); }
    .alert-danger  { background: rgba(255,60,60,0.07);  color: #ff6060; border: 1px solid rgba(255,60,60,0.2); }
    .alert-warning { background: rgba(255,200,0,0.07);  color: #ffc800; border: 1px solid rgba(255,200,0,0.2); }
    .alert-info    { background: rgba(0,200,255,0.07);  color: #00c8ff; border: 1px solid rgba(0,200,255,0.2); }

    /* TABLES */
    .mantiz-table { width: 100%; border-collapse: collapse; }
    .mantiz-table thead th { background: rgba(17,17,17,0.8); color: var(--pink); padding: 10px 14px; font-family: 'Bebas Neue', sans-serif; font-size: 12px; letter-spacing: 2px; text-transform: uppercase; border-bottom: 1px solid var(--border); }
    .mantiz-table tbody td { padding: 12px 14px; border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 13px; color: var(--white); vertical-align: middle; }
    .mantiz-table tbody tr:hover td { background: rgba(233,30,140,0.04); }

    /* TOAST */
    #toast {
      position: fixed; bottom: 32px; left: 50%;
      transform: translateX(-50%) translateY(80px); background: var(--pink);
      color: white; padding: 12px 32px; font-family: 'Bebas Neue', sans-serif;
      font-size: 16px; letter-spacing: 3px; z-index: 9999;
      transition: transform 0.4s cubic-bezier(0.4,0,0.2,1); pointer-events: none; filter: url(#gb);
    }
    #toast.show { transform: translateX(-50%) translateY(0); }

    /* CHAT FAB */
    .chat-fab {
      position: fixed; bottom: 24px; right: 24px; width: 54px; height: 54px;
      border-radius: 50%; background: var(--pink); color: white; border: 2px solid rgba(255,255,255,0.3);
      font-size: 1.3rem; display: flex; align-items: center; justify-content: center;
      z-index: 2000; box-shadow: 0 4px 20px rgba(233,30,140,0.6); cursor: pointer;
      transition: all 0.3s; filter: url(#gb); animation: fabP 3s infinite;
    }
    @keyframes fabP { 0%,100%{box-shadow:0 4px 20px rgba(233,30,140,0.6)} 50%{box-shadow:0 4px 30px rgba(233,30,140,0.9),0 0 40px rgba(233,30,140,0.4)} }
    .chat-fab:hover { transform: scale(1.1); animation: none; }
    .chat-window {
      position: fixed; bottom: 90px; right: 24px; width: 340px; height: 480px;
      background: rgba(17,17,17,0.98); border: 1px solid var(--border);
      box-shadow: 0 20px 60px rgba(0,0,0,0.8); z-index: 1999;
      display: none; flex-direction: column; overflow: hidden;
    }
    .chat-window.active { display: flex; }
    .chat-header-bar { background: var(--pink); color: white; padding: 14px 16px; font-family: 'Bebas Neue', sans-serif; font-size: 14px; letter-spacing: 3px; display: flex; justify-content: space-between; align-items: center; }
    .chat-messages { flex: 1; overflow-y: auto; padding: 14px; display: flex; flex-direction: column; gap: 10px; }
    .chat-msg { max-width: 84%; padding: 10px 14px; font-size: 13px; line-height: 1.5; font-family: 'Rajdhani', sans-serif; }
    .chat-msg.user { background: var(--pink); color: white; align-self: flex-end; }
    .chat-msg.bot { background: rgba(255,255,255,0.06); color: var(--white); align-self: flex-start; border-left: 2px solid var(--pink); }
    .chat-input-row { padding: 12px; border-top: 1px solid rgba(255,255,255,0.08); display: flex; gap: 8px; background: rgba(0,0,0,0.3); }
    .chat-input-row input { flex: 1; background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: var(--white); padding: 8px 12px; font-family: 'Rajdhani', sans-serif; font-size: 13px; outline: none; }
    .chat-send-btn { background: var(--pink); border: none; color: white; width: 36px; height: 36px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s; }
    .chat-send-btn:hover { background: var(--pink-light); }

    /* IA CHATBOT FAB (asistente virtual, independiente del chat de soporte) */
    .ia-fab {
      position: fixed; bottom: 24px; right: 24px; width: 54px; height: 54px;
      border-radius: 50%; background: linear-gradient(135deg, var(--pink), #c2185b); color: white; border: 2px solid rgba(255,255,255,0.3);
      font-size: 1.3rem; display: flex; align-items: center; justify-content: center;
      z-index: 2001; box-shadow: 0 4px 20px rgba(233,30,140,0.6); cursor: pointer;
      transition: all 0.3s; filter: url(#gb); animation: fabP 3s infinite;
    }
    .ia-fab:hover { transform: scale(1.1); animation: none; }
    /* Si el fab de soporte también está visible, lo empujamos a la izquierda */
    .chat-fab ~ .ia-fab, .ia-fab:has(~ .chat-fab) { right: 90px; }
    .ia-fab-window {
      position: fixed; bottom: 90px; right: 24px; width: 340px; height: 480px;
      background: rgba(17,17,17,0.98); border: 1px solid var(--border);
      box-shadow: 0 20px 60px rgba(0,0,0,0.8); z-index: 2000;
      display: none; flex-direction: column; overflow: hidden;
    }
    .ia-fab-window.active { display: flex; }
    .ia-fab-hdr { background: linear-gradient(90deg,var(--pink),#c2185b); color: white; padding: 14px 16px; font-family: 'Bebas Neue', sans-serif; font-size: 14px; letter-spacing: 3px; display: flex; justify-content: space-between; align-items: center; flex-shrink:0; }
    .ia-fab-hdr small { display:block; font-family:'Rajdhani',sans-serif; font-size:10px; letter-spacing:1px; opacity:.85; font-weight:400; }
    .ia-fab-close { background:rgba(255,255,255,.15); border:none; color:white; width:26px; height:26px; border-radius:50%; cursor:pointer; font-size:14px; display:flex; align-items:center; justify-content:center; }
    .ia-fab-msgs { flex: 1; overflow-y: auto; padding: 14px; display: flex; flex-direction: column; gap: 10px; }
    .ia-fab-msg { max-width: 84%; padding: 10px 14px; font-size: 13px; line-height: 1.5; font-family: 'Rajdhani', sans-serif; }
    .ia-fab-msg.user { background: var(--pink); color: white; align-self: flex-end; }
    .ia-fab-msg.bot { background: rgba(255,255,255,0.06); color: var(--white); align-self: flex-start; border-left: 2px solid var(--pink); }
    .ia-fab-typing { align-self:flex-start; display:none; gap:5px; align-items:center; background: rgba(255,255,255,0.06); border-left: 2px solid var(--pink); padding:10px 14px; }
    .ia-fab-typing.show { display:flex; }
    .ia-fab-typing span { width:6px; height:6px; border-radius:50%; background:var(--pink); animation:iadot 1.2s infinite; }
    .ia-fab-typing span:nth-child(2){animation-delay:.2s} .ia-fab-typing span:nth-child(3){animation-delay:.4s}
    @keyframes iadot{0%,60%,100%{transform:translateY(0);opacity:.35}30%{transform:translateY(-6px);opacity:1}}
    .ia-fab-input-row { padding: 12px; border-top: 1px solid rgba(255,255,255,0.08); display: flex; gap: 8px; background: rgba(0,0,0,0.3); flex-shrink:0; }
    .ia-fab-input-row input { flex: 1; background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: var(--white); padding: 8px 12px; font-family: 'Rajdhani', sans-serif; font-size: 13px; outline: none; }
    .ia-fab-input-row input:focus { border-color: var(--pink); }
    .ia-fab-send { background: var(--pink); border: none; color: white; width: 36px; height: 36px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s; flex-shrink:0; }
    .ia-fab-send:hover { background: #c2185b; }
    .ia-fab-send:disabled { opacity:.5; cursor:not-allowed; }
    @media(max-width:767px){ .ia-fab{ display:none !important; } .ia-fab-window{ display:none !important; } }

    /* HAMBURGER */
    .hamburger-btn { display: none; background: none; border: none; color: var(--white); cursor: pointer; padding: 6px; flex-direction: column; gap: 5px; }
    .hamburger-btn span { display: block; width: 22px; height: 2px; background: var(--white); transition: all 0.3s ease; transform-origin: center; }
    .hamburger-btn.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger-btn.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
    .hamburger-btn.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
    #mobile-menu { display: none; position: fixed; top: 64px; left: 0; right: 0; background: rgba(10,10,10,0.98); backdrop-filter: blur(16px); z-index: 1000; transform: translateY(-110%); transition: transform 0.4s cubic-bezier(0.4,0,0.2,1); border-bottom: 1px solid var(--border); pointer-events: none; }
    #mobile-menu.open { transform: translateY(0); pointer-events: all; }
    .mobile-menu-inner { display: flex; flex-direction: column; padding: 8px 0 24px; }
    .mobile-menu-inner a { color: var(--white); text-decoration: none; font-family: 'Rajdhani', sans-serif; font-weight: 600; font-size: 15px; letter-spacing: 3px; text-transform: uppercase; padding: 14px 28px; border-bottom: 1px solid rgba(255,255,255,0.04); transition: color 0.2s, background 0.2s; }
    .mobile-menu-inner a:hover { color: var(--pink); background: rgba(233,30,140,0.05); }

    /* ADMIN */
    .admin-wrapper { display: flex; min-height: 100vh; }
    .admin-sidebar { width: var(--sw); background: #0a0a0a; border-right: 1px solid var(--border); position: fixed; top: 0; left: 0; height: 100vh; overflow-y: auto; z-index: 999; display: flex; flex-direction: column; transition: transform 0.3s; }
    .admin-sidebar::-webkit-scrollbar { width: 2px; }
    .admin-sidebar::-webkit-scrollbar-thumb { background: var(--pink); }
    .admin-content { margin-left: var(--sw); flex: 1; min-height: 100vh; }
    .sl-logo { padding: 20px 18px 16px; border-bottom: 1px solid var(--border); position: relative; }
    .sl-logo::after { content: ''; position: absolute; bottom: 0; left: 18px; right: 18px; height: 1px; background: linear-gradient(90deg,var(--pink),transparent); }
    .sl-brand { font-family: 'Permanent Marker', cursive; font-size: 1.2rem; color: var(--pink); letter-spacing: 2px; text-shadow: 0 0 15px rgba(233,30,140,0.5); }
    .sl-sub { font-family: 'Bebas Neue', sans-serif; font-size: 9px; color: var(--muted); letter-spacing: 3px; text-transform: uppercase; margin-top: 3px; }
    .sl-section { font-size: 9px; color: var(--muted); text-transform: uppercase; letter-spacing: 2px; padding: 14px 18px 5px; font-family: 'Bebas Neue', sans-serif; }
    .sl-link { display: flex; align-items: center; gap: 10px; padding: 9px 18px; color: var(--muted); text-decoration: none; font-family: 'Rajdhani', sans-serif; font-weight: 600; font-size: 13px; letter-spacing: 0.5px; transition: all 0.2s; border-left: 2px solid transparent; }
    .sl-link:hover { color: var(--white); background: rgba(233,30,140,0.07); border-left-color: var(--pink); }
    .sl-link.active { color: var(--pink); background: rgba(233,30,140,0.1); border-left-color: var(--pink); }
    .sl-badge { margin-left: auto; background: var(--pink); color: white; font-size: 9px; padding: 2px 6px; font-family: 'Bebas Neue', sans-serif; }
    .sl-bottom { margin-top: auto; padding: 14px 18px; border-top: 1px solid var(--border); }
    .sl-user { display: flex; align-items: center; gap: 10px; padding: 10px 12px; background: rgba(255,255,255,0.03); border: 1px solid var(--border); text-decoration: none; transition: border-color 0.2s; }
    .sl-user:hover { border-color: var(--pink); }
    .sl-name { color: var(--white); font-weight: 600; font-size: 13px; }
    .sl-role { color: var(--pink); font-size: 9px; letter-spacing: 2px; text-transform: uppercase; }
    .admin-topbar { background: rgba(10,10,10,0.97); border-bottom: 1px solid var(--border); padding: 12px 22px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; backdrop-filter: blur(10px); }
    .admin-topbar::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg,transparent,var(--pink),transparent); }
    .page-title { font-family: 'Bebas Neue', sans-serif; font-size: 14px; color: var(--white); letter-spacing: 3px; text-transform: uppercase; }
    .page-bc { font-size: 10px; color: var(--muted); letter-spacing: 1px; }
    .sidebar-toggle-btn { display: none; background: none; border: none; color: var(--white); font-size: 1.4rem; padding: 4px; cursor: pointer; }
    .stat-card { background: rgba(255,255,255,0.03); border: 1px solid var(--border); padding: 20px; transition: all 0.3s; }
    .stat-card:hover { border-color: var(--pink); box-shadow: 0 10px 30px rgba(233,30,140,0.15); transform: translateY(-2px); }
    .stat-value { font-family: 'Bebas Neue', sans-serif; font-size: 2rem; color: var(--white); letter-spacing: 2px; }
    .stat-label { font-size: 9px; color: var(--muted); text-transform: uppercase; letter-spacing: 3px; margin-top: 4px; font-family: 'Rajdhani', sans-serif; font-weight: 600; }

    /* UTILITIES */
    .text-pink { color: var(--pink) !important; }
    .bebas { font-family: 'Bebas Neue', sans-serif !important; }
    .pm { font-family: 'Permanent Marker', cursive !important; }
    .stars { color: #ffd700; }

    /* ── BOOTSTRAP ALIASES FOR ADMIN ── */
    .btn-primary-mantiz,.btn-pm { background: linear-gradient(135deg,var(--pink),var(--pink-light)); border: none; color: white; font-family: 'Rajdhani',sans-serif; font-weight: 700; font-size:.82rem; letter-spacing: 1px; text-transform: uppercase; transition: all .3s; }
    .btn-primary-mantiz:hover,.btn-pm:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(233,30,140,.5); color: white; }
    .btn-outline-mantiz,.btn-om { border: 1px solid var(--pink); color: var(--pink); font-family: 'Rajdhani',sans-serif; font-weight: 700; font-size:.82rem; letter-spacing: 1px; text-transform: uppercase; transition: all .3s; background: transparent; }
    .btn-outline-mantiz:hover,.btn-om:hover { background: var(--pink); color: white; }
    .card { background: rgba(255,255,255,0.03) !important; border: 1px solid var(--border) !important; }
    .card-dark { background: rgba(255,255,255,0.02); border: 1px solid var(--border); }
    .card-body { color: var(--white); }
    .card-producto { background: rgba(255,255,255,0.03); border: 1px solid var(--border) !important; overflow: hidden; transition: all .35s; }
    .card-producto:hover { transform: translateY(-4px); border-color: var(--pink) !important; box-shadow: 0 20px 50px rgba(233,30,140,.2); }
    .form-control,.form-select { background: rgba(255,255,255,0.04) !important; border: 1px solid var(--border) !important; color: var(--white) !important; font-family: 'Rajdhani',sans-serif; }
    .form-control:focus,.form-select:focus { background: rgba(255,255,255,0.06) !important; border-color: var(--pink) !important; box-shadow: 0 0 0 3px rgba(233,30,140,.15) !important; color: var(--white) !important; }
    .form-control::placeholder { color: var(--muted) !important; }
    .form-label { color: var(--text); font-weight: 600; font-size:.82rem; letter-spacing:.5px; text-transform: uppercase; }
    .table { color: var(--white) !important; }
    .table thead th { background: rgba(17,17,17,.8) !important; color: var(--pink) !important; border-color: var(--border) !important; font-family: 'Bebas Neue',sans-serif; font-size:.7rem; text-transform: uppercase; letter-spacing: 1px; }
    .table tbody tr { border-color: var(--border) !important; }
    .table tbody td { border-color: var(--border) !important; background: transparent !important; vertical-align: middle; }
    .table-hover tbody tr:hover td { background: rgba(233,30,140,.04) !important; }
    .alert { border: none; font-family: 'Rajdhani',sans-serif; font-weight: 600; }
    .alert-success { background: rgba(0,255,100,.08); color: #00ff64; border: 1px solid rgba(0,255,100,.2) !important; }
    .alert-danger  { background: rgba(255,60,60,.08);  color: #ff6060; border: 1px solid rgba(255,60,60,.2) !important; }
    .alert-warning { background: rgba(255,200,0,.08);  color: #ffc800; border: 1px solid rgba(255,200,0,.2) !important; }
    .alert-info    { background: rgba(0,200,255,.08);  color: #00c8ff; border: 1px solid rgba(0,200,255,.2) !important; }
    .badge { font-family: 'Bebas Neue',sans-serif; letter-spacing:.5px; }
    .dropdown-menu { background: rgba(17,17,17,.98) !important; border: 1px solid var(--border) !important; }
    .dropdown-item { color: var(--white) !important; font-family: 'Rajdhani',sans-serif; font-weight: 500; transition: all .2s; }
    .dropdown-item:hover { background: rgba(233,30,140,.1) !important; color: var(--pink) !important; }
    .modal-content { background: rgba(17,17,17,.98) !important; border: 1px solid var(--border) !important; }
    .modal-header { border-bottom: 1px solid var(--border) !important; background: rgba(0,0,0,.3) !important; }
    .modal-footer { border-top: 1px solid var(--border) !important; }
    .modal-title { font-family: 'Bebas Neue',sans-serif; letter-spacing: 2px; color: var(--pink); }
    .btn-close { filter: invert(1); }
    .progress { background: rgba(255,255,255,.07) !important; }
    .progress-bar { background: linear-gradient(90deg,var(--pink),var(--pink-light)) !important; }
    .nav-tabs { border-color: var(--border) !important; }
    .nav-tabs .nav-link { color: var(--muted) !important; font-family: 'Rajdhani',sans-serif; font-weight: 600; font-size:.82rem; border: none !important; border-bottom: 2px solid transparent !important; text-transform: uppercase; letter-spacing:.5px; }
    .nav-tabs .nav-link:hover { color: var(--white) !important; background: transparent !important; }
    .nav-tabs .nav-link.active { color: var(--pink) !important; border-bottom-color: var(--pink) !important; background: transparent !important; }
    .accordion-item { background: rgba(255,255,255,.03) !important; border: 1px solid var(--border) !important; margin-bottom: 6px; }
    .accordion-button { background: rgba(255,255,255,.03) !important; color: var(--white) !important; font-family: 'Rajdhani',sans-serif; font-weight: 600; box-shadow: none !important; }
    .accordion-button:not(.collapsed) { color: var(--pink) !important; background: rgba(233,30,140,.05) !important; }
    .accordion-button::after { filter: invert(1) sepia(1) saturate(5) hue-rotate(290deg); }
    .accordion-body { background: rgba(0,0,0,.2) !important; color: var(--white); }
    .text-muted { color: var(--muted) !important; }
    .bg-dark { background: var(--dark) !important; }
    .border { border-color: var(--border) !important; }
    .rounded-4 { border-radius: 4px !important; }
    input[type="color"] { background: transparent; border: 1px solid var(--border); padding: 2px; cursor: pointer; }
    select option { background: var(--dark); color: var(--white); }

    /* ── DARK MODE / LIGHT MODE ── */
    body.light-mode {
      --black: #f5f5f5; --dark: #ebebeb; --dark2: #e0e0e0; --dark3: #d5d5d5;
      --card-bg: #ffffff; --card: #ffffff;
      --white: #1a1a1a; --gray: #555; --border: rgba(0,0,0,0.12);
      --text: #1a1a1a; --muted: #666;
      --faint-1: rgba(0,0,0,0.06);
      --faint-2: rgba(0,0,0,0.13);
      --faint-3: rgba(0,0,0,0.18);
    }
    body.light-mode #navbar { background: rgba(255,255,255,0.95); border-bottom: 1px solid rgba(0,0,0,0.06); }
    body.light-mode #navbar.scrolled { background: rgba(255,255,255,0.98) !important; }
    body.light-mode #search-bar { background: rgba(255,255,255,0.98); }
    body.light-mode #search-bar input { background: rgba(0,0,0,0.04); border-color: rgba(0,0,0,0.12); color: var(--white); }
    body.light-mode .search-suggestions { background: #fff; border-color: rgba(0,0,0,0.1); }
    body.light-mode .search-suggestions .item { border-color: rgba(0,0,0,0.05); }
    body.light-mode #cart-panel,
    body.light-mode .notif-panel,
    body.light-mode .user-dropdown { background: rgba(255,255,255,0.98); }
    body.light-mode .cart-ph, body.light-mode .notif-ph { border-color: rgba(0,0,0,0.08); }
    body.light-mode .cart-pitem, body.light-mode .notif-item { border-color: rgba(0,0,0,0.06); }
    body.light-mode .product-card { background: #fff; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
    body.light-mode .product-card::before { border-color: rgba(0,0,0,0.15); }
    body.light-mode .chat-window { background: rgba(255,255,255,0.98); }
    body.light-mode .chat-msg.bot { background: rgba(0,0,0,0.05); }
    body.light-mode #mobile-menu { background: rgba(255,255,255,0.98); border-color: rgba(0,0,0,0.08); }
    body.light-mode .mobile-menu-inner a { border-color: rgba(0,0,0,0.05); }
    body.light-mode .mantiz-input,
    body.light-mode .mantiz-select { background: rgba(0,0,0,0.03); }
    body.light-mode .user-dropdown a { border-color: rgba(0,0,0,0.05); }
    body.light-mode .chat-social-panel { background: rgba(255,255,255,0.98); }
    body.light-mode .csp-contact { border-color: rgba(0,0,0,0.06); }
    body.light-mode footer { background: #eee !important; }
    body.light-mode footer a, body.light-mode footer p, body.light-mode footer div { color: var(--gray) !important; }
    body.light-mode footer h4 { color: var(--pink) !important; }
    body.light-mode .theme-toggle-btn { border-color: rgba(0,0,0,0.15); }
    body.light-mode .admin-sidebar { background: #f0f0f0; }
    body.light-mode .admin-topbar { background: rgba(255,255,255,0.97); }
    body.light-mode .admin-content { background: var(--black); }
    body.light-mode .sl-link { color: #555; }
    body.light-mode .sl-link:hover, body.light-mode .sl-link.active { color: var(--pink); }
    body.light-mode .stat-card { background: #fff; }
    body.light-mode .card { background: #fff !important; }
    body.light-mode .form-control, body.light-mode .form-select { background: rgba(0,0,0,0.03) !important; }
    body.light-mode .table thead th { background: rgba(0,0,0,0.04) !important; }
    body.light-mode .modal-content { background: #fff !important; }
    body.light-mode .dropdown-menu { background: #fff !important; }
    body.light-mode .accordion-item { background: #fff !important; }
    body.light-mode .accordion-button { background: #fff !important; }
    body.light-mode .accordion-body { background: rgba(0,0,0,0.02) !important; }
    .theme-transition { transition: background 0.3s, color 0.3s, border-color 0.3s; }

    /* ── ADMIN TEXT FIXES ── */
    .admin-content h1, .admin-content h2, .admin-content h3,
    .admin-content h4, .admin-content h5, .admin-content h6,
    .admin-content .fw-bold, .admin-content .fw-semibold { color: var(--text) !important; }
    .admin-content p, .admin-content label, .admin-content span,
    .admin-content td, .admin-content th, .admin-content li { color: var(--text); }
    .admin-content .small, .admin-content small { color: var(--muted) !important; }
    .admin-content .text-dark { color: var(--text) !important; }
    .admin-content .table-light { --bs-table-bg: rgba(17,17,17,0.8); --bs-table-color: var(--pink); }
    .admin-content .table-light th { background: rgba(17,17,17,0.8) !important; color: var(--pink) !important; }
    body.light-mode .admin-content .table-light th { background: rgba(0,0,0,0.05) !important; color: var(--pink) !important; }
    .admin-content .btn-outline-secondary { color: var(--text) !important; border-color: var(--border) !important; }
    .admin-content .btn-outline-secondary:hover { background: rgba(255,255,255,0.08) !important; color: var(--pink) !important; }
    .admin-content .shadow-sm { box-shadow: 0 2px 8px rgba(0,0,0,0.3) !important; }
    body.light-mode .admin-content .shadow-sm { box-shadow: 0 2px 8px rgba(0,0,0,0.08) !important; }
    .admin-content .card { color: var(--text); }
    .admin-content .form-select { color: var(--text) !important; }
    .admin-content .page-link { background: rgba(255,255,255,0.04); border-color: var(--border); color: var(--text); }
    .admin-content .page-link:hover { background: rgba(233,30,140,0.1); color: var(--pink); }

    /* ════════════════════════════════════════════════════════════════════
       MODO CLARO — OVERRIDES GLOBALES DE CONTRASTE (conservador)
       ════════════════════════════════════════════════════════════════════
       IMPORTANTE: este bloque es DELIBERADAMENTE conservador. Una primera
       versión usaba selectores de atributo `[style*="color: white"]` para
       forzar TODO texto blanco a oscuro en modo claro, pero se detectó que
       varios componentes del proyecto son "siempre oscuros por diseño"
       independientemente del tema — por ejemplo:
         • El footer completo (`background:#060606`, fijo)
         • Las flechas de la galería de fotos sobre el producto
           (`background:rgba(10,10,10,0.7)`, fijo — para legibilidad sobre
           la imagen, no relacionado con el tema del sitio)
         • Overlays/badges sobre imágenes de productos y tableros
       Esos elementos tienen fondo oscuro FIJO + texto blanco FIJO a
       propósito: deben verse igual en ambos temas. Un selector global que
       solo mira "tiene color:white" no puede distinguir ese caso del caso
       real de bug (texto fijo sobre un fondo que SÍ cambia con el tema).
       Por eso aquí solo se incluyen overrides 100% seguros y predecibles
       (clases utilitarias, inputs nativos); los bugs reales de contraste
       se corrigieron directamente en cada vista — ver CAMBIOS_DARKMODE.md.
       ════════════════════════════════════════════════════════════════════ */

    /* Clases utilitarias Bootstrap usadas en admin (fondo SÍ adapta vía var(--card)) */
    body.light-mode .text-white { color: var(--text) !important; }
    body.light-mode .text-white-50 { color: var(--muted) !important; }
    body.light-mode .text-light { color: var(--text) !important; }

    /* Inputs/selects/textareas nativos: SIEMPRE deben adaptar (no hay
       "input intencionalmente oscuro" en este proyecto) */
    body.light-mode input::placeholder,
    body.light-mode textarea::placeholder { color: var(--muted) !important; opacity: 0.8; }
    body.light-mode input:not([type="color"]):not([type="range"]),
    body.light-mode textarea,
    body.light-mode select { color: var(--text); }

    /* Scrollbar: track más sutil sobre fondo claro */
    body.light-mode ::-webkit-scrollbar-track { background: rgba(0,0,0,0.04); }

    /* ── NOTIFICATION PANEL ── */
    .notif-panel {
      position: fixed; top: 0; right: 0; width: 360px; height: 100vh;
      background: rgba(17,17,17,0.98); backdrop-filter: blur(20px);
      z-index: 1002; transform: translateX(100%);
      transition: transform 0.4s cubic-bezier(0.4,0,0.2,1);
      display: flex; flex-direction: column; border-left: 3px solid var(--pink);
    }
    .notif-panel.open { transform: translateX(0); }
    .notif-ph { padding: 20px 24px 12px; border-bottom: 1px solid rgba(255,255,255,0.1);
      font-family: 'Bebas Neue',sans-serif; font-size: 18px; letter-spacing: 3px; color: var(--pink);
      display: flex; justify-content: space-between; align-items: center; flex-shrink: 0; }
    .notif-list { flex: 1; overflow-y: auto; }
    .notif-item { display: flex; gap: 12px; padding: 14px 20px; border-bottom: 1px solid rgba(255,255,255,0.05);
      cursor: pointer; transition: background 0.2s; position: relative; }
    .notif-item:hover { background: rgba(233,30,140,0.08); }
    .notif-item.unread::before { content: ''; position: absolute; left: 8px; top: 50%;
      transform: translateY(-50%); width: 6px; height: 6px; border-radius: 50%; background: var(--pink); }
    .notif-icon { width: 36px; height: 36px; border-radius: 50%; display: flex;
      align-items: center; justify-content: center; flex-shrink: 0; font-size: 16px; }
    .notif-title { font-weight: 700; font-size: 13px; margin-bottom: 2px; color: var(--white); }
    .notif-msg { font-size: 12px; color: var(--gray); line-height: 1.4; }
    .notif-time { font-size: 10px; color: var(--muted); margin-top: 4px; }
    .notif-badge {
      position: absolute; top: -5px; right: -5px; background: var(--pink); color: white;
      font-size: 9px; min-width: 16px; height: 16px; border-radius: 8px; padding: 0 4px;
      display: none; align-items: center; justify-content: center; font-weight: 700;
    }
    .notif-badge.show { display: flex; }

    /* ── CHAT SOCIAL PANEL (bandeja de mensajes) ── */
    .chat-social-panel {
      position: fixed; bottom: 0; right: 90px; width: 280px;
      background: rgba(17,17,17,0.98); border: 1px solid var(--border); border-bottom: none;
      z-index: 1500; display: none; flex-direction: column; max-height: 380px;
    }
    .chat-social-panel.open { display: flex; }
    .csp-header { background: var(--pink); padding: 10px 14px; font-family:'Bebas Neue',sans-serif;
      font-size: 13px; letter-spacing: 2px; display: flex; justify-content: space-between; align-items: center; }
    .csp-body { flex: 1; overflow-y: auto; }
    .csp-contact { display: flex; gap: 10px; padding: 10px 14px; border-bottom: 1px solid rgba(255,255,255,0.06);
      cursor: pointer; transition: background 0.2s; align-items: center; text-decoration: none; color: var(--white); }
    .csp-contact:hover { background: rgba(233,30,140,0.08); color: var(--white); }
    .csp-unread { background: var(--pink); color: white; font-size: 9px; font-weight: 700;
      min-width: 16px; height: 16px; border-radius: 8px; display: flex; align-items: center;
      justify-content: center; margin-left: auto; padding: 0 4px; }

    /* ═══════════════════════════════════════════════════════════════════════
       RESPONSIVE — existente (tablet + desktop se mantiene intacto)
       ═══════════════════════════════════════════════════════════════════════ */
    @media (max-width: 768px) {
      .admin-sidebar { transform: translateX(-100%); } .admin-sidebar.open { transform: translateX(0); }
      .admin-content { margin-left: 0; } .sidebar-toggle-btn { display: block; }
      #cart-panel { width: 100%; } .chat-window { width: calc(100vw - 32px); right: 16px; }
      .notif-panel { width: 100%; } .chat-social-panel { width: calc(100vw - 32px); right: 16px; }
    }

    /* ═══════════════════════════════════════════════════════════════════════
       PINTEREST MOBILE UI — solo ≤767px
       REGLA ABSOLUTA: nada de lo que hay debajo toca tablet ni desktop.
       ═══════════════════════════════════════════════════════════════════════ */

    /* ── Ocultar elementos del navbar original en móvil ── */
    @media (max-width: 767px) {
      #navbar               { display: none !important; }
      #mobile-menu          { display: none !important; }
      .hamburger-btn        { display: none !important; }
      .chat-fab             { display: none !important; } /* se solapa con la barra inferior #mn-nav */
    }

    /* ── Mobile header / cats / bottom-nav: ocultos en tablet+ ── */
    #mn-header, #mn-cats, #mn-nav, #mn-search-overlay { display: none; }

    @media (max-width: 767px) {
      /* compensar la nueva barra superior (56px) + barra de categorías (46px) */
      main { padding-top: 108px !important; padding-bottom: 80px !important; }

      /* ── MN-HEADER: top bar flotante ── */
      #mn-header {
        display: flex;
        position: fixed; top: 0; left: 0; right: 0; z-index: 1100;
        height: 56px; padding: 0 16px;
        align-items: center; justify-content: space-between;
        background: rgba(10,10,10,0.82);
        backdrop-filter: blur(18px) saturate(180%);
        -webkit-backdrop-filter: blur(18px) saturate(180%);
        border-bottom: 1px solid rgba(233,30,140,0.15);
        box-shadow: 0 2px 24px rgba(0,0,0,0.5);
      }
      body.light-mode #mn-header {
        background: rgba(255,255,255,0.88);
        border-bottom-color: rgba(233,30,140,0.2);
        box-shadow: 0 2px 20px rgba(0,0,0,0.08);
      }
      #mn-logo {
        font-family: var(--fd); font-size: 22px; letter-spacing: 4px;
        color: var(--cp); text-decoration: none; filter: url(#gb);
        flex-shrink: 0;
      }
      .mn-icons {
        display: flex; align-items: center; gap: 4px;
      }
      .mn-icon-btn {
        position: relative; background: none; border: none;
        color: var(--text); width: 40px; height: 40px;
        display: flex; align-items: center; justify-content: center;
        font-size: 17px; cursor: pointer; border-radius: 50%;
        transition: background 0.18s, color 0.18s;
        -webkit-tap-highlight-color: transparent;
      }
      .mn-icon-btn:active { background: rgba(233,30,140,0.12); color: var(--cp); }
      .mn-icon-btn .mn-badge {
        position: absolute; top: 6px; right: 6px;
        background: var(--cp); color: white;
        font-size: 8px; font-weight: 700; font-family: var(--fm);
        min-width: 14px; height: 14px; border-radius: 7px;
        display: none; align-items: center; justify-content: center;
        padding: 0 3px; border: 1.5px solid var(--dark);
      }
      .mn-icon-btn .mn-badge.show { display: flex; }

      /* ── MN-CATS: barra de categorías horizontal ── */
      #mn-cats {
        display: flex;
        position: fixed; top: 56px; left: 0; right: 0; z-index: 1090;
        height: 46px;
        background: rgba(10,10,10,0.9);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(255,255,255,0.05);
        overflow-x: auto; overflow-y: hidden;
        -webkit-overflow-scrolling: touch;
        scroll-snap-type: x mandatory;
        scrollbar-width: none; /* Firefox */
        gap: 6px; padding: 0 12px; align-items: center;
        white-space: nowrap;
      }
      body.light-mode #mn-cats {
        background: rgba(248,248,252,0.93);
        border-bottom-color: rgba(0,0,0,0.06);
      }
      #mn-cats::-webkit-scrollbar { display: none; }
      .mn-cat {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 5px 14px; border-radius: 20px; height: 30px;
        font-family: var(--fm); font-size: 11px; font-weight: 700;
        letter-spacing: 1px; text-transform: uppercase;
        text-decoration: none; color: var(--muted);
        border: 1px solid transparent;
        background: rgba(255,255,255,0.05);
        transition: all 0.18s; flex-shrink: 0;
        scroll-snap-align: start;
        -webkit-tap-highlight-color: transparent;
      }
      body.light-mode .mn-cat {
        color: #888; background: rgba(0,0,0,0.04);
      }
      .mn-cat.active, .mn-cat:active {
        color: var(--cp); border-color: rgba(233,30,140,0.4);
        background: rgba(233,30,140,0.1);
      }
      .mn-cat i { font-size: 12px; }

      /* ── MN-NAV: bottom navigation flotante ── */
      #mn-nav {
        display: flex;
        position: fixed; bottom: 12px; left: 16px; right: 16px; z-index: 1100;
        height: 58px; border-radius: 18px;
        background: rgba(17,17,17,0.92);
        backdrop-filter: blur(24px) saturate(180%);
        -webkit-backdrop-filter: blur(24px) saturate(180%);
        border: 1px solid rgba(233,30,140,0.2);
        box-shadow: 0 8px 40px rgba(0,0,0,0.7), 0 0 0 1px rgba(255,255,255,0.04);
        align-items: center; justify-content: space-around; padding: 0 8px;
      }
      body.light-mode #mn-nav {
        background: rgba(255,255,255,0.92);
        border-color: rgba(233,30,140,0.15);
        box-shadow: 0 8px 40px rgba(0,0,0,0.12);
      }
      .mn-nav-btn {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: 3px; width: 64px; height: 48px; border: none; background: none;
        color: var(--muted); font-size: 20px; cursor: pointer; border-radius: 12px;
        transition: color 0.18s, background 0.18s;
        -webkit-tap-highlight-color: transparent;
        text-decoration: none;
      }
      .mn-nav-btn span {
        font-family: var(--fm); font-size: 9px; font-weight: 700;
        letter-spacing: 0.5px; text-transform: uppercase;
      }
      .mn-nav-btn.active, .mn-nav-btn:active { color: var(--cp); background: rgba(233,30,140,0.08); }
      body.light-mode .mn-nav-btn { color: #aaa; }
      body.light-mode .mn-nav-btn.active { color: var(--cp); }

      /* Search central expandido */
      #mn-search-overlay {
        display: none;
        position: fixed; top: 56px; left: 0; right: 0; z-index: 1200;
        background: rgba(10,10,10,0.98);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        padding: 12px 16px 16px;
        border-bottom: 1px solid rgba(233,30,140,0.2);
        animation: mnSearchIn 0.22s ease;
      }
      body.light-mode #mn-search-overlay {
        background: rgba(250,250,252,0.98);
        border-bottom-color: rgba(233,30,140,0.15);
      }
      #mn-search-overlay.open { display: block; }
      @keyframes mnSearchIn {
        from { opacity: 0; transform: translateY(-8px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      #mn-search-overlay .mn-search-wrap { position: relative; }
      #mn-search-inp {
        width: 100%; height: 44px;
        background: rgba(255,255,255,0.07); border: 1px solid rgba(233,30,140,0.3);
        border-radius: 22px; padding: 0 44px 0 18px;
        color: var(--text); font-family: var(--fm); font-size: 14px;
        letter-spacing: 0.5px; outline: none;
        transition: border-color 0.2s;
      }
      body.light-mode #mn-search-inp {
        background: rgba(0,0,0,0.04); color: #111; border-color: rgba(233,30,140,0.25);
      }
      #mn-search-inp:focus { border-color: var(--cp); }
      #mn-search-inp::placeholder { color: var(--muted); }
      #mn-search-close {
        position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
        background: none; border: none; color: var(--muted); font-size: 18px; cursor: pointer;
        display: flex; align-items: center; justify-content: center; padding: 4px;
      }
      #mn-search-sugg {
        margin-top: 8px; border-radius: 12px;
        overflow: hidden; background: rgba(20,20,20,0.9);
        border: 1px solid rgba(255,255,255,0.06);
        max-height: 240px; overflow-y: auto; display: none;
      }
      body.light-mode #mn-search-sugg { background: white; border-color: rgba(0,0,0,0.08); }
      #mn-search-sugg.open { display: block; }
      .mn-sugg-item {
        display: flex; align-items: center; gap: 12px; padding: 10px 16px;
        color: var(--text); font-family: var(--fm); font-size: 13px; cursor: pointer;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        transition: background 0.15s;
        -webkit-tap-highlight-color: transparent;
      }
      .mn-sugg-item:last-child { border-bottom: none; }
      .mn-sugg-item:active { background: rgba(233,30,140,0.1); color: var(--cp); }
      body.light-mode .mn-sugg-item { color: #111; border-bottom-color: rgba(0,0,0,0.05); }
      .mn-sugg-img {
        width: 36px; height: 36px; border-radius: 8px; object-fit: cover;
        background: rgba(255,255,255,0.05); flex-shrink: 0;
      }
    }
  </style>
</head>
