<script>
// NAVBAR SCROLL
let lastY=0;const navEl=document.getElementById('navbar');const avisoBar=document.getElementById('aviso-bar');
// Ocultar aviso-bar en la página de perfil
if(avisoBar && (window.location.pathname==='/perfil'||window.location.pathname.startsWith('/perfil/'))) {
  avisoBar.classList.add('page-hidden');
}
if(navEl){window.addEventListener('scroll',()=>{const y=window.scrollY;const hide=y>lastY&&y>100;navEl.classList.toggle('hidden',hide);if(avisoBar&&!avisoBar.classList.contains('page-hidden'))avisoBar.classList.toggle('nav-hidden',hide);lastY=y;});}

// HAMBURGER
const hBtn=document.getElementById('hamburger-btn'),mMenu=document.getElementById('mobile-menu');
let mOpen=false;
if(hBtn){hBtn.addEventListener('click',e=>{e.stopPropagation();mOpen=!mOpen;hBtn.classList.toggle('open',mOpen);mMenu.classList.toggle('open',mOpen);});document.addEventListener('click',e=>{if(mOpen&&mMenu&&!mMenu.contains(e.target)&&e.target!==hBtn){mOpen=false;hBtn.classList.remove('open');mMenu.classList.remove('open');}});}

// SEARCH — autocompletado letra a letra con imagen y precio
const sTgl=document.getElementById('search-toggle'),sBar=document.getElementById('search-bar'),sInp=document.getElementById('searchInput');
let sOpen=false;
if(sTgl){sTgl.addEventListener('click',e=>{e.stopPropagation();sOpen=!sOpen;sBar.classList.toggle('open',sOpen);if(sOpen&&sInp)setTimeout(()=>sInp.focus(),300);});document.addEventListener('click',e=>{if(sOpen&&sBar&&!sBar.contains(e.target)&&e.target!==sTgl){sOpen=false;sBar.classList.remove('open');}});}
const sSugg=document.getElementById('searchSugg');let sTimer;
if(sInp){
  sInp.addEventListener('input',()=>{
    clearTimeout(sTimer);
    const q=sInp.value.trim();
    if(!q){if(sSugg)sSugg.style.display='none';return;}
    sTimer=setTimeout(async()=>{
      try{
        const r=await fetch(`/buscar/sugerencias?q=${encodeURIComponent(q)}`);
        const d=await r.json();
        if(!d||!d.length){if(sSugg)sSugg.style.display='none';return;}
        sSugg.innerHTML=d.slice(0,8).map(p=>{
          const href=p.tipo==='usuario'?`/u/${p.sub}`:`/productos/${p.id}`;
          let imgHtml='<div style="width:38px;height:38px;border-radius:4px;background:var(--dark2);flex-shrink:0"></div>';
          if(p.tipo==='producto'&&p.img){
            imgHtml=`<img src="/uploads/products/${p.img}" style="width:38px;height:38px;object-fit:cover;border-radius:4px;flex-shrink:0" onerror="this.style.background='var(--dark2)'">`;
          }
          const sub=p.tipo==='usuario'?`<span style="color:var(--gray);font-size:11px">@${p.sub}</span>`
            :(p.precio?`<span style="color:var(--pink);font-size:11px">COP ${parseFloat(p.precio).toLocaleString('es-CO')}</span>`
            :(p.sub?`<span style="color:var(--gray);font-size:11px">${p.sub}</span>`:''));
          return `<div class="item" onclick="window.location='${href}'" style="display:flex;align-items:center;gap:10px;padding:9px 14px;cursor:pointer">${imgHtml}<div style="flex:1;min-width:0"><div style="font-size:13px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${p.nombre}</div>${sub}</div></div>`;
        }).join('');
        sSugg.style.display='block';
      }catch(e){if(sSugg)sSugg.style.display='none';}
    },100);
  });
  sInp.addEventListener('keydown',e=>{if(e.key==='Enter'){window.location.href='/buscar?q='+encodeURIComponent(sInp.value.trim());}});
  document.addEventListener('click',e=>{if(sSugg&&sInp&&!sInp.closest('form').contains(e.target))sSugg.style.display='none';});
}

// USER DROPDOWN
const uBtn=document.getElementById('user-btn'),uDd=document.getElementById('user-dd');
if(uBtn){uBtn.addEventListener('click',e=>{e.stopPropagation();uDd.classList.toggle('open');});document.addEventListener('click',e=>{if(uDd&&!uBtn.contains(e.target))uDd.classList.remove('open');});}

// CART PANEL
const cTgl=document.getElementById('cart-toggle'),cPanel=document.getElementById('cart-panel'),cClose=document.getElementById('cart-close');
let cOpen=false;
if(cTgl){cTgl.addEventListener('click',e=>{e.stopPropagation();cOpen=!cOpen;cPanel.classList.toggle('open',cOpen);if(cOpen)loadCartPanel();});cClose&&cClose.addEventListener('click',e=>{e.stopPropagation();cOpen=false;cPanel.classList.remove('open');});cPanel&&cPanel.addEventListener('click',e=>e.stopPropagation());document.addEventListener('click',e=>{if(cOpen&&cPanel&&!cPanel.contains(e.target)&&e.target!==cTgl){cOpen=false;cPanel.classList.remove('open');}});}

async function loadCartPanel(){
  const iEl=document.getElementById('cartItems'),tEl=document.getElementById('cartTotal'),cEl=document.getElementById('cart-count');
  if(!iEl)return;
  try{const r=await fetch('/carrito/panel');const d=await r.json();
    if(!d.items||!d.items.length){iEl.innerHTML='<div class="cart-empty-msg">TU CARRITO ESTÁ VACÍO</div>';if(tEl)tEl.textContent='$0';if(cEl){cEl.textContent='0';cEl.classList.remove('show');}return;}
    const total=d.items.reduce((s,i)=>s+(i.precio*i.cantidad),0);
    iEl.innerHTML=d.items.map(i=>`<div class="cart-pitem"><img src="/uploads/products/${i.imagen_principal}" alt="${i.titulo}" onerror="this.src='https://via.placeholder.com/56x56/111/888?text=?'" style="width:56px;height:56px;object-fit:cover"><div style="flex:1;min-width:0"><div style="font-weight:600;font-size:13px;letter-spacing:1px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${i.titulo}</div>${i.talla?`<div style="font-size:11px;color:var(--pink)">Talla: ${i.talla}</div>`:''}<div style="font-size:11px;color:var(--gray)">x${i.cantidad}</div></div><div style="font-family:'Bebas Neue',sans-serif;font-size:15px;color:var(--pink);flex-shrink:0">$${(i.precio*i.cantidad).toLocaleString('es-CO')}</div></div>`).join('');
    if(tEl)tEl.textContent='$'+total.toLocaleString('es-CO');
    const qty=d.items.reduce((s,i)=>s+i.cantidad,0);
    if(cEl){cEl.textContent=qty;cEl.classList.toggle('show',qty>0);}
  }catch(e){}
}
loadCartPanel();

function showToast(msg){const t=document.getElementById('toast');if(!t)return;t.textContent=msg||'¡PRODUCTO AÑADIDO!';t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2500);}


// ADMIN CLOCK
const cl=document.getElementById('adminClock');if(cl){const uc=()=>{const n=new Date();cl.textContent=n.toLocaleTimeString('es-CO',{hour:'2-digit',minute:'2-digit',second:'2-digit'});};uc();setInterval(uc,1000);}
document.addEventListener('click',e=>{const sb=document.getElementById('adminSidebar');if(sb&&sb.classList.contains('open')&&!sb.contains(e.target)&&!e.target.closest('.sidebar-toggle-btn'))sb.classList.remove('open');});

// AUTO DISMISS ALERTS
setTimeout(()=>{document.querySelectorAll('.alert-mantiz').forEach(a=>{a.style.transition='opacity 0.5s';a.style.opacity='0';setTimeout(()=>a.remove(),500);});},5000);

// ── DARK MODE ──────────────────────────────────────────────────────────────────
function applyTheme(t){
  document.body.classList.toggle('light-mode',t==='claro');
  const icon=document.getElementById('theme-icon');
  const btn=document.getElementById('theme-toggle-btn');
  if(icon){
    icon.className=t==='claro'?'bi bi-sun-fill':'bi bi-moon-stars-fill';
  }
  if(btn)btn.title=t==='claro'?'Cambiar a modo oscuro':'Cambiar a modo claro';
  // Notificar a componentes que dependen del tema (ej. viewer 3D) para que
  // se actualicen en vivo sin necesitar recargar la página.
  window.dispatchEvent(new CustomEvent('mantiz-theme-change',{detail:{tema:t}}));
}
function toggleTheme(){
  const actual=localStorage.getItem('mantiz_tema')||'oscuro';
  const nuevo=actual==='oscuro'?'claro':'oscuro';
  localStorage.setItem('mantiz_tema',nuevo);
  applyTheme(nuevo);
  fetch('/perfil/config',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({tema_global:nuevo})}).catch(()=>{});
}
(function(){applyTheme(localStorage.getItem('mantiz_tema')||'oscuro');})();

// ── PWA: registro del Service Worker (notificaciones push + base de instalación) ──
if ('serviceWorker' in navigator) {
  window.addEventListener('load', function(){
    navigator.serviceWorker.register('/sw.js').catch(function(e){ console.warn('SW registro falló:', e); });
  });
}

<% if (user) { %>
// ── NOTIFICACIONES ─────────────────────────────────────────────────────────────
let notifOpen=false;
const notifPanel=document.getElementById('notif-panel');
const notifClose=document.getElementById('notif-close');
const notifBadge=document.getElementById('notif-badge');

document.getElementById('notif-toggle')?.addEventListener('click',e=>{
  e.stopPropagation();
  notifOpen=!notifOpen;
  notifPanel?.classList.toggle('open',notifOpen);
  // Cerrar carrito si está abierto
  if(notifOpen){cOpen=false;document.getElementById('cart-panel')?.classList.remove('open');}
  if(notifOpen)cargarNotificaciones();
});
notifClose?.addEventListener('click',()=>{notifOpen=false;notifPanel?.classList.remove('open');});
document.addEventListener('click',e=>{
  if(notifOpen&&notifPanel&&!notifPanel.contains(e.target)&&!e.target.closest('#notif-toggle')){
    notifOpen=false;notifPanel.classList.remove('open');
  }
});

async function cargarNotificaciones(){
  const list=document.getElementById('notif-list');
  if(!list)return;
  try{
    const r=await fetch('/notificaciones');const d=await r.json();
    if(!d.notificaciones?.length){list.innerHTML='<div style="text-align:center;padding:40px;color:var(--gray);font-size:13px;letter-spacing:1px">Sin notificaciones aún</div>';return;}
    list.innerHTML=d.notificaciones.map(n=>`
      <div class="notif-item ${n.leida?'':'unread'}" onclick="abrirNotif(${n.id},'${(n.enlace||'').replace(/'/g,'')}')">
        <div class="notif-icon" style="background:${n.color||'var(--pink)'}22;color:${n.color||'var(--pink)'}">
          <i class="${n.icono||'bi-bell'}"></i>
        </div>
        <div style="flex:1;min-width:0">
          <div class="notif-title">${n.titulo}</div>
          ${n.mensaje?`<div class="notif-msg">${String(n.mensaje).substring(0,75)}${n.mensaje.length>75?'...':''}</div>`:''}
          <div class="notif-time">${relTime(n.creado_en)}</div>
        </div>
      </div>`).join('');
  }catch(e){list.innerHTML='<div style="text-align:center;padding:40px;color:#ff6060;font-size:12px">Error al cargar</div>';}
}

async function abrirNotif(id,enlace){
  await fetch(`/notificaciones/${id}/leer`,{method:'POST'}).catch(()=>{});
  checkNotifCount();
  if(enlace&&enlace!=='null'&&enlace!=='')window.location=enlace;
  else{const el=document.querySelector(`.notif-item[onclick*="${id},"]`)||document.querySelector(`.notif-item[onclick*="${id}'"]`);if(el)el.classList.remove('unread');}
}

async function marcarTodasLeidas(){
  await fetch('/notificaciones/leer-todas',{method:'POST'}).catch(()=>{});
  document.querySelectorAll('.notif-item').forEach(el=>el.classList.remove('unread'));
  if(notifBadge){notifBadge.textContent='';notifBadge.classList.remove('show');}
}

async function checkNotifCount(){
  try{
    const r=await fetch('/notificaciones/count');const d=await r.json();
    if(notifBadge){notifBadge.textContent=d.count>9?'9+':d.count||'';notifBadge.classList.toggle('show',d.count>0);}
  }catch(e){}
}

function relTime(ts){
  if(!ts)return'';const diff=(Date.now()-new Date(ts).getTime())/1000;
  if(diff<60)return'hace un momento';if(diff<3600)return`hace ${Math.floor(diff/60)}m`;
  if(diff<86400)return`hace ${Math.floor(diff/3600)}h`;return`hace ${Math.floor(diff/86400)}d`;
}

let mantizNotifInterval=setInterval(checkNotifCount,30000);
checkNotifCount();

// SSE tiempo real
let mantizSSE=null;
function mantizConnectSSE(){
  try{
    mantizSSE=new EventSource('/chat/stream');
    mantizSSE.onmessage=e=>{
      try{
        const d=JSON.parse(e.data);
        if(d.tipo==='mensaje'){const cb=document.getElementById('chat-badge');if(cb){const n=parseInt(cb.textContent)||0;cb.textContent=n+1>9?'9+':n+1;cb.classList.add('show');}}
      }catch(er){}
    };
    mantizSSE.onerror=()=>{mantizSSE.close();};
  }catch(e){}
}
mantizConnectSSE();

// ── CHAT SOCIAL ────────────────────────────────────────────────────────────────
const chatSocialPanel=document.getElementById('chat-social-panel');
document.getElementById('chat-social-toggle')?.addEventListener('click',e=>{
  e.stopPropagation();
  chatSocialPanel?.classList.toggle('open');
  if(chatSocialPanel?.classList.contains('open'))cargarConversaciones();
});

async function cargarConversaciones(){
  const body=document.getElementById('csp-body');if(!body)return;
  try{
    const r=await fetch('/chat/conversaciones');const d=await r.json();
    if(!d.conversaciones?.length){body.innerHTML='<div style="text-align:center;padding:30px;color:var(--gray);font-size:12px;letter-spacing:1px">Sin conversaciones</div>';return;}
    body.innerHTML=d.conversaciones.map(c=>`
      <a href="/u/${c.username}" class="csp-contact">
        <img src="${c.foto_perfil_tipo==='upload'?'/uploads/profiles/'+c.foto_perfil:'/img/defaults/avatars/'+(c.foto_perfil_preset||'avatar1.png')}"
             width="36" height="36" style="border-radius:50%;object-fit:cover;border:2px solid var(--border);flex-shrink:0">
        <div style="flex:1;min-width:0">
          <div style="font-size:12px;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${c.nombre_visible}</div>
          ${c.ultimo_mensaje?`<div style="font-size:11px;color:var(--gray);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${String(c.ultimo_mensaje).substring(0,28)}</div>`:''}
        </div>
        ${c.no_leidos>0?`<span class="csp-unread">${c.no_leidos}</span>`:''}
      </a>`).join('');
  }catch(e){}
}

// ── PING TIEMPO (gamificación) ──────────────────────────────────────────────────
let mantizPingInterval=setInterval(()=>{fetch('/gamificacion/ping-tiempo',{method:'POST'}).catch(()=>{});},60000);

// ── LIMPIEZA AL SALIR DE LA PÁGINA ────────────────────────────────────────────────
// Si no se cierra la conexión SSE y los intervalos al navegar, pueden quedar
// "zombies" (sobre todo con la caché atrás/adelante del navegador) que agotan
// el límite de conexiones simultáneas hacia el mismo origen y producen una
// sensación de carga infinita en navegaciones posteriores.
function mantizCleanup(){
  clearInterval(mantizNotifInterval);
  clearInterval(mantizPingInterval);
  if(mantizSSE){mantizSSE.close();mantizSSE=null;}
}
window.addEventListener('pagehide',mantizCleanup);
window.addEventListener('beforeunload',mantizCleanup);
// Si la página vuelve desde la caché atrás/adelante, reabrir SSE e intervalos
window.addEventListener('pageshow',e=>{
  if(e.persisted){
    if(!mantizSSE||mantizSSE.readyState===EventSource.CLOSED)mantizConnectSSE();
    mantizNotifInterval=setInterval(checkNotifCount,30000);
    mantizPingInterval=setInterval(()=>{fetch('/gamificacion/ping-tiempo',{method:'POST'}).catch(()=>{});},60000);
    checkNotifCount();
  }
});
<% } %>

// ── PINTEREST MOBILE UI ───────────────────────────────────────────────────
// Solo se activa en pantallas ≤767px (matchMedia). En tablet/desktop es
// letra muerta: los elementos mn-* tienen display:none por CSS y este bloque
// no registra ningún listener que interfiera con la lógica desktop existente.
(function(){
  var MQ = window.matchMedia('(max-width:767px)');
  if (!MQ.matches) return; // exit temprano en tablet/desktop

  // ── Sincronizar badges con los originales del navbar ─────────────────
  function syncBadges(){
    var nb = document.getElementById('notif-badge');
    var mnb = document.getElementById('mn-notif-badge');
    if (nb && mnb) {
      if (nb.classList.contains('show')) { mnb.textContent = nb.textContent; mnb.classList.add('show'); }
      else { mnb.classList.remove('show'); }
    }
    var cb = document.getElementById('chat-badge');
    var mcb = document.getElementById('mn-chat-badge');
    if (cb && mcb) {
      if (cb.classList.contains('show')) { mcb.textContent = cb.textContent; mcb.classList.add('show'); }
      else { mcb.classList.remove('show'); }
    }
    var cc = document.getElementById('cart-count');
    var mcc = document.getElementById('mn-cart-badge');
    if (cc && mcc) {
      if (cc.classList.contains('show')) { mcc.textContent = cc.textContent; mcc.classList.add('show'); }
      else { mcc.classList.remove('show'); }
    }
  }
  setInterval(syncBadges, 1500);
  syncBadges();

  // ── Marcar categoría activa según la URL actual ───────────────────────
  var currentPath = window.location.pathname;
  document.querySelectorAll('.mn-cat').forEach(function(a){
    var p = a.getAttribute('data-path') || '';
    if (p && currentPath.startsWith(p)) a.classList.add('active');
    if (p === '/' && currentPath === '/') a.classList.add('active');
  });

  // ── Home button: marcar activo ────────────────────────────────────────
  var homeBtn = document.getElementById('mn-btn-home');
  if (homeBtn && (currentPath === '/' || currentPath === '')) homeBtn.classList.add('active');

  // ── Cerrar overlay de búsqueda ────────────────────────────────────────
  var searchOverlay = document.getElementById('mn-search-overlay');
  var searchInp    = document.getElementById('mn-search-inp');
  var searchSugg   = document.getElementById('mn-search-sugg');
  var searchClose  = document.getElementById('mn-search-close');
  if (searchClose) searchClose.addEventListener('click', function(){ mnCloseSearch(); });

  // Cerrar al tocar fuera del overlay
  document.addEventListener('touchstart', function(e){
    if (searchOverlay && searchOverlay.classList.contains('open') && !searchOverlay.contains(e.target)){
      var sb = document.getElementById('mn-btn-search');
      if (sb && !sb.contains(e.target)) mnCloseSearch();
    }
  }, {passive:true});

  // ── Búsqueda con debounce (reutiliza el endpoint /api/buscar existente) ─
  var searchTimer;
  if (searchInp) {
    searchInp.addEventListener('input', function(){
      clearTimeout(searchTimer);
      var q = this.value.trim();
      if (!q || q.length < 2) { if(searchSugg) searchSugg.classList.remove('open'); return; }
      searchTimer = setTimeout(function(){
        fetch('/api/buscar?q='+encodeURIComponent(q)+'&limite=6')
          .then(function(r){ return r.json(); })
          .then(function(data){
            if (!searchSugg) return;
            var items = (data.productos||[]).concat(data.usuarios||[]).slice(0,7);
            if (!items.length) { searchSugg.classList.remove('open'); return; }
            searchSugg.innerHTML = items.map(function(it){
              var img = it.imagen_principal ? '/uploads/'+it.imagen_principal
                : it.foto_perfil_tipo==='upload' ? '/uploads/profiles/'+it.foto_perfil
                : '/img/defaults/avatars/'+(it.foto_perfil_preset||'avatar1.png');
              var label = it.titulo || it.nombre_visible || it.username || '';
              var href  = it.titulo ? '/productos/'+it.id : '/perfil/'+it.username;
              return '<a class="mn-sugg-item" href="'+href+'">'
                +'<img class="mn-sugg-img" src="'+img+'" onerror="this.src=\'/img/defaults/placeholder.png\'">'
                +'<span>'+label+'</span></a>';
            }).join('');
            searchSugg.classList.add('open');
          }).catch(function(){});
      }, 280);
    });
    searchInp.addEventListener('keydown', function(e){
      if (e.key === 'Enter') {
        window.location.href = '/buscar?q=' + encodeURIComponent(this.value.trim());
      }
    });
  }

  // ── Profile toggle: abre el user-dropdown existente ──────────────────
  // (reutiliza exactamente la lógica desktop, no crea un nuevo menú)

})(); // fin IIFE Pinterest Mobile

// ── Funciones globales Mobile — fuera del IIFE para ser llamables desde onclick ──
function mnToggleSearch(){
  var o = document.getElementById('mn-search-overlay');
  if (!o) return;
  var opening = !o.classList.contains('open');
  o.classList.toggle('open');
  if (opening) {
    var i = document.getElementById('mn-search-inp');
    if (i) { i.value = ''; i.focus(); }
    var sb = document.getElementById('mn-btn-search');
    if (sb) sb.classList.add('active');
  } else {
    mnCloseSearch();
  }
}
function mnCloseSearch(){
  var o = document.getElementById('mn-search-overlay');
  if (o) o.classList.remove('open');
  var s = document.getElementById('mn-search-sugg');
  if (s) s.classList.remove('open');
  var sb = document.getElementById('mn-btn-search');
  if (sb) sb.classList.remove('active');
}
function mnToggleProfile(){
  var dd = document.getElementById('user-dd');
  if (!dd) return;
  if (!dd.style.position || dd.style.position === 'absolute') {
    // Solo reposicionar (no fijar display aquí: eso lo controla la clase
    // .open vía CSS — fijarlo inline anulaba permanentemente el toggle,
    // dejando el menú atascado abierto en móvil tras el primer toque).
    dd.style.cssText = [
      'position:fixed','bottom:80px','right:16px',
      'background:rgba(17,17,17,0.98)','backdrop-filter:blur(20px)',
      'border:1px solid rgba(233,30,140,0.25)','min-width:200px',
      'z-index:1200','border-radius:12px','overflow:hidden','box-shadow:0 8px 40px rgba(0,0,0,.6)'
    ].join(';');
  }
  dd.classList.toggle('open');
  var pb = document.getElementById('mn-btn-profile');
  if (pb) pb.classList.toggle('active', dd.classList.contains('open'));
}
document.addEventListener('click', function(e){
  var dd = document.getElementById('user-dd');
  var pb = document.getElementById('mn-btn-profile');
  if (dd && dd.classList.contains('open') && !dd.contains(e.target) && (!pb || !pb.contains(e.target))) {
    dd.classList.remove('open');
    if (pb) pb.classList.remove('active');
  }
});
</script>