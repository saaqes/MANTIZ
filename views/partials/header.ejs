      <div class="sl-section">Tienda</div>
      <a href="/admin/productos" class="sl-link <%= title&&title.includes('Producto')?'active':'' %>"><i class="bi bi-bag-fill" style="width:18px"></i>Productos</a>
      <a href="/admin/carrusel" class="sl-link <%= title&&title.includes('Carrusel')?'active':'' %>"><i class="bi bi-images" style="width:18px"></i>Carrusel / Banners</a>
      <a href="/admin/pedidos" class="sl-link <%= title&&title.includes('Pedidos')?'active':'' %>"><i class="bi bi-box-seam-fill" style="width:18px"></i>Pedidos<% if(typeof stats!=='undefined'&&stats.pedidos_activos>0){%><span class="sl-badge"><%=stats.pedidos_activos%></span><%}%></a>
      <div class="sl-section">Gestión</div>
      <a href="/admin/usuarios" class="sl-link <%= title&&title.includes('Usuarios')?'active':'' %>"><i class="bi bi-people-fill" style="width:18px"></i>Usuarios</a>
      <a href="/admin/proveedores" class="sl-link <%= title&&title.includes('Proveedores')?'active':'' %>"><i class="bi bi-truck" style="width:18px"></i>Proveedores</a>
      <a href="/admin/tiendas" class="sl-link <%= title&&title.includes('Tiendas')?'active':'' %>"><i class="bi bi-shop" style="width:18px"></i>Tiendas</a>
      <a href="/admin/comentarios" class="sl-link <%= title&&title.includes('Comentarios')?'active':'' %>"><i class="bi bi-chat-dots-fill" style="width:18px"></i>Comentarios</a>
      <div class="sl-section">Sistema</div>
      <a href="/admin/modelos" class="sl-link <%= title&&title.includes('Modelos')?'active':'' %>"><i class="bi bi-box-seam" style="width:18px"></i>Modelos 3D</a>
      <a href="/admin/homepage" class="sl-link <%= title&&title.includes('Estructura')?'active':'' %>"><i class="bi bi-layout-three-columns" style="width:18px"></i>Estructura Inicio</a>
      <a href="/admin/configuracion" class="sl-link <%= title&&title.includes('Configuración')?'active':'' %>"><i class="bi bi-gear-fill" style="width:18px"></i>Configuración</a>
      <div class="sl-section">Comunidad</div>
      <a href="/opiniones" class="sl-link"><i class="bi bi-bar-chart-fill" style="width:18px"></i>Encuestas</a>
      <a href="/comunidad" class="sl-link"><i class="bi bi-people-fill" style="width:18px"></i>Comunidad</a>
      <a href="/admin/notificaciones" class="sl-link <%= title&&title.includes('Notificaciones')?'active':'' %>"><i class="bi bi-megaphone-fill" style="width:18px"></i>Notificaciones</a>
      <a href="/" class="sl-link"><i class="bi bi-globe" style="width:18px"></i>Ver tienda</a>
    </nav>
    <div class="sl-bottom">
      <a href="/perfil" class="sl-user">
        <img src="<%= user.foto_perfil_tipo==='upload' ? '/uploads/profiles/'+user.foto_perfil : '/img/defaults/avatars/'+(user.foto_perfil_preset||'avatar1.png') %>" width="34" height="34" style="border-radius:50%;object-fit:cover;border:2px solid var(--pink)" onerror="this.src='/img/defaults/avatars/avatar1.png'">
        <div><div class="sl-name"><%= user.nombre_visible.split(' ')[0] %></div><div class="sl-role">ADMINISTRADOR</div></div>
        <a href="/auth/logout" style="color:var(--muted);margin-left:auto" title="Salir"><i class="bi bi-power"></i></a>
      </a>
    </div>
  </aside>
  <div class="admin-content">
    <div class="admin-topbar">
      <div style="display:flex;align-items:center;gap:14px">
        <button class="sidebar-toggle-btn" onclick="document.getElementById('adminSidebar').classList.toggle('open')"><i class="bi bi-list"></i></button>
        <div><div class="page-title"><%= title||'Admin' %></div><div class="page-bc">MANTIZ / ADMIN / <%= (title||'').toUpperCase() %></div></div>
      </div>
      <div style="display:flex;align-items:center;gap:16px">
        <% if(success&&success.length>0){%><div class="alert-mantiz alert-success" style="margin:0;padding:6px 12px;font-size:12px"><i class="bi bi-check-circle me-1"></i><%=success[0]%></div><%}%>
        <% if(error&&error.length>0){%><div class="alert-mantiz alert-danger" style="margin:0;padding:6px 12px;font-size:12px"><i class="bi bi-exclamation-circle me-1"></i><%=error[0]%></div><%}%>
        <span style="font-family:'Bebas Neue',sans-serif;font-size:12px;color:var(--muted);letter-spacing:1px" id="adminClock"></span>
      </div>
    </div>
    <div style="padding:22px;position:relative;z-index:1">
<% } %>

<script>
// NAVBAR SCROLL
let lastY=0;const navEl=document.getElementById('navbar');
if(navEl){window.addEventListener('scroll',()=>{const y=window.scrollY;if(y>lastY&&y>100)navEl.classList.add('hidden');else navEl.classList.remove('hidden');lastY=y;});}

// HAMBURGER
const hBtn=document.getElementById('hamburger-btn'),mMenu=document.getElementById('mobile-menu');
let mOpen=false;
if(hBtn){hBtn.addEventListener('click',e=>{e.stopPropagation();mOpen=!mOpen;hBtn.classList.toggle('open',mOpen);mMenu.classList.toggle('open',mOpen);});document.addEventListener('click',e=>{if(mOpen&&mMenu&&!mMenu.contains(e.target)&&e.target!==hBtn){mOpen=false;hBtn.classList.remove('open');mMenu.classList.remove('open');}});}

// SEARCH
const sTgl=document.getElementById('search-toggle'),sBar=document.getElementById('search-bar'),sInp=document.getElementById('searchInput');
let sOpen=false;
if(sTgl){sTgl.addEventListener('click',e=>{e.stopPropagation();sOpen=!sOpen;sBar.classList.toggle('open',sOpen);if(sOpen&&sInp)setTimeout(()=>sInp.focus(),300);});document.addEventListener('click',e=>{if(sOpen&&sBar&&!sBar.contains(e.target)&&e.target!==sTgl){sOpen=false;sBar.classList.remove('open');}});}
// Suggestions
const sSugg=document.getElementById('searchSugg');let sTimer;
if(sInp){sInp.addEventListener('input',()=>{clearTimeout(sTimer);const q=sInp.value.trim();if(q.length<2){if(sSugg)sSugg.style.display='none';return;}sTimer=setTimeout(async()=>{try{const r=await fetch(`/buscar/sugerencias?q=${encodeURIComponent(q)}`);const d=await r.json();if(!d.length){sSugg.style.display='none';return;}sSugg.innerHTML=d.map(p=>`<div class="item" onclick="window.location='/productos/${p.id}'">${p.titulo}<span style="color:var(--pink);font-size:11px;margin-left:8px">${p.categoria}</span></div>`).join('');sSugg.style.display='block';}catch(e){}},300);});document.addEventListener('click',e=>{if(sSugg&&sInp&&!sInp.closest('form').contains(e.target))sSugg.style.display='none';});}

// USER DROPDOWN
const uBtn=document.getElementById('user-btn'),uDd=document.getElementById('user-dd');
if(uBtn){uBtn.addEventListener('click',e=>{e.stopPropagation();uDd.classList.toggle('open');});document.addEventListener('click',e=>{if(uDd&&!uBtn.contains(e.target))uDd.classList.remove('open');});}

// CART PANEL
const cTgl=document.getElementById('cart-toggle'),cPanel=document.getElementById('cart-panel'),cClose=document.getElementById('cart-close');
let cOpen=false;
if(cTgl){cTgl.addEventListener('click',e=>{e.stopPropagation();cOpen=!cOpen;cPanel.classList.toggle('open',cOpen);if(cOpen)loadCartPanel();});cClose&&cClose.addEventListener('click',e=>{e.stopPropagation();cOpen=false;cPanel.classList.remove('open');});cPanel&&cPanel.addEventListener('click',e=>e.stopPropagation());document.addEventListener('click',e=>{if(cOpen&&cPanel&&!cPanel.contains(e.target)&&e.target!==cTgl){cOpen=false;cPanel.classList.remove('open');}});}

async function loadCartPanel(){
  const iEl=document.getElementById('cartItems'),tEl=document.getElementById('cartTotal'),cEl=document.getElementById('cart-count');
  if(!iEl)return;
  try{const r=await fetch('/carrito/panel');const d=await r.json();
    if(!d.items||!d.items.length){iEl.innerHTML='<div class="cart-empty-msg">TU CARRITO ESTÁ VACÍO</div>';if(tEl)tEl.textContent='$0';if(cEl){cEl.textContent='0';cEl.classList.remove('show');}return;}
    const total=d.items.reduce((s,i)=>s+(i.precio*i.cantidad),0);
    iEl.innerHTML=d.items.map(i=>`<div class="cart-pitem"><img src="/uploads/products/${i.imagen_principal}" alt="${i.titulo}" onerror="this.src='https://via.placeholder.com/56x56/111/888?text=?'" style="width:56px;height:56px;object-fit:cover"><div style="flex:1;min-width:0"><div style="font-weight:600;font-size:13px;letter-spacing:1px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${i.titulo}</div>${i.talla?`<div style="font-size:11px;color:var(--pink)">Talla: ${i.talla}</div>`:''}<div style="font-size:11px;color:var(--gray)">x${i.cantidad}</div></div><div style="font-family:'Bebas Neue',sans-serif;font-size:15px;color:var(--pink);flex-shrink:0">$${(i.precio*i.cantidad).toLocaleString('es-CO')}</div></div>`).join('');
    if(tEl)tEl.textContent='$'+total.toLocaleString('es-CO');
    const qty=d.items.reduce((s,i)=>s+i.cantidad,0);
    if(cEl){cEl.textContent=qty;cEl.classList.toggle('show',qty>0);}
  }catch(e){}
}
loadCartPanel();

function showToast(msg){const t=document.getElementById('toast');if(!t)return;t.textContent=msg||'¡PRODUCTO AÑADIDO!';t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2500);}

// CHAT
let chatH=[],chatOpen2=false;
function toggleChat(){chatOpen2=!chatOpen2;document.getElementById('chatWin')?.classList.toggle('active',chatOpen2);const ic=document.getElementById('chatFabIc');if(ic)ic.className=chatOpen2?'bi bi-x-lg':'bi bi-robot';if(chatOpen2)document.getElementById('chatInp')?.focus();}
async function sendChat(){const inp=document.getElementById('chatInp');const msg=inp.value.trim();if(!msg)return;appendCM(msg,'user');inp.value='';const msgs=document.getElementById('chatMsgs');const el=document.createElement('div');el.className='chat-msg bot';el.id='cLoad';el.textContent='...';msgs.appendChild(el);msgs.scrollTop=msgs.scrollHeight;try{const r=await fetch('/ia/chat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({mensaje:msg,historial:chatH})});const d=await r.json();document.getElementById('cLoad')?.remove();const resp=d.respuesta||'Sin respuesta.';appendCM(resp,'bot');chatH.push({rol:'user',contenido:msg},{rol:'assistant',contenido:resp});if(chatH.length>12)chatH=chatH.slice(-12);}catch(e){document.getElementById('cLoad')?.remove();appendCM('Error de conexión.','bot');}}
function appendCM(text,role){const msgs=document.getElementById('chatMsgs');if(!msgs)return;const d=document.createElement('div');d.className=`chat-msg ${role}`;d.textContent=text;msgs.appendChild(d);msgs.scrollTop=msgs.scrollHeight;}

// ADMIN CLOCK
const cl=document.getElementById('adminClock');if(cl){const uc=()=>{const n=new Date();cl.textContent=n.toLocaleTimeString('es-CO',{hour:'2-digit',minute:'2-digit',second:'2-digit'});};uc();setInterval(uc,1000);}
document.addEventListener('click',e=>{const sb=document.getElementById('adminSidebar');if(sb&&sb.classList.contains('open')&&!sb.contains(e.target)&&!e.target.closest('.sidebar-toggle-btn'))sb.classList.remove('open');});

// AUTO DISMISS ALERTS
setTimeout(()=>{document.querySelectorAll('.alert-mantiz').forEach(a=>{a.style.transition='opacity 0.5s';a.style.opacity='0';setTimeout(()=>a.remove(),500);});},5000);

// ── DARK MODE ──────────────────────────────────────────────────────────────────
function applyTheme(t){
  document.body.classList.toggle('light-mode',t==='claro');
  const icon=document.getElementById('theme-icon'),label=document.getElementById('theme-label');
  const mBtn=document.getElementById('mobile-theme-btn');
  if(icon)icon.className=t==='claro'?'bi bi-sun-fill me-2':'bi bi-moon-stars-fill me-2';
  if(label)label.textContent=t==='claro'?'MODO OSCURO':'MODO CLARO';
  if(mBtn)mBtn.textContent=t==='claro'?'☀️ MODO OSCURO':'🌙 MODO CLARO';
}
function toggleTheme(){
  const actual=localStorage.getItem('mantiz_tema')||'oscuro';
  const nuevo=actual==='oscuro'?'claro':'oscuro';
  localStorage.setItem('mantiz_tema',nuevo);
  applyTheme(nuevo);
  fetch('/perfil/config',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({tema_global:nuevo})}).catch(()=>{});
}
(function(){applyTheme(localStorage.getItem('mantiz_tema')||'oscuro');})();

<% if (user) { %>
// ── NOTIFICACIONES ─────────────────────────────────────────────────────────────
let notifOpen=false;
const notifPanel=document.getElementById('notif-panel');
const notifClose=document.getElementById('notif-close');
const notifBadge=document.getElementById('notif-badge');

document.getElementById('notif-toggle')?.addEventListener('click',e=>{
  e.stopPropagation();
  notifOpen=!notifOpen;
  notifPanel?.classList.toggle('open',notifOpen);
  // Cerrar carrito si está abierto
  if(notifOpen){cOpen=false;document.getElementById('cart-panel')?.classList.remove('open');}
  if(notifOpen)cargarNotificaciones();
});
notifClose?.addEventListener('click',()=>{notifOpen=false;notifPanel?.classList.remove('open');});
document.addEventListener('click',e=>{
  if(notifOpen&&notifPanel&&!notifPanel.contains(e.target)&&!e.target.closest('#notif-toggle')){
    notifOpen=false;notifPanel.classList.remove('open');
  }
});

async function cargarNotificaciones(){
  const list=document.getElementById('notif-list');
  if(!list)return;
  try{
    const r=await fetch('/notificaciones');const d=await r.json();
    if(!d.notificaciones?.length){list.innerHTML='<div style="text-align:center;padding:40px;color:var(--gray);font-size:13px;letter-spacing:1px">Sin notificaciones aún</div>';return;}
    list.innerHTML=d.notificaciones.map(n=>`
      <div class="notif-item ${n.leida?'':'unread'}" onclick="abrirNotif(${n.id},'${(n.enlace||'').replace(/'/g,'')}')">
        <div class="notif-icon" style="background:${n.color||'var(--pink)'}22;color:${n.color||'var(--pink)'}">
          <i class="${n.icono||'bi-bell'}"></i>
        </div>
        <div style="flex:1;min-width:0">
          <div class="notif-title">${n.titulo}</div>
          ${n.mensaje?`<div class="notif-msg">${String(n.mensaje).substring(0,75)}${n.mensaje.length>75?'...':''}</div>`:''}
          <div class="notif-time">${relTime(n.creado_en)}</div>
        </div>
      </div>`).join('');
  }catch(e){list.innerHTML='<div style="text-align:center;padding:40px;color:#ff6060;font-size:12px">Error al cargar</div>';}
}

async function abrirNotif(id,enlace){
  await fetch(`/notificaciones/${id}/leer`,{method:'POST'}).catch(()=>{});
  checkNotifCount();
  if(enlace&&enlace!=='null'&&enlace!=='')window.location=enlace;
  else{const el=document.querySelector(`.notif-item[onclick*="${id},"]`)||document.querySelector(`.notif-item[onclick*="${id}'"]`);if(el)el.classList.remove('unread');}
}

async function marcarTodasLeidas(){
  await fetch('/notificaciones/leer-todas',{method:'POST'}).catch(()=>{});
  document.querySelectorAll('.notif-item').forEach(el=>el.classList.remove('unread'));
  if(notifBadge){notifBadge.textContent='';notifBadge.classList.remove('show');}
}

async function checkNotifCount(){
  try{
    const r=await fetch('/notificaciones/count');const d=await r.json();
    if(notifBadge){notifBadge.textContent=d.count>9?'9+':d.count||'';notifBadge.classList.toggle('show',d.count>0);}
  }catch(e){}
}

function relTime(ts){
  if(!ts)return'';const diff=(Date.now()-new Date(ts).getTime())/1000;
  if(diff<60)return'hace un momento';if(diff<3600)return`hace ${Math.floor(diff/60)}m`;
  if(diff<86400)return`hace ${Math.floor(diff/3600)}h`;return`hace ${Math.floor(diff/86400)}d`;
}

checkNotifCount();setInterval(checkNotifCount,30000);

// SSE tiempo real
try{
  const es=new EventSource('/chat/stream');
  es.onmessage=e=>{
    try{
      const d=JSON.parse(e.data);
      if(d.tipo==='mensaje'){const cb=document.getElementById('chat-badge');if(cb){const n=parseInt(cb.textContent)||0;cb.textContent=n+1>9?'9+':n+1;cb.classList.add('show');}}
    }catch(er){}
  };
  es.onerror=()=>{es.close();};
}catch(e){}

// ── CHAT SOCIAL ────────────────────────────────────────────────────────────────
const chatSocialPanel=document.getElementById('chat-social-panel');
document.getElementById('chat-social-toggle')?.addEventListener('click',e=>{
  e.stopPropagation();
  chatSocialPanel?.classList.toggle('open');
  if(chatSocialPanel?.classList.contains('open'))cargarConversaciones();
});

async function cargarConversaciones(){
  const body=document.getElementById('csp-body');if(!body)return;
  try{
    const r=await fetch('/chat/conversaciones');const d=await r.json();
    if(!d.conversaciones?.length){body.innerHTML='<div style="text-align:center;padding:30px;color:var(--gray);font-size:12px;letter-spacing:1px">Sin conversaciones</div>';return;}
    body.innerHTML=d.conversaciones.map(c=>`
      <a href="/u/${c.username}" class="csp-contact">
        <img src="${c.foto_perfil_tipo==='upload'?'/uploads/profiles/'+c.foto_perfil:'/img/defaults/avatars/'+(c.foto_perfil_preset||'avatar1.png')}"
             width="36" height="36" style="border-radius:50%;object-fit:cover;border:2px solid var(--border);flex-shrink:0">
        <div style="flex:1;min-width:0">
          <div style="font-size:12px;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${c.nombre_visible}</div>
          ${c.ultimo_mensaje?`<div style="font-size:11px;color:var(--gray);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${String(c.ultimo_mensaje).substring(0,28)}</div>`:''}
        </div>
        ${c.no_leidos>0?`<span class="csp-unread">${c.no_leidos}</span>`:''}
      </a>`).join('');
  }catch(e){}
}

// ── PING TIEMPO (gamificación) ──────────────────────────────────────────────────
setInterval(()=>{fetch('/gamificacion/ping-tiempo',{method:'POST'}).catch(()=>{});},60000);
<% } %>
</script>
