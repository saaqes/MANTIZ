      <button id="notif-close" style="background:none;border:none;color:var(--gray);font-size:22px;cursor:pointer;line-height:1;transition:color 0.2s" onmouseover="this.style.color='var(--pink)'" onmouseout="this.style.color='var(--gray)'">✕</button>
